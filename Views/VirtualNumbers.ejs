<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FREE Virtual Number Generation - SSPAR Cloud</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-right: 1px solid rgba(255, 255, 255, 0.2);
            height: 100vh;
            position: fixed;
            overflow-y: auto;
        }

        .sidebar-header {
            padding: 30px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        }

        .sidebar-header h2 {
            color: white;
            font-size: 24px;
            font-weight: 700;
        }

        .sidebar-header span {
            color: #00ff88;
        }

        .sidebar-header .free-badge {
            background: #ff6b6b;
            color: white;
            font-size: 12px;
            padding: 4px 12px;
            border-radius: 20px;
            margin-top: 10px;
            display: inline-block;
            font-weight: bold;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .menu-title {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.6);
            margin: 25px 20px 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .menu-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            font-size: 15px;
            border-left: 3px solid transparent;
            transition: all 0.3s;
            margin: 2px 0;
        }

        .menu-link:hover, .menu-link.active {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border-left-color: #00ff88;
        }

        .menu-link i {
            width: 20px;
            text-align: center;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 250px;
            padding: 20px;
        }

        .header {
            background: white;
            border-radius: 15px;
            padding: 25px 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-info h1 {
            color: #333;
            font-size: 32px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .header-info h1 i {
            color: #667eea;
        }

        .header-info p {
            color: #666;
            font-size: 16px;
            line-height: 1.6;
        }

        .free-count {
            background: linear-gradient(135deg, #00ff88, #00cc6a);
            color: white;
            padding: 20px 30px;
            border-radius: 15px;
            text-align: center;
            min-width: 200px;
        }

        .free-count .count {
            font-size: 48px;
            font-weight: bold;
            line-height: 1;
        }

        .free-count .label {
            font-size: 14px;
            opacity: 0.9;
            margin-top: 5px;
        }

        /* FREE Number Types Grid */
        .number-types {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }

        .type-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transition: all 0.3s;
            border: 3px solid transparent;
            position: relative;
            overflow: hidden;
        }

        .type-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        }

        .type-card.free {
            border-color: #00ff88;
        }

        .type-card.free::before {
            content: 'FREE';
            position: absolute;
            top: 20px;
            right: -30px;
            background: #00ff88;
            color: white;
            padding: 5px 40px;
            font-size: 14px;
            font-weight: bold;
            transform: rotate(45deg);
        }

        .type-card.featured {
            border-color: #667eea;
        }

        .type-card.featured::before {
            content: 'FEATURED';
            position: absolute;
            top: 20px;
            right: -30px;
            background: #667eea;
            color: white;
            padding: 5px 40px;
            font-size: 14px;
            font-weight: bold;
            transform: rotate(45deg);
        }

        .type-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            color: white;
            margin-bottom: 20px;
        }

        .type-card.free .type-icon {
            background: linear-gradient(135deg, #00ff88, #00cc6a);
        }

        .type-card.featured .type-icon {
            background: linear-gradient(135deg, #667eea, #764ba2);
        }

        .type-card h3 {
            color: #333;
            font-size: 22px;
            margin-bottom: 15px;
        }

        .type-features {
            list-style: none;
            margin-bottom: 25px;
        }

        .type-features li {
            padding: 8px 0;
            color: #666;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .type-features li i {
            color: #00ff88;
        }

        .type-price {
            font-size: 28px;
            font-weight: bold;
            color: #333;
            margin-bottom: 20px;
        }

        .type-price .original {
            text-decoration: line-through;
            color: #999;
            font-size: 18px;
            margin-right: 10px;
        }

        .type-price .free-text {
            color: #00ff88;
            font-size: 32px;
        }

        /* Free Numbers Pool */
        .numbers-pool {
            background: white;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .pool-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .pool-header h2 {
            color: #333;
            font-size: 24px;
        }

        .search-box {
            position: relative;
            width: 300px;
        }

        .search-box input {
            width: 100%;
            padding: 12px 20px 12px 45px;
            border: 2px solid #e0e6ed;
            border-radius: 10px;
            font-size: 15px;
            transition: all 0.3s;
        }

        .search-box input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .search-box i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #666;
        }

        .numbers-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
        }

        .number-card {
            background: #f8f9fa;
            border: 2px solid #e0e6ed;
            border-radius: 10px;
            padding: 25px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }

        .number-card:hover {
            border-color: #00ff88;
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 255, 136, 0.1);
        }

        .number-card.selected {
            border-color: #00ff88;
            background: rgba(0, 255, 136, 0.05);
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);
        }

        .number-card.free::after {
            content: 'FREE';
            position: absolute;
            top: -10px;
            right: -10px;
            background: #00ff88;
            color: white;
            padding: 5px 15px;
            font-size: 12px;
            font-weight: bold;
            border-radius: 20px;
            box-shadow: 0 5px 15px rgba(0, 255, 136, 0.3);
        }

        .number {
            font-size: 20px;
            font-weight: bold;
            color: #333;
            margin-bottom: 10px;
            font-family: 'Courier New', monospace;
        }

        .number-type {
            font-size: 12px;
            color: #666;
            background: #e9ecef;
            padding: 4px 12px;
            border-radius: 20px;
            display: inline-block;
        }

        .free-label {
            color: #00ff88;
            font-weight: bold;
            font-size: 14px;
            margin-top: 8px;
        }

        /* Generation Process */
        .generation-process {
            background: white;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .process-steps {
            display: flex;
            justify-content: space-between;
            position: relative;
            margin: 40px 0;
        }

        .process-steps::before {
            content: '';
            position: absolute;
            top: 25px;
            left: 0;
            right: 0;
            height: 3px;
            background: #e0e6ed;
            z-index: 1;
        }

        .step {
            text-align: center;
            position: relative;
            z-index: 2;
            flex: 1;
        }

        .step-circle {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #f8f9fa;
            border: 3px solid #e0e6ed;
            color: #666;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
            margin: 0 auto 15px;
            transition: all 0.3s;
        }

        .step.active .step-circle {
            background: #00ff88;
            border-color: #00ff88;
            color: white;
            box-shadow: 0 0 20px rgba(0, 255, 136, 0.4);
        }

        .step.completed .step-circle {
            background: #667eea;
            border-color: #667eea;
            color: white;
        }

        .step-label {
            color: #666;
            font-weight: 600;
            font-size: 14px;
        }

        .step.active .step-label {
            color: #333;
        }

        /* Generation Form */
        .generation-form {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 30px;
            margin-top: 30px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            color: #333;
            font-weight: 600;
            margin-bottom: 10px;
            font-size: 15px;
        }

        .form-control {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e0e6ed;
            border-radius: 10px;
            font-size: 16px;
            transition: all 0.3s;
            background: white;
        }

        .form-control:focus {
            outline: none;
            border-color: #667eea;
            background: white;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .form-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        /* Buttons */
        .btn {
            padding: 15px 30px;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
            text-decoration: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-success {
            background: linear-gradient(135deg, #00ff88 0%, #00cc6a 100%);
            color: white;
        }

        .btn-success:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 255, 136, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid #667eea;
            color: #667eea;
        }

        .btn-outline:hover {
            background: #667eea;
            color: white;
        }

        .btn-large {
            padding: 20px 40px;
            font-size: 18px;
        }

        /* Generated Number Display */
        .generated-number-display {
            text-align: center;
            padding: 40px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 20px;
            color: white;
            margin: 30px 0;
            display: none;
        }

        .generated-number-display.show {
            display: block;
            animation: slideIn 0.5s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .number-icon {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 36px;
        }

        .generated-number {
            font-size: 48px;
            font-weight: bold;
            margin: 20px 0;
            font-family: 'Courier New', monospace;
        }

        .number-actions {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 30px;
        }

        /* Technical Info */
        .technical-info {
            background: white;
            border-radius: 15px;
            padding: 30px;
            margin-top: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        }

        .tech-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
            margin-top: 20px;
        }

        .tech-item {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            border-left: 4px solid #00ff88;
        }

        .tech-item h4 {
            color: #333;
            margin-bottom: 10px;
            font-size: 16px;
        }

        .tech-item p {
            color: #666;
            font-size: 14px;
            line-height: 1.6;
        }

        /* Responsive */
        @media (max-width: 992px) {
            .sidebar {
                display: none;
            }
            
            .main-content {
                margin-left: 0;
            }
            
            .header {
                flex-direction: column;
                gap: 20px;
            }
            
            .numbers-grid {
                grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            }
            
            .process-steps {
                flex-wrap: wrap;
                gap: 20px;
            }
            
            .step {
                flex: none;
                width: calc(50% - 10px);
            }
        }

        @media (max-width: 768px) {
            .number-types {
                grid-template-columns: 1fr;
            }
            
            .pool-header {
                flex-direction: column;
                gap: 15px;
                align-items: stretch;
            }
            
            .search-box {
                width: 100%;
            }
            
            .numbers-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .step {
                width: 100%;
            }
            
            .number-actions {
                flex-direction: column;
            }
            
            .btn {
                width: 100%;
                justify-content: center;
            }
        }

        /* Verification Section */
        .verification-section {
            background: white;
            border-radius: 15px;
            padding: 30px;
            margin: 30px 0;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            display: none;
        }

        .verification-section.show {
            display: block;
        }

        .verification-methods {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .verification-method {
            border: 2px solid #e0e6ed;
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }

        .verification-method:hover {
            border-color: #667eea;
            transform: translateY(-5px);
        }

        .verification-method.selected {
            border-color: #00ff88;
            background: rgba(0, 255, 136, 0.05);
        }

        .verification-method i {
            font-size: 36px;
            color: #667eea;
            margin-bottom: 15px;
        }

        /* Progress Bar */
        .progress-container {
            width: 100%;
            background: #e0e6ed;
            border-radius: 10px;
            overflow: hidden;
            margin: 30px 0;
            height: 10px;
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #00ff88, #00cc6a);
            width: 0%;
            transition: width 0.5s ease;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2>SSPAR <span>Cloud</span></h2>
            <div class="free-badge">FREE NUMBERS AVAILABLE</div>
        </div>

        <div class="menu-title">Main Menu</div>
        <a href="/dashboard" class="menu-link">
            <i class="fas fa-home"></i>
            <span>Dashboard</span>
        </a>
        
        <a href="/virtual-numbers" class="menu-link active">
            <i class="fas fa-phone"></i>
            <span>Virtual Numbers</span>
        </a>
        
        <a href="/free-numbers" class="menu-link">
            <i class="fas fa-gift"></i>
            <span>Free Numbers</span>
        </a>
        
        <a href="/calls" class="menu-link">
            <i class="fas fa-phone-volume"></i>
            <span>Calls</span>
        </a>
        
        <a href="/sms" class="menu-link">
            <i class="fas fa-sms"></i>
            <span>SMS</span>
        </a>

        <div class="menu-title">My Account</div>
        <a href="/profile" class="menu-link">
            <i class="fas fa-user"></i>
            <span>Profile</span>
        </a>
        
        <a href="/my-numbers" class="menu-link">
            <i class="fas fa-list"></i>
            <span>My Numbers (3)</span>
        </a>
        
        <a href="/settings" class="menu-link">
            <i class="fas fa-cog"></i>
            <span>Settings</span>
        </a>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Header -->
        <div class="header">
            <div class="header-info">
                <h1><i class="fas fa-gift"></i> FREE Virtual Numbers</h1>
                <p>Get FREE virtual numbers for testing, development, and personal use. No payment required!</p>
            </div>
            <div class="free-count">
                <div class="count">5</div>
                <div class="label">FREE NUMBERS LEFT TODAY</div>
            </div>
        </div>

        <!-- Free Number Types -->
        <div class="number-types">
            <div class="type-card free">
                <div class="type-icon">
                    <i class="fas fa-mobile-alt"></i>
                </div>
                <h3>Basic Free Number</h3>
                <ul class="type-features">
                    <li><i class="fas fa-check"></i> FREE Forever</li>
                    <li><i class="fas fa-check"></i> 100 Calls/Month</li>
                    <li><i class="fas fa-check"></i> 100 SMS/Month</li>
                    <li><i class="fas fa-check"></i> Basic IVR</li>
                    <li><i class="fas fa-check"></i> 7 Days Call Recording</li>
                </ul>
                <div class="type-price">
                    <span class="original">₹299</span>
                    <span class="free-text">FREE</span>
                </div>
                <button class="btn btn-success btn-large" onclick="selectFreePlan('basic')" style="width: 100%;">
                    <i class="fas fa-download"></i> Get FREE Number
                </button>
            </div>

            <div class="type-card free">
                <div class="type-icon">
                    <i class="fas fa-phone-square"></i>
                </div>
                <h3>Toll Free Number</h3>
                <ul class="type-features">
                    <li><i class="fas fa-check"></i> FREE for 30 Days</li>
                    <li><i class="fas fa-check"></i> Unlimited Incoming</li>
                    <li><i class="fas fa-check"></i> Multi-level IVR</li>
                    <li><i class="fas fa-check"></i> Call Forwarding</li>
                    <li><i class="fas fa-check"></i> 30 Days Recording</li>
                </ul>
                <div class="type-price">
                    <span class="original">₹899</span>
                    <span class="free-text">FREE TRIAL</span>
                </div>
                <button class="btn btn-success btn-large" onclick="selectFreePlan('toll-free')" style="width: 100%;">
                    <i class="fas fa-star"></i> Start FREE Trial
                </button>
            </div>

            <div class="type-card featured">
                <div class="type-icon">
                    <i class="fas fa-bolt"></i>
                </div>
                <h3>Developer Number</h3>
                <ul class="type-features">
                    <li><i class="fas fa-check"></i> FREE for Developers</li>
                    <li><i class="fas fa-check"></i> API Access</li>
                    <li><i class="fas fa-check"></i> Webhooks Support</li>
                    <li><i class="fas fa-check"></i> SDK Integration</li>
                    <li><i class="fas fa-check"></i> 60 Days Validity</li>
                </ul>
                <div class="type-price">
                    <span class="original">₹1,499</span>
                    <span class="free-text">DEVELOPER FREE</span>
                </div>
                <button class="btn btn-primary btn-large" onclick="selectFreePlan('developer')" style="width: 100%;">
                    <i class="fas fa-code"></i> Developer Access
                </button>
            </div>
        </div>

        <!-- Free Numbers Pool -->
        <div class="numbers-pool">
            <div class="pool-header">
                <h2><i class="fas fa-tags"></i> Available FREE Numbers</h2>
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" id="searchNumbers" placeholder="Search numbers (e.g., 8888, 1234)" oninput="filterFreeNumbers()">
                </div>
            </div>
            
            <div class="numbers-grid" id="freeNumbersGrid">
                <!-- Free numbers will be loaded here -->
            </div>
        </div>

        <!-- Generation Process -->
        <div class="generation-process">
            <h2 style="color: #333; font-size: 24px; margin-bottom: 10px;">
                <i class="fas fa-cogs"></i> FREE Number Generation Process
            </h2>
            <p style="color: #666; margin-bottom: 30px;">
                Get your FREE virtual number in just 3 simple steps
            </p>

            <div class="process-steps">
                <div class="step active" id="step1-indicator">
                    <div class="step-circle">1</div>
                    <div class="step-label">Select Number</div>
                </div>
                <div class="step" id="step2-indicator">
                    <div class="step-circle">2</div>
                    <div class="step-label">Verify Account</div>
                </div>
                <div class="step" id="step3-indicator">
                    <div class="step-circle">3</div>
                    <div class="step-label">Get Number</div>
                </div>
            </div>

            <!-- Step 1: Select Number -->
            <div class="generation-form" id="step1-form">
                <div class="form-group">
                    <label><i class="fas fa-flag"></i> Select Country</label>
                    <select class="form-control" id="freeCountrySelect" onchange="loadFreeNumbers()">
                        <option value="IN">India (+91) - FREE</option>
                        <option value="US">United States (+1) - FREE Trial</option>
                        <option value="UK">United Kingdom (+44) - FREE Trial</option>
                    </select>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-phone"></i> Choose Your FREE Number</label>
                    <div style="color: #666; margin-bottom: 15px; font-size: 14px;">
                        Select from available FREE numbers. These are completely FREE with no hidden charges.
                    </div>
                    <div id="selectedNumberDisplay" style="display: none;">
                        <div style="background: rgba(0, 255, 136, 0.1); padding: 15px; border-radius: 10px; border: 2px solid #00ff88;">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <div>
                                    <div style="font-size: 20px; font-weight: bold; color: #333;" id="selectedNumberText"></div>
                                    <div style="color: #666; font-size: 14px;" id="selectedNumberType"></div>
                                </div>
                                <button class="btn btn-outline" onclick="clearSelection()">
                                    <i class="fas fa-times"></i> Change
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-info-circle"></i> Purpose (Optional)</label>
                    <select class="form-control" id="purposeSelect">
                        <option value="">-- Select Purpose --</option>
                        <option value="testing">Testing & Development</option>
                        <option value="personal">Personal Use</option>
                        <option value="business">Small Business</option>
                        <option value="education">Educational Purpose</option>
                        <option value="other">Other</option>
                    </select>
                    <small style="color: #666; margin-top: 5px; display: block;">
                        Helps us improve our FREE number allocation
                    </small>
                </div>

                <div style="text-align: center; margin-top: 30px;">
                    <button class="btn btn-success btn-large" onclick="proceedToVerification()" id="proceedBtn" disabled>
                        <i class="fas fa-arrow-right"></i> Proceed to Verification
                    </button>
                </div>
            </div>

            <!-- Step 2: Verification -->
            <div class="verification-section" id="step2-form">
                <h3 style="color: #333; margin-bottom: 20px; font-size: 22px;">
                    <i class="fas fa-shield-alt"></i> Account Verification
                </h3>
                <p style="color: #666; margin-bottom: 25px;">
                    To prevent abuse and ensure fair usage, please verify your account
                </p>

                <div class="verification-methods">
                    <div class="verification-method" onclick="selectVerification('email')">
                        <i class="fas fa-envelope"></i>
                        <h4>Email Verification</h4>
                        <p>Verify via email OTP</p>
                    </div>
                    
                    <div class="verification-method" onclick="selectVerification('mobile')">
                        <i class="fas fa-mobile-alt"></i>
                        <h4>Mobile OTP</h4>
                        <p>OTP sent to your mobile</p>
                    </div>
                    
                    <div class="verification-method" onclick="selectVerification('google')">
                        <i class="fab fa-google"></i>
                        <h4>Google Account</h4>
                        <p>Login with Google</p>
                    </div>
                    
                    <div class="verification-method" onclick="selectVerification('github')">
                        <i class="fab fa-github"></i>
                        <h4>GitHub Account</h4>
                        <p>For developers</p>
                    </div>
                </div>

                <div id="verificationDetails" style="display: none;">
                    <div class="form-group">
                        <label id="verificationLabel">Enter verification code</label>
                        <div style="display: flex; gap: 10px;">
                            <input type="text" class="form-control" id="verificationCode" placeholder="Enter code">
                            <button class="btn btn-success" onclick="sendVerification()" id="sendCodeBtn">
                                <i class="fas fa-paper-plane"></i> Send Code
                            </button>
                        </div>
                    </div>
                    
                    <div style="text-align: center; margin-top: 30px;">
                        <button class="btn btn-success btn-large" onclick="verifyAccount()" id="verifyBtn" disabled>
                            <i class="fas fa-check"></i> Verify & Get Number
                        </button>
                    </div>
                </div>
            </div>

            <!-- Step 3: Generation Progress -->
            <div class="generated-number-display" id="step3-form">
                <div class="number-icon">
                    <i class="fas fa-cog fa-spin"></i>
                </div>
                <h2>Generating Your FREE Number</h2>
                <p>Please wait while we allocate and activate your number...</p>
                
                <div class="progress-container">
                    <div class="progress-bar" id="generationProgress"></div>
                </div>
                
                <div id="generationStatus" style="margin: 20px 0; min-height: 100px;">
                    <!-- Status updates will appear here -->
                </div>
            </div>
        </div>

        <!-- Generated Number Result -->
        <div class="generated-number-display" id="resultDisplay">
            <div class="number-icon">
                <i class="fas fa-check"></i>
            </div>
            <h2>FREE Number Activated!</h2>
            <div class="generated-number" id="finalGeneratedNumber">+91 98765 43210</div>
            <p>Your FREE virtual number is now active and ready to use</p>
            
            <div style="background: rgba(255, 255, 255, 0.1); border-radius: 10px; padding: 20px; margin: 30px 0;">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                    <div>
                        <small>Number Type</small>
                        <p style="font-weight: bold;" id="resultType">Mobile</p>
                    </div>
                    <div>
                        <small>Country</small>
                        <p style="font-weight: bold;" id="resultCountry">India</p>
                    </div>
                    <div>
                        <small>Validity</small>
                        <p style="font-weight: bold;" id="resultValidity">30 Days</p>
                    </div>
                    <div>
                        <small>Calls/SMS Limit</small>
                        <p style="font-weight: bold;" id="resultLimits">100/100</p>
                    </div>
                </div>
            </div>
            
            <div class="number-actions">
                <button class="btn btn-success" onclick="makeTestCall()">
                    <i class="fas fa-phone-alt"></i> Test Call
                </button>
                <button class="btn btn-primary" onclick="sendTestSMS()">
                    <i class="fas fa-sms"></i> Test SMS
                </button>
                <button class="btn" style="background: white; color: #333;" onclick="goToDashboard()">
                    <i class="fas fa-tachometer-alt"></i> Go to Dashboard
                </button>
            </div>
        </div>

        <!-- Technical Information -->
        <div class="technical-info">
            <h3 style="color: #333; margin-bottom: 20px; font-size: 22px;">
                <i class="fas fa-info-circle"></i> How FREE Numbers Work
            </h3>
            
            <div class="tech-grid">
                <div class="tech-item">
                    <h4><i class="fas fa-database"></i> Number Pool System</h4>
                    <p>We maintain a rotating pool of numbers that are allocated to users for FREE periods. Numbers rotate every 30 days.</p>
                </div>
                
                <div class="tech-item">
                    <h4><i class="fas fa-server"></i> Shared Infrastructure</h4>
                    <p>FREE numbers use shared telephony infrastructure, ensuring cost efficiency while maintaining quality.</p>
                </div>
                
                <div class="tech-item">
                    <h4><i class="fas fa-shield-alt"></i> Fair Usage Policy</h4>
                    <p>To prevent abuse, FREE numbers have usage limits. You can upgrade anytime for unlimited access.</p>
                </div>
                
                <div class="tech-item">
                    <h4><i class="fas fa-sync-alt"></i> Automatic Recycling</h4>
                    <p>After FREE period ends, numbers are returned to the pool for other users, ensuring maximum availability.</p>
                </div>
            </div>
            
            <div style="margin-top: 30px; padding: 20px; background: rgba(0, 255, 136, 0.1); border-radius: 10px;">
                <h4 style="color: #333; margin-bottom: 10px;"><i class="fas fa-lightbulb"></i> Pro Tips</h4>
                <ul style="color: #666; list-style: none;">
                    <li><i class="fas fa-check" style="color: #00ff88;"></i> Use FREE numbers for testing and development</li>
                    <li><i class="fas fa-check" style="color: #00ff88;"></i> Get multiple FREE numbers for different projects</li>
                    <li><i class="fas fa-check" style="color: #00ff88;"></i> Upgrade to premium for business use</li>
                </ul>
            </div>
        </div>
    </div>

    <script>
        // Initialize variables
        let selectedFreeNumber = null;
        let selectedPlan = null;
        let verificationMethod = null;
        let currentStep = 1;

        // Available FREE numbers data
        const freeNumbers = [
            { number: "+91 98765 43210", type: "mobile", country: "IN", status: "free", pattern: "98765" },
            { number: "+91 98765 12345", type: "mobile", country: "IN", status: "free", pattern: "12345" },
            { number: "+91 98765 67890", type: "mobile", country: "IN", status: "free", pattern: "67890" },
            { number: "1800 123 4567", type: "toll-free", country: "IN", status: "free", pattern: "1234567" },
            { number: "+1 (555) 123-4567", type: "mobile", country: "US", status: "free-trial", pattern: "1234567" },
            { number: "+44 7911 123456", type: "mobile", country: "UK", status: "free-trial", pattern: "123456" },
            { number: "+91 98765 88888", type: "mobile", country: "IN", status: "free", pattern: "88888" },
            { number: "+91 98765 99999", type: "mobile", country: "IN", status: "free", pattern: "99999" },
        ];

        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            loadFreeNumbers();
        });

        // Load FREE numbers
        function loadFreeNumbers() {
            const country = document.getElementById('freeCountrySelect').value;
            const container = document.getElementById('freeNumbersGrid');
            container.innerHTML = '';
            
            const filteredNumbers = freeNumbers.filter(num => num.country === country);
            
            if (filteredNumbers.length === 0) {
                container.innerHTML = `
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #666;">
                        <i class="fas fa-phone-slash" style="font-size: 48px; margin-bottom: 20px; display: block;"></i>
                        <h3>No FREE Numbers Available</h3>
                        <p>Check back later or try a different country</p>
                    </div>
                `;
                return;
            }
            
            filteredNumbers.forEach(num => {
                const div = document.createElement('div');
                div.className = `number-card ${num.status === 'free' ? 'free' : ''}`;
                div.innerHTML = `
                    <div class="number">${num.number}</div>
                    <div class="number-type">${num.type.toUpperCase()}</div>
                    <div class="free-label">${num.status === 'free' ? 'FREE FOREVER' : 'FREE TRIAL'}</div>
                `;
                div.onclick = () => selectFreeNumber(num);
                container.appendChild(div);
            });
        }

        // Filter FREE numbers
        function filterFreeNumbers() {
            const search = document.getElementById('searchNumbers').value.toLowerCase();
            const country = document.getElementById('freeCountrySelect').value;
            
            const cards = document.querySelectorAll('.number-card');
            cards.forEach(card => {
                const number = card.querySelector('.number').textContent;
                const matchesSearch = !search || number.includes(search);
                card.style.display = matchesSearch ? 'block' : 'none';
            });
        }

        // Select FREE number
        function selectFreeNumber(number) {
            selectedFreeNumber = number;
            
            // Remove selected class from all
            document.querySelectorAll('.number-card').forEach(card => {
                card.classList.remove('selected');
            });
            
            // Add selected class to clicked card
            event.currentTarget.classList.add('selected');
            
            // Show selected number display
            document.getElementById('selectedNumberText').textContent = number.number;
            document.getElementById('selectedNumberType').textContent = `${number.type.toUpperCase()} • ${number.status === 'free' ? 'FREE Forever' : 'FREE Trial'}`;
            document.getElementById('selectedNumberDisplay').style.display = 'block';
            
            // Enable proceed button
            document.getElementById('proceedBtn').disabled = false;
        }

        // Clear selection
        function clearSelection() {
            selectedFreeNumber = null;
            document.getElementById('selectedNumberDisplay').style.display = 'none';
            document.getElementById('proceedBtn').disabled = true;
            
            // Remove selected class from all
            document.querySelectorAll('.number-card').forEach(card => {
                card.classList.remove('selected');
            });
        }

        // Select FREE plan
        function selectFreePlan(plan) {
            selectedPlan = plan;
            alert(`Selected ${plan} FREE plan. Now choose a number from the available pool.`);
            
            // Scroll to numbers pool
            document.querySelector('.numbers-pool').scrollIntoView({ behavior: 'smooth' });
        }

        // Proceed to verification
        function proceedToVerification() {
            if (!selectedFreeNumber) {
                alert('Please select a FREE number first');
                return;
            }
            
            // Update steps
            document.getElementById('step1-indicator').classList.remove('active');
            document.getElementById('step1-indicator').classList.add('completed');
            document.getElementById('step2-indicator').classList.add('active');
            
            // Show verification section
            document.getElementById('step2-form').classList.add('show');
            document.getElementById('step1-form').style.display = 'none';
            
            currentStep = 2;
        }

        // Select verification method
        function selectVerification(method) {
            verificationMethod = method;
            
            // Remove selected class from all
            document.querySelectorAll('.verification-method').forEach(item => {
                item.classList.remove('selected');
            });
            
            // Add selected class to clicked method
            event.currentTarget.classList.add('selected');
            
            // Show verification details
            const details = document.getElementById('verificationDetails');
            details.style.display = 'block';
            
            // Update label and button text based on method
            let label = '';
            let btnText = '';
            
            switch(method) {
                case 'email':
                    label = 'Enter email address';
                    btnText = 'Send OTP to Email';
                    break;
                case 'mobile':
                    label = 'Enter mobile number';
                    btnText = 'Send OTP to Mobile';
                    break;
                case 'google':
                    label = 'Click to authenticate with Google';
                    btnText = 'Login with Google';
                    break;
                case 'github':
                    label = 'Click to authenticate with GitHub';
                    btnText = 'Login with GitHub';
                    break;
            }
            
            document.getElementById('verificationLabel').textContent = label;
            document.getElementById('sendCodeBtn').innerHTML = `<i class="fas fa-paper-plane"></i> ${btnText}`;
            document.getElementById('verifyBtn').disabled = method === 'google' || method === 'github';
        }

        // Send verification code
        function sendVerification() {
            const method = verificationMethod;
            
            if (!method) {
                alert('Please select a verification method');
                return;
            }
            
            if (method === 'google' || method === 'github') {
                // Social login - open OAuth window
                if (method === 'google') {
                    alert('Redirecting to Google authentication...');
                    // window.open('/auth/google', 'oauth', 'width=500,height=600');
                } else {
                    alert('Redirecting to GitHub authentication...');
                    // window.open('/auth/github', 'oauth', 'width=500,height=600');
                }
                document.getElementById('verifyBtn').disabled = false;
                return;
            }
            
            // Email/Mobile OTP
            const codeInput = document.getElementById('verificationCode');
            if (!codeInput.value.trim()) {
                alert(`Please enter your ${method === 'email' ? 'email address' : 'mobile number'}`);
                return;
            }
            
            alert(`Verification code sent to ${codeInput.value}`);
            codeInput.value = '';
            codeInput.placeholder = 'Enter 6-digit OTP';
            document.getElementById('verifyBtn').disabled = false;
            document.getElementById('sendCodeBtn').innerHTML = '<i class="fas fa-redo"></i> Resend Code';
        }

        // Verify account and generate number
        function verifyAccount() {
            if (!verificationMethod) {
                alert('Please select a verification method');
                return;
            }
            
            if (verificationMethod === 'email' || verificationMethod === 'mobile') {
                const code = document.getElementById('verificationCode').value;
                if (!code || code.length !== 6) {
                    alert('Please enter a valid 6-digit OTP');
                    return;
                }
            }
            
            // Update steps
            document.getElementById('step2-indicator').classList.remove('active');
            document.getElementById('step2-indicator').classList.add('completed');
            document.getElementById('step3-indicator').classList.add('active');
            
            // Hide verification, show generation
            document.getElementById('step2-form').classList.remove('show');
            document.getElementById('step3-form').classList.add('show');
            
            currentStep = 3;
            
            // Start generation process
            startNumberGeneration();
        }

        // Start number generation
        function startNumberGeneration() {
            const progressBar = document.getElementById('generationProgress');
            const statusDiv = document.getElementById('generationStatus');
            
            // Step 1: Verification
            setTimeout(() => {
                progressBar.style.width = '20%';
                statusDiv.innerHTML = `
                    <div style="background: rgba(0, 255, 136, 0.1); padding: 15px; border-radius: 10px; margin: 10px 0;">
                        <i class="fas fa-check-circle" style="color: #00ff88;"></i>
                        <strong>Account Verified</strong>
                        <p>Your account has been verified successfully</p>
                    </div>
                `;
            }, 1000);
            
            // Step 2: Allocating number
            setTimeout(() => {
                progressBar.style.width = '40%';
                statusDiv.innerHTML += `
                    <div style="background: rgba(102, 126, 234, 0.1); padding: 15px; border-radius: 10px; margin: 10px 0;">
                        <i class="fas fa-sync fa-spin" style="color: #667eea;"></i>
                        <strong>Allocating Number</strong>
                        <p>Reserving ${selectedFreeNumber.number} from FREE pool</p>
                    </div>
                `;
            }, 2000);
            
            // Step 3: System configuration
            setTimeout(() => {
                progressBar.style.width = '60%';
                statusDiv.innerHTML += `
                    <div style="background: rgba(102, 126, 234, 0.1); padding: 15px; border-radius: 10px; margin: 10px 0;">
                        <i class="fas fa-server" style="color: #667eea;"></i>
                        <strong>Configuring System</strong>
                        <p>Setting up telephony infrastructure</p>
                    </div>
                `;
            }, 3000);
            
            // Step 4: Activation
            setTimeout(() => {
                progressBar.style.width = '80%';
                statusDiv.innerHTML += `
                    <div style="background: rgba(102, 126, 234, 0.1); padding: 15px; border-radius: 10px; margin: 10px 0;">
                        <i class="fas fa-bolt" style="color: #667eea;"></i>
                        <strong>Activating Number</strong>
                        <p>Activating number in telecom network</p>
                    </div>
                `;
            }, 4000);
            
            // Step 5: Testing
            setTimeout(() => {
                progressBar.style.width = '90%';
                statusDiv.innerHTML += `
                    <div style="background: rgba(102, 126, 234, 0.1); padding: 15px; border-radius: 10px; margin: 10px 0;">
                        <i class="fas fa-vial" style="color: #667eea;"></i>
                        <strong>Testing Functionality</strong>
                        <p>Verifying call and SMS capabilities</p>
                    </div>
                `;
            }, 5000);
            
            // Final step: Show result
            setTimeout(() => {
                progressBar.style.width = '100%';
                
                // Hide generation, show result
                document.getElementById('step3-form').classList.remove('show');
                document.getElementById('resultDisplay').classList.add('show');
                
                // Update result display
                document.getElementById('finalGeneratedNumber').textContent = selectedFreeNumber.number;
                document.getElementById('resultType').textContent = selectedFreeNumber.type.toUpperCase();
                document.getElementById('resultCountry').textContent = selectedFreeNumber.country === 'IN' ? 'India' : 
                                                                      selectedFreeNumber.country === 'US' ? 'USA' : 'UK';
                document.getElementById('resultValidity').textContent = selectedFreeNumber.status === 'free' ? '30 Days' : '7 Days';
                document.getElementById('resultLimits').textContent = '100 Calls, 100 SMS';
                
                // Update FREE count
                const freeCount = document.querySelector('.free-count .count');
                let currentCount = parseInt(freeCount.textContent);
                if (currentCount > 0) {
                    freeCount.textContent = currentCount - 1;
                }
                
            }, 6000);
        }

        // Test call functionality
        function makeTestCall() {
            const number = document.getElementById('finalGeneratedNumber').textContent;
            alert(`Initiating test call to ${number}...\n\nCall will be made to verify your new FREE number is working properly.`);
        }

        // Test SMS functionality
        function sendTestSMS() {
            const number = document.getElementById('finalGeneratedNumber').textContent;
            alert(`Sending test SMS to ${number}...\n\nYou should receive a test message on your new number.`);
        }

        // Go to dashboard
        function goToDashboard() {
            alert('Redirecting to your dashboard...');
            // window.location.href = '/dashboard';
        }

        // Add CSS for payment options
        const verificationMethods = document.querySelectorAll('.verification-method');
        verificationMethods.forEach(method => {
            method.style.cursor = 'pointer';
        });
    </script>
</body>
</html>