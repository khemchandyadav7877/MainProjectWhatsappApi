<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sessions Management - SSPAR Cloud</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* ===== THEME VARIABLES ===== */
        :root {
            --primary: #f59e0b;
            --primary-dark: #d97706;
            --primary-light: #fbbf24;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f3f4f6;
            --bg-white: #ffffff;
            --bg-offwhite: #f8fafc;
            --bg-card: #ffffff;
            --text: #1f2937;
            --text-light: #4b5563;
            --text-muted: #6b7280;
            --dark: #111827;
            --border: #e5e7eb;
            --shadow: 0 2px 10px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #111827;
            --bg-white: #1f2937;
            --bg-offwhite: #374151;
            --bg-card: #1f2937;
            --text: #f9fafb;
            --text-light: #e5e7eb;
            --text-muted: #9ca3af;
            --dark: #f9fafb;
            --border: #374151;
            --shadow: 0 2px 10px rgba(0,0,0,0.3);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.5);
        }

        /* RESET */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar-wrapper,
        body.round-border .main-content-card,
        body.round-border .session-stat-card,
        body.round-border .table-container,
        body.round-border .btn,
        body.round-border .form-control,
        body.round-border .session-badge,
        body.round-border .action-link,
        body.round-border .empty-box,
        body.round-border .toast-notification {
            border-radius: 16px !important;
        }

        body.round-border .active::before {
            border-radius: 50% !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar-wrapper,
        body.no-radius .main-content-card,
        body.no-radius .session-stat-card,
        body.no-radius .table-container,
        body.no-radius .btn,
        body.no-radius .form-control,
        body.no-radius .session-badge,
        body.no-radius .action-link,
        body.no-radius .empty-box,
        body.no-radius .toast-notification,
        body.no-radius .active::before {
            border-radius: 0 !important;
        }

        /* HEADER FIXED */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        /* MAIN LAYOUT */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
        }

        /* SIDEBAR WRAPPER */
        .sidebar-wrapper {
            width: 280px;
            flex-shrink: 0;
            position: fixed;
            left: 0;
            top: 70px;
            bottom: 0;
            z-index: 1020;
            transition: width 0.3s ease;
            background: var(--bg-white);
            border-right: 1px solid var(--border);
        }

        .sidebar-wrapper.collapsed {
            width: 80px;
        }

        /* CONTENT WRAPPER */
        .content-wrapper {
            flex: 1;
            margin-left: 280px;
            padding: 25px;
            transition: margin-left 0.3s ease;
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
        }

        .sidebar-wrapper.collapsed + .content-wrapper {
            margin-left: 80px;
        }

        /* PAGE HEADER */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .page-title {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .page-icon {
            width: 50px;
            height: 50px;
            background: var(--primary);
            color: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .page-title h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--dark);
            margin: 0;
        }

        .page-title p {
            color: var(--text-muted);
            margin: 5px 0 0;
            font-size: 14px;
        }

        .active-session-badge {
            background: var(--bg-white);
            border: 1px solid var(--border);
            border-radius: 30px;
            padding: 8px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .active-session-badge i {
            color: var(--primary);
            font-size: 18px;
        }

        .active-session-badge span {
            font-weight: 600;
            color: var(--dark);
        }

        .active-session-badge .badge {
            background: var(--success);
            color: white;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            margin-left: 5px;
        }

        /* STATS CARDS */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }

        .session-stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            box-shadow: var(--shadow);
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            background: rgba(245, 158, 11, 0.1);
            color: var(--primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
        }

        .stat-info h4 {
            font-size: 24px;
            font-weight: 700;
            color: var(--dark);
            margin: 0;
            line-height: 1.2;
        }

        .stat-info p {
            color: var(--text-muted);
            margin: 5px 0 0;
            font-size: 13px;
        }

        /* MAIN CONTENT CARD */
        .main-content-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 25px;
            box-shadow: var(--shadow);
        }

        /* TABLE CONTAINER */
        .table-container {
            background: var(--bg-white);
            border-radius: 12px;
            border: 1px solid var(--border);
            overflow: hidden;
            margin-top: 20px;
        }

        .table-header {
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
            background: var(--bg-offwhite);
        }

        .table-title {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .table-title i {
            color: var(--primary);
            font-size: 18px;
        }

        .table-title h5 {
            font-size: 16px;
            font-weight: 600;
            color: var(--dark);
            margin: 0;
        }

        .table-filters {
            display: flex;
            gap: 10px;
        }

        .search-box {
            position: relative;
        }

        .search-box i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
        }

        .search-box input {
            padding: 8px 15px 8px 35px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--bg-white);
            color: var(--text);
            width: 200px;
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--primary);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead {
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(217, 119, 6, 0.1));
        }

        th {
            padding: 16px 20px;
            color: var(--dark);
            font-weight: 600;
            font-size: 14px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            font-size: 14px;
        }

        tr:hover {
            background: var(--bg-offwhite);
        }

        .active {
            color: var(--success);
            font-weight: 600;
            position: relative;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .active::before {
            content: "";
            width: 10px;
            height: 10px;
            background: var(--success);
            border-radius: 50%;
            display: inline-block;
        }

        .inactive {
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .inactive::before {
            content: "";
            width: 10px;
            height: 10px;
            background: var(--text-muted);
            border-radius: 50%;
            display: inline-block;
        }

        .session-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-current {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .badge-next {
            background: rgba(245, 158, 11, 0.1);
            color: var(--primary);
            border: 1px solid rgba(245, 158, 11, 0.3);
        }

        .action-link {
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            margin: 0 3px;
            transition: all 0.2s;
        }

        .action-link.set-active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .action-link.set-active:hover {
            background: var(--success);
            color: white;
        }

        .action-link.delete {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .action-link.delete:hover {
            background: var(--danger);
            color: white;
        }

        /* EMPTY STATE */
        .empty-box {
            text-align: center;
            padding: 60px 20px;
            background: var(--bg-white);
            border: 2px dashed var(--border);
            border-radius: 12px;
            margin: 20px 0;
        }

        .empty-box i {
            font-size: 60px;
            color: var(--primary);
            opacity: 0.5;
            margin-bottom: 20px;
        }

        .empty-box h3 {
            font-size: 20px;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 10px;
        }

        .empty-box p {
            color: var(--text-muted);
            margin-bottom: 20px;
        }

        /* MESSAGES */
        .message-container {
            margin-bottom: 20px;
        }

        .message {
            padding: 15px 20px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideDown 0.3s ease;
            position: relative;
        }

        .message-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .message-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .close-btn {
            background: none;
            border: none;
            color: currentColor;
            font-size: 18px;
            cursor: pointer;
            margin-left: auto;
            opacity: 0.7;
        }

        .close-btn:hover {
            opacity: 1;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* BUTTONS */
        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 500;
            font-size: 14px;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(245, 158, 11, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text);
        }

        .btn-outline:hover {
            background: var(--bg-offwhite);
            border-color: var(--primary);
        }

        /* TOAST */
        #toast {
            position: fixed;
            top: 24px;
            right: 24px;
            width: 320px;
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 9999;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-progress {
            height: 3px;
            border-radius: 4px;
            margin-top: 10px;
            background: rgba(255,255,255,.6);
            animation: toast-load 3s linear forwards;
        }

        @keyframes toast-load {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* LOADING OVERLAY */
        .loading-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            z-index: 9999;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            color: white;
        }

        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(255,255,255,0.3);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 15px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* RESPONSIVE */
        @media (max-width: 992px) {
            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .sidebar-wrapper {
                transform: translateX(-100%);
                width: 280px !important;
            }
            
            .sidebar-wrapper.mobile-open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                padding: 15px;
            }
            
            .page-header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .stats-row {
                grid-template-columns: 1fr;
            }
            
            .table-filters {
                width: 100%;
            }
            
            .search-box input {
                width: 100%;
            }
            
            table {
                display: block;
                overflow-x: auto;
            }
            
            th, td {
                white-space: nowrap;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <div class="sidebar-wrapper" id="sidebarWrapper">
            <%- include('../partials/ram/sidebaar') %>
        </div>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <!-- Toast Container -->
            <div id="toast"></div>

            <!-- Loading Overlay -->
            <div class="loading-overlay" id="loadingOverlay">
                <div class="loading-spinner"></div>
                <h5 id="loadingText">Processing...</h5>
                <p id="loadingSubtext">Please wait</p>
            </div>

            <!-- Page Header -->
            <div class="page-header">
                <div class="page-title">
                    <div class="page-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div>
                        <h2>Sessions Management</h2>
                        <p>Manage academic sessions and set active session</p>
                    </div>
                </div>
                <div class="active-session-badge">
                    <i class="fas fa-calendar-check"></i>
                    <span><%= activeSession ? activeSession.sessionna : 'No Active Session' %></span>
                    <% if (activeSession) { %>
                        <span class="badge">Active</span>
                    <% } %>
                </div>
            </div>

            <!-- Messages -->
            <% if (typeof message !== 'undefined' && message) { %>
                <div class="message-container">
                    <div class="message message-success">
                        <i class="fas fa-check-circle"></i>
                        <span><%= message %></span>
                        <button class="close-btn" onclick="this.parentElement.remove()">&times;</button>
                    </div>
                </div>
            <% } %>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="message-container">
                    <div class="message message-error">
                        <i class="fas fa-exclamation-circle"></i>
                        <span><%= error %></span>
                        <button class="close-btn" onclick="this.parentElement.remove()">&times;</button>
                    </div>
                </div>
            <% } %>

            <!-- Stats Cards -->
            <div class="stats-row">
                <div class="session-stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-calendar"></i>
                    </div>
                    <div class="stat-info">
                        <h4><%= records ? records.length : 0 %></h4>
                        <p>Total Sessions</p>
                    </div>
                </div>
                <div class="session-stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-info">
                        <h4><%= records ? records.filter(r => r.status === 'Active').length : 0 %></h4>
                        <p>Active Sessions</p>
                    </div>
                </div>
                <div class="session-stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="stat-info">
                        <h4><%= records ? records.filter(r => r.status === 'Inactive').length : 0 %></h4>
                        <p>Inactive Sessions</p>
                    </div>
                </div>
                <div class="session-stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-tag"></i>
                    </div>
                    <div class="stat-info">
                        <h4><%= activeSession ? activeSession.sessionna.split('-')[0] : 'N/A' %></h4>
                        <p>Current Year</p>
                    </div>
                </div>
            </div>

            <!-- Main Content Card -->
            <div class="main-content-card">
                <!-- Header with Add Button -->
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;">
                    <div>
                        <h5 style="font-size: 18px; font-weight: 600; color: var(--dark); margin: 0;">All Sessions</h5>
                        <p style="color: var(--text-muted); font-size: 14px; margin: 5px 0 0;">List of all academic sessions</p>
                    </div>
                    <a href="/addnewsessionyears" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Add New Session
                    </a>
                </div>

                <!-- Table Container -->
                <div class="table-container">
                    <div class="table-header">
                        <div class="table-title">
                            <i class="fas fa-list"></i>
                            <h5>Sessions List</h5>
                        </div>
                        <div class="table-filters">
                            <div class="search-box">
                                <i class="fas fa-search"></i>
                                <input type="text" id="searchInput" placeholder="Search sessions...">
                            </div>
                        </div>
                    </div>

                    <% if (records && records.length > 0) { %>
                        <table id="sessionsTable">
                            <thead>
                                <tr>
                                    <th>Session</th>
                                    <th>Status</th>
                                    <th>Type</th>
                                    <th>Created At</th>
                                    <th>Last Updated</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% records.forEach((val) => { %>
                                    <tr class="session-row" data-session="<%= val.sessionna %>">
                                        <td>
                                            <strong><%= val.sessionna %></strong>
                                        </td>
                                        <td>
                                            <span class="<%= val.status === 'Active' ? 'active' : 'inactive' %>">
                                                <%= val.status %>
                                            </span>
                                        </td>
                                        <td>
                                            <span class="session-badge <%= val.sessionType === 'Current' ? 'badge-current' : 'badge-next' %>">
                                                <%= val.sessionType || 'Current' %>
                                            </span>
                                        </td>
                                        <td>
                                            <%= new Date(val.createdAt).toLocaleDateString('en-IN', { 
                                                year: 'numeric', 
                                                month: 'short', 
                                                day: 'numeric',
                                                hour: '2-digit',
                                                minute: '2-digit'
                                            }) %>
                                        </td>
                                        <td>
                                            <%= new Date(val.updatedAt || val.createdAt).toLocaleDateString('en-IN', { 
                                                year: 'numeric', 
                                                month: 'short', 
                                                day: 'numeric',
                                                hour: '2-digit',
                                                minute: '2-digit'
                                            }) %>
                                        </td>
                                        <td>
                                            <% if (val.status !== 'Active') { %>
                                                <a href="/activesession/<%= val._id %>" 
                                                   class="action-link set-active"
                                                   onclick="return confirmSetActive('<%= val.sessionna %>', event)">
                                                   <i class="fas fa-check-circle"></i> Set Active
                                                </a>
                                            <% } %>
                                            <a href="/deletesession/<%= val._id %>" 
                                               class="action-link delete"
                                               onclick="return confirmDelete('<%= val.sessionna %>', event)">
                                               <i class="fas fa-trash"></i> Delete
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div class="empty-box">
                            <i class="fas fa-calendar-times"></i>
                            <h3>No Sessions Found</h3>
                            <p>Add your first session to get started</p>
                            <a href="/addnewsessionyears" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Add New Session
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR SYNC
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('mainSidebar');
            const sidebarWrapper = document.getElementById('sidebarWrapper');
            
            if (sidebar && sidebarWrapper) {
                if (sidebar.classList.contains('collapsed')) {
                    sidebarWrapper.classList.add('collapsed');
                }
                
                window.toggleCollapse = function() {
                    if (sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        sidebarWrapper.classList.remove('collapsed');
                    } else {
                        sidebar.classList.add('collapsed');
                        sidebarWrapper.classList.add('collapsed');
                    }
                };
                
                window.toggleMobileSidebar = function() {
                    if (sidebar.classList.contains('open')) {
                        sidebar.classList.remove('open');
                        sidebarWrapper.classList.remove('mobile-open');
                    } else {
                        sidebar.classList.add('open');
                        sidebarWrapper.classList.add('mobile-open');
                    }
                };
                
                window.closeMobileSidebar = function() {
                    sidebar.classList.remove('open');
                    sidebarWrapper.classList.remove('mobile-open');
                };
            }

            // Show welcome toast
            setTimeout(() => {
                showToast('Sessions Management', 'Manage your academic sessions', 'info');
            }, 500);
        });

        // ======================
        // TOAST FUNCTION
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.className = '';
            toast.innerHTML = `
                <div style="display: flex; gap: 12px; align-items: flex-start;">
                    <div style="width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,.25);">
                        ${icon}
                    </div>
                    <div style="flex: 1;">
                        <h4 style="margin: 0; font-size: 14px; font-weight: 600;">${title}</h4>
                        <p style="margin: 4px 0 0; font-size: 13px; opacity: .9;">${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.classList.add(`toast-${type}`, 'show');
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOADING OVERLAY
        // ======================
        const loadingOverlay = document.getElementById('loadingOverlay');
        const loadingText = document.getElementById('loadingText');
        const loadingSubtext = document.getElementById('loadingSubtext');

        function showLoading(text, subtext) {
            loadingText.textContent = text || 'Processing...';
            loadingSubtext.textContent = subtext || 'Please wait';
            loadingOverlay.style.display = 'flex';
        }

        function hideLoading() {
            loadingOverlay.style.display = 'none';
        }

        // ======================
        // CONFIRMATION FUNCTIONS
        // ======================
        function confirmSetActive(sessionName, event) {
            event.preventDefault();
            const link = event.currentTarget.href;
            
            if (confirm(`⚠️ Set "${sessionName}" as active session?\n\nThis will log out all users immediately!`)) {
                showLoading('Changing Session', `Setting ${sessionName} as active...`);
                window.location.href = link;
            }
            return false;
        }

        function confirmDelete(sessionName, event) {
            event.preventDefault();
            const link = event.currentTarget.href;
            
            if (confirm(`🗑️ Delete session "${sessionName}"?\n\nThis action cannot be undone!`)) {
                showLoading('Deleting Session', `Removing ${sessionName}...`);
                window.location.href = link;
            }
            return false;
        }

        // ======================
        // SEARCH FUNCTIONALITY
        // ======================
        const searchInput = document.getElementById('searchInput');
        if (searchInput) {
            searchInput.addEventListener('keyup', function() {
                const searchTerm = this.value.toLowerCase();
                const rows = document.querySelectorAll('.session-row');
                
                rows.forEach(row => {
                    const sessionName = row.dataset.session.toLowerCase();
                    if (sessionName.includes(searchTerm)) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });
        }

        // ======================
        // AUTO-HIDE MESSAGES
        // ======================
        setTimeout(() => {
            document.querySelectorAll('.message-container').forEach(msg => {
                msg.style.opacity = '0';
                setTimeout(() => msg.remove(), 500);
            });
        }, 5000);

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            // Ctrl+N for new session
            if ((e.ctrlKey || e.metaKey) && e.key === 'n') {
                e.preventDefault();
                window.location.href = '/addnewsessionyears';
            }
            
            // F1 for help
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Keyboard Shortcuts', 'Ctrl+N: New Session\nF1: Help', 'info');
            }
        });

        // ======================
        // EXPORT FUNCTION (Optional)
        // ======================
        function exportSessions() {
            showToast('Export', 'Exporting sessions list...', 'info');
            // Add export logic here
        }
    </script>
</body>
</html>