<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Role Permissions Management</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Toastify CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    
    <style>
        .role-permissions-container {
            min-height: 100vh;
            background-color: #f8f9fa;
            padding: 20px;
        }
        
        .main-content {
            max-width: 1400px;
            margin: 0 auto;
        }
        
        /* Enhanced Refresh Button */
        .refresh-btn {
            background: linear-gradient(135deg, #0d6efd, #0a58ca);
            border: none;
            color: white;
            padding: 8px 16px;
            border-radius: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 2px 5px rgba(13, 110, 253, 0.3);
        }
        
        .refresh-btn:hover:not(:disabled) {
            background: linear-gradient(135deg, #0a58ca, #084298);
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.4);
        }
        
        .refresh-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }
        
        /* Enhanced Export Button */
        .export-btn {
            background: linear-gradient(135deg, #198754, #146c43);
            border: none;
            color: white;
            padding: 8px 16px;
            border-radius: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 2px 5px rgba(25, 135, 84, 0.3);
        }
        
        .export-btn:hover:not(:disabled) {
            background: linear-gradient(135deg, #146c43, #0f5132);
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(25, 135, 84, 0.4);
        }
        
        .export-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }
        
        /* Spin animation for refresh icon */
        .spin {
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        /* Improved Table Action Buttons */
        .btn-group .btn {
            border-radius: 6px !important;
            padding: 8px 12px;
            font-size: 14px;
        }
        
        .btn-group .btn:hover {
            transform: translateY(-1px);
        }
        
        /* Table styling */
        .table th {
            font-weight: 600;
            color: #6c757d;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid #dee2e6;
        }
        
        .table td {
            vertical-align: middle;
            padding: 1rem 0.75rem;
            border-bottom: 1px solid #e9ecef;
        }
        
        .table tbody tr:hover {
            background-color: rgba(13, 110, 253, 0.05);
        }
        
        .table-primary {
            background-color: rgba(13, 110, 253, 0.1) !important;
        }
        
        /* Order controls */
        .order-controls button {
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        /* Icon text styling */
        .icon-text {
            font-size: 18px;
            display: inline-block;
        }
        
        /* Stats cards styling */
        .card.border-0.shadow-sm {
            border-radius: 12px;
            transition: transform 0.2s ease;
        }
        
        .card.border-0.shadow-sm:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important;
        }
        
        /* Role tabs styling */
        .btn-outline-primary {
            border-color: #dee2e6;
            color: #6c757d;
        }
        
        .btn-outline-primary:hover {
            background-color: #0d6efd;
            border-color: #0d6efd;
            color: white;
        }
        
        /* Badge colors */
        .badge.bg-primary {
            background-color: #0d6efd !important;
        }
        
        .badge.bg-danger {
            background-color: #dc3545 !important;
        }
        
        .badge.bg-success {
            background-color: #198754 !important;
        }
        
        .badge.bg-warning {
            background-color: #ffc107 !important;
            color: #000;
        }
        
        .badge.bg-secondary {
            background-color: #6c757d !important;
        }
        
        .badge.bg-info {
            background-color: #0dcaf0 !important;
        }
        
        /* Responsive adjustments */
        @media (max-width: 768px) {
            .role-permissions-container {
                padding: 15px;
            }
            
            .content-header .d-flex {
                flex-direction: column;
                align-items: flex-start !important;
                gap: 15px;
            }
            
            .content-header .input-group {
                width: 100% !important;
            }
            
            .btn-group .btn {
                padding: 6px 10px;
                font-size: 12px;
            }
            
            .table-responsive {
                margin: 0 -15px;
                padding: 0 15px;
            }
            
            /* Hide order column on mobile */
            .table td:nth-child(5),
            .table th:nth-child(5) {
                display: none;
            }
            
            /* Smaller section/feature icons on mobile */
            .table td div.rounded-circle {
                width: 35px !important;
                height: 35px !important;
            }
            
            .table td .fs-5 {
                font-size: 1rem !important;
            }
        }
        
        @media (max-width: 576px) {
            .role-permissions-container {
                padding: 10px;
            }
            
            .content-header {
                padding: 15px;
            }
            
            /* Hide status column on small mobile */
            .table td:nth-child(4),
            .table th:nth-child(4) {
                display: none;
            }
            
            .badge {
                font-size: 0.75rem;
                padding: 0.5rem 0.75rem !important;
            }
            
            .stats-cards .col-6 {
                padding: 0 5px;
            }
            
            .card-body.text-center {
                padding: 10px !important;
            }
            
            h3.fw-bold {
                font-size: 1.2rem !important;
            }
        }
        
        @media (max-width: 480px) {
            /* Stack buttons vertically */
            .card-header .btn-group {
                flex-direction: column;
                width: 100%;
            }
            
            .card-header .btn-group .btn {
                width: 100%;
                margin-bottom: 5px;
            }
            
            /* Reduce font sizes */
            .fs-4 {
                font-size: 1.1rem !important;
            }
            
            .text-muted.small {
                font-size: 0.8rem;
            }
            
            /* Compact table row */
            .table td {
                padding: 8px 5px;
            }
            
            /* Smaller icons in table */
            .table td div.rounded-circle {
                width: 30px !important;
                height: 30px !important;
            }
        }
        
        @media (max-width: 360px) {
            /* Very small screens */
            .content-header h1 {
                font-size: 1rem !important;
            }
            
            .btn-sm {
                padding: 4px 8px;
                font-size: 0.75rem;
            }
            
            /* Hide section column */
            .table td:nth-child(2),
            .table th:nth-child(2) {
                display: none;
            }
        }
    </style>
</head>
<body>


    <div class="role-permissions-container">
        <div class="main-content">
            
            <!-- Content Header -->
            <div class="content-header bg-white rounded shadow-sm p-3 mb-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div>
                        <h1 class="fw-bold text-dark mb-0 fs-4">
                            <i class="fas fa-cubes me-2 text-primary"></i>
                            Role Permissions Management
                        </h1>
                        <p class="text-muted mb-0 small">Manage sidebar navigation features for each role</p>
                    </div>
                    
                    <div class="d-flex align-items-center gap-3">
                        <div class="input-group" style="width: 300px;">
                            <span class="input-group-text bg-white border-end-0">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                            <input
                                type="text"
                                class="form-control border-start-0"
                                id="searchInput"
                                placeholder="Search features..."
                            />
                        </div>
                        <a 
                            href="/dashboard"
                            class="btn btn-primary d-flex align-items-center gap-2 text-white"
                        >
                            <i class="fas fa-home"></i> Dashboard
                        </a>
                        <a 
                            href="/add-new-feature"
                            class="btn btn-success d-flex align-items-center gap-2 text-white"
                        >
                            <i class="fas fa-plus"></i> Add New Feature
                        </a>
                    </div>
                </div>

                <!-- Filter Controls -->
                <div class="row g-3 align-items-center">
                    <div class="col-auto">
                        <button 
                            class="btn btn-sm btn-outline-primary d-flex align-items-center gap-2"
                            id="toggleFilters"
                        >
                            <i class="fas fa-filter"></i>
                            <span id="filterText">Show Filters</span>
                        </button>
                    </div>
                    
                    <div id="filterControls" style="display: none;">
                        <div class="col-auto">
                            <label class="form-label mb-0 text-muted small">Status</label>
                            <select 
                                class="form-select form-select-sm border-primary"
                                id="statusFilter"
                            >
                                <option value="all">All Status</option>
                                <option value="active">Active</option>
                                <option value="inactive">Inactive</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <label class="form-label mb-0 text-muted small">Sort By</label>
                            <select 
                                class="form-select form-select-sm border-primary"
                                id="sortBy"
                            >
                                <option value="order">By Order</option>
                                <option value="name">A-Z by Name</option>
                                <option value="section">By Section</option>
                                <option value="newest">Newest First</option>
                                <option value="oldest">Oldest First</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Action Buttons -->
                    <div class="col-auto ms-auto">
                        <div class="d-flex align-items-center gap-2">
                            <button
                                class="btn btn-primary btn-sm d-flex align-items-center gap-2 refresh-btn"
                                id="refreshBtn"
                                title="Refresh Features"
                            >
                                <i class="fas fa-sync"></i>
                                Refresh
                            </button>
                            
                            <button
                                class="btn btn-success btn-sm d-flex align-items-center gap-2 export-btn"
                                id="exportBtn"
                                title="Export to CSV"
                            >
                                <i class="fas fa-file-export"></i>
                                Export
                            </button>

                            <button
                                class="btn btn-warning btn-sm d-flex align-items-center gap-2"
                                id="resetBtn"
                                title="Reset to Defaults"
                            >
                                <i class="fas fa-sync"></i>
                                Reset
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Stats Bar -->
            <div class="card border-0 bg-light mb-4">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-4">
                            <div class="d-flex align-items-center gap-2">
                                <i class="fas fa-cubes text-primary"></i>
                                <span class="text-muted">Total Features:</span>
                                <span class="fw-bold" id="totalFeatures">0</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <i class="fas fa-check-circle text-success"></i>
                                <span class="text-muted">Active:</span>
                                <span class="fw-bold text-success" id="activeFeatures">0</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <i class="fas fa-times-circle text-secondary"></i>
                                <span class="text-muted">Inactive:</span>
                                <span class="fw-bold text-secondary" id="inactiveFeatures">0</span>
                            </div>
                        </div>
                        <button 
                            class="btn btn-sm btn-outline-primary"
                            id="debugBtn"
                        >
                            Debug Data
                        </button>
                    </div>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="row g-3 mb-4">
                <div class="col-6 col-md-3 col-lg-2">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center p-3">
                            <h3 class="fw-bold text-dark mb-2" id="totalStats">0</h3>
                            <p class="text-muted small mb-0">Total Features</p>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center p-3">
                            <h3 class="fw-bold text-dark mb-2" id="superadminStats">0</h3>
                            <p class="text-muted small mb-0">SuperAdmin</p>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center p-3">
                            <h3 class="fw-bold text-dark mb-2" id="educatorStats">0</h3>
                            <p class="text-muted small mb-0">Educator</p>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center p-3">
                            <h3 class="fw-bold text-dark mb-2" id="trainerStats">0</h3>
                            <p class="text-muted small mb-0">Trainer</p>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center p-3">
                            <h3 class="fw-bold text-dark mb-2" id="studentStats">0</h3>
                            <p class="text-muted small mb-0">Student</p>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-3 col-lg-2">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center p-3">
                            <h3 class="fw-bold text-dark mb-2" id="activeStats">0</h3>
                            <p class="text-muted small mb-0">Active</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Role Tabs -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2" id="roleTabs">
                        <button
                            class="btn btn-primary d-flex align-items-center gap-2 role-tab"
                            data-role="SuperAdmin"
                        >
                            <i class="fas fa-user-shield"></i>
                            SuperAdmin
                            <span class="badge bg-light text-dark ms-1" id="superadminCount">0</span>
                        </button>
                        <button
                            class="btn btn-outline-primary d-flex align-items-center gap-2 role-tab"
                            data-role="Educator"
                        >
                            <i class="fas fa-user-tie"></i>
                            Educator
                            <span class="badge bg-light text-dark ms-1" id="educatorCount">0</span>
                        </button>
                        <button
                            class="btn btn-outline-primary d-flex align-items-center gap-2 role-tab"
                            data-role="Trainer"
                        >
                            <i class="fas fa-graduation-cap"></i>
                            Trainer
                            <span class="badge bg-light text-dark ms-1" id="trainerCount">0</span>
                        </button>
                        <button
                            class="btn btn-outline-primary d-flex align-items-center gap-2 role-tab"
                            data-role="Student"
                        >
                            <i class="fas fa-chalkboard-teacher"></i>
                            Student
                            <span class="badge bg-light text-dark ms-1" id="studentCount">0</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Bulk Actions -->
            <div class="card border-primary border-2 mb-4" id="bulkActions" style="display: none;">
                <div class="card-body bg-primary bg-opacity-5 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary text-white rounded-circle p-2">
                                <i class="fas fa-cubes" style="font-size: 20px;"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0" id="selectedCount">0 feature(s) selected</h6>
                                <small class="text-muted">Perform bulk actions on selected features</small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button
                                class="btn btn-outline-success btn-sm d-flex align-items-center gap-2"
                                id="bulkActiveBtn"
                            >
                                <i class="fas fa-check-circle"></i> Active
                            </button>
                            <button
                                class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-2"
                                id="bulkInactiveBtn"
                            >
                                <i class="fas fa-times-circle"></i> Inactive
                            </button>
                            <button
                                class="btn btn-outline-danger btn-sm d-flex align-items-center gap-2"
                                id="bulkDeleteBtn"
                            >
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Features Table -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">
                            <i class="fas fa-cubes me-2 text-primary"></i>
                            <span id="currentRoleTitle">SuperAdmin</span> Features (<span id="filteredCount">0</span>)
                            <span id="statusFilterText"></span>
                        </h5>
                        
                        <!-- Table Action Buttons -->
                        <div class="d-flex align-items-center gap-3">
                            <div class="text-muted small d-flex align-items-center gap-1">
                                <i class="fas fa-sort"></i>
                                <span id="sortText">Sorted: Order</span>
                            </div>
                            
                            <div class="btn-group" role="group">
                                <button 
                                    class="btn btn-outline-primary d-flex align-items-center gap-2"
                                    id="refreshTableBtn"
                                    title="Refresh Data"
                                >
                                    <i class="fas fa-sync"></i>
                                    <span class="d-none d-md-inline">Refresh</span>
                                </button>
                                
                                <button 
                                    class="btn btn-outline-success d-flex align-items-center gap-2"
                                    id="exportTableBtn"
                                    title="Export to CSV"
                                >
                                    <i class="fas fa-file-export"></i>
                                    <span class="d-none d-md-inline">Export</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="card-body p-0">
                    <div id="loadingState" class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted mt-3">Loading features...</p>
                    </div>
                    
                    <div id="emptyState" class="text-center py-5" style="display: none;">
                        <div class="mb-3">
                            <i class="fas fa-cubes text-muted" style="font-size: 3rem;"></i>
                        </div>
                        <h5 class="text-muted">No features found</h5>
                        <p class="text-muted small" id="emptyMessage">
                            Try different search terms
                        </p>
                    </div>
                    
                    <div id="tableContainer" style="display: none;">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 50px;">
                                            <div class="form-check">
                                                <input
                                                    class="form-check-input"
                                                    type="checkbox"
                                                    id="selectAll"
                                                />
                                            </div>
                                        </th>
                                        <th>Section</th>
                                        <th>Feature</th>
                                        <th class="text-center">Status</th>
                                        <th class="text-center">Order</th>
                                        <th class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="featuresTableBody">
                                    <!-- Features will be populated here -->
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        <div id="paginationContainer" class="d-flex justify-content-between align-items-center p-3 border-top">
                            <!-- Pagination will be populated here -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="text-center text-muted mt-4 small pt-3 border-top">
                © 2025 eClassify - Role Permissions Management System
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    
    <script>
        // ============================================
        // ROLE PERMISSIONS MANAGEMENT
        // Synchronized with Add New Feature data ✅
        // ============================================

        const roles = ['SuperAdmin', 'Educator', 'Trainer', 'Student'];
        
        // Updated sections to match Add New Feature page
        const sectionOptions = [
            '*** Dashboard',
            '*** Reports',
            '*** Chats',
            '*** Virtual Numbers',
            '*** Devices',
            '*** RCS',
            '*** Scan device',
            '*** API',
            '*** Client Management',
            '*** Administration'
        ];

        // Updated feature labels to match Add New Feature page
        const allFeatureLabels = {
            '*** Dashboard': ['1. Dashboard', '2. Notifications'],
            '*** Reports': ['1. Web Report', '2. API Reports'],
            '*** Chats': ['1. New Chat'],
            '*** Virtual Numbers': ['1. My Numbers', '2. Buy Number', '3. Call Logs', '4. SMS Logs'],
