        // Toast notification
        function showToast(message, type = 'success') {
            Toastify({
                text: message,
                duration: 3000,
                gravity: "top",
                position: "right",
                backgroundColor: type === 'success' ? "#198754" : 
                               type === 'error' ? "#dc3545" : 
                               type === 'warning' ? "#ffc107" : "#0d6efd",
                stopOnFocus: true
            }).showToast();
        }

        // Load features from localStorage
        function loadFeatures() {
            isLoading = true;
            updateLoadingState();
            
            try {
                const savedFeatures = localStorage.getItem('sidebarFeatures');
                
                if (savedFeatures) {
                    const parsedFeatures = JSON.parse(savedFeatures);
                    console.log("✅ Loaded features from localStorage:", parsedFeatures.length);
                    features = parsedFeatures;
                } else {
                    // Create default features for SuperAdmin using the updated sections
                    features = [];
                    let idCounter = 1;
                    
                    // Only add features for SuperAdmin by default
                    // Other roles can be added via the Add New Feature page
                    Object.keys(allFeatureLabels).forEach(section => {
                        allFeatureLabels[section].forEach((label, index) => {
                            features.push({
                                id: idCounter++,
                                role: 'SuperAdmin',
                                section: section,
                                label: label,
                                isActive: true,
                                order: index + 1,
                                createdAt: new Date().toISOString()
                            });
                        });
                    });
                    
                    console.log("✅ Created default SuperAdmin features:", features.length);
                    localStorage.setItem('sidebarFeatures', JSON.stringify(features));
                }
                
                updateStats();
                renderTable();
                showToast("Features loaded successfully!");
            } catch (error) {
                console.error('❌ Error loading features:', error);
                showToast("Failed to load features", 'error');
            } finally {
                isLoading = false;
                updateLoadingState();
            }
        }

        // Save features to localStorage
        function saveFeatures(updatedFeatures) {
            try {
                localStorage.setItem('sidebarFeatures', JSON.stringify(updatedFeatures));
                features = updatedFeatures;
                
                // Notify other tabs/pages that features have been updated
                localStorage.setItem('sidebar-update-time', Date.now().toString());
                window.dispatchEvent(new CustomEvent('featuresUpdated'));
                
                showToast("Features updated successfully!");
                
                updateStats();
                renderTable();
            } catch (error) {
                console.error('❌ Error saving features:', error);
                showToast("Failed to save features", 'error');
            }
        }

        // Update statistics
        function updateStats() {
            const roleStats = {
                total: features.length,
                superadmin: features.filter(f => f.role === 'SuperAdmin').length,
                educator: features.filter(f => f.role === 'Educator').length,
                trainer: features.filter(f => f.role === 'Trainer').length,
                student: features.filter(f => f.role === 'Student').length,
                active: features.filter(f => f.isActive).length,
                inactive: features.filter(f => !f.isActive).length
            };

            // Update quick stats
            elements.totalFeatures.textContent = roleStats.total;
            elements.activeFeatures.textContent = roleStats.active;
            elements.inactiveFeatures.textContent = roleStats.inactive;

            // Update stats cards
            elements.totalStats.textContent = roleStats.total;
            elements.superadminStats.textContent = roleStats.superadmin;
            elements.educatorStats.textContent = roleStats.educator;
            elements.trainerStats.textContent = roleStats.trainer;
            elements.studentStats.textContent = roleStats.student;
            elements.activeStats.textContent = roleStats.active;

            // Update role tabs counts
            elements.superadminCount.textContent = roleStats.superadmin;
            elements.educatorCount.textContent = roleStats.educator;
            elements.trainerCount.textContent = roleStats.trainer;
            elements.studentCount.textContent = roleStats.student;
        }

        // Get features for current role
        function getFeaturesForCurrentRole() {
            return features.filter(f => f.role === activeTab);
        }

        // Filter and sort features
        function getFilteredFeatures() {
            const roleFeatures = getFeaturesForCurrentRole();
            
            return roleFeatures
                .filter(feature => {
                    const matchesSearch = 
                        (feature.label && feature.label.toLowerCase().includes(searchTerm.toLowerCase())) ||
                        (feature.section && feature.section.toLowerCase().includes(searchTerm.toLowerCase()));
                    
                    const matchesStatus = 
                        statusFilter === "all" || 
                        (statusFilter === "active" && feature.isActive) ||
                        (statusFilter === "inactive" && !feature.isActive);
                    
                    return matchesSearch && matchesStatus;
                })
                .sort((a, b) => {
                    switch(sortBy) {
                        case "order":
                            return a.order - b.order;
                        case "name":
                            return a.label.localeCompare(b.label);
                        case "section":
                            return a.section.localeCompare(b.section);
                        case "newest":
                            return new Date(b.createdAt || 0) - new Date(a.createdAt || 0);
                        case "oldest":
                            return new Date(a.createdAt || 0) - new Date(b.createdAt || 0);
                        default:
                            return 0;
                    }
                });
        }

        // Render table
        function renderTable() {
            const filteredFeatures = getFilteredFeatures();
            const lastIndex = currentPage * featuresPerPage;
            const firstIndex = lastIndex - featuresPerPage;
            const currentFeatures = filteredFeatures.slice(firstIndex, lastIndex);
            const totalPages = Math.ceil(filteredFeatures.length / featuresPerPage);

            // Update header information
            elements.currentRoleTitle.textContent = activeTab;
            elements.filteredCount.textContent = filteredFeatures.length;
            
            if (statusFilter !== "all") {
                elements.statusFilterText.textContent = ` - ${statusFilter.toUpperCase()}`;
            } else {
                elements.statusFilterText.textContent = '';
            }
            
            // Update sort text
            const sortTexts = {
                'order': 'Sorted: Order',
                'name': 'Sorted: Name A-Z',
                'section': 'Sorted: Section',
                'newest': 'Sorted: Newest',
                'oldest': 'Sorted: Oldest'
            };
            elements.sortText.textContent = sortTexts[sortBy] || 'Sorted: Order';

            // Show/hide states
            if (isLoading) {
                elements.loadingState.style.display = 'block';
                elements.emptyState.style.display = 'none';
                elements.tableContainer.style.display = 'none';
                return;
            }

            if (filteredFeatures.length === 0) {
                elements.loadingState.style.display = 'none';
                elements.emptyState.style.display = 'block';
                elements.tableContainer.style.display = 'none';
                elements.emptyMessage.textContent = searchTerm ? "Try different search terms" : "No features for this role. Add features from the 'Add New Feature' page.";
                return;
            }

            elements.loadingState.style.display = 'none';
            elements.emptyState.style.display = 'none';
            elements.tableContainer.style.display = 'block';

            // Render table rows
            let tableHTML = '';
            currentFeatures.forEach((feature) => {
                const isSelected = selectedFeatures.includes(feature.id);
                const rowClass = isSelected ? 'table-primary' : '';
                
                const sectionIcon = sectionIcons[feature.section] || '<i class="fas fa-cog"></i>';
                const featureIcon = featureIcons[feature.label] || '<i class="fas fa-cog"></i>';
                
                tableHTML += `
                    <tr 
                        class="${rowClass}"
                        onclick="toggleSelect(${feature.id})"
                        style="cursor: pointer;"
                    >
                        <td onclick="event.stopPropagation();">
                            <div class="form-check">
                                <input
                                    class="form-check-input feature-checkbox"
                                    type="checkbox"
                                    data-id="${feature.id}"
                                    ${isSelected ? 'checked' : ''}
                                    onclick="event.stopPropagation(); handleFeatureCheckbox(${feature.id}, event)"
                                />
                            </div>
                        </td>
                        
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center"
                                    style="
                                        width: 45px;
                                        height: 45px;
                                        background-color: #f3f4f6;
                                    "
                                >
                                    <span class="text-primary fs-5">
                                        ${sectionIcon}
                                    </span>
                                </div>
                                <div>
                                    <div class="fw-semibold text-dark">
                                        ${feature.section.replace('*** ', '')}
                                    </div>
                                    <div class="text-muted small">
                                        ${feature.role}
                                    </div>
                                </div>
                            </div>
                        </td>
                        
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center"
                                    style="
                                        width: 45px;
                                        height: 45px;
                                        background-color: #f0f9ff;
                                    "
                                >
                                    <span class="text-primary fs-5">
                                        ${featureIcon}
                                    </span>
                                </div>
                                <div>
                                    <div class="fw-semibold text-dark">
                                        ${feature.label}
                                    </div>
                                    <div class="text-muted small">
                                        Order: ${feature.order}
                                    </div>
                                </div>
                            </div>
                        </td>
                        
                        <td class="text-center">
                            <span
                                class="badge ${feature.isActive ? 'bg-success' : 'bg-secondary'} px-3 py-2"
                                style="cursor: pointer;"
                                onclick="event.stopPropagation(); toggleFeatureStatus(${feature.id})"
                                title="Click to toggle status (Current: ${feature.isActive ? 'Active' : 'Inactive'})"
                            >
                                ${feature.isActive ? 
                                    '<i class="fas fa-check-circle"></i> Active' : 
                                    '<i class="fas fa-times-circle"></i> Inactive'}
                            </span>
                        </td>
                        
                        <td class="text-center">
                            <div class="d-flex flex-column align-items-center">
                                <div class="order-controls d-flex align-items-center gap-2">
                                    <button
                                        class="btn btn-sm btn-outline-primary p-1"
                                        onclick="event.stopPropagation(); moveFeature(${feature.id}, 'up')"
                                        title="Move Up"
                                        ${feature.order === 1 ? 'disabled' : ''}
                                    >
                                        <i class="fas fa-arrow-up"></i>
                                    </button>
                                    <span class="fw-bold">${feature.order}</span>
                                    <button
                                        class="btn btn-sm btn-outline-primary p-1"
                                        onclick="event.stopPropagation(); moveFeature(${feature.id}, 'down')"
                                        title="Move Down"
                                    >
                                        <i class="fas fa-arrow-down"></i>
                                    </button>
                                </div>
                            </div>
                        </td>
                        
                        <td class="text-center" onclick="event.stopPropagation();">
                            <div class="btn-group" role="group">
                                <button
                                    class="btn btn-outline-primary btn-sm"
                                    onclick="startEditing(${feature.id})"
                                    title="Edit Feature"
                                >
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button
                                    class="btn btn-outline-danger btn-sm"
                                    onclick="deleteFeature(${feature.id}, '${feature.label.replace(/'/g, "\\'")}')"
                                    title="Delete Feature"
                                >
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });

            elements.featuresTableBody.innerHTML = tableHTML;

            // Render pagination
            renderPagination(filteredFeatures.length, totalPages);
        }

        // Render pagination
        function renderPagination(totalItems, totalPages) {
            if (totalPages <= 1) {
                elements.paginationContainer.style.display = 'none';
                return;
            }

            elements.paginationContainer.style.display = 'flex';

            let paginationHTML = `
                <div>
                    <small class="text-muted">
                        Showing ${Math.min((currentPage - 1) * featuresPerPage + 1, totalItems)} to ${Math.min(currentPage * featuresPerPage, totalItems)} of ${totalItems} features
                    </small>
                </div>
                
                <div class="d-flex align-items-center gap-2">
                    <button
                        class="btn btn-outline-primary btn-sm"
                        ${currentPage === 1 ? 'disabled' : ''}
                        onclick="changePage(${currentPage - 1})"
                    >
                        Previous
                    </button>
                    
                    <div class="d-flex gap-1">
            `;

            // Calculate page numbers to show
            let startPage = Math.max(1, currentPage - 2);
            let endPage = Math.min(totalPages, currentPage + 2);

            for (let i = startPage; i <= endPage; i++) {
                paginationHTML += `
                    <button
                        class="btn btn-sm ${currentPage === i ? 'btn-primary text-white' : 'btn-outline-primary'}"
                        onclick="changePage(${i})"
                    >
                        ${i}
                    </button>
                `;
            }

            paginationHTML += `
                    </div>
                    
                    <button
                        class="btn btn-outline-primary btn-sm"
                        ${currentPage === totalPages ? 'disabled' : ''}
                        onclick="changePage(${currentPage + 1})"
                    >
                        Next
                    </button>
                </div>
            `;

            elements.paginationContainer.innerHTML = paginationHTML;
        }

        // Update loading state
        function updateLoadingState() {
            const buttons = document.querySelectorAll('.refresh-btn, #refreshTableBtn');
            buttons.forEach(btn => {
                if (isLoading) {
                    btn.innerHTML = '<i class="fas fa-sync spin"></i> Refreshing...';
                    btn.disabled = true;
                } else {
                    btn.innerHTML = '<i class="fas fa-sync"></i> Refresh';
                    btn.disabled = false;
                }
            });
        }

        // Feature actions (exposed to global scope for onclick handlers)
        window.toggleSelect = function(id) {
            if (selectedFeatures.includes(id)) {
                selectedFeatures = selectedFeatures.filter(fId => fId !== id);
            } else {
                selectedFeatures.push(id);
            }
            updateBulkActions();
            renderTable();
        };

        window.handleFeatureCheckbox = function(id, event) {
            event.stopPropagation();
            window.toggleSelect(id);
        };

        window.toggleFeatureStatus = function(id) {
            const updatedFeatures = features.map(f => 
                f.id === id ? { ...f, isActive: !f.isActive } : f
            );
            saveFeatures(updatedFeatures);
        };

        window.moveFeature = function(id, direction) {
            const feature = features.find(f => f.id === id);
            const sectionFeatures = features
                .filter(f => f.role === feature.role && f.section === feature.section)
                .sort((a, b) => a.order - b.order);
            
            const currentIndex = sectionFeatures.findIndex(f => f.id === id);
            
            if (direction === 'up' && currentIndex > 0) {
                const tempOrder = sectionFeatures[currentIndex].order;
                sectionFeatures[currentIndex].order = sectionFeatures[currentIndex - 1].order;
                sectionFeatures[currentIndex - 1].order = tempOrder;
            } else if (direction === 'down' && currentIndex < sectionFeatures.length - 1) {
                const tempOrder = sectionFeatures[currentIndex].order;
                sectionFeatures[currentIndex].order = sectionFeatures[currentIndex + 1].order;
                sectionFeatures[currentIndex + 1].order = tempOrder;
            }
            
            const otherFeatures = features.filter(f => 
                !(f.role === feature.role && f.section === feature.section)
            );
            const updatedFeatures = [...otherFeatures, ...sectionFeatures];
            saveFeatures(updatedFeatures);
        };

        window.startEditing = function(id) {
            const feature = features.find(f => f.id === id);
            if (feature) {
                // For demonstration, show alert with edit info
                // In production, open a modal with edit form
                alert(`Edit Feature: ${feature.label}\n\nRole: ${feature.role}\nSection: ${feature.section}\n\nThis would open an edit form in production.`);
            }
        };

        window.deleteFeature = function(id, name) {
            if (confirm(`Delete feature "${name}"?`)) {
                const updatedFeatures = features.filter(f => f.id !== id);
                saveFeatures(updatedFeatures);
                selectedFeatures = selectedFeatures.filter(fId => fId !== id);
                updateBulkActions();
            }
        };

        window.changePage = function(page) {
            currentPage = page;
            renderTable();
        };

        // Bulk actions
        function updateBulkActions() {
            if (selectedFeatures.length > 0) {
                elements.bulkActions.style.display = 'block';
                elements.selectedCount.textContent = `${selectedFeatures.length} feature(s) selected`;
                
                // Update select all checkbox
                const currentFeatures = getFilteredFeatures();
                elements.selectAll.checked = selectedFeatures.length === currentFeatures.length;
            } else {
                elements.bulkActions.style.display = 'none';
            }
        }

        function handleBulkStatus(newStatus) {
            if (selectedFeatures.length === 0) {
                showToast("Please select features first", 'warning');
                return;
            }
            
            if (confirm(`Change status to ${newStatus} for ${selectedFeatures.length} feature(s)?`)) {
                const updatedFeatures = features.map(f =>
                    selectedFeatures.includes(f.id) ? { 
                        ...f, 
                        isActive: newStatus === 'active' 
                    } : f
                );
                saveFeatures(updatedFeatures);
                selectedFeatures = [];
                updateBulkActions();
            }
        }

        function handleBulkDelete() {
            if (selectedFeatures.length === 0) {
                showToast("Please select features first", 'warning');
                return;
            }
            
            if (confirm(`Delete ${selectedFeatures.length} selected feature(s)?`)) {
                const updatedFeatures = features.filter(f => !selectedFeatures.includes(f.id));
                saveFeatures(updatedFeatures);
                selectedFeatures = [];
                updateBulkActions();
            }
        }

        // Reset to defaults (SuperAdmin features only)
        function resetToDefaults() {
            if (confirm('Reset all features to default SuperAdmin features? This will remove all features for other roles.\n\nThis cannot be undone.')) {
                const defaultFeatures = [];
                let idCounter = 1;
                
                Object.keys(allFeatureLabels).forEach(section => {
                    allFeatureLabels[section].forEach((label, index) => {
                        defaultFeatures.push({
                            id: idCounter++,
                            role: 'SuperAdmin',
                            section: section,
                            label: label,
                            isActive: true,
                            order: index + 1,
                            createdAt: new Date().toISOString()
                        });
                    });
                });
                
                saveFeatures(defaultFeatures);
                selectedFeatures = [];
                updateBulkActions();
            }
        }

        // Export features to CSV
        function handleExport() {
            const filteredFeatures = getFilteredFeatures();
            
            if (filteredFeatures.length === 0) {
                showToast("No data to export", 'warning');
                return;
            }

            try {
                // Create CSV headers
                const headers = [
                    "Section",
                    "Feature",
                    "Role",
                    "Status",
                    "Order",
                    "Created At"
                ];

                // Create CSV rows
                const rows = filteredFeatures.map(feature => [
                    feature.section.replace('*** ', ''),
                    feature.label,
                    feature.role,
                    feature.isActive ? "Active" : "Inactive",
                    feature.order,
                    new Date(feature.createdAt).toLocaleDateString('en-IN')
                ]);

                // Combine headers and rows
                const csvContent = [
                    headers.join(","),
                    ...rows.map(row => row.map(cell => `"${cell}"`).join(","))
                ].join("\n");

                // Create and download file
                const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.setAttribute('download', `features_${activeTab}_${new Date().toISOString().split('T')[0]}.csv`);
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                
                showToast(`✅ Exported ${filteredFeatures.length} features successfully!`);
            } catch (error) {
                console.error('Export error:', error);
                showToast("Failed to export data", 'error');
            }
        }

        // Initialize event listeners
        function initEventListeners() {
            // Search input
            elements.searchInput.addEventListener('input', (e) => {
                searchTerm = e.target.value;
                currentPage = 1;
                renderTable();
            });

            // Toggle filters
            elements.toggleFilters.addEventListener('click', () => {
                showFilters = !showFilters;
                if (showFilters) {
                    elements.filterControls.style.display = 'flex';
                    elements.filterText.textContent = 'Hide Filters';
                } else {
                    elements.filterControls.style.display = 'none';
                    elements.filterText.textContent = 'Show Filters';
                }
            });

            // Status filter
            elements.statusFilter.addEventListener('change', (e) => {
                statusFilter = e.target.value;
                currentPage = 1;
                renderTable();
            });

            // Sort by
            elements.sortBy.addEventListener('change', (e) => {
                sortBy = e.target.value;
                currentPage = 1;
                renderTable();
            });

            // Refresh button
            elements.refreshBtn.addEventListener('click', loadFeatures);
            elements.refreshTableBtn.addEventListener('click', loadFeatures);

            // Export button
            elements.exportBtn.addEventListener('click', handleExport);
            elements.exportTableBtn.addEventListener('click', handleExport);

            // Reset button
            elements.resetBtn.addEventListener('click', resetToDefaults);

            // Debug button
            elements.debugBtn.addEventListener('click', () => {
                console.log("Current features data:", features);
                console.log("LocalStorage data:", localStorage.getItem('sidebarFeatures'));
                showToast("Check browser console for features data", 'info');
            });

            // Role tabs
            document.querySelectorAll('.role-tab').forEach(tab => {
                tab.addEventListener('click', (e) => {
                    const role = e.currentTarget.getAttribute('data-role');
                    
                    // Update active tab
                    activeTab = role;
                    
                    // Update tab buttons
                    document.querySelectorAll('.role-tab').forEach(t => {
                        if (t.getAttribute('data-role') === role) {
                            t.classList.remove('btn-outline-primary');
                            t.classList.add('btn-primary');
                        } else {
                            t.classList.remove('btn-primary');
                            t.classList.add('btn-outline-primary');
                        }
                    });
                    
                    // Reset pagination and selection
                    currentPage = 1;
                    selectedFeatures = [];
                    updateBulkActions();
                    
                    // Render table
                    renderTable();
                });
            });

            // Bulk action buttons
            elements.bulkActiveBtn.addEventListener('click', () => handleBulkStatus('active'));
            elements.bulkInactiveBtn.addEventListener('click', () => handleBulkStatus('inactive'));
            elements.bulkDeleteBtn.addEventListener('click', handleBulkDelete);

            // Select all checkbox
            elements.selectAll.addEventListener('change', (e) => {
                const currentFeatures = getFilteredFeatures();
                if (e.target.checked) {
                    selectedFeatures = currentFeatures.map(f => f.id);
                } else {
                    selectedFeatures = [];
                }
                updateBulkActions();
                renderTable();
            });

            // Listen for storage events (cross-tab sync)
            window.addEventListener('storage', (e) => {
                if (e.key === 'sidebarFeatures' || e.key === 'sidebar-update-time') {
                    console.log('🔄 Detected update from another tab, reloading...');
                    loadFeatures();
                }
            });

            // Listen for custom events from Add New Feature page
            window.addEventListener('featuresUpdated', () => {
                console.log('🔄 featuresUpdated event received, reloading...');
                loadFeatures();
            });
        }

        // Initialize the application
        function init() {
            console.log("🚀 Initializing Role Permissions Management...");
            initEventListeners();
            loadFeatures();
        }

        // Start when DOM is loaded
        document.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>