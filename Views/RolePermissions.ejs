        const sectionIcons = {
            '*** Dashboard': '<i class="fas fa-chart-line"></i>',
            '*** Reports': '<i class="fas fa-file-alt"></i>',
            '*** Chats': '<i class="fas fa-comment-dots"></i>',
            '*** Virtual Numbers': '<i class="fas fa-phone-alt"></i>',
            '*** Devices': '<i class="fas fa-mobile-alt"></i>',
            '*** RCS': '<i class="fas fa-envelope"></i>',
            '*** Scan device': '<i class="fas fa-qrcode"></i>',
            '*** API': '<i class="fas fa-code"></i>',
            '*** Client Management': '<i class="fas fa-users"></i>',
            '*** Administration': '<i class="fas fa-cog"></i>'
        };

        const featureIcons = {
            '1. Dashboard': '<i class="fas fa-chart-line"></i>',
            '2. Notifications': '<i class="fas fa-bell"></i>',
            '1. Web Report': '<i class="fas fa-file-alt"></i>',
            '2. API Reports': '<i class="fas fa-code"></i>',
            '1. New Chat': '<i class="fas fa-comment-dots"></i>',
            '1. My Numbers': '<i class="fas fa-phone-alt"></i>',
            '2. Buy Number': '<i class="fas fa-shopping-cart"></i>',
            '3. Call Logs': '<i class="fas fa-phone"></i>',
