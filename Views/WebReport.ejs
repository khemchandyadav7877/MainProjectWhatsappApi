        // ======================
        // UPDATE STATISTICS
        // ======================
        function updateStatistics() {
            let images = 0, videos = 0, pdfs = 0, docs = 0, texts = 0;
            
            allMedia.forEach(media => {
                if (media.type === 'image') images++;
                else if (media.type === 'video') videos++;
                else if (media.type === 'pdf') pdfs++;
                else if (media.type === 'document') docs++;
                else if (media.type === 'text') texts++;
            });
            
            document.getElementById('totalImages').textContent = images;
            document.getElementById('totalVideos').textContent = videos;
            document.getElementById('totalPDFs').textContent = pdfs;
            document.getElementById('totalDocs').textContent = docs;
            document.getElementById('totalTexts').textContent = texts;
        }

        // ======================
        // UPDATE CHARTS
        // ======================
        function updateCharts() {
            const mediaCtx = document.getElementById('mediaChart').getContext('2d');
            const statusCtx = document.getElementById('statusChart').getContext('2d');
            
            // Destroy existing charts
            if (mediaChart) mediaChart.destroy();
            if (statusChart) statusChart.destroy();
            
            // Media distribution data
            const images = parseInt(document.getElementById('totalImages').textContent);
            const videos = parseInt(document.getElementById('totalVideos').textContent);
            const pdfs = parseInt(document.getElementById('totalPDFs').textContent);
            const docs = parseInt(document.getElementById('totalDocs').textContent);
            const texts = parseInt(document.getElementById('totalTexts').textContent);
            
            // Media Chart
            mediaChart = new Chart(mediaCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Images', 'Videos', 'PDFs', 'Documents', 'Text'],
                    datasets: [{
                        data: [images, videos, pdfs, docs, texts],
                        backgroundColor: ['#3b82f6', '#8b5cf6', '#ef4444', '#f59e0b', '#10b981'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    cutout: '70%'
                }
            });
            
            // Status distribution
            let success = 0, failed = 0, pending = 0;
            allMedia.forEach(media => {
                if (media.status === 'success') success++;
                else if (media.status === 'failed') failed++;
                else pending++;
            });
            
            // Status Chart
            statusChart = new Chart(statusCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Success', 'Failed', 'Pending'],
                    datasets: [{
                        data: [success, failed, pending],
                        backgroundColor: ['#10b981', '#ef4444', '#f59e0b'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    cutout: '70%'
                }
            });
            
            // Update legends
            document.getElementById('mediaLegend').innerHTML = `
                <div class="legend-item"><span class="legend-color" style="background:#3b82f6;"></span> Images (${images})</div>
                <div class="legend-item"><span class="legend-color" style="background:#8b5cf6;"></span> Videos (${videos})</div>
                <div class="legend-item"><span class="legend-color" style="background:#ef4444;"></span> PDFs (${pdfs})</div>
            `;
            
            document.getElementById('statusLegend').innerHTML = `
                <div class="legend-item"><span class="legend-color" style="background:#10b981;"></span> Success (${success})</div>
                <div class="legend-item"><span class="legend-color" style="background:#ef4444;"></span> Failed (${failed})</div>
                <div class="legend-item"><span class="legend-color" style="background:#f59e0b;"></span> Pending (${pending})</div>
            `;
        }

        // ======================
        // FILTER MEDIA
        // ======================
        function filterMedia(type) {
            currentFilter = type;
            currentPage = 1;
            
            // Update active tab
            document.querySelectorAll('.filter-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            event.target.classList.add('active');
            
            displayMedia();
            
            const filterNames = {
                'all': 'All Media',
                'image': 'Images',
                'video': 'Videos',
                'pdf': 'PDFs',
                'document': 'Documents',
                'text': 'Text Messages'
            };
            showToast('Filter Applied', `Showing ${filterNames[type]}`, 'info');
        }

        // ======================
        // DISPLAY MEDIA IN GRID
        // ======================
        function displayMedia() {
            const grid = document.getElementById('mediaGrid');
            
            // Filter media based on current filter
            let filteredMedia = allMedia;
            if (currentFilter !== 'all') {
                filteredMedia = allMedia.filter(m => m.type === currentFilter);
            }
            
            // Sort by time (latest first)
            filteredMedia.sort((a, b) => new Date(b.time) - new Date(a.time));
            
            // Pagination
            const start = (currentPage - 1) * itemsPerPage;
            const end = start + itemsPerPage;
            const pageItems = filteredMedia.slice(start, end);
            
            if (pageItems.length === 0) {
                if (currentPage > 1) {
                    currentPage = 1;
                    displayMedia();
                    return;
                }
                
                grid.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-photo-video"></i>
                        <h3>No media found</h3>
                        <p>Try changing your filter or upload some media first</p>
                    </div>
                `;
                return;
            }
            
            let html = '';
            
            pageItems.forEach(media => {
                const time = media.time ? new Date(media.time).toLocaleString() : 'N/A';
                const statusClass = media.status === 'success' ? 'success' : 
                                   media.status === 'failed' ? 'failed' : 'pending';
                
                html += `
                    <div class="media-card">
                        ${getMediaPreview(media)}
                        
                        <div class="media-info">
                            <div class="media-header">
                                <div class="media-title" title="${media.fileName || 'Message'}">
                                    ${media.fileName || 'Text Message'}
                                </div>
                                <div class="media-campaign">${media.campaignName}</div>
                            </div>
                            
                            <div class="media-meta">
                                <span><i class="far fa-clock"></i> ${time}</span>
                                <span><i class="fas fa-${media.type === 'image' ? 'image' : 
                                                       media.type === 'video' ? 'video' : 
                                                       media.type === 'pdf' ? 'file-pdf' : 
                                                       media.type === 'document' ? 'file-word' : 'comment'}"></i> 
                                    ${media.type}
                                </span>
                            </div>
                            
                            <div class="media-recipient">
                                <i class="fas fa-phone"></i> ${media.recipient || 'Unknown'}
                            </div>
                            
                            ${media.message ? `
                                <div class="media-message" id="msg-${media.id}">
                                    ${media.message}
                                </div>
                                ${media.message.length > 100 ? `
                                    <button class="expand-btn" onclick="toggleMessage('${media.id}')">
                                        Read more...
                                    </button>
                                ` : ''}
                            ` : ''}
                            
                            <div class="media-footer">
                                <span class="status-badge ${statusClass}">
                                    ${media.status === 'success' ? '✅ Sent' : 
                                      media.status === 'failed' ? '❌ Failed' : '⏳ Pending'}
                                </span>
                                
                                <button class="view-btn" onclick="viewMedia('${media.id}')">
                                    View Details
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            grid.innerHTML = html;
        }

        // ======================
        // GET MEDIA PREVIEW HTML
        // ======================
        function getMediaPreview(media) {
            switch(media.type) {
                case 'image':
                    return `
                        <div class="media-preview" onclick="viewImage('${media.url}')">
                            <img src="${media.url}" alt="Image" class="image-preview" loading="lazy"
                                 onerror="this.src='https://via.placeholder.com/400x250?text=Image+Not+Found'">
                            <div class="media-badge">
                                <i class="fas fa-image"></i> Image
                            </div>
                        </div>
                    `;
                    
                case 'video':
                    return `
                        <div class="media-preview" onclick="playVideo('${media.url}')">
                            <div class="video-preview">
                                <video class="video-thumbnail" src="${media.url}" preload="metadata"></video>
                                <div class="play-overlay">
                                    <i class="fas fa-play-circle"></i>
                                </div>
                            </div>
                            <div class="media-badge">
                                <i class="fas fa-video"></i> Video
                            </div>
                        </div>
                    `;
                    
                case 'pdf':
                    return `
                        <div class="media-preview" onclick="viewPDF('${media.url}')">
                            <div class="pdf-preview">
                                <i class="fas fa-file-pdf"></i>
                                <span>${media.fileName || 'PDF File'}</span>
                            </div>
                            <div class="media-badge">
                                <i class="fas fa-file-pdf"></i> PDF
                            </div>
                        </div>
                    `;
                    
                case 'document':
                    return `
                        <div class="media-preview" onclick="viewDocument('${media.url}')">
                            <div class="doc-preview">
                                <i class="fas fa-file-word"></i>
                                <span>${media.fileName || 'Document'}</span>
                            </div>
                            <div class="media-badge">
                                <i class="fas fa-file-word"></i> Document
                            </div>
                        </div>
                    `;
                    
                default:
                    return `
                        <div class="media-preview" style="background: #e5e7eb;" onclick="viewTextMessage('${media.id}')">
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; flex-direction: column; gap: 10px;">
                                <i class="fas fa-comment" style="font-size: 50px; color: #9ca3af;"></i>
                                <span style="color: #6b7280;">Text Message</span>
                            </div>
                            <div class="media-badge">
                                <i class="fas fa-comment"></i> Text
                            </div>
                        </div>
                    `;
            }
        }

        // ======================
        // LOAD MORE MEDIA
        // ======================
        function loadMoreMedia() {
            let filteredMedia = allMedia;
            if (currentFilter !== 'all') {
                filteredMedia = allMedia.filter(m => m.type === currentFilter);
            }
            
            const totalPages = Math.ceil(filteredMedia.length / itemsPerPage);
            
            if (currentPage < totalPages) {
                currentPage++;
                displayMedia();
                showToast('Loading', `Showing page ${currentPage} of ${totalPages}`, 'info');
            } else {
                showToast('Info', 'No more media to load', 'info');
            }
        }

        // ======================
        // MESSAGE ACTIONS
        // ======================
        function toggleMessage(id) {
            const msgElement = document.getElementById(`msg-${id}`);
            const btn = msgElement.nextElementSibling;
            
            if (msgElement.classList.contains('expanded')) {
                msgElement.classList.remove('expanded');
                btn.textContent = 'Read more...';
            } else {
                msgElement.classList.add('expanded');
                btn.textContent = 'Read less';
            }
        }

        function viewMedia(id) {
            const media = allMedia.find(m => m.id === id);
            if (!media) return;
            
            const modal = document.getElementById('messageModal');
            const content = document.getElementById('messageModalContent');
            
            const time = media.time ? new Date(media.time).toLocaleString() : 'N/A';
            const statusClass = media.status === 'success' ? 'success' : 
                               media.status === 'failed' ? 'failed' : 'pending';
            
            let mediaHtml = '';
            
            if (media.type === 'image' && media.url) {
                mediaHtml = `
                    <div class="modal-media">
                        <img src="${media.url}" alt="Image" style="max-width: 100%; max-height: 400px;">
                    </div>
                `;
            } else if (media.type === 'video' && media.url) {
                mediaHtml = `
                    <div class="modal-media">
                        <video controls style="max-width: 100%; max-height: 400px;">
                            <source src="${media.url}" type="video/mp4">
                        </video>
                    </div>
                `;
            } else if (media.type === 'pdf' && media.url) {
                mediaHtml = `
                    <div class="modal-media">
                        <iframe src="${media.url}" style="width: 100%; height: 400px; border: none;"></iframe>
                    </div>
                `;
            }
            
            content.innerHTML = `
                <h3 style="margin-bottom: 20px;">${media.type.toUpperCase()} Details</h3>
                
                ${mediaHtml}
                
                <div class="modal-details">
                    <p><strong>Campaign:</strong> ${media.campaignName}</p>
                    <p><strong>Recipient:</strong> ${media.recipient}</p>
                    <p><strong>Time:</strong> ${time}</p>
                    <p><strong>Type:</strong> ${media.type}</p>
                    <p><strong>Status:</strong> 
                        <span class="status-badge ${statusClass}">
                            ${media.status}
                        </span>
                    </p>
                    ${media.sentCount ? `<p><strong>Sent:</strong> ${media.sentCount}/${media.totalContacts}</p>` : ''}
                </div>
                
                ${media.message ? `
                    <div class="modal-message">
                        <strong>Message:</strong><br>
                        ${media.message}
                    </div>
                ` : ''}
            `;
            
            modal.classList.add('show');
        }

        // ======================
        // MEDIA VIEWERS
        // ======================
        function viewImage(url) {
            const modal = document.getElementById('imageModal');
            const img = document.getElementById('modalImage');
            img.src = url;
            modal.classList.add('show');
        }

        function playVideo(url) {
            const modal = document.getElementById('videoModal');
            const player = document.getElementById('videoPlayer');
            player.src = url;
            modal.classList.add('show');
            player.play();
        }

        function viewPDF(url) {
            const modal = document.getElementById('pdfModal');
            const viewer = document.getElementById('pdfViewer');
            viewer.src = url;
            modal.classList.add('show');
        }

        function viewDocument(url) {
            window.open(url, '_blank');
        }

        function viewTextMessage(id) {
            viewMedia(id);
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('show');
            if (id === 'videoModal') {
                document.getElementById('videoPlayer').pause();
            }
        }

        // Close modals on escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal('imageModal');
                closeModal('videoModal');
                closeModal('pdfModal');
                closeModal('messageModal');
            }
        });
    </script>
</body>
</html>