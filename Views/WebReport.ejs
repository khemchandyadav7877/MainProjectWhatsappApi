    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // ======================
        // SIDEBAR STATE SYNC - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOADING OVERLAY FUNCTIONS
        // ======================
        function showLoading(text = 'Loading...') {
            const overlay = document.getElementById('loadingOverlay');
            document.querySelector('.loading-text').textContent = text;
            overlay.style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        // ======================
        // GLOBAL VARIABLES
        // ======================
        let allMedia = [];
        let displayedMedia = [];
        let currentFilter = 'all';
        let itemsPerPage = 6;
        let currentPage = 1;

        // Chart instances
        let mediaChart = null;
        let statusChart = null;

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);

            // Set current date
            document.getElementById('currentDate').textContent = '• ' + new Date().toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
            });
            
            // Load data
            loadData();
            
            // Auto refresh every 30 seconds
            setInterval(loadData, 30000);
            
            // Show welcome toast
            setTimeout(() => {
                showToast('Welcome', 'Campaign Media Dashboard', 'info');
            }, 1000);
        });

        // ======================
        // LOAD DATA FROM SERVER
        // ======================
        async function loadData() {
            showLoading('Loading media...');
            
            try {
                document.getElementById('mediaGrid').innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-spinner fa-spin"></i>
                        <h3>Loading media...</h3>
                        <p>Please wait while we fetch your campaign data</p>
                    </div>
                `;
                
                // API se campaigns fetch karo
                const response = await fetch('/api/campaigns');
                const data = await response.json();
                
                if (!data.status || !data.campaigns) {
                    throw new Error('Failed to load campaigns');
                }
                
                // Saare media items ko process karo
                allMedia = [];
                
                data.campaigns.forEach(campaign => {
                    const campaignData = {
                        id: campaign.campaignId || `camp-${Date.now()}-${Math.random()}`,
                        campaignId: campaign.campaignId,
                        campaignName: campaign.campaignName || `Campaign ${campaign.campaignId?.substring(0, 8) || 'New'}`,
                        message: campaign.message || '',
                        status: campaign.status === 'completed' ? 'success' : 
                               campaign.status === 'failed' ? 'failed' : 'pending',
                        time: campaign.completedAt || campaign.createdAt || new Date().toISOString(),
                        sentCount: campaign.sentCount || 0,
                        failedCount: campaign.failedCount || 0,
                        totalContacts: campaign.totalContacts || 0
                    };
                    
                    // AGAR MEDIA URL HAI TOH MEDIA ITEM BANAO
                    if (campaign.mediaUrl && campaign.mediaUrl.trim() !== '') {
                        const mediaType = getMediaType(campaign.mediaUrl);
                        
                        allMedia.push({
                            ...campaignData,
                            type: mediaType,
                            url: campaign.mediaUrl,
                            fileName: getFileName(campaign.mediaUrl),
                            recipient: `Campaign to ${campaign.totalContacts || 0} contacts`
                        });
                    } 
                    // TEXT MESSAGE
                    else if (campaign.message && campaign.message.trim() !== '') {
                        allMedia.push({
                            ...campaignData,
                            type: 'text',
                            recipient: `Campaign to ${campaign.totalContacts || 0} contacts`
                        });
                    }
                });
                
                // Agar koi media nahi mila toh demo data dikhao
                if (allMedia.length === 0) {
                    loadDemoData();
                } else {
                    // Reset pagination
                    currentPage = 1;
                    
                    // Statistics update karo
                    updateStatistics();
                    
                    // Update charts
                    updateCharts();
                    
                    // Media display karo
                    displayMedia();
                    
                    showToast('Success', `${allMedia.length} media items loaded`, 'success');
                }
                
            } catch (error) {
                console.error('Load error:', error);
                showToast('Error', 'Failed to load from server: ' + error.message, 'error');
                loadDemoData();
            } finally {
                hideLoading();
            }
        }

        // ======================
        // GET MEDIA TYPE FROM URL
        // ======================
        function getMediaType(url) {
            if (!url) return 'unknown';
            
            const ext = url.split('.').pop().toLowerCase();
            
            if (['jpg', 'jpeg', 'png', 'gif', 'webp', 'bmp', 'svg'].includes(ext)) {
                return 'image';
            } else if (['mp4', 'avi', 'mov', 'wmv', 'flv', 'mkv', 'webm'].includes(ext)) {
                return 'video';
            } else if (ext === 'pdf') {
                return 'pdf';
            } else if (['doc', 'docx', 'xls', 'xlsx', 'ppt', 'pptx', 'txt', 'csv'].includes(ext)) {
                return 'document';
            }
            
            return 'unknown';
        }

        function getFileName(url) {
            return url.split('/').pop() || 'Unknown';
        }

