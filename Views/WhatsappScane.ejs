<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Scan - Channels / Devices</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ===== THEME VARIABLES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Role Colors */
            --role-superadmin: #8b5cf6;
            --role-educator: #3b82f6;
            --role-trainer: #10b981;
            --role-student: #f59e0b;
            
            /* Status Colors */
            --status-online-bg: rgba(16, 185, 129, 0.1);
            --status-online-text: #10b981;
            --status-pending-bg: rgba(245, 158, 11, 0.1);
            --status-pending-text: #f59e0b;
            --status-offline-bg: rgba(239, 68, 68, 0.1);
            --status-offline-text: #ef4444;
            
            /* Light Mode */
            --bg-body: #f8fafc;
            --bg-white: #ffffff;
            --bg-offwhite: #f1f5f9;
            --bg-card: #ffffff;
            --text: #334155;
            --text-light: #64748b;
            --text-muted: #94a3b8;
            --dark: #0f172a;
            --border: #eef2f6;
            --shadow: 0 8px 25px rgba(0,0,0,0.03);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
            --sidebar-mini-width: 80px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --text: #e2e8f0;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 8px 25px rgba(0,0,0,0.2);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
            
            --status-online-bg: rgba(16, 185, 129, 0.2);
            --status-pending-bg: rgba(245, 158, 11, 0.2);
            --status-offline-bg: rgba(239, 68, 68, 0.2);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: 'Inter', 'Segoe UI', sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar,
        body.round-border .mid-content,
        body.round-border .device-table,
        body.round-border .search-box input,
        body.round-border .column-toggle-btn,
        body.round-border .column-toggle-menu,
        body.round-border .action-menu-btn,
        body.round-border .action-dropdown,
        body.round-border .status-badge,
        body.round-border .phone-badge,
        body.round-border .ip-address,
        body.round-border .device-icon,
        body.round-border .btn-add-device,
        body.round-border .page-btn,
        body.round-border .modal-content,
        body.round-border .qr-loader,
        body.round-border .toast-notification,
        body.round-border .role-badge-mini {
            border-radius: 20px !important;
        }

        body.round-border .device-icon {
            border-radius: 16px !important;
        }

        body.round-border .status-dot {
            border-radius: 50% !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar,
        body.no-radius .mid-content,
        body.no-radius .device-table,
        body.no-radius .search-box input,
        body.no-radius .column-toggle-btn,
        body.no-radius .column-toggle-menu,
        body.no-radius .action-menu-btn,
        body.no-radius .action-dropdown,
        body.no-radius .status-badge,
        body.no-radius .phone-badge,
        body.no-radius .ip-address,
        body.no-radius .device-icon,
        body.no-radius .btn-add-device,
        body.no-radius .page-btn,
        body.no-radius .modal-content,
        body.no-radius .qr-loader,
        body.no-radius .toast-notification,
        body.no-radius .role-badge-mini,
        body.no-radius .status-dot {
            border-radius: 0 !important;
        }

        /* Header */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        /* MAIN LAYOUT - EXACTLY LIKE PREVIOUS TEMPLATES */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
            position: relative;
        }

        /* SIDEBAR - EXACTLY LIKE PREVIOUS TEMPLATES */
        .sidebar {
            width: var(--sidebar-width, 280px);
            background: var(--bg-white);
            border-right: 1px solid var(--border);
            height: calc(100vh - var(--header-height, 70px));
            position: fixed;
            left: 0;
            top: 70px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1020;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }

        /* Sidebar Mini Mode */
        .sidebar.mini {
            width: var(--sidebar-mini-width, 80px);
        }

        /* CONTENT WRAPPER - EXACTLY LIKE PREVIOUS TEMPLATES */
        .content-wrapper {
            flex: 1;
            margin-left: var(--sidebar-width, 280px);
            padding: 25px;
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
            width: calc(100% - var(--sidebar-width, 280px));
        }

        /* When sidebar has mini class, adjust content wrapper */
        .sidebar.mini ~ .content-wrapper {
            margin-left: var(--sidebar-mini-width, 80px);
            width: calc(100% - var(--sidebar-mini-width, 80px));
        }

        .mid-content {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 30px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            min-height: 500px;
        }

        @media (max-width: 1200px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
                transition: transform 0.3s ease;
            }
            
            .sidebar.open {
                transform: translateX(0);
            }
            
            .sidebar.mini {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
            }
            
            .sidebar.mini.open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
                padding: 20px;
            }
            
            .sidebar.mini ~ .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
            }
            
            .mid-content {
                padding: 25px;
            }
        }

        @media (max-width: 768px) {
            .content-wrapper {
                padding: 15px;
            }
            
            .mid-content {
                padding: 20px;
            }
        }

        @media (max-width: 576px) {
            .content-wrapper {
                padding: 10px;
            }
            
            .mid-content {
                padding: 15px;
            }
        }

        /* Toast - EXACTLY LIKE PREVIOUS TEMPLATES */
        #toast {
            position: fixed;
            top: 90px;
            right: 29px;
            width: 320px;
            padding: 16px 20px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 1001;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-content {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            font-size: 20px;
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 5px 0 0;
            font-size: 13px;
            opacity: 0.9;
        }

        .toast-progress {
            height: 3px;
            background: rgba(255,255,255,0.6);
            margin-top: 12px;
            width: 100%;
            animation: progress 3s linear;
        }

        @keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* Loading Overlay */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(5px);
            flex-direction: column;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid var(--bg-offwhite);
            border-top: 5px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 15px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .loading-text {
            color: white;
            margin-bottom: 5px;
            font-size: 18px;
            font-weight: 600;
        }

        .loading-subtext {
            color: rgba(255,255,255,0.8);
            font-size: 14px;
        }

        /* PAGE HEADER */
        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 25px;
        }

        .header-title h5 {
            font-size: 24px;
            font-weight: 700;
            color: var(--dark);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header-title h5 i {
            color: var(--primary);
        }

        .action-bar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
        }

        /* Search Box */
        .search-box {
            position: relative;
            min-width: 280px;
        }

        .search-box i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
            z-index: 1;
        }

        .search-box input {
            width: 100%;
            padding: 12px 16px 12px 45px;
            border: 1px solid var(--border);
            border-radius: 12px;
            font-size: 14px;
            background: var(--bg-white);
            color: var(--text);
            transition: all 0.3s;
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            background: var(--bg-white);
        }

        .search-box input::placeholder {
            color: var(--text-muted);
            opacity: 0.7;
        }

        /* Column Toggle Button */
        .column-toggle-dropdown {
            position: relative;
            display: inline-block;
        }

        .column-toggle-btn {
            padding: 12px 24px;
            border-radius: 12px;
            background: var(--bg-white);
            border: 1px solid var(--border);
            color: var(--text);
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .column-toggle-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--bg-offwhite);
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        .column-toggle-menu {
            position: absolute;
            top: 100%;
            right: 0;
            min-width: 220px;
            background: var(--bg-white);
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
            z-index: 1000;
            padding: 12px;
            margin-top: 8px;
            border: 1px solid var(--border);
            display: none;
        }

        .column-toggle-menu.show {
            display: block;
            animation: fadeIn 0.2s ease;
        }

        .column-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .column-item:hover {
            background: var(--bg-offwhite);
        }

        .column-item input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: var(--primary);
        }

        .column-item label {
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            cursor: pointer;
            flex: 1;
        }

        /* Add Device Button */
        .btn-add-device {
            padding: 12px 24px;
            border-radius: 12px;
            background: var(--primary-gradient);
            color: white;
            border: none;
            font-size: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
            white-space: nowrap;
            cursor: pointer;
        }

        .btn-add-device:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        /* DEVICE TABLE - NO SCROLL */
        .device-table {
            width: 100%;
            border-collapse: collapse;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            overflow: hidden;
            margin: 25px 0;
            table-layout: fixed; /* Fixed layout for better control */
        }

        .device-table th {
            background: var(--bg-offwhite);
            padding: 16px 12px;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--border);
            text-align: left;
            white-space: nowrap;
        }

        /* Column widths - perfect distribution */
        .device-table th:nth-child(1) { width: 18%; } /* Device */
        .device-table th:nth-child(2) { width: 15%; } /* WhatsApp Name */
        .device-table th:nth-child(3) { width: 12%; } /* IP Address */
        .device-table th:nth-child(4) { width: 15%; } /* Added On */
        .device-table th:nth-child(5) { width: 10%; } /* Status */
        .device-table th:nth-child(6) { width: 15%; } /* WhatsApp Number */
        .device-table th:nth-child(7) { width: 15%; } /* Actions */

        .device-table td {
            padding: 16px 12px;
            font-size: 14px;
            color: var(--text);
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .device-table tbody tr:hover {
            background: var(--bg-offwhite);
        }

        .device-table tbody tr:last-child td {
            border-bottom: none;
        }

        /* Column Hidden Class */
        .column-hidden {
            display: none !important;
        }

        /* Device Name Cell */
        .device-name-cell {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .device-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            background: var(--bg-offwhite);
            box-shadow: var(--shadow);
            flex-shrink: 0;
        }

        .device-icon.online {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .device-icon.pending {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }

        .device-icon.offline {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
        }

        .device-info {
            display: flex;
            flex-direction: column;
            min-width: 0; /* For text truncation */
        }

        .device-name {
            font-weight: 600;
            color: var(--dark);
            font-size: 14px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .device-id {
            font-size: 11px;
            color: var(--text-muted);
            font-family: monospace;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .whatsapp-name {
            font-weight: 500;
            color: var(--dark);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* IP Address */
        .ip-address {
            font-family: monospace;
            background: var(--bg-offwhite);
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--text);
            white-space: nowrap;
            max-width: 100%;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ip-address i {
            color: var(--primary);
            font-size: 12px;
            flex-shrink: 0;
        }

        /* Date Cell */
        .date-cell {
            display: flex;
            flex-direction: column;
        }

        .date-main {
            font-weight: 500;
            color: var(--dark);
            font-size: 13px;
            white-space: nowrap;
        }

        .date-sub {
            font-size: 11px;
            color: var(--text-muted);
            white-space: nowrap;
        }

        /* Status Badge */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
            max-width: 100%;
        }

        .status-connected {
            background: var(--status-online-bg);
            color: var(--status-online-text);
        }

        .status-pending {
            background: var(--status-pending-bg);
            color: var(--status-pending-text);
        }

        .status-offline {
            background: var(--status-offline-bg);
            color: var(--status-offline-text);
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            display: inline-block;
            flex-shrink: 0;
        }

        .status-dot.connected { background: var(--success); }
        .status-dot.pending { background: var(--warning); }
        .status-dot.offline { background: var(--danger); }

        /* Phone Badge */
        .phone-badge {
            background: var(--bg-offwhite);
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 500;
            color: var(--text);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
            max-width: 100%;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .phone-badge i {
            color: var(--primary);
            font-size: 12px;
            flex-shrink: 0;
        }

        /* Role Badge Mini */
        .role-badge-mini {
            display: inline-flex;
            align-items: center;
            padding: 4px 8px;
            border-radius: 50px;
            font-size: 10px;
            font-weight: 600;
            margin-right: 6px;
            color: white;
            white-space: nowrap;
        }
        
        .role-superadmin { background: var(--role-superadmin); }
        .role-educator { background: var(--role-educator); }
        .role-trainer { background: var(--role-trainer); }
        .role-student { background: var(--role-student); }
        .role-user { background: var(--text-muted); }

        /* Action Menu */
        .action-menu {
            position: relative;
            display: inline-block;
        }

        .action-menu-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.2s;
            margin: 0 auto;
        }

        .action-menu-btn:hover {
            background: var(--bg-offwhite);
            color: var(--primary);
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .action-dropdown {
            position: absolute;
            top: 100%;
            right: 0;
            min-width: 240px;
            background: var(--bg-white);
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
            z-index: 1000;
            padding: 8px;
            display: none;
            margin-top: 8px;
            border: 1px solid var(--border);
        }

        .action-dropdown.show {
            display: block;
            animation: fadeIn 0.2s ease;
        }

        .action-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            color: var(--text);
            border: none;
            background: transparent;
            width: 100%;
            text-align: left;
            font-size: 13px;
            font-weight: 500;
        }

        .action-item:hover {
            background: var(--bg-offwhite);
            color: var(--primary);
        }

        .action-item.delete:hover {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
        }

        .action-item i {
            width: 18px;
            text-align: center;
            font-size: 14px;
        }

        .menu-divider {
            height: 1px;
            background: var(--border);
            margin: 8px 0;
        }

        .created-by-info {
            padding: 10px 12px;
            background: var(--bg-offwhite);
            border-radius: 10px;
            margin-bottom: 8px;
            font-size: 12px;
            border: 1px solid var(--border);
        }

        .created-by-label {
            color: var(--text-muted);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .created-by-details {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .created-by-email {
            color: var(--dark);
            font-weight: 500;
            font-size: 12px;
            max-width: 140px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Pagination */
        .pagination-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }

        .pagination-info {
            font-size: 13px;
            color: var(--text-muted);
        }

        .pagination-controls {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .rows-per-page {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .rows-per-page span {
            font-size: 13px;
            color: var(--text-muted);
        }

        .rows-per-page select {
            padding: 8px 12px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--bg-white);
            font-size: 13px;
            color: var(--text);
            font-weight: 500;
            cursor: pointer;
            outline: none;
        }

        .rows-per-page select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .page-btn {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--bg-white);
            color: var(--text);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .page-btn:hover:not(:disabled) {
            background: var(--primary-gradient);
            border-color: transparent;
            color: white;
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        .page-btn.active {
            background: var(--primary-gradient);
            border-color: transparent;
            color: white;
        }

        .page-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .page-numbers {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 64px;
            color: var(--border);
            margin-bottom: 20px;
        }

        .empty-state h5 {
            color: var(--dark);
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .empty-state p {
            color: var(--text-muted);
            font-size: 14px;
            max-width: 400px;
            margin: 0 auto;
        }

        /* QR Modal */
        .modal-content {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
        }

        .modal-header {
            border-bottom: 1px solid var(--border);
            padding: 20px 25px;
        }

        .modal-title {
            color: var(--dark);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
        }

        .modal-body {
            padding: 30px;
        }

        .modal-footer {
            border-top: 1px solid var(--border);
            padding: 20px 25px;
        }

        .btn-close {
            filter: var(--close-btn-invert);
        }

        body.dark .btn-close {
            filter: invert(1);
        }

        /* QR Loader */
        .qr-loader {
            width: 220px;
            height: 220px;
            margin: 0 auto 20px;
            position: relative;
            background: var(--bg-offwhite);
            border-radius: 20px;
            box-shadow: var(--shadow-lg);
            overflow: hidden;
        }

        .qr-loader::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(
                45deg,
                transparent 30%,
                rgba(102, 126, 234, 0.1) 50%,
                transparent 70%
            );
            animation: shimmer 2s infinite linear;
        }

        @keyframes shimmer {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .ring {
            position: absolute;
            inset: 0;
            animation: rotate 1.8s linear infinite;
        }

        .dot-big {
            width: 95px;
            height: 95px;
            background: var(--primary-gradient);
            border-radius: 50%;
            position: absolute;
            bottom: 20px;
            left: 25px;
            box-shadow: 0 8px 24px rgba(102, 126, 234, 0.4);
            animation: pulse-primary 2s infinite ease-in-out;
        }

        .dot-small {
            width: 55px;
            height: 55px;
            background: var(--info);
            border-radius: 50%;
            position: absolute;
            top: 20px;
            right: 25px;
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.4);
            animation: pulse-info 2s infinite ease-in-out;
        }

        @keyframes rotate { 
            from { transform: rotate(0deg); } 
            to { transform: rotate(360deg); } 
        }
        
        @keyframes pulse-primary { 
            0%, 100% { transform: scale(1); } 
            50% { transform: scale(1.05); } 
        }
        
        @keyframes pulse-info { 
            0%, 100% { transform: scale(1); } 
            50% { transform: scale(1.08); } 
        }

        .whatsapp-center {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 2;
            font-size: 48px;
            color: var(--primary);
            animation: heartbeat 1.5s infinite ease-in-out;
        }

        @keyframes heartbeat { 
            0%, 100% { transform: translate(-50%, -50%) scale(1); } 
            50% { transform: translate(-50%, -50%) scale(1.1); } 
        }

        .loading-text {
            margin-top: 15px;
            font-size: 14px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .loading-text span {
            animation: dots 1.5s infinite;
            opacity: 0;
        }

        .loading-text span:nth-child(1) { animation-delay: 0.1s; }
        .loading-text span:nth-child(2) { animation-delay: 0.2s; }
        .loading-text span:nth-child(3) { animation-delay: 0.3s; }

        @keyframes dots { 
            0%, 100% { opacity: 0; } 
            50% { opacity: 1; } 
        }

        #qrImage {
            width: 220px;
            height: 220px;
            border-radius: 16px;
            box-shadow: var(--shadow-lg);
            border: 2px solid var(--border);
            padding: 10px;
            background: var(--bg-white);
            margin: 0 auto 20px;
        }

        .status-indicator {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 15px;
            font-size: 13px;
        }

        .success-animation {
            animation: slideUp 0.5s ease-out;
        }

        .connected-check {
            color: var(--success);
            font-size: 48px;
            animation: bounceIn 0.5s ease-out;
        }

        @keyframes bounceIn { 
            0% { transform: scale(0); } 
            70% { transform: scale(1.2); } 
            100% { transform: scale(1); } 
        }

        @keyframes fadeIn { 
            from { opacity: 0; transform: translateY(-10px); } 
            to { opacity: 1; transform: translateY(0); } 
        }

        @keyframes slideUp { 
            from { opacity: 0; transform: translateY(20px); } 
            to { opacity: 1; transform: translateY(0); } 
        }

        /* Buttons */
        .btn {
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .btn-outline-secondary {
            background: var(--bg-white);
            color: var(--text);
            border: 1px solid var(--border);
        }

        .btn-outline-secondary:hover {
            background: var(--bg-offwhite);
            border-color: var(--primary);
            color: var(--primary);
        }

        .btn-primary {
            background: var(--primary-gradient);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .header-title h5 {
                font-size: 22px;
            }
            
            .device-table th:nth-child(1) { width: 17%; }
            .device-table th:nth-child(2) { width: 14%; }
            .device-table th:nth-child(3) { width: 11%; }
            .device-table th:nth-child(4) { width: 14%; }
            .device-table th:nth-child(5) { width: 9%; }
            .device-table th:nth-child(6) { width: 14%; }
            .device-table th:nth-child(7) { width: 21%; }
            
            .ip-address {
                font-size: 11px;
                padding: 4px 8px;
            }
            
            .created-by-email {
                max-width: 100px;
            }
        }

        @media (max-width: 992px) {
            .action-bar {
                width: 100%;
            }
            
            .search-box {
                flex: 1;
            }
            
            .device-table th {
                font-size: 12px;
                padding: 14px 10px;
            }
            
            .device-table td {
                padding: 14px 10px;
                font-size: 13px;
            }
            
            .device-name {
                font-size: 13px;
            }
            
            .device-id {
                font-size: 10px;
            }
            
            .status-badge {
                padding: 4px 10px;
                font-size: 11px;
            }
            
            .phone-badge {
                padding: 4px 10px;
                font-size: 11px;
            }
            
            .action-menu-btn {
                width: 32px;
                height: 32px;
            }
        }

        @media (max-width: 768px) {
            .content-wrapper {
                padding: 15px;
            }
            
            .mid-content {
                padding: 20px;
            }
            
            .header-section {
                flex-direction: column;
                align-items: stretch;
            }
            
            .action-bar {
                flex-direction: column;
            }
            
            .search-box {
                width: 100%;
            }
            
            .column-toggle-btn,
            .btn-add-device {
                width: 100%;
                justify-content: center;
            }
            
            /* Table column widths for tablet */
            .device-table th:nth-child(1) { width: 18%; }
            .device-table th:nth-child(2) { width: 15%; }
            .device-table th:nth-child(3) { width: 12%; }
            .device-table th:nth-child(4) { width: 15%; }
            .device-table th:nth-child(5) { width: 10%; }
            .device-table th:nth-child(6) { width: 15%; }
            .device-table th:nth-child(7) { width: 15%; }
            
            .ip-address {
                font-size: 10px;
                padding: 3px 6px;
            }
            
            .pagination-container {
                flex-direction: column;
                align-items: stretch;
                gap: 15px;
            }
            
            .pagination-info {
                text-align: center;
            }
            
            .pagination-controls {
                width: 100%;
                justify-content: center;
                flex-wrap: wrap;
            }
            
            .rows-per-page {
                width: 100%;
                justify-content: center;
                margin-right: 0;
            }
            
            .page-numbers {
                order: 3;
                width: 100%;
                justify-content: center;
                margin-top: 8px;
            }
        }

        @media (max-width: 576px) {
            .content-wrapper {
                padding: 10px;
            }
            
            .mid-content {
                padding: 15px;
            }
            
            .header-title h5 {
                font-size: 20px;
            }
            
            .device-table {
                font-size: 12px;
            }
            
            .device-table th {
                font-size: 11px;
                padding: 12px 8px;
            }
            
            .device-table td {
                padding: 12px 8px;
                font-size: 12px;
            }
            
            .device-name-cell {
                gap: 8px;
            }
            
            .device-icon {
                width: 32px;
                height: 32px;
                font-size: 16px;
            }
            
            .device-name {
                font-size: 12px;
            }
            
            .device-id {
                font-size: 9px;
            }
            
            .status-badge {
                padding: 3px 8px;
                font-size: 10px;
            }
            
            .phone-badge {
                padding: 3px 8px;
                font-size: 10px;
            }
            
            .ip-address {
                font-size: 9px;
                padding: 2px 4px;
            }
            
            .date-main {
                font-size: 11px;
            }
            
            .date-sub {
                font-size: 9px;
            }
            
            .action-menu-btn {
                width: 28px;
                height: 28px;
            }
            
            .page-btn {
                width: 32px;
                height: 32px;
                font-size: 12px;
            }
            
            .modal-body {
                padding: 20px;
            }
            
            #toast {
                width: calc(100% - 30px);
                left: 15px;
                right: 15px;
            }
            
            .created-by-email {
                max-width: 80px;
                font-size: 10px;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- Toast Container -->
    <div id="toast"></div>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner"></div>
        <div class="loading-text" id="loadingText">Processing...</div>
        <div class="loading-subtext" id="loadingSubtext">Please wait</div>
    </div>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <%- include('../partials/ram/sidebaar') %>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <div class="mid-content">
                <!-- HEADER SECTION -->
                <div class="header-section">
                    <div class="header-title">
                        <h5>
                            <i class="fab fa-whatsapp text-success"></i> 
                            WhatsApp Devices
                        </h5>
                    </div>

                    <div class="action-bar">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" id="searchInput" placeholder="Search devices..." onkeyup="handleSearch()">
                        </div>
                        
                        <!-- Column Visibility Toggle -->
                        <div class="column-toggle-dropdown">
                            <button class="column-toggle-btn" onclick="toggleColumnMenu(event)">
                                <i class="fas fa-table"></i> Columns
                                <i class="fas fa-chevron-down"></i>
                            </button>
                            <div class="column-toggle-menu" id="columnMenu">
                                <div class="column-item">
                                    <input type="checkbox" id="colDevice" checked onchange="toggleColumn(0, this.checked)">
                                    <label for="colDevice">Device</label>
                                </div>
                                <div class="column-item">
                                    <input type="checkbox" id="colWhatsApp" checked onchange="toggleColumn(1, this.checked)">
                                    <label for="colWhatsApp">WhatsApp Name</label>
                                </div>
                                <div class="column-item">
                                    <input type="checkbox" id="colIP" checked onchange="toggleColumn(2, this.checked)">
                                    <label for="colIP">IP Address</label>
                                </div>
                                <div class="column-item">
                                    <input type="checkbox" id="colAdded" checked onchange="toggleColumn(3, this.checked)">
                                    <label for="colAdded">Added On</label>
                                </div>
                                <div class="column-item">
                                    <input type="checkbox" id="colStatus" checked onchange="toggleColumn(4, this.checked)">
                                    <label for="colStatus">Status</label>
                                </div>
                                <div class="column-item">
                                    <input type="checkbox" id="colNumber" checked onchange="toggleColumn(5, this.checked)">
                                    <label for="colNumber">WhatsApp Number</label>
                                </div>
                                <div class="column-item">
                                    <input type="checkbox" id="colActions" checked onchange="toggleColumn(6, this.checked)">
                                    <label for="colActions">Actions</label>
                                </div>
                            </div>
                        </div>

                        <button class="btn-add-device" onclick="openQrModal()">
                            <i class="fas fa-plus-circle"></i> Add New Device
                        </button>
                    </div>
                </div>

                <!-- TABLE - NO SCROLL -->
                <table class="device-table" id="deviceTable">
                    <thead>
                        <tr id="tableHeader">
                            <th>Device</th>
                            <th>WhatsApp Name</th>
                            <th>IP Address</th>
                            <th>Added On</th>
                            <th>Status</th>
                            <th>WhatsApp Number</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="deviceTableBody">
                        <% if (devices && devices.length > 0) { %>
                            <% devices.forEach(device => { 
                                const statusClass = device.connectionStatus === 'online' ? 'connected' : 
                                                   device.connectionStatus === 'pending' ? 'pending' : 'offline';
                            %>
                            <tr class="device-row" data-device-id="<%= device.deviceId %>" data-search="<%= ((device.whatsappName || '') + ' ' + (device.whatsappNumber || '') + ' ' + (device.phone || '')).toLowerCase() %>">
                                <td>
                                    <div class="device-name-cell">
                                        <div class="device-icon <%= statusClass %>">
                                            <i class="fab fa-whatsapp"></i>
                                        </div>
                                        <div class="device-info">
                                            <span class="device-name">WhatsApp Device</span>
                                            <span class="device-id"><%= device.deviceId ? device.deviceId.substring(0, 10) + '...' : 'N/A' %></span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="whatsapp-name" title="<%= device.whatsappName || 'Not Available' %>">
                                        <%= device.whatsappName || 'Not Available' %>
                                    </div>
                                </td>
                                <td>
                                    <span class="ip-address" title="<%= device.ipAddress || '-' %>">
                                        <i class="fas fa-network-wired"></i> <%= device.ipAddress || '-' %>
                                    </span>
                                </td>
                                <td>
                                    <div class="date-cell">
                                        <% if (device.deviceAddedAt) { %>
                                            <span class="date-main"><%= new Date(device.deviceAddedAt).toLocaleDateString() %></span>
                                            <span class="date-sub"><%= new Date(device.deviceAddedAt).toLocaleTimeString() %></span>
                                        <% } else if (device.createdAt) { %>
                                            <span class="date-main"><%= new Date(device.createdAt).toLocaleDateString() %></span>
                                            <span class="date-sub"><%= new Date(device.createdAt).toLocaleTimeString() %></span>
                                        <% } else { %>
                                            <span class="text-muted">—</span>
                                        <% } %>
                                    </div>
                                </td>
                                <td>
                                    <span class="status-badge status-<%= statusClass %>">
                                        <span class="status-dot <%= statusClass %>"></span>
                                        <%= device.connectionStatus ? device.connectionStatus.toUpperCase() : 'OFFLINE' %>
                                    </span>
                                </td>
                                <td>
                                    <% if (device.whatsappNumber) { %>
                                        <span class="phone-badge" title="<%= device.whatsappNumber %>">
                                            <i class="fas fa-phone-alt"></i> <%= device.whatsappNumber %>
                                        </span>
                                    <% } else if (device.phone) { %>
                                        <span class="phone-badge" title="<%= device.phone %>">
                                            <i class="fas fa-phone-alt"></i> <%= device.phone %>
                                        </span>
                                    <% } else { %>
                                        <span class="text-muted">—</span>
                                    <% } %>
                                </td>
                                
                                <td class="text-center">
                                    <div class="action-menu">
                                        <button class="action-menu-btn" onclick="toggleActionMenu(event, '<%= device.deviceId %>')">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <div class="action-dropdown" id="actionMenu-<%= device.deviceId %>">
                                            
                                            <% if (user.role === 'SuperAdmin') { %>
                                            <div class="created-by-info">
                                                <div class="created-by-label">
                                                    <i class="fas fa-user-circle me-1"></i> Created By
                                                </div>
                                                <div class="created-by-details">
                                                    <span class="role-badge-mini role-<%= device.createdByRole ? device.createdByRole.toLowerCase() : 'user' %>">
                                                        <%= device.createdByRole || 'User' %>
                                                    </span>
                                                    <span class="created-by-email" title="<%= device.createdByEmail || '' %>">
                                                        <%= device.createdByEmail || 'Unknown' %>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="menu-divider"></div>
                                            <% } %>
                                            
                                            <button class="action-item" onclick="copyToken('<%= device.token %>')">
                                                <i class="fas fa-copy"></i> Copy Token
                                            </button>
                                            <button class="action-item delete" onclick="deleteDevice('<%= device.deviceId %>')">
                                                <i class="fas fa-trash-alt"></i> Delete Device
                                            </button>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr id="noDevicesRow">
                                <td colspan="7">
                                    <div class="empty-state">
                                        <i class="fas fa-wifi-slash"></i>
                                        <h5>No WhatsApp Devices Found</h5>
                                        <p>
                                            <% if (user.role === 'SuperAdmin') { %>
                                                No devices have been added by any user yet.
                                            <% } else { %>
                                                You haven't added any WhatsApp devices yet.
                                            <% } %>
                                        </p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>

                <!-- Pagination Section -->
                <div class="pagination-container" id="paginationContainer" style="<% if (!devices || devices.length === 0) { %>display: none;<% } %>">
                    <div class="pagination-info" id="paginationInfo">
                        Showing 0 to 0 of 0 entries
                    </div>
                    <div class="pagination-controls">
                        <div class="rows-per-page">
                            <span>Show:</span>
                            <select id="rowsPerPage" onchange="changeRowsPerPage()">
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="15">15</option>
                                <option value="20">20</option>
                                <option value="30">30</option>
                                <option value="50">50</option>
                                <option value="100">100</option>
                            </select>
                        </div>
                        <button class="page-btn" id="prevPage" onclick="changePage('prev')" disabled>
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <div class="page-numbers" id="pageNumbers"></div>
                        <button class="page-btn" id="nextPage" onclick="changePage('next')" disabled>
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- QR MODAL -->
    <div class="modal fade" id="qrModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fab fa-whatsapp text-success me-2"></i>
                        Scan QR Code
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body text-center py-4">
                    <!-- Loader -->
                    <div id="qrLoader" class="qr-loader">
                        <div class="ring">
                            <div class="dot-big"></div>
                            <div class="dot-small"></div>
                        </div>
                        <div class="whatsapp-center">
                            <i class="fab fa-whatsapp"></i>
                        </div>
                    </div>

                    <!-- Loading Text -->
                    <div id="loadingTextQR" class="loading-text">
                        Preparing QR<span>.</span><span>.</span><span>.</span>
                    </div>

                    <!-- QR Code Container -->
                    <div id="qrContainer" style="display:none">
                        <img id="qrImage" width="220"/>
                        
                        <div class="status-indicator">
                            <div class="spinner-border spinner-border-sm text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <span class="text-muted">Waiting for scan...</span>
                        </div>
                        
                        <p class="mt-3 text-muted" style="font-size:13px">
                            <i class="fas fa-info-circle me-1"></i>
                            Open WhatsApp → Menu → Linked Devices → Scan QR
                        </p>
                    </div>

                    <!-- Success Message -->
                    <div id="successMessage" class="success-animation" style="display:none">
                        <div class="connected-check">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <h6 class="mt-3 text-success fw-bold">Device Connected Successfully!</h6>
                        <p class="text-muted small">
                            Refreshing page...
                        </p>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-primary" onclick="refreshQR()" id="refreshBtn" style="display:none">
                        <i class="fas fa-redo-alt me-2"></i> Refresh QR
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR STATE SYNC - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOADING OVERLAY FUNCTIONS
        // ======================
        function showLoading(text = 'Processing...', subtext = 'Please wait') {
            const overlay = document.getElementById('loadingOverlay');
            document.getElementById('loadingText').textContent = text;
            document.getElementById('loadingSubtext').textContent = subtext;
            overlay.style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        // ======================
        // GLOBAL VARIABLES
        // ======================
        let currentDeviceId;
        let pollInterval;
        let allDevices = [];
        let filteredDevices = [];
        let currentPage = 1;
        let rowsPerPage = 10;

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);

            // Load all devices from table
            loadDevicesFromTable();
            
            // Initialize pagination
            initializePagination();
            
            // Load column preferences
            loadColumnPreferences();
            
            // Show welcome toast
            setTimeout(() => {
                showToast('Welcome', 'WhatsApp Devices Management', 'info');
            }, 1000);
            
            // Close column menu when clicking outside
            document.addEventListener('click', function(event) {
                if (!event.target.closest('.column-toggle-dropdown')) {
                    document.getElementById('columnMenu').classList.remove('show');
                }
            });
            
            // Close action menus when clicking outside
            document.addEventListener('click', function(event) {
                if (!event.target.closest('.action-menu')) {
                    document.querySelectorAll('.action-dropdown.show').forEach(menu => {
                        menu.classList.remove('show');
                    });
                }
            });
        });

        // ======================
        // COLUMN VISIBILITY TOGGLE
        // ======================
        function toggleColumnMenu(event) {
            event.stopPropagation();
            document.getElementById('columnMenu').classList.toggle('show');
        }

        function toggleColumn(index, isVisible) {
            const headers = document.querySelectorAll('#tableHeader th');
            const rows = document.querySelectorAll('.device-row');
            
            // Toggle header
            if (headers[index]) {
                if (isVisible) {
                    headers[index].classList.remove('column-hidden');
                } else {
                    headers[index].classList.add('column-hidden');
                }
            }
            
            // Toggle all cells in this column
            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells[index]) {
                    if (isVisible) {
                        cells[index].classList.remove('column-hidden');
                    } else {
                        cells[index].classList.add('column-hidden');
                    }
                }
            });
            
            // Save preference to localStorage
            saveColumnPreferences();
        }

        function saveColumnPreferences() {
            const preferences = [];
            for (let i = 0; i < 7; i++) {
                const checkbox = document.getElementById(`col${getColumnName(i)}`);
                if (checkbox) {
                    preferences.push(checkbox.checked);
                }
            }
            localStorage.setItem('deviceColumnPreferences', JSON.stringify(preferences));
        }

        function loadColumnPreferences() {
            const saved = localStorage.getItem('deviceColumnPreferences');
            if (saved) {
                const preferences = JSON.parse(saved);
                preferences.forEach((checked, index) => {
                    const checkbox = document.getElementById(`col${getColumnName(index)}`);
                    if (checkbox) {
                        checkbox.checked = checked;
                        toggleColumn(index, checked);
                    }
                });
            }
        }

        function getColumnName(index) {
            const names = ['Device', 'WhatsApp', 'IP', 'Added', 'Status', 'Number', 'Actions'];
            return names[index];
        }

        // ======================
        // PAGINATION FUNCTIONS
        // ======================
        function loadDevicesFromTable() {
            const rows = document.querySelectorAll('.device-row');
            allDevices = Array.from(rows).map(row => ({
                element: row,
                deviceId: row.dataset.deviceId,
                searchText: row.dataset.search || ''
            }));
            filteredDevices = [...allDevices];
        }

        function initializePagination() {
            if (allDevices.length === 0) {
                document.getElementById('paginationContainer').style.display = 'none';
                return;
            }
            document.getElementById('paginationContainer').style.display = 'flex';
            updatePagination();
        }

        function changeRowsPerPage() {
            rowsPerPage = parseInt(document.getElementById('rowsPerPage').value);
            currentPage = 1;
            updatePagination();
        }

        function changePage(direction) {
            const totalPages = Math.ceil(filteredDevices.length / rowsPerPage);
            
            if (direction === 'prev' && currentPage > 1) {
                currentPage--;
            } else if (direction === 'next' && currentPage < totalPages) {
                currentPage++;
            }
            updatePagination();
        }

        function goToPage(page) {
            currentPage = page;
            updatePagination();
        }

        function updatePagination() {
            const totalItems = filteredDevices.length;
            const totalPages = Math.ceil(totalItems / rowsPerPage);
            
            // Adjust current page if out of bounds
            if (currentPage < 1) currentPage = 1;
            if (currentPage > totalPages) currentPage = totalPages || 1;
            
            // Calculate start and end indices
            const start = (currentPage - 1) * rowsPerPage;
            const end = Math.min(start + rowsPerPage, totalItems);
            
            // Hide all devices first
            allDevices.forEach(device => {
                device.element.style.display = 'none';
            });
            
            // Show only devices for current page
            for (let i = start; i < end; i++) {
                if (filteredDevices[i]) {
                    filteredDevices[i].element.style.display = '';
                }
            }
            
            // Update pagination info
            document.getElementById('paginationInfo').textContent = 
                `Showing ${totalItems > 0 ? start + 1 : 0} to ${end} of ${totalItems} entries`;
            
            // Update page numbers
            updatePageNumbers(totalPages);
            
            // Update prev/next buttons
            document.getElementById('prevPage').disabled = currentPage === 1 || totalItems === 0;
            document.getElementById('nextPage').disabled = currentPage === totalPages || totalItems === 0;
        }

        function updatePageNumbers(totalPages) {
            const pageNumbersContainer = document.getElementById('pageNumbers');
            pageNumbersContainer.innerHTML = '';
            
            if (totalPages <= 7) {
                // Show all pages
                for (let i = 1; i <= totalPages; i++) {
                    addPageButton(i);
                }
            } else {
                // Show first page
                addPageButton(1);
                
                if (currentPage > 3) {
                    addEllipsis();
                }
                
                // Show pages around current page
                for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) {
                    if (i > 1 && i < totalPages) {
                        addPageButton(i);
                    }
                }
                
                if (currentPage < totalPages - 2) {
                    addEllipsis();
                }
                
                // Show last page
                if (totalPages > 1) {
                    addPageButton(totalPages);
                }
            }
        }

        function addPageButton(pageNum) {
            const button = document.createElement('button');
            button.className = `page-btn ${pageNum === currentPage ? 'active' : ''}`;
            button.textContent = pageNum;
            button.onclick = () => goToPage(pageNum);
            document.getElementById('pageNumbers').appendChild(button);
        }

        function addEllipsis() {
            const span = document.createElement('span');
            span.className = 'page-btn';
            span.textContent = '...';
            span.disabled = true;
            document.getElementById('pageNumbers').appendChild(span);
        }

        // ======================
        // SEARCH FUNCTIONALITY
        // ======================
        function handleSearch() {
            clearTimeout(window.searchTimeout);
            window.searchTimeout = setTimeout(() => {
                const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
                
                if (searchTerm === '') {
                    filteredDevices = [...allDevices];
                } else {
                    filteredDevices = allDevices.filter(device => 
                        device.searchText.includes(searchTerm)
                    );
                }
                
                currentPage = 1;
                updatePagination();
                
                // Show empty state if no results
                const noResultsRow = document.getElementById('noResultsRow');
                if (filteredDevices.length === 0 && allDevices.length > 0) {
                    if (!noResultsRow) {
                        const tbody = document.getElementById('deviceTableBody');
                        const row = document.createElement('tr');
                        row.id = 'noResultsRow';
                        row.innerHTML = `
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="fas fa-search"></i>
                                    <h5>No Results Found</h5>
                                    <p>No devices match your search criteria.</p>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(row);
                    }
                } else if (noResultsRow) {
                    noResultsRow.remove();
                }
            }, 300);
        }

        // ======================
        // ACTION MENU FUNCTIONS
        // ======================
        function toggleActionMenu(event, deviceId) {
            event.stopPropagation();
            
            // Close all other open menus
            document.querySelectorAll('.action-dropdown.show').forEach(menu => {
                if (menu.id !== `actionMenu-${deviceId}`) {
                    menu.classList.remove('show');
                }
            });
            
            // Toggle current menu
            const menu = document.getElementById(`actionMenu-${deviceId}`);
            if (menu) {
                menu.classList.toggle('show');
            }
        }

        // ======================
        // QR MODAL FUNCTIONS
        // ======================
        function openQrModal(){
            // Reset UI
            document.getElementById('qrLoader').style.display = 'block';
            document.getElementById('loadingTextQR').style.display = 'block';
            document.getElementById('qrContainer').style.display = 'none';
            document.getElementById('successMessage').style.display = 'none';
            document.getElementById('refreshBtn').style.display = 'none';
            
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('qrModal'));
            modal.show();
            
            showToast('Creating Device', 'Generating new WhatsApp device...', 'info');
            
            fetch('/add-device', { method:'POST' })
            .then(r => r.json())
            .then(data => {
                if (data.status) {
                    currentDeviceId = data.deviceId;
                    showToast('Device Created', 'QR code generating...', 'success');
                    startPolling();
                } else {
                    showToast('Error', data.msg || 'Failed to create device', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Error', 'Failed to generate QR. Please try again.', 'error');
            });
        }

        function startPolling(){
            clearInterval(pollInterval);
            
            pollInterval = setInterval(() => {
                fetch('/get-qr/' + currentDeviceId)
                .then(r => r.json())
                .then(data => {
                    if (data.status === 'CONNECTED') {
                        clearInterval(pollInterval);
                        
                        document.getElementById('qrLoader').style.display = 'none';
                        document.getElementById('loadingTextQR').style.display = 'none';
                        document.getElementById('qrContainer').style.display = 'none';
                        document.getElementById('successMessage').style.display = 'block';
                        
                        showToast('Success', 'Device connected successfully!', 'success');
                        
                        setTimeout(() => {
                            location.reload();
                        }, 2000);
                    }
                    else if (data.qr) {
                        document.getElementById('qrLoader').style.display = 'none';
                        document.getElementById('loadingTextQR').style.display = 'none';
                        document.getElementById('qrContainer').style.display = 'block';
                        document.getElementById('qrImage').src = data.qr;
                        document.getElementById('refreshBtn').style.display = 'block';
                        
                        showToast('QR Ready', 'Scan the QR code with WhatsApp', 'info');
                    }
                })
                .catch(error => {
                    console.error('Error polling QR:', error);
                });
            }, 1500);
        }

        function refreshQR() {
            if (currentDeviceId) {
                document.getElementById('qrContainer').style.display = 'none';
                document.getElementById('qrLoader').style.display = 'block';
                document.getElementById('loadingTextQR').style.display = 'block';
                
                showToast('Refreshing', 'Generating new QR code...', 'info');
                
                startPolling();
            }
        }

        // ======================
        // UTILITY FUNCTIONS
        // ======================
        function copyToken(token){
            document.querySelectorAll('.action-dropdown.show').forEach(menu => {
                menu.classList.remove('show');
            });
            
            navigator.clipboard.writeText(token);
            showToast('Copied!', 'Token copied to clipboard', 'success');
        }

        function deleteDevice(deviceId){
            document.querySelectorAll('.action-dropdown.show').forEach(menu => {
                menu.classList.remove('show');
            });
            
            if (!confirm('Are you sure you want to delete this device?')) {
                return;
            }
            
            showToast('Deleting Device', 'Removing device from system...', 'info');
            
            fetch('/delete-device/' + deviceId, { method:'DELETE' })
            .then(r => r.json())
            .then(data => {
                if (data.status) {
                    showToast('Deleted', 'Device deleted successfully!', 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast('Error', data.msg || 'Failed to delete device', 'error');
                }
            })
            .catch(error => {
                console.error('Error deleting device:', error);
                showToast('Error', 'Error deleting device. Please try again.', 'error');
            });
        }

        // Clean up intervals when modal is closed
        document.getElementById('qrModal').addEventListener('hidden.bs.modal', function() {
            clearInterval(pollInterval);
            showToast('Cancelled', 'QR code generation cancelled', 'warning');
        });

        // ======================
        // THEME FUNCTIONS
        // ======================
        function toggleTheme() {
            if (document.body.classList.contains('dark')) {
                document.body.classList.remove('dark');
                document.body.classList.add('light');
                localStorage.setItem('theme', 'light');
                showToast('Theme Updated', 'Light mode activated', 'info');
            } else {
                document.body.classList.remove('light');
                document.body.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                showToast('Theme Updated', 'Dark mode activated', 'info');
            }
        }

        function toggleBorder() {
            if (document.body.classList.contains('round-border')) {
                document.body.classList.remove('round-border');
                document.body.classList.add('no-radius');
                localStorage.setItem('border', 'no-radius');
                showToast('Border Style', 'Square corners activated', 'info');
            } else {
                document.body.classList.remove('no-radius');
                document.body.classList.add('round-border');
                localStorage.setItem('border', 'round-border');
                showToast('Border Style', 'Rounded corners activated', 'info');
            }
        }

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Press Ctrl+F to search | Ctrl+N to add device', 'info');
            }
            
            if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
                e.preventDefault();
                document.getElementById('searchInput').focus();
            }
            
            if ((e.ctrlKey || e.metaKey) && e.key === 'n') {
                e.preventDefault();
                openQrModal();
            }
            
            if (e.key === 'Escape') {
                // Close any open dropdowns
                document.getElementById('columnMenu').classList.remove('show');
                document.querySelectorAll('.action-dropdown.show').forEach(menu => {
                    menu.classList.remove('show');
                });
            }
        });
    </script>
</body>
</html>