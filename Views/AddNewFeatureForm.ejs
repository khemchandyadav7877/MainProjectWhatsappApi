<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Feature - WhatsApp Business Manager</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Toastify CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    
    <style>
        /* ===== THEME VARIABLES ===== */
        :root {
            --primary: #4f46e5;
            --primary-dark: #4338ca;
            --primary-light: #6366f1;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f3f4f6;
            --bg-white: #ffffff;
            --bg-offwhite: #f9fafb;
            --bg-card: #ffffff;
            --text: #111827;
            --text-light: #374151;
            --text-muted: #6b7280;
            --dark: #1f2937;
            --border: #e5e7eb;
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #111827;
            --bg-white: #1f2937;
            --bg-offwhite: #374151;
            --bg-card: #1f2937;
            --text: #f9fafb;
            --text-light: #e5e7eb;
            --text-muted: #9ca3af;
            --dark: #f9fafb;
            --border: #374151;
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.3);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-body);
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES ===== */
        body.round-border .main-card,
        body.round-border .role-card,
        body.round-border .form-control,
        body.round-border .form-select,
        body.round-border .status-badge,
        body.round-border .feature-tag,
        body.round-border .alert-custom,
        body.round-border .tips-card,
        body.round-border .btn,
        body.round-border .available-badge,
        body.round-border .order-badge {
            border-radius: 16px !important;
        }

        body.round-border .role-icon {
            border-radius: 12px !important;
        }

        body.round-border .selected-badge {
            border-radius: 50% !important;
        }

        body.no-radius .main-card,
        body.no-radius .role-card,
        body.no-radius .form-control,
        body.no-radius .form-select,
        body.no-radius .status-badge,
        body.no-radius .feature-tag,
        body.no-radius .alert-custom,
        body.no-radius .tips-card,
        body.no-radius .btn,
        body.no-radius .available-badge,
        body.no-radius .order-badge,
        body.no-radius .role-icon,
        body.no-radius .selected-badge {
            border-radius: 0 !important;
        }

        .add-feature-container {
            min-height: 100vh;
            background: var(--bg-body);
            padding: 2rem;
        }
        
        .main-content {
            max-width: 1400px;
            margin: 0 auto;
        }
        
        /* Header */
        .page-header {
            margin-bottom: 2rem;
        }

        .page-header h1 {
            font-size: 2rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 0.25rem;
        }

        .page-header p {
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        /* Main Card */
        .main-card {
            background: var(--bg-card);
            border-radius: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .card-header {
            padding: 1.5rem 2rem;
            border-bottom: 1px solid var(--border);
            background: var(--bg-offwhite);
        }

        .card-header h5 {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--dark);
            margin: 0;
        }

        .card-body {
            padding: 2rem;
        }

        /* Section Title */
        .section-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 1rem;
        }

        /* Role Selection - Professional Cards */
        .role-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .role-card {
            background: var(--bg-card);
            border: 2px solid var(--border);
            border-radius: 16px;
            padding: 1.25rem;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
            min-width: 160px;
            flex: 1;
        }

        .role-card:hover {
            border-color: var(--primary);
            background: rgba(79, 70, 229, 0.05);
            transform: translateY(-2px);
        }

        .role-card.selected {
            border-color: var(--primary);
            background: rgba(79, 70, 229, 0.1);
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.2);
        }

        .role-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            margin-bottom: 1rem;
        }

        .role-card.superadmin .role-icon {
            background: rgba(79, 70, 229, 0.1);
            color: var(--primary);
        }

        .role-card.educator .role-icon {
            background: rgba(59, 130, 246, 0.1);
            color: #3b82f6;
        }

        .role-card.trainer .role-icon {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .role-card.student .role-icon {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }

        .role-card h4 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 0.25rem;
        }

        .role-card p {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin: 0;
        }

        .selected-badge {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            width: 20px;
            height: 20px;
            background: var(--success);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.75rem;
            opacity: 0;
            transform: scale(0);
            transition: all 0.2s;
        }

        .role-card.selected .selected-badge {
            opacity: 1;
            transform: scale(1);
        }

        /* Form Layout */
        .form-layout {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-light);
            margin-bottom: 0.5rem;
            display: block;
        }

        .form-control, .form-select {
            width: 100%;
            padding: 0.625rem 1rem;
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 0.95rem;
            color: var(--text);
            background: var(--bg-white);
            transition: all 0.2s;
        }

        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
            background: var(--bg-white);
            color: var(--text);
        }

        /* Status Badge */
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 1rem;
            background: var(--bg-offwhite);
            border-radius: 9999px;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-light);
            cursor: pointer;
            transition: all 0.2s;
            border: 2px solid transparent;
        }

        .status-badge i {
            margin-right: 0.5rem;
            font-size: 0.5rem;
        }

        .status-badge.active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .status-badge.active.selected {
            background: var(--success);
            color: white;
            border-color: #059669;
        }

        .status-badge.inactive {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
        }

        .status-badge.inactive.selected {
            background: var(--danger);
            color: white;
            border-color: #dc2626;
        }

        .status-badge.pending {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }

        .status-badge.pending.selected {
            background: var(--warning);
            color: white;
            border-color: #d97706;
        }

        /* Already Added Features */
        .already-added-section {
            background: var(--bg-offwhite);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border: 1px solid var(--border);
        }

        .already-added-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-light);
            margin-bottom: 1rem;
        }

        .feature-tag {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 1rem;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 9999px;
            font-size: 0.875rem;
            color: var(--text);
            margin-right: 0.5rem;
            margin-bottom: 0.5rem;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        .feature-tag i {
            margin-left: 0.5rem;
            color: var(--danger);
            cursor: pointer;
            opacity: 0.6;
            transition: opacity 0.2s;
        }

        .feature-tag i:hover {
            opacity: 1;
        }

        .order-badge {
            background: var(--primary);
            color: white;
            border-radius: 9999px;
            padding: 0.125rem 0.5rem;
            font-size: 0.75rem;
            margin-left: 0.5rem;
        }

        /* Alert */
        .alert-custom {
            padding: 1rem 1.5rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            border: 1px solid;
        }

        .alert-warning {
            background: rgba(245, 158, 11, 0.1);
            border-color: var(--warning);
            color: var(--warning);
        }

        .alert-info {
            background: rgba(59, 130, 246, 0.1);
            border-color: var(--info);
            color: var(--info);
        }

        /* Action Buttons */
        .action-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
        }

        .btn {
            padding: 0.625rem 1.5rem;
            border-radius: 10px;
            font-size: 0.95rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover:not(:disabled) {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.4);
        }

        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn-secondary {
            background: var(--bg-white);
            color: var(--text-light);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--bg-offwhite);
            transform: translateY(-2px);
        }

        .btn-outline-danger {
            background: transparent;
            color: var(--danger);
            border: 1px solid var(--danger);
        }

        .btn-outline-danger:hover {
            background: var(--danger);
            color: white;
            transform: translateY(-2px);
        }

        /* Available Count Badge */
        .available-badge {
            background: rgba(79, 70, 229, 0.1);
            color: var(--primary);
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-left: 0.5rem;
        }

        /* Quick Tips */
        .tips-card {
            background: var(--bg-card);
            border-radius: 16px;
            border: 1px solid var(--border);
            padding: 1.5rem;
            margin-top: 2rem;
        }

        .tips-title {
            font-size: 1rem;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 1rem;
        }

        .tips-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .tips-list li {
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--text-light);
            font-size: 0.875rem;
        }

        .tips-list i {
            color: var(--success);
            font-size: 0.875rem;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .add-feature-container {
                padding: 1rem;
            }
            
            .form-layout {
                grid-template-columns: 1fr;
            }
            
            .role-card {
                min-width: 100%;
            }
            
            .action-buttons {
                flex-direction: column;
            }
            
            .btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>
    
    <div class="add-feature-container">
        <div class="main-content">
            
            <!-- Header -->
            <div class="page-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h1>
                            <i class="fas fa-plus-circle me-2" style="color: var(--primary);"></i>
                            Add New Feature
                        </h1>
                        <p>Configure sidebar navigation for different user roles</p>
                    </div>
                    <div>
                        <a href="/dashboard" class="btn btn-primary me-2">
                            <i class="fas fa-home me-2"></i>Dashboard
                        </a>
                        <a href="/role-permissions" class="btn btn-secondary">
                            <i class="fas fa-user-shield me-2"></i>Permissions
                        </a>
                    </div>
                </div>
            </div>

            <!-- Warning Alert -->
            <div class="alert-custom alert-warning" id="alreadyExistsWarning" style="display: none;">
                <i class="fas fa-exclamation-triangle fs-5"></i>
                <div>
                    <strong>Feature Already Exists!</strong>
                    <p class="mb-0 small">This feature is already configured for the selected role and section.</p>
                </div>
            </div>

            <!-- Main Card -->
            <div class="main-card">
                <div class="card-header">
                    <h5>
                        <i class="fas fa-cog me-2" style="color: var(--primary);"></i>
                        Feature Configuration
                    </h5>
                </div>
                
                <div class="card-body">
                    <form id="addFeatureForm">
                        
                        <!-- Role Selection - Professional Cards -->
                        <div class="section-title">Select User Role</div>
                        
                        <div class="role-grid" id="roleSelection"></div>

                        <!-- Form Grid -->
                        <div class="form-layout">
                            <!-- Section Selection -->
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-folder me-2" style="color: var(--primary);"></i>
                                    Section
                                </label>
                                <select
                                    id="sectionSelect"
                                    class="form-select"
                                    required
                                >
                                    <option value="">Choose section...</option>
                                </select>
                            </div>

                            <!-- Feature Selection -->
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-star me-2" style="color: var(--primary);"></i>
                                    Feature
                                    <span class="available-badge" id="availableCountBadge" style="display: none;">0 available</span>
                                </label>
                                <select
                                    id="featureSelect"
                                    class="form-select"
                                    required
                                >
                                    <option value="">Choose feature...</option>
                                </select>
                                
                                <div class="alert-custom alert-info mt-2" id="noFeaturesAlert" style="display: none;">
                                    <i class="fas fa-info-circle"></i>
                                    <span id="noFeaturesMessage"></span>
                                </div>
                            </div>

                            <!-- Status Selection -->
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-toggle-on me-2" style="color: var(--primary);"></i>
                                    Status
                                </label>
                                <div class="d-flex gap-2">
                                    <span class="status-badge active selected" onclick="setStatus('active')" id="statusActive">
                                        <i class="fas fa-circle"></i> Active
                                    </span>
                                    <span class="status-badge inactive" onclick="setStatus('inactive')" id="statusInactive">
                                        <i class="fas fa-circle"></i> Inactive
                                    </span>
                                </div>
                            </div>

                            <!-- Order -->
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-sort-numeric-down me-2" style="color: var(--primary);"></i>
                                    Display Order
                                </label>
                                <input
                                    type="number"
                                    id="orderInput"
                                    class="form-control"
                                    value="1"
                                    min="1"
                                    style="max-width: 150px;"
                                />
                                <small class="text-muted">Lower numbers appear first</small>
                            </div>
                        </div>

                        <!-- Already Added Features -->
                        <div class="already-added-section" id="alreadyAddedSection" style="display: none;">
                            <div class="already-added-title" id="alreadyAddedTitle"></div>
                            <div id="alreadyAddedFeatures"></div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="action-buttons">
                            <button
                                type="submit"
                                id="submitBtn"
                                class="btn btn-primary"
                            >
                                <i class="fas fa-save me-2"></i>
                                Add Feature
                                <span style="background: rgba(255,255,255,0.2); padding: 0.25rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; margin-left: 0.5rem;" id="selectedRoleBadge">SuperAdmin</span>
                            </button>
                            
                            <button
                                type="button"
                                id="resetBtn"
                                class="btn btn-secondary"
                            >
                                <i class="fas fa-redo me-2"></i>
                                Reset
                            </button>
                            
                            <button
                                type="button"
                                id="cancelBtn"
                                class="btn btn-outline-danger"
                            >
                                <i class="fas fa-times me-2"></i>
                                Cancel
                            </button>
                        </div>

                    </form>
                </div>
            </div>

            <!-- Quick Tips -->
            <div class="tips-card">
                <div class="tips-title">
                    <i class="fas fa-lightbulb me-2" style="color: var(--warning);"></i>
                    Quick Tips
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <ul class="tips-list">
                            <li>
                                <i class="fas fa-check-circle"></i>
                                <span>Features appear instantly in the sidebar</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle"></i>
                                <span>Each role can have unique features</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle"></i>
                                <span>Inactive features are hidden from users</span>
                            </li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="tips-list">
                            <li>
                                <i class="fas fa-check-circle"></i>
                                <span>No duplicate features per role</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle"></i>
                                <span>Changes sync across all tabs</span>
                            </li>
                            <li>
                                <i class="fas fa-check-circle"></i>
                                <span>Real-time updates without refresh</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Toastify JS -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    
    <script>
