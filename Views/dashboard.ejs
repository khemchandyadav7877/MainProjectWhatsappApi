<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SSPAR Cloud - WhatsApp Campaign Dashboard</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- ApexCharts -->
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* ===== THEME VARIABLES ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f8fafc;
            --bg-white: #ffffff;
            --bg-offwhite: #f1f5f9;
            --bg-card: #ffffff;
            --text: #334155;
            --text-light: #64748b;
            --text-muted: #94a3b8;
            --dark: #0f172a;
            --border: #eef2f6;
            --shadow: 0 8px 25px rgba(0,0,0,0.03);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --text: #e2e8f0;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 8px 25px rgba(0,0,0,0.2);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: 'Inter', 'Segoe UI', sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar-wrapper,
        body.round-border .stat-card,
        body.round-border .campaign-card,
        body.round-border .chart-card,
        body.round-border .device-card,
        body.round-border .type-item,
        body.round-border .recent-section,
        body.round-border .action-btn,
        body.round-border .welcome-section {
            border-radius: 20px !important;
        }

        body.round-border .stat-icon,
        body.round-border .campaign-icon,
        body.round-border .type-icon,
        body.round-border .device-icon,
        body.round-border .btn {
            border-radius: 16px !important;
        }

        body.round-border .status-dot,
        body.round-border .notification-badge,
        body.round-border .mobile-toggle {
            border-radius: 50% !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar-wrapper,
        body.no-radius .stat-card,
        body.no-radius .campaign-card,
        body.no-radius .chart-card,
        body.no-radius .device-card,
        body.no-radius .type-item,
        body.no-radius .recent-section,
        body.no-radius .action-btn,
        body.no-radius .welcome-section,
        body.no-radius .stat-icon,
        body.no-radius .campaign-icon,
        body.no-radius .type-icon,
        body.no-radius .device-icon,
        body.no-radius .btn,
        body.no-radius .status-dot,
        body.no-radius .notification-badge,
        body.no-radius .mobile-toggle {
            border-radius: 0 !important;
        }

        /* HEADER FIXED */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
            transition: all 0.3s;
        }

        /* MAIN LAYOUT */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
        }

        /* SIDEBAR WRAPPER */
        .sidebar-wrapper {
            width: 280px;
            flex-shrink: 0;
            position: fixed;
            left: 0;
            top: 70px;
            bottom: 0;
            z-index: 1020;
            transition: all 0.3s ease;
            background: var(--bg-white);
            border-right: 1px solid var(--border);
            overflow-y: auto;
        }

        .sidebar-wrapper.collapsed {
            width: 80px;
        }

        /* CONTENT WRAPPER */
        .content-wrapper {
            flex: 1;
            margin-left: 280px;
            padding: 25px;
            transition: margin-left 0.3s ease;
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
        }

        .sidebar-wrapper.collapsed + .content-wrapper {
            margin-left: 80px;
        }

        /* MAIN CONTENT */
        .mid-content {
            background: transparent;
            border-radius: 0;
            padding: 0;
            box-shadow: none;
            min-height: 500px;
        }

        /* MOBILE */
        @media (max-width: 768px) {
            .sidebar-wrapper {
                transform: translateX(-100%);
                width: 280px !important;
            }
            
            .sidebar-wrapper.mobile-open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
            }
        }

        /* Welcome Section */
        .welcome-section {
            background: linear-gradient(135deg, var(--primary) 0%, #764ba2 100%);
            border-radius: 25px;
            padding: 30px 35px;
            margin-bottom: 30px;
            color: white;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(102, 126, 234, 0.25);
        }

        .welcome-section::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

        .welcome-section::after {
            content: '';
            position: absolute;
            bottom: -80px;
            left: -80px;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

        .welcome-content {
            position: relative;
            z-index: 1;
        }

        .welcome-content h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .welcome-content h1 i {
            font-size: 40px;
        }

        .welcome-content p {
            font-size: 16px;
            opacity: 0.95;
            margin-bottom: 20px;
        }

        .date-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.2);
            padding: 8px 18px;
            border-radius: 50px;
            font-size: 14px;
            backdrop-filter: blur(10px);
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 25px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--primary-gradient);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .stat-card:hover::before {
            opacity: 1;
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            font-size: 28px;
            color: white;
        }

        .stat-icon.purple { background: linear-gradient(135deg, #667eea, #764ba2); }
        .stat-icon.green { background: linear-gradient(135deg, #25D366, #1EBEA5); }
        .stat-icon.blue { background: linear-gradient(135deg, #3b82f6, #2563eb); }
        .stat-icon.orange { background: linear-gradient(135deg, #f59e0b, #d97706); }

        .stat-label {
            color: var(--text-light);
            font-size: 14px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 36px;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 8px;
        }

        .stat-change {
            font-size: 13px;
            color: var(--success);
            background: rgba(16, 185, 129, 0.1);
            padding: 4px 10px;
            border-radius: 50px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .stat-change.negative {
            color: var(--danger);
            background: rgba(239, 68, 68, 0.1);
        }

        /* Campaign Stats */
        .campaign-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
            margin-bottom: 30px;
        }

        .campaign-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 25px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
        }

        .campaign-header {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }

        .campaign-icon {
            width: 50px;
            height: 50px;
            border-radius: 16px;
            background: var(--bg-offwhite);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: var(--primary);
        }

        .campaign-header h3 {
            color: var(--dark);
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .campaign-header p {
            color: var(--text-light);
            font-size: 13px;
        }

        .progress {
            height: 8px;
            background: var(--bg-offwhite);
            border-radius: 10px;
            margin-bottom: 15px;
            overflow: hidden;
        }

        .progress-bar {
            background: var(--primary-gradient);
            border-radius: 10px;
        }

        .campaign-footer {
            display: flex;
            justify-content: space-between;
            color: var(--text-light);
            font-size: 13px;
        }

        /* Charts Row */
        .charts-row {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 25px;
            margin-bottom: 30px;
        }

        .chart-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 25px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .chart-header h3 {
            color: var(--dark);
            font-size: 18px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .chart-header h3 i {
            color: var(--primary);
        }

        .chart-actions select {
            padding: 8px 15px;
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 13px;
            color: var(--text);
            background: var(--bg-white);
            cursor: pointer;
        }

        #campaignChart, #typeChart {
            width: 100%;
            height: 300px;
        }

        /* Device Grid */
        .device-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .device-card {
            background: var(--bg-card);
            border-radius: 18px;
            padding: 20px;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 15px;
            transition: all 0.3s;
            cursor: pointer;
        }

        .device-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary);
        }

        .device-icon {
            width: 50px;
            height: 50px;
            border-radius: 16px;
            background: var(--bg-offwhite);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #25D366;
        }

        .device-icon.connected {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .device-icon.pending {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }

        .device-icon.offline {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
        }

        .device-info {
            flex: 1;
        }

        .device-info h4 {
            color: var(--dark);
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .device-info p {
            color: var(--text-light);
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
        }

        .status-dot.connected { 
            background: var(--success); 
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
            animation: pulse 2s infinite;
        }
        
        .status-dot.pending { 
            background: var(--warning); 
            box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2);
        }
        
        .status-dot.offline { 
            background: var(--danger); 
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2);
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }
            70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }

        /* Message Type Grid */
        .type-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .type-item {
            background: var(--bg-card);
            border-radius: 18px;
            padding: 20px;
            text-align: center;
            border: 1px solid var(--border);
            transition: all 0.3s;
        }

        .type-item:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary);
        }

        .type-icon {
            width: 60px;
            height: 60px;
            border-radius: 16px;
            margin: 0 auto 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: white;
        }

        .type-icon.text { background: linear-gradient(135deg, #3b82f6, #2563eb); }
        .type-icon.image { background: linear-gradient(135deg, #10b981, #059669); }
        .type-icon.video { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
        .type-icon.pdf { background: linear-gradient(135deg, #ef4444, #dc2626); }

        .type-count {
            font-size: 28px;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 5px;
        }

        .type-label {
            color: var(--text-light);
            font-size: 14px;
        }

        /* Recent Campaigns */
        .recent-section {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid var(--border);
            margin-bottom: 30px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .section-header h3 {
            color: var(--dark);
            font-size: 18px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .view-all {
            color: var(--primary);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .view-all:hover {
            color: var(--primary-dark);
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            padding: 15px 10px;
            color: var(--text-light);
            font-weight: 600;
            font-size: 13px;
            border-bottom: 1px solid var(--border);
        }

        td {
            padding: 15px 10px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
            font-size: 14px;
        }

        .campaign-badge {
            padding: 5px 12px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge-success { background: rgba(16, 185, 129, 0.1); color: var(--success); }
        .badge-warning { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
        .badge-danger { background: rgba(239, 68, 68, 0.1); color: var(--danger); }
        .badge-info { background: rgba(59, 130, 246, 0.1); color: var(--info); }

        .progress-mini {
            width: 100px;
            height: 6px;
            background: var(--bg-offwhite);
            border-radius: 10px;
            overflow: hidden;
        }

        .progress-mini-bar {
            height: 100%;
            background: var(--primary-gradient);
            border-radius: 10px;
        }

        /* Quick Actions */
        .quick-actions {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .action-btn {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            transition: all 0.3s;
            cursor: pointer;
            text-decoration: none;
            color: var(--text);
        }

        .action-btn:hover {
            transform: translateY(-3px);
            border-color: var(--primary);
            box-shadow: var(--shadow-lg);
        }

        .action-btn i {
            font-size: 28px;
            color: var(--primary);
            margin-bottom: 12px;
        }

        .action-btn h4 {
            color: var(--dark);
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .action-btn p {
            color: var(--text-light);
            font-size: 12px;
        }

        /* Loading Spinner */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(5px);
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid var(--bg-offwhite);
            border-top: 5px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Toast */
        #toast {
            position: fixed;
            top: 24px;
            right: 24px;
            width: 320px;
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 9999;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); }

        .toast-content {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            font-size: 20px;
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 5px 0 0;
            font-size: 13px;
            opacity: 0.9;
        }

        .toast-progress {
            height: 3px;
            background: rgba(255,255,255,0.6);
            margin-top: 10px;
            width: 100%;
            animation: progress 3s linear;
        }

        @keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* Empty States */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
        }

        .empty-state i {
            font-size: 50px;
            color: var(--text-muted);
            margin-bottom: 15px;
        }

        .empty-state h5 {
            color: var(--dark);
            font-size: 18px;
            margin-bottom: 10px;
        }

        .empty-state p {
            color: var(--text-light);
            max-width: 300px;
            margin: 0 auto;
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .campaign-stats {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .charts-row {
                grid-template-columns: 1fr;
            }
            
            .type-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .device-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .quick-actions {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
            
            .campaign-stats {
                grid-template-columns: 1fr;
            }
            
            .type-grid {
                grid-template-columns: 1fr;
            }

            .device-grid {
                grid-template-columns: 1fr;
            }

            .quick-actions {
                grid-template-columns: 1fr;
            }

            .welcome-section {
                padding: 20px;
            }

            .welcome-content h1 {
                font-size: 24px;
            }
        }
    </style>
</head>
<body>
    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner"></div>
    </div>

    <!-- Toast -->
    <div id="toast"></div>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <div class="sidebar-wrapper" id="sidebarWrapper">
            <%- include('../partials/ram/sidebaar') %>
        </div>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <div class="mid-content">
                <!-- Welcome Section -->
                <div class="welcome-section">
                    <div class="welcome-content">
                        <h1>
                            <i class="fab fa-whatsapp"></i>
                            WhatsApp Campaign Dashboard
                        </h1>
                        <p>Welcome back, <strong><%= user?.role || 'Admin' %></strong>! Here's what's happening with your campaigns today.</p>
                        <div class="date-badge">
                            <i class="far fa-calendar-alt"></i>
                            <span id="currentDate"></span>
                            <i class="far fa-clock ms-2"></i>
                            <span id="currentTime"></span>
                        </div>
                    </div>
                </div>

                <!-- Stats Cards Row 1 -->
                <div class="stats-grid">
                    <div class="stat-card" onclick="window.location.href='/scan/whatsapp'">
                        <div class="stat-icon purple">
                            <i class="fab fa-whatsapp"></i>
                        </div>
                        <div class="stat-label">Connected Devices</div>
                        <div class="stat-value" id="totalDevices">0</div>
                        <span class="stat-change">
                            <i class="fas fa-circle"></i> <span id="onlineDevices">0</span> online
                        </span>
                    </div>
                    
                    <div class="stat-card" onclick="window.location.href='/contacts'">
                        <div class="stat-icon green">
                            <i class="fas fa-address-book"></i>
                        </div>
                        <div class="stat-label">Total Contacts</div>
                        <div class="stat-value" id="totalContacts">0</div>
                        <span class="stat-change">
                            <i class="fas fa-user-check"></i> <span id="activeContacts">0</span> active
                        </span>
                    </div>
                    
                    <div class="stat-card" onclick="window.location.href='/campaign'">
                        <div class="stat-icon blue">
                            <i class="fas fa-bullhorn"></i>
                        </div>
                        <div class="stat-label">Total Campaigns</div>
                        <div class="stat-value" id="totalCampaigns">0</div>
                        <span class="stat-change">
                            <i class="fas fa-play"></i> <span id="activeCampaigns">0</span> active
                        </span>
                    </div>
                    
                    <div class="stat-card">
                        <div class="stat-icon orange">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="stat-label">Messages Sent</div>
                        <div class="stat-value" id="totalMessages">0</div>
                        <span class="stat-change">
                            <i class="fas fa-calendar-day"></i> <span id="todayMessages">0</span> today
                        </span>
                    </div>
                </div>

                <!-- Stats Cards Row 2 - Campaign Stats -->
                <div class="campaign-stats">
                    <div class="campaign-card">
                        <div class="campaign-header">
                            <div class="campaign-icon">
                                <i class="fas fa-check-circle"></i>
                            </div>
                            <div>
                                <h3>Successful Messages</h3>
                                <p>Delivered successfully</p>
                            </div>
                        </div>
                        <div class="stat-value" style="font-size: 32px;" id="successfulMessages">0</div>
                        <div class="progress">
                            <div class="progress-bar" id="successRateBar" style="width: 0%"></div>
                        </div>
                        <div class="campaign-footer">
                            <span id="successRate">0% success rate</span>
                            <span class="text-success"><i class="fas fa-arrow-up"></i> <span id="successTrend">0</span>%</span>
                        </div>
                    </div>

                    <div class="campaign-card">
                        <div class="campaign-header">
                            <div class="campaign-icon">
                                <i class="fas fa-exclamation-circle"></i>
                            </div>
                            <div>
                                <h3>Failed Messages</h3>
                                <p>Delivery failed</p>
                            </div>
                        </div>
                        <div class="stat-value" style="font-size: 32px; color: var(--danger);" id="failedMessages">0</div>
                        <div class="progress">
                            <div class="progress-bar" id="failureRateBar" style="width: 0%; background: var(--danger);"></div>
                        </div>
                        <div class="campaign-footer">
                            <span id="failureRate">0% failure rate</span>
                            <span class="text-danger"><i class="fas fa-arrow-down"></i> <span id="failureTrend">0</span>%</span>
                        </div>
                    </div>

                    <div class="campaign-card">
                        <div class="campaign-header">
                            <div class="campaign-icon">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div>
                                <h3>Pending/Scheduled</h3>
                                <p>Awaiting delivery</p>
                            </div>
                        </div>
                        <div class="stat-value" style="font-size: 32px; color: var(--warning);" id="pendingMessages">0</div>
                        <div class="progress">
                            <div class="progress-bar" style="width: 0%; background: var(--warning);" id="pendingBar"></div>
                        </div>
                        <div class="campaign-footer">
                            <span id="pendingCount">0 campaigns scheduled</span>
                            <span class="text-warning" id="nextCampaign">Next: --</span>
                        </div>
                    </div>
                </div>

                <!-- Device Status Grid -->
                <div class="device-grid" id="deviceGrid">
                    <!-- Devices will be loaded here dynamically -->
                    <div class="text-center text-muted py-4" id="noDevicesMessage" style="grid-column: 1/-1; display: none;">
                        <i class="fas fa-wifi-slash fa-3x mb-3"></i>
                        <h5>No Devices Connected</h5>
                        <p>Connect your first WhatsApp device to get started</p>
                        <a href="/scan/whatsapp" class="btn btn-primary btn-sm mt-2">Connect Device</a>
                    </div>
                </div>

                <!-- Charts Row -->
                <div class="charts-row">
                    <!-- Campaign Performance Chart -->
                    <div class="chart-card">
                        <div class="chart-header">
                            <h3><i class="fas fa-chart-line"></i> Campaign Performance (Last 7 Days)</h3>
                            <div class="chart-actions">
                                <select id="chartRange" onchange="loadCampaignData()">
                                    <option value="7">Last 7 days</option>
                                    <option value="30">Last 30 days</option>
                                    <option value="90">Last 90 days</option>
                                </select>
                            </div>
                        </div>
                        <div id="campaignChart"></div>
                    </div>

                    <!-- Message Type Distribution -->
                    <div class="chart-card">
                        <div class="chart-header">
                            <h3><i class="fas fa-chart-pie"></i> Message Types</h3>
                        </div>
                        <div id="typeChart"></div>
                    </div>
                </div>

                <!-- Message Type Stats -->
                <div class="type-grid">
                    <div class="type-item">
                        <div class="type-icon text">
                            <i class="fas fa-comment"></i>
                        </div>
                        <div class="type-count" id="textCount">0</div>
                        <div class="type-label">Text Messages</div>
                    </div>
                    
                    <div class="type-item">
                        <div class="type-icon image">
                            <i class="fas fa-image"></i>
                        </div>
                        <div class="type-count" id="imageCount">0</div>
                        <div class="type-label">Images</div>
                    </div>
                    
                    <div class="type-item">
                        <div class="type-icon video">
                            <i class="fas fa-video"></i>
                        </div>
                        <div class="type-count" id="videoCount">0</div>
                        <div class="type-label">Videos</div>
                    </div>
                    
                    <div class="type-item">
                        <div class="type-icon pdf">
                            <i class="fas fa-file-pdf"></i>
                        </div>
                        <div class="type-count" id="pdfCount">0</div>
                        <div class="type-label">PDFs & Docs</div>
                    </div>
                </div>

                <!-- Recent Campaigns -->
                <div class="recent-section">
                    <div class="section-header">
                        <h3><i class="fas fa-history"></i> Recent Campaigns</h3>
                        <a href="/campaign" class="view-all">
                            View All <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                    
                    <div class="table-responsive">
                        <table>
                            <thead>
                                <tr>
                                    <th>Campaign Name</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Sent/Total</th>
                                    <th>Success Rate</th>
                                    <th>Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="recentCampaigns">
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="fas fa-spinner fa-spin me-2"></i> Loading campaigns...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="quick-actions">
                    <a href="/devices/campaign" class="action-btn">
                        <i class="fas fa-plus-circle"></i>
                        <h4>New Campaign</h4>
                        <p>Create WhatsApp campaign</p>
                    </a>
                    
                    <a href="/devices/add" class="action-btn">
                        <i class="fas fa-user-plus"></i>
                        <h4>Add Contact</h4>
                        <p>Add new contact</p>
                    </a>
                    
                    <a href="/scan/whatsapp" class="action-btn">
                        <i class="fab fa-whatsapp"></i>
                        <h4>Connect Device</h4>
                        <p>Add WhatsApp device</p>
                    </a>
                    
                    <a href="/analytics" class="action-btn">
                        <i class="fas fa-chart-bar"></i>
                        <h4>Analytics</h4>
                        <p>Detailed reports</p>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ======================
        // THEME INITIALIZATION
        // ======================
        (function() {
            // Load saved theme
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.body.classList.add(savedTheme);
            
            // Load saved border mode
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedBorder);
            
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();

        // ======================
        // GLOBAL VARIABLES
        // ======================
        let campaignChart = null;
        let typeChart = null;
        let refreshInterval = null;

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Sidebar sync
            const sidebar = document.getElementById('mainSidebar');
            const sidebarWrapper = document.getElementById('sidebarWrapper');
            
            if (sidebar && sidebarWrapper) {
                if (sidebar.classList.contains('collapsed')) {
                    sidebarWrapper.classList.add('collapsed');
                }
                
                window.toggleCollapse = function() {
                    if (sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        sidebarWrapper.classList.remove('collapsed');
                    } else {
                        sidebar.classList.add('collapsed');
                        sidebarWrapper.classList.add('collapsed');
                    }
                };
                
                window.toggleMobileSidebar = function() {
                    if (sidebar.classList.contains('open')) {
                        sidebar.classList.remove('open');
                        sidebarWrapper.classList.remove('mobile-open');
                    } else {
                        sidebar.classList.add('open');
                        sidebarWrapper.classList.add('mobile-open');
                    }
                };
                
                window.closeMobileSidebar = function() {
                    sidebar.classList.remove('open');
                    sidebarWrapper.classList.remove('mobile-open');
                };
            }
            
            // Update date and time
            updateDateTime();
            setInterval(updateDateTime, 1000);
            
            // Load all data
            loadDashboardData();
            
            // Auto-refresh every 30 seconds
            refreshInterval = setInterval(loadDashboardData, 30000);
            
            // Hide loading overlay after first load
            setTimeout(() => {
                document.getElementById('loadingOverlay').style.display = 'none';
            }, 1000);
        });

        // Clean up on page unload
        window.addEventListener('beforeunload', function() {
            if (refreshInterval) {
                clearInterval(refreshInterval);
            }
        });

        // ======================
        // DATE/TIME FUNCTIONS
        // ======================
        function updateDateTime() {
            const now = new Date();
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            document.getElementById('currentDate').textContent = now.toLocaleDateString('en-US', options);
            document.getElementById('currentTime').textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
        }

        // ======================
        // TOAST FUNCTION
        // ======================
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            if (window.toastTimeout) {
                clearTimeout(window.toastTimeout);
            }
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            window.toastTimeout = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOAD DASHBOARD DATA
        // ======================
        async function loadDashboardData() {
            try {
                const response = await fetch('/api/dashboard-data');
                const data = await response.json();
                
                if (data.success) {
                    // Update all sections
                    updateDeviceStats(data.devices);
                    updateContactStats(data.contacts);
                    updateCampaignStats(data.campaigns);
                    updateMessageStats(data.messages);
                    updateDeviceGrid(data.devices.list);
                    updateRecentCampaigns(data.campaigns.recent);
                    updateCharts(data.messages, data.campaigns.recent);
                    
                    // Show success toast on first load
                    if (!window.dataLoaded) {
                        showToast('Dashboard Updated', 'Data loaded successfully', 'success');
                        window.dataLoaded = true;
                    }
                }
            } catch (error) {
                console.error('Error loading dashboard data:', error);
                showToast('Error', 'Failed to load dashboard data', 'error');
            }
        }

        // ======================
        // UPDATE DEVICE STATS
        // ======================
        function updateDeviceStats(devices) {
            document.getElementById('totalDevices').textContent = devices.total || 0;
            document.getElementById('onlineDevices').textContent = devices.online || 0;
        }

        // ======================
        // UPDATE CONTACT STATS
        // ======================
        function updateContactStats(contacts) {
            document.getElementById('totalContacts').textContent = contacts.total || 0;
            document.getElementById('activeContacts').textContent = contacts.active || 0;
        }

        // ======================
        // UPDATE CAMPAIGN STATS
        // ======================
        function updateCampaignStats(campaigns) {
            document.getElementById('totalCampaigns').textContent = campaigns.total || 0;
            document.getElementById('activeCampaigns').textContent = campaigns.active || 0;
        }

        // ======================
        // UPDATE MESSAGE STATS
        // ======================
        function updateMessageStats(messages) {
            document.getElementById('totalMessages').textContent = (messages.total || 0).toLocaleString();
            document.getElementById('todayMessages').textContent = (messages.today || 0).toLocaleString();
            document.getElementById('successfulMessages').textContent = (messages.successful || 0).toLocaleString();
            document.getElementById('failedMessages').textContent = (messages.failed || 0).toLocaleString();
            document.getElementById('pendingMessages').textContent = messages.pending || 0;
            
            document.getElementById('successRate').textContent = messages.successRate + '% success rate';
            document.getElementById('failureRate').textContent = messages.failureRate + '% failure rate';
            document.getElementById('pendingCount').textContent = (messages.pending || 0) + ' campaigns scheduled';
            
            document.getElementById('successRateBar').style.width = messages.successRate + '%';
            document.getElementById('failureRateBar').style.width = messages.failureRate + '%';
            document.getElementById('pendingBar').style.width = messages.pending > 0 ? '100%' : '0%';
            
            document.getElementById('textCount').textContent = (messages.byType?.text || 0).toLocaleString();
            document.getElementById('imageCount').textContent = (messages.byType?.image || 0).toLocaleString();
            document.getElementById('videoCount').textContent = (messages.byType?.video || 0).toLocaleString();
            document.getElementById('pdfCount').textContent = (messages.byType?.pdf || 0).toLocaleString();
        }

        // ======================
        // UPDATE DEVICE GRID
        // ======================
        function updateDeviceGrid(devices) {
            const deviceGrid = document.getElementById('deviceGrid');
            const noDevicesMsg = document.getElementById('noDevicesMessage');
            
            if (!devices || devices.length === 0) {
                noDevicesMsg.style.display = 'block';
                deviceGrid.innerHTML = '';
                return;
            }
            
            noDevicesMsg.style.display = 'none';
            
            let deviceHtml = '';
            devices.forEach(device => {
                const status = device.isConnected ? 'connected' : 'offline';
                const statusText = device.isConnected ? 'Connected' : 'Disconnected';
                const timeAgo = device.lastConnected ? 
                    getTimeAgo(new Date(device.lastConnected)) : 
                    'Never';
                
                deviceHtml += `
                    <div class="device-card" onclick="window.location.href='/devices/view/${device._id}'">
                        <div class="device-icon ${status}">
                            <i class="fab fa-whatsapp"></i>
                        </div>
                        <div class="device-info">
                            <h4>${device.name || 'WhatsApp Device'}</h4>
                            <p>
                                <span class="status-dot ${status}"></span>
                                ${statusText}
                                ${device.isConnected ? `<span class="ms-2"><i class="far fa-clock"></i> ${timeAgo}</span>` : ''}
                            </p>
                            <small class="text-muted">${device.phoneNumber ? '+91 ' + device.phoneNumber : 'No number'}</small>
                        </div>
                    </div>
                `;
            });
            
            deviceGrid.innerHTML = deviceHtml;
        }

        // ======================
        // UPDATE RECENT CAMPAIGNS
        // ======================
        function updateRecentCampaigns(campaigns) {
            const tbody = document.getElementById('recentCampaigns');
            
            if (!campaigns || campaigns.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="fas fa-bullhorn fa-3x mb-3"></i>
                            <p>No campaigns found</p>
                            <a href="/devices/campaign" class="btn btn-sm btn-primary">Create Campaign</a>
                        </td>
                    </tr>
                `;
                return;
            }
            
            let html = '';
            campaigns.forEach(c => {
                const date = new Date(c.createdAt).toLocaleDateString();
                const statusClass = {
                    'completed': 'badge-success',
                    'scheduled': 'badge-warning',
                    'sending': 'badge-info',
                    'failed': 'badge-danger'
                }[c.status] || 'badge-info';
                
                const typeIcon = {
                    'text': 'fa-comment',
                    'image': 'fa-image',
                    'video': 'fa-video',
                    'pdf': 'fa-file-pdf',
                    'document': 'fa-file-word'
                }[c.messageType] || 'fa-comment';
                
                const typeColor = {
                    'text': 'text-primary',
                    'image': 'text-success',
                    'video': 'text-purple',
                    'pdf': 'text-danger',
                    'document': 'text-warning'
                }[c.messageType] || 'text-primary';
                
                const sent = c.sentCount || 0;
                const total = c.totalContacts || 0;
                const progress = total > 0 ? Math.round((sent / total) * 100) : 0;
                
                html += `
                    <tr>
                        <td><strong>${c.campaignName || 'Campaign'}</strong></td>
                        <td><i class="fas ${typeIcon} ${typeColor} me-1"></i> ${c.messageType || 'text'}</td>
                        <td><span class="campaign-badge ${statusClass}">${c.status}</span></td>
                        <td>${sent}/${total}</td>
                        <td>
                            <div class="progress-mini">
                                <div class="progress-mini-bar" style="width: ${progress}%"></div>
                            </div>
                        </td>
                        <td>${date}</td>
                        <td>
                            <i class="fas fa-eye text-primary" style="cursor: pointer;" 
                               onclick="window.location.href='/campaign/view/${c._id}'"></i>
                        </td>
                    </tr>
                `;
            });
            
            tbody.innerHTML = html;
        }

        // ======================
        // UPDATE CHARTS
        // ======================
        function updateCharts(messages, campaigns) {
            // Campaign Performance Chart
            const days = parseInt(document.getElementById('chartRange').value);
            const dateMap = new Map();
            
            const endDate = new Date();
            const startDate = new Date();
            startDate.setDate(startDate.getDate() - days);
            
            // Initialize all dates
            for (let d = new Date(startDate); d <= endDate; d.setDate(d.getDate() + 1)) {
                const dateStr = d.toLocaleDateString('en-US', { weekday: 'short' });
                dateMap.set(dateStr, { sent: 0, failed: 0 });
            }
            
            // Aggregate campaign data
            campaigns.forEach(c => {
                const date = new Date(c.createdAt);
                if (date >= startDate && date <= endDate) {
                    const dateStr = date.toLocaleDateString('en-US', { weekday: 'short' });
                    if (dateMap.has(dateStr)) {
                        const existing = dateMap.get(dateStr);
                        existing.sent += c.sentCount || 0;
                        existing.failed += c.failedCount || 0;
                    }
                }
            });
            
            const categories = Array.from(dateMap.keys());
            const sentData = Array.from(dateMap.values()).map(v => v.sent);
            const failedData = Array.from(dateMap.values()).map(v => v.failed);
            
            // Destroy existing chart if any
            if (campaignChart) {
                campaignChart.destroy();
            }
            
            // Create new chart
            const campaignOptions = {
                series: [{
                    name: 'Messages Sent',
                    data: sentData
                }, {
                    name: 'Failed',
                    data: failedData
                }],
                chart: {
                    type: 'area',
                    height: 300,
                    toolbar: { show: false },
                    zoom: { enabled: false },
                    animations: {
                        enabled: true,
                        easing: 'easeinout',
                        speed: 800
                    },
                    background: 'transparent'
                },
                colors: ['#667eea', '#ef4444'],
                dataLabels: { enabled: false },
                stroke: { curve: 'smooth', width: 2 },
                fill: {
                    type: 'gradient',
                    gradient: {
                        shadeIntensity: 1,
                        opacityFrom: 0.7,
                        opacityTo: 0.3
                    }
                },
                xaxis: {
                    categories: categories,
                    labels: { style: { colors: 'var(--text-light)' } }
                },
                yaxis: {
                    labels: { style: { colors: 'var(--text-light)' } }
                },
                legend: { show: false },
                tooltip: { theme: document.body.classList.contains('dark') ? 'dark' : 'light' }
            };

            campaignChart = new ApexCharts(document.querySelector("#campaignChart"), campaignOptions);
            campaignChart.render();

            // Message Type Chart
            const typeOptions = {
                series: [
                    messages.byType?.text || 0,
                    messages.byType?.image || 0,
                    messages.byType?.video || 0,
                    messages.byType?.pdf || 0
                ],
                chart: {
                    type: 'donut',
                    height: 300,
                    animations: {
                        enabled: true,
                        easing: 'easeinout',
                        speed: 800
                    },
                    background: 'transparent'
                },
                labels: ['Text', 'Images', 'Videos', 'PDF/Docs'],
                colors: ['#3b82f6', '#10b981', '#8b5cf6', '#f59e0b'],
                plotOptions: {
                    pie: {
                        donut: {
                            size: '70%',
                            labels: {
                                show: true,
                                total: {
                                    show: true,
                                    label: 'Total',
                                    formatter: function(w) {
                                        const total = (messages.byType?.text || 0) + 
                                                      (messages.byType?.image || 0) + 
                                                      (messages.byType?.video || 0) + 
                                                      (messages.byType?.pdf || 0);
                                        return total.toLocaleString();
                                    }
                                }
                            }
                        }
                    }
                },
                dataLabels: { enabled: false },
                legend: { show: false },
                tooltip: { theme: document.body.classList.contains('dark') ? 'dark' : 'light' },
                responsive: [{
                    breakpoint: 480,
                    options: { chart: { width: 200 } }
                }]
            };

            if (typeChart) {
                typeChart.destroy();
            }
            
            typeChart = new ApexCharts(document.querySelector("#typeChart"), typeOptions);
            typeChart.render();
        }

        // ======================
        // UTILITY FUNCTIONS
        // ======================
        function getTimeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000);
            
            let interval = Math.floor(seconds / 31536000);
            if (interval > 1) return interval + ' years ago';
            
            interval = Math.floor(seconds / 2592000);
            if (interval > 1) return interval + ' months ago';
            
            interval = Math.floor(seconds / 86400);
            if (interval > 1) return interval + ' days ago';
            
            interval = Math.floor(seconds / 3600);
            if (interval > 1) return interval + ' hours ago';
            
            interval = Math.floor(seconds / 60);
            if (interval > 1) return interval + ' minutes ago';
            
            return Math.floor(seconds) + ' seconds ago';
        }

        // ======================
        // LOAD CAMPAIGN DATA (for chart range change)
        // ======================
        function loadCampaignData() {
            // This will refresh the whole dashboard with new date range
            loadDashboardData();
        }
    </script>

</body>
