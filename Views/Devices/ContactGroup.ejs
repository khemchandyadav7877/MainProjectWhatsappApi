<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Groups - SSPAR Cloud</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* ===== THEME VARIABLES - EXACTLY LIKE DASHBOARD ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f8fafc;
            --bg-white: #ffffff;
            --bg-offwhite: #f1f5f9;
            --bg-card: #ffffff;
            --text: #334155;
            --text-light: #64748b;
            --text-muted: #94a3b8;
            --dark: #0f172a;
            --border: #eef2f6;
            --shadow: 0 8px 25px rgba(0,0,0,0.03);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
            --sidebar-mini-width: 80px;
        }

        /* Dark Mode - EXACTLY LIKE DASHBOARD */
        body.dark {
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --text: #e2e8f0;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 8px 25px rgba(0,0,0,0.2);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: 'Inter', 'Segoe UI', sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES - EXACTLY LIKE DASHBOARD ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar,
        body.round-border .page-header,
        body.round-border .card,
        body.round-border .contact-item,
        body.round-border .group-item,
        body.round-border .selected-tag,
        body.round-border .search-box input,
        body.round-border .form-group input,
        body.round-border .form-group textarea,
        body.round-border .btn,
        body.round-border .modal-content,
        body.round-border .delete-modal-content,
        body.round-border #toast {
            border-radius: 20px !important;
        }

        body.round-border .contact-avatar,
        body.round-border .status-badge,
        body.round-border .whatsapp-badge,
        body.round-border .selected-count {
            border-radius: 50px !important;
        }

        body.round-border .contact-avatar {
            border-radius: 16px !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar,
        body.no-radius .page-header,
        body.no-radius .card,
        body.no-radius .contact-item,
        body.no-radius .group-item,
        body.no-radius .selected-tag,
        body.no-radius .search-box input,
        body.no-radius .form-group input,
        body.no-radius .form-group textarea,
        body.no-radius .btn,
        body.no-radius .modal-content,
        body.no-radius .delete-modal-content,
        body.no-radius #toast,
        body.no-radius .contact-avatar,
        body.no-radius .status-badge,
        body.no-radius .whatsapp-badge,
        body.no-radius .selected-count {
            border-radius: 0 !important;
        }

        /* HEADER FIXED - EXACTLY LIKE DASHBOARD */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
            transition: all 0.3s;
        }

        /* MAIN LAYOUT - EXACTLY LIKE DASHBOARD */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
            position: relative;
        }

        /* SIDEBAR - EXACTLY LIKE DASHBOARD */
        .sidebar {
            width: var(--sidebar-width, 280px);
            background: var(--bg-white);
            border-right: 1px solid var(--border);
            height: calc(100vh - var(--header-height, 70px));
            position: fixed;
            left: 0;
            top: 70px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1020;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }

        /* Sidebar Mini Mode */
        .sidebar.mini {
            width: var(--sidebar-mini-width, 80px);
        }

        /* CONTENT WRAPPER - EXACTLY LIKE DASHBOARD */
        .content-wrapper {
            flex: 1;
            margin-left: var(--sidebar-width, 280px);
            padding: 25px;
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
            width: calc(100% - var(--sidebar-width, 280px));
        }

        /* When sidebar has mini class, adjust content wrapper */
        .sidebar.mini ~ .content-wrapper {
            margin-left: var(--sidebar-mini-width, 80px);
            width: calc(100% - var(--sidebar-mini-width, 80px));
        }

        /* Page Header - Enhanced */
        .page-header {
            background: var(--primary-gradient);
            color: white;
            padding: 30px 35px;
            border-radius: 25px;
            margin-bottom: 30px;
            box-shadow: var(--shadow-lg);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

        .page-header::after {
            content: '';
            position: absolute;
            bottom: -80px;
            left: -80px;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

        .page-header h1 {
            font-size: 28px;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 15px;
            position: relative;
            z-index: 1;
        }

        .page-header p {
            margin: 5px 0 0;
            opacity: 0.9;
            font-size: 14px;
        }

        .user-info {
            background: rgba(255,255,255,0.2);
            padding: 10px 20px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: white;
            backdrop-filter: blur(10px);
            position: relative;
            z-index: 1;
        }

        /* Cards */
        .card {
            background: var(--bg-card);
            border-radius: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            overflow: hidden;
            margin-bottom: 25px;
            transition: all 0.3s;
        }

        .card:hover {
            box-shadow: var(--shadow-lg);
        }

        .card-header {
            padding: 20px 25px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-card);
        }

        .card-header h2 {
            font-size: 18px;
            color: var(--dark);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-header h2 i {
            color: var(--primary);
        }

        .card-body {
            padding: 25px;
        }

        /* Search Box */
        .search-box {
            position: relative;
            margin-bottom: 20px;
        }

        .search-box input {
            width: 100%;
            padding: 14px 20px 14px 50px;
            border: 1px solid var(--border);
            border-radius: 16px;
            font-size: 14px;
            transition: all 0.3s;
            background: var(--bg-white);
            color: var(--text);
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .search-box i {
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        /* Contacts List */
        .contacts-list, .group-contacts-list {
            max-height: 450px;
            overflow-y: auto;
            border: 1px solid var(--border);
            border-radius: 16px;
            background: var(--bg-card);
        }

        .contact-item {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            transition: all 0.3s;
            cursor: pointer;
            background: var(--bg-card);
        }

        .contact-item:hover {
            background: var(--bg-offwhite);
            transform: translateX(5px);
        }

        .contact-item:last-child {
            border-bottom: none;
        }

        .contact-checkbox {
            margin-right: 15px;
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: var(--primary);
        }

        .contact-avatar {
            width: 45px;
            height: 45px;
            border-radius: 16px;
            background: var(--primary-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 18px;
            margin-right: 15px;
            flex-shrink: 0;
        }

        .contact-info {
            flex: 1;
            min-width: 0;
        }

        .contact-name {
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

        .contact-number {
            font-size: 14px;
            color: var(--text-light);
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .whatsapp-badge {
            background: #25D366;
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .no-whatsapp {
            opacity: 0.6;
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .badge-active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .badge-inactive {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
        }

        .badge-connected {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .badge-disconnected {
            background: rgba(100, 116, 139, 0.1);
            color: var(--text-muted);
        }

        /* Selected Contacts */
        .selected-contacts {
            background: var(--bg-offwhite);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .selected-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .selected-header h3 {
            font-size: 16px;
            color: var(--dark);
            margin: 0;
        }

        .selected-count {
            background: var(--primary);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .selected-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 15px;
            max-height: 150px;
            overflow-y: auto;
        }

        .selected-tag {
            background: var(--bg-card);
            border: 1px solid var(--primary);
            border-radius: 30px;
            padding: 6px 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: var(--primary);
        }

        .selected-tag i.fa-times {
            cursor: pointer;
            transition: all 0.2s;
        }

        .selected-tag i.fa-times:hover {
            color: var(--danger);
        }

        /* Form Elements */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--dark);
            font-size: 14px;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 14px 20px;
            border: 1px solid var(--border);
            border-radius: 16px;
            font-size: 14px;
            transition: all 0.3s;
            background: var(--bg-white);
            color: var(--text);
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 100px;
        }

        /* Buttons - EXACTLY LIKE DASHBOARD */
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            justify-content: center;
        }

        .btn:hover {
            transform: translateY(-2px);
        }

        .btn-primary {
            background: var(--primary-gradient);
            color: white;
            width: 100%;
        }

        .btn-primary:hover {
            box-shadow: var(--shadow-lg);
        }

        .btn-secondary {
            background: var(--bg-offwhite);
            color: var(--text);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--border);
        }

        .btn-sm {
            padding: 8px 16px;
            font-size: 13px;
        }

        .btn-danger {
            background: var(--danger);
            color: white;
        }

        .btn-danger:hover {
            background: #dc2626;
            box-shadow: 0 5px 15px rgba(239, 68, 68, 0.3);
        }

        .btn-outline-secondary {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text);
        }

        .btn-outline-secondary:hover {
            background: var(--bg-offwhite);
            border-color: var(--primary);
        }

        /* Groups List */
        .groups-list {
            max-height: 450px;
            overflow-y: auto;
        }

        .group-item {
            padding: 20px;
            border: 1px solid var(--border);
            border-radius: 16px;
            margin-bottom: 15px;
            transition: all 0.3s;
            cursor: pointer;
            background: var(--bg-card);
        }

        .group-item:hover {
            border-color: var(--primary);
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        .group-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .group-name {
            font-weight: 600;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 16px;
        }

        .group-name i {
            color: var(--primary);
        }

        .group-count {
            background: var(--bg-offwhite);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            color: var(--text);
        }

        .group-description {
            font-size: 14px;
            color: var(--text-light);
            margin-bottom: 12px;
            line-height: 1.5;
        }

        .group-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            color: var(--text-muted);
        }

        .group-actions {
            display: flex;
            gap: 8px;
        }

        .group-actions button {
            padding: 6px 12px;
            border: none;
            border-radius: 8px;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .group-actions .view-btn {
            background: var(--primary);
            color: white;
        }

        .group-actions .view-btn:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }

        .group-actions .delete-btn {
            background: var(--danger);
            color: white;
        }

        .group-actions .delete-btn:hover {
            background: #dc2626;
            transform: translateY(-2px);
        }

        /* TOAST - EXACTLY LIKE DASHBOARD */
        #toast {
            position: fixed;
            top: 90px;
            right: 29px;
            width: 320px;
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 9999;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-content {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            font-size: 20px;
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 5px 0 0;
            font-size: 13px;
            opacity: 0.9;
        }

        .toast-progress {
            height: 3px;
            background: rgba(255,255,255,0.6);
            margin-top: 10px;
            width: 100%;
            animation: progress 3s linear;
        }

        @keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* Loading Spinner */
        .loading-spinner {
            text-align: center;
            padding: 40px;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 3px solid var(--border);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 10px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 50px 20px;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 60px;
            margin-bottom: 15px;
            color: var(--border);
        }

        .empty-state h4 {
            font-size: 18px;
            margin-bottom: 8px;
            color: var(--dark);
        }

        .empty-state p {
            font-size: 14px;
            max-width: 300px;
            margin: 0 auto;
        }

        /* MODALS */
        .modal {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            animation: fadeIn 0.3s ease;
        }

        .modal-content {
            background-color: var(--bg-card);
            margin: 50px auto;
            width: 90%;
            max-width: 700px;
            border-radius: 20px;
            box-shadow: var(--shadow-lg);
            animation: slideDown 0.3s ease;
            max-height: 80vh;
            overflow-y: auto;
            border: 1px solid var(--border);
        }

        .delete-modal-content {
            background-color: var(--bg-card);
            margin: 200px auto;
            width: 90%;
            max-width: 400px;
            border-radius: 20px;
            box-shadow: var(--shadow-lg);
            animation: slideDown 0.3s ease;
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .modal-header {
            padding: 20px 25px;
            background: var(--primary-gradient);
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
        }

        .modal-header h2 {
            font-size: 20px;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-header .close {
            color: white;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.3s;
        }

        .modal-header .close:hover {
            opacity: 0.8;
        }

        .modal-body {
            padding: 25px;
        }

        .delete-modal-header {
            padding: 20px;
            background: var(--danger);
            color: white;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .delete-modal-body {
            padding: 25px;
            text-align: center;
        }

        .delete-modal-body strong {
            color: var(--danger);
            font-size: 18px;
            display: block;
            margin: 10px 0;
        }

        .delete-modal-footer {
            padding: 20px;
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            border-top: 1px solid var(--border);
        }

        .group-info {
            background: var(--bg-offwhite);
            padding: 20px;
            border-radius: 16px;
            margin-bottom: 20px;
            border: 1px solid var(--border);
        }

        .group-info p {
            margin: 8px 0;
            color: var(--text);
        }

        .group-info strong {
            color: var(--dark);
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes slideDown {
            from {
                transform: translateY(-50px);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        /* Grid Layout */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }

        /* RESPONSIVE - EXACTLY LIKE DASHBOARD */
        @media (max-width: 1200px) {
            .content-grid {
                gap: 20px;
            }
        }

        @media (max-width: 992px) {
            .content-grid {
                grid-template-columns: 1fr;
            }
            
            .page-header {
                flex-direction: column;
                text-align: center;
                gap: 15px;
                padding: 25px;
            }
            
            .page-header h1 {
                font-size: 24px;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
                transition: transform 0.3s ease;
            }
            
            .sidebar.open {
                transform: translateX(0);
            }
            
            .sidebar.mini {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
            }
            
            .sidebar.mini.open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
                padding: 15px;
            }
            
            .sidebar.mini ~ .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
            }
            
            .page-header h1 {
                font-size: 22px;
            }
            
            .user-info {
                width: 100%;
                justify-content: center;
            }
            
            .card-header {
                flex-direction: column;
                gap: 10px;
            }
            
            .group-meta {
                flex-direction: column;
                gap: 10px;
                align-items: flex-start;
            }
            
            .group-actions {
                width: 100%;
            }
            
            .group-actions button {
                flex: 1;
            }
            
            .modal-content {
                width: 95%;
                margin: 20px auto;
            }
            
            .delete-modal-content {
                margin: 100px auto;
            }
        }

        @media (max-width: 576px) {
            .content-wrapper {
                padding: 10px;
            }
            
            .page-header {
                padding: 20px;
            }
            
            .page-header h1 {
                font-size: 20px;
            }
            
            .card-body {
                padding: 20px;
            }
            
            .contact-item {
                padding: 12px 15px;
            }
            
            .contact-avatar {
                width: 40px;
                height: 40px;
                font-size: 16px;
            }
            
            .btn {
                padding: 10px 20px;
            }
            
            .modal-header h2 {
                font-size: 18px;
            }
            
            .delete-modal-content {
                margin: 50px auto;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <%- include('../../partials/ram/sidebaar') %>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <!-- Toast Container -->
            <div id="toast"></div>

            <!-- Page Header -->
            <div class="page-header">
                <div>
                    <h1>
                        <i class="fas fa-users"></i>
                        Contact Groups
                    </h1>
                    <p>Select WhatsApp contacts and create groups for campaigns</p>
                </div>
                <div class="user-info">
                    <i class="fas fa-user-circle"></i>
                    <span><%= user?.firstName || 'Admin' %> <%= user?.lastName || '' %> (<%= user?.role || 'SuperAdmin' %>)</span>
                </div>
            </div>

            <!-- Main Content Grid -->
            <div class="content-grid">
                <!-- Left Column - Contact Selection -->
                <div class="card">
                    <div class="card-header">
                        <h2><i class="fab fa-whatsapp" style="color: #25D366;"></i> WhatsApp Contacts</h2>
                        <button class="btn btn-sm btn-secondary" onclick="refreshContacts()">
                            <i class="fas fa-sync-alt"></i>
                        </button>
                    </div>
                    <div class="card-body">
                        <!-- Search -->
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <input type="text" id="searchInput" placeholder="Search WhatsApp contacts by name or number..." onkeyup="searchContacts()">
                        </div>

                        <!-- Contacts List -->
                        <div class="contacts-list" id="contactsList">
                            <div class="loading-spinner">
                                <div class="spinner"></div>
                                <p>Loading contacts...</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column - Group Creation -->
                <div>
                    <!-- Selected Contacts Card -->
                    <div class="card">
                        <div class="card-header">
                            <h2><i class="fas fa-check-circle"></i> Selected Contacts</h2>
                        </div>
                        <div class="card-body">
                            <div class="selected-contacts" id="selectedContactsSection">
                                <div class="selected-header">
                                    <h3>Selected Contacts</h3>
                                    <span class="selected-count" id="selectedCount">0</span>
                                </div>
                                <div class="selected-list" id="selectedList">
                                    <p style="color: var(--text-muted); text-align: center; width: 100%;">No contacts selected</p>
                                </div>
                                <button class="btn btn-sm btn-outline-secondary" onclick="clearSelection()" style="width: 100%;">
                                    <i class="fas fa-times"></i> Clear All
                                </button>
                            </div>

                            <!-- Create Group Form -->
                            <form id="groupForm" style="margin-top: 20px;">
                                <div class="form-group">
                                    <label for="groupName">Group Name *</label>
                                    <input type="text" id="groupName" placeholder="e.g., VIP Customers, WhatsApp Group" required>
                                </div>
                                <div class="form-group">
                                    <label for="groupDescription">Description (Optional)</label>
                                    <textarea id="groupDescription" placeholder="Enter group description..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary" id="createGroupBtn">
                                    <i class="fas fa-users"></i> Create WhatsApp Group
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Existing Groups Card -->
                    <div class="card">
                        <div class="card-header">
                            <h2><i class="fas fa-layer-group"></i> Your Groups</h2>
                            <button class="btn btn-sm btn-secondary" onclick="loadGroups()">
                                <i class="fas fa-sync-alt"></i>
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="groups-list" id="groupsList">
                                <div class="loading-spinner">
                                    <div class="spinner"></div>
                                    <p>Loading groups...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Group Details Modal -->
    <div id="groupModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2><i class="fas fa-users"></i> <span id="modalGroupName"></span></h2>
                <span class="close" onclick="closeModal()">&times;</span>
            </div>
            <div class="modal-body">
                <div class="group-info" id="groupInfo">
                    <p><strong>Description:</strong> <span id="modalGroupDescription"></span></p>
                    <p><strong>Total Contacts:</strong> <span id="modalTotalContacts"></span></p>
                    <p><strong>Created:</strong> <span id="modalCreatedAt"></span></p>
                </div>
                <h3 style="margin-bottom: 15px; color: var(--dark);">WhatsApp Contacts in this Group</h3>
                <div class="group-contacts-list" id="groupContactsList">
                    <div class="loading-spinner">
                        <div class="spinner"></div>
                        <p>Loading contacts...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="modal">
        <div class="delete-modal-content">
            <div class="delete-modal-header">
                <i class="fas fa-exclamation-triangle"></i>
                <h3>Delete Group</h3>
            </div>
            <div class="delete-modal-body">
                <p>Are you sure you want to delete this group?</p>
                <strong id="deleteGroupName"></strong>
                <p style="font-size: 14px; color: var(--text-muted); margin-top: 15px;">This action cannot be undone.</p>
            </div>
            <div class="delete-modal-footer">
                <button class="btn btn-outline-secondary" onclick="closeDeleteModal()">Cancel</button>
                <button class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR STATE SYNC - EXACTLY LIKE DASHBOARD
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize page
            loadContacts();
            loadGroups();
            
            // Show welcome toast
            setTimeout(() => {
                showToast('WhatsApp Groups', 'Select WhatsApp contacts to create groups', 'info');
            }, 500);

            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);
        });

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE DASHBOARD
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // State
        let allContacts = [];
        let selectedContacts = new Map();
        let searchTimeout = null;
        let currentGroupId = null;
        let groupToDelete = null;

        // Load contacts - WhatsApp numbers only
        async function loadContacts() {
            try {
                const search = document.getElementById('searchInput').value;
                const url = search ? `/api/contacts/all?search=${encodeURIComponent(search)}` : '/api/contacts/all';
                
                const response = await fetch(url);
                const data = await response.json();
                
                if (data.success) {
                    allContacts = data.data;
                    renderContacts();
                } else {
                    showToast('Error', 'Failed to load contacts', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error', 'Failed to load contacts', 'error');
                document.getElementById('contactsList').innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-exclamation-circle"></i>
                        <h4>Failed to load contacts</h4>
                        <p>Please try again</p>
                    </div>
                `;
            }
        }

        // Render contacts - Always show WhatsApp numbers
        function renderContacts() {
            const container = document.getElementById('contactsList');

            if (allContacts.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-address-book"></i>
                        <h4>No Contacts Found</h4>
                        <p>Add contacts with phone numbers first</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = allContacts.map(contact => {
                const isSelected = selectedContacts.has(contact._id);
                const hasWhatsApp = contact.whatsappNumber ? true : false;
                const displayNumber = hasWhatsApp ? contact.whatsappNumber : contact.phoneNumber;
                const itemClass = !hasWhatsApp ? 'no-whatsapp' : '';
                const connectedClass = contact.isConnected ? 'badge-connected' : 'badge-disconnected';
                
                return `
                <div class="contact-item ${itemClass}">
                    <input type="checkbox" 
                           class="contact-checkbox" 
                           value="${contact._id}"
                           ${isSelected ? 'checked' : ''}
                           ${!hasWhatsApp ? 'disabled' : ''}
                           onchange="toggleContact('${contact._id}', this.checked)">
                    <div class="contact-avatar">${contact.name ? contact.name.charAt(0).toUpperCase() : '?'}</div>
                    <div class="contact-info">
                        <div class="contact-name">
                            ${contact.name || 'Unnamed'}
                            ${hasWhatsApp ? '<span class="whatsapp-badge"><i class="fab fa-whatsapp"></i> WhatsApp</span>' : ''}
                        </div>
                        ${hasWhatsApp ? `
                            <div class="contact-number">
                                <i class="fab fa-whatsapp" style="color: #25D366;"></i> ${displayNumber}
                                <span class="status-badge ${connectedClass}">
                                    <i class="fas fa-circle"></i> ${contact.isConnected ? 'Connected' : 'Disconnected'}
                                </span>
                            </div>
                        ` : `
                            <div class="contact-number">
                                <i class="fas fa-phone"></i> ${contact.phoneNumber}
                                <span class="status-badge badge-inactive">
                                    <i class="fas fa-exclamation-triangle"></i> No WhatsApp
                                </span>
                            </div>
                        `}
                    </div>
                </div>
            `}).join('');
        }

        // Search contacts
        function searchContacts() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                loadContacts();
            }, 500);
        }

        // Refresh contacts
        function refreshContacts() {
            document.getElementById('searchInput').value = '';
            loadContacts();
            showToast('Refreshing', 'Loading latest contacts...', 'info');
        }

        // Toggle contact selection
        function toggleContact(id, checked) {
            const contact = allContacts.find(c => c._id === id);
            if (!contact) return;

            // Don't allow selection if no WhatsApp number
            if (!contact.whatsappNumber && !contact.phoneNumber) {
                showToast('Cannot Select', 'This contact has no phone number', 'warning');
                return;
            }

            if (checked) {
                selectedContacts.set(id, contact);
                showToast('Selected', `${contact.name || contact.phoneNumber} added`, 'success');
            } else {
                selectedContacts.delete(id);
            }

            updateSelectedUI();
        }

        // Update selected contacts UI
        function updateSelectedUI() {
            const selectedList = document.getElementById('selectedList');
            const selectedCount = document.getElementById('selectedCount');
            
            const contacts = Array.from(selectedContacts.values());
            selectedCount.textContent = contacts.length;

            if (contacts.length === 0) {
                selectedList.innerHTML = '<p style="color: var(--text-muted); text-align: center; width: 100%;">No contacts selected</p>';
                return;
            }

            selectedList.innerHTML = contacts.map(contact => {
                const displayNumber = contact.whatsappNumber || contact.phoneNumber;
                return `
                <div class="selected-tag">
                    <i class="fab fa-whatsapp"></i>
                    <span>${contact.name || displayNumber}</span>
                    <i class="fas fa-times" onclick="removeContact('${contact._id}')"></i>
                </div>
            `}).join('');
        }

        // Remove individual contact
        function removeContact(id) {
            selectedContacts.delete(id);
            
            // Uncheck checkbox
            const checkbox = document.querySelector(`.contact-checkbox[value="${id}"]`);
            if (checkbox) checkbox.checked = false;
            
            updateSelectedUI();
        }

        // Clear all selection
        function clearSelection() {
            if (selectedContacts.size === 0) return;
            
            selectedContacts.clear();
            
            // Uncheck all checkboxes
            document.querySelectorAll('.contact-checkbox').forEach(cb => {
                cb.checked = false;
            });
            
            updateSelectedUI();
            showToast('Cleared', 'All contacts deselected', 'info');
        }

        // Create group
        document.getElementById('groupForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const groupName = document.getElementById('groupName').value.trim();
            const description = document.getElementById('groupDescription').value.trim();
            const contactIds = Array.from(selectedContacts.keys());

            if (!groupName) {
                showToast('Error', 'Please enter a group name', 'error');
                return;
            }

            if (contactIds.length === 0) {
                showToast('Error', 'Please select at least one WhatsApp contact', 'error');
                return;
            }

            const btn = document.getElementById('createGroupBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating...';

            try {
                const response = await fetch('/api/groups/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        groupName,
                        description,
                        contactIds
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showToast('Success!', 'WhatsApp group created successfully!', 'success');
                    
                    // Clear form
                    document.getElementById('groupName').value = '';
                    document.getElementById('groupDescription').value = '';
                    clearSelection();
                    
                    // Reload groups
                    loadGroups();
                } else {
                    showToast('Error', data.message || 'Failed to create group', 'error');
                }
            } catch (error) {
                showToast('Error', 'Failed to create group', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });

        // Load groups
        async function loadGroups() {
            try {
                const response = await fetch('/api/groups');
                const data = await response.json();
                
                const container = document.getElementById('groupsList');

                if (!data.success || data.count === 0) {
                    container.innerHTML = `
                        <div class="empty-state">
                            <i class="fas fa-layer-group"></i>
                            <h4>No Groups Yet</h4>
                            <p>Create your first WhatsApp group by selecting contacts</p>
                        </div>
                    `;
                    return;
                }

                container.innerHTML = data.data.map(group => `
                    <div class="group-item">
                        <div class="group-header">
                            <div class="group-name">
                                <i class="fas fa-users"></i>
                                ${group.name}
                            </div>
                            <span class="group-count">${group.totalContacts} contacts</span>
                        </div>
                        <div class="group-description">
                            ${group.description || 'No description'}
                        </div>
                        <div class="group-meta">
                            <span><i class="far fa-clock"></i> ${new Date(group.createdAt).toLocaleDateString()}</span>
                            <div class="group-actions">
                                <button class="view-btn" onclick="viewGroupDetails('${group._id}')">
                                    <i class="fas fa-eye"></i> View
                                </button>
                                <button class="delete-btn" onclick="showDeleteModal('${group._id}', '${group.name}')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                `).join('');

            } catch (error) {
                console.error('Error loading groups:', error);
                document.getElementById('groupsList').innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-exclamation-circle"></i>
                        <h4>Failed to load groups</h4>
                        <p>Please try again</p>
                    </div>
                `;
            }
        }

        // View group details
        async function viewGroupDetails(groupId) {
            try {
                currentGroupId = groupId;
                
                // Show modal with loading
                document.getElementById('groupModal').style.display = 'block';
                document.getElementById('modalGroupName').textContent = 'Loading...';
                document.getElementById('groupContactsList').innerHTML = `
                    <div class="loading-spinner">
                        <div class="spinner"></div>
                        <p>Loading contacts...</p>
                    </div>
                `;

                // Fetch group details
                const response = await fetch(`/api/groups/${groupId}`);
                const data = await response.json();

                if (data.success) {
                    const group = data.data;
                    
                    // Update modal header
                    document.getElementById('modalGroupName').textContent = group.name;
                    
                    // Update group info
                    document.getElementById('modalGroupDescription').textContent = group.description || 'No description';
                    document.getElementById('modalTotalContacts').textContent = group.totalContacts;
                    document.getElementById('modalCreatedAt').textContent = new Date(group.createdAt).toLocaleString();
                    
                    // Render contacts
                    renderGroupContacts(group.contacts);
                } else {
                    showToast('Error', 'Failed to load group details', 'error');
                    closeModal();
                }
            } catch (error) {
                console.error('Error loading group details:', error);
                showToast('Error', 'Failed to load group details', 'error');
                closeModal();
            }
        }

        // Render group contacts
        function renderGroupContacts(contacts) {
            const container = document.getElementById('groupContactsList');

            if (!contacts || contacts.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-address-book"></i>
                        <h4>No Contacts in this Group</h4>
                        <p>This group has no contacts</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = contacts.map(contact => {
                const hasWhatsApp = contact.whatsappNumber ? true : false;
                const displayNumber = hasWhatsApp ? contact.whatsappNumber : contact.phoneNumber;
                const connectedClass = contact.isConnected ? 'badge-connected' : 'badge-disconnected';
                
                return `
                <div class="contact-item">
                    <div class="contact-avatar">${contact.name ? contact.name.charAt(0).toUpperCase() : '?'}</div>
                    <div class="contact-info">
                        <div class="contact-name">
                            ${contact.name || 'Unnamed'}
                            ${hasWhatsApp ? '<span class="whatsapp-badge"><i class="fab fa-whatsapp"></i> WhatsApp</span>' : ''}
                        </div>
                        <div class="contact-number">
                            <i class="fab fa-whatsapp" style="color: #25D366;"></i> ${displayNumber}
                            <span class="status-badge ${connectedClass}">
                                <i class="fas fa-circle"></i> ${contact.isConnected ? 'Connected' : 'Disconnected'}
                            </span>
                        </div>
                        <div class="contact-number">
                            <i class="fas fa-phone"></i> Phone: ${contact.phoneNumber}
                        </div>
                    </div>
                </div>
            `}).join('');
        }

        // Close modal
        function closeModal() {
            document.getElementById('groupModal').style.display = 'none';
            currentGroupId = null;
        }

        // Show delete confirmation modal
        function showDeleteModal(groupId, groupName) {
            groupToDelete = groupId;
            document.getElementById('deleteGroupName').textContent = groupName;
            document.getElementById('deleteModal').style.display = 'block';
        }

        // Close delete modal
        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
            groupToDelete = null;
        }

        // Delete group
        document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
            if (!groupToDelete) return;

            const btn = this;
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...';

            try {
                const response = await fetch(`/api/groups/${groupToDelete}`, {
                    method: 'DELETE'
                });

                const data = await response.json();

                if (data.success) {
                    showToast('Deleted!', 'Group deleted successfully!', 'success');
                    closeDeleteModal();
                    loadGroups();
                } else {
                    showToast('Error', data.message || 'Failed to delete group', 'error');
                }
            } catch (error) {
                console.error('Error deleting group:', error);
                showToast('Error', 'Failed to delete group', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('groupModal');
            const deleteModal = document.getElementById('deleteModal');
            
            if (event.target === modal) {
                closeModal();
            }
            if (event.target === deleteModal) {
                closeDeleteModal();
            }
        }
    </script>
</body>
</html>