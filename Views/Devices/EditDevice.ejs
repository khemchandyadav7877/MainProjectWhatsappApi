<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Contact - SSPAR Cloud</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* ===== THEME VARIABLES ===== */
        :root {
            --primary: #f59e0b;
            --primary-dark: #d97706;
            --primary-light: #fbbf24;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f3f4f6;
            --bg-white: #ffffff;
            --bg-offwhite: #f8fafc;
            --bg-card: #ffffff;
            --text: #1f2937;
            --text-light: #4b5563;
            --text-muted: #6b7280;
            --dark: #111827;
            --border: #e5e7eb;
            --shadow: 0 2px 10px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #111827;
            --bg-white: #1f2937;
            --bg-offwhite: #374151;
            --bg-card: #1f2937;
            --text: #f9fafb;
            --text-light: #e5e7eb;
            --text-muted: #9ca3af;
            --dark: #f9fafb;
            --border: #374151;
            --shadow: 0 2px 10px rgba(0,0,0,0.3);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.5);
        }

        /* RESET */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: system-ui;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar-wrapper,
        body.round-border .main-content-card,
        body.round-border .info-card,
        body.round-border .status-option,
        body.round-border .btn,
        body.round-border .form-control,
        body.round-border .form-select,
        body.round-border .country-code,
        body.round-border .delete-btn,
        body.round-border .toast-notification {
            border-radius: 16px !important;
        }

        body.round-border .icon,
        body.round-border .badge-success,
        body.round-border .badge-secondary {
            border-radius: 50% !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar-wrapper,
        body.no-radius .main-content-card,
        body.no-radius .info-card,
        body.no-radius .status-option,
        body.no-radius .btn,
        body.no-radius .form-control,
        body.no-radius .form-select,
        body.no-radius .country-code,
        body.no-radius .delete-btn,
        body.no-radius .toast-notification,
        body.no-radius .icon,
        body.no-radius .badge-success,
        body.no-radius .badge-secondary {
            border-radius: 0 !important;
        }

        /* HEADER FIXED */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        /* MAIN LAYOUT */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
        }

        /* SIDEBAR WRAPPER */
        .sidebar-wrapper {
            width: 280px;
            flex-shrink: 0;
            position: fixed;
            left: 0;
            top: 70px;
            bottom: 0;
            z-index: 1020;
            transition: width 0.3s ease;
            background: var(--bg-white);
            border-right: 1px solid var(--border);
        }

        .sidebar-wrapper.collapsed {
            width: 80px;
        }

        /* CONTENT WRAPPER */
        .content-wrapper {
            flex: 1;
            margin-left: 280px;
            padding: 20px;
            transition: margin-left 0.3s ease;
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
        }

        .sidebar-wrapper.collapsed + .content-wrapper {
            margin-left: 80px;
        }

        /* MAIN CONTENT CARD */
        .main-content-card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 24px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            min-height: 500px;
        }

        /* DEVICE HEADER */
        .device-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .device-header .icon {
            width: 60px;
            height: 60px;
            background: var(--primary);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            margin: 0 auto 10px;
        }

        .device-header h5 {
            margin: 0;
            font-weight: 700;
            color: var(--dark);
        }

        .device-sub {
            text-align: center;
            color: var(--text-muted);
            margin-bottom: 10px;
        }

        .device-line {
            height: 3px;
            background: var(--primary);
            width: 100%;
            margin-bottom: 25px;
        }

        .form-label {
            font-weight: 600;
            color: var(--text-light);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .form-label .required {
            color: var(--danger);
            font-size: 12px;
        }

        .form-control, .form-select {
            border-radius: 25px;
            padding: 12px 18px;
            border: 1px solid var(--border);
            background: var(--bg-white);
            color: var(--text);
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 0.2rem rgba(245, 158, 11, 0.25);
            outline: none;
            background: var(--bg-white);
            color: var(--text);
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.7;
        }

        /* PHONE INPUT */
        .phone-wrapper {
            position: relative;
        }

        .country-code {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: var(--bg-offwhite);
            padding: 6px 12px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 14px;
            color: var(--text);
            border: 1px solid var(--border);
            z-index: 2;
        }

        .phone-input {
            padding-left: 80px !important;
        }

        /* VALIDATION ICON */
        .validation-icon {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 3;
        }

        .validation-icon.valid {
            color: var(--success);
        }

        .validation-icon.invalid {
            color: var(--danger);
        }

        /* STATUS RADIO */
        .status-option {
            background: var(--bg-offwhite);
            border-radius: 12px;
            padding: 12px;
            border: 2px solid transparent;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .status-option:hover {
            border-color: var(--primary);
            background: rgba(245, 158, 11, 0.1);
        }

        .status-option input[type="radio"] {
            margin-right: 8px;
            accent-color: var(--primary);
        }

        .badge-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 600;
        }

        .badge-secondary {
            background: var(--bg-offwhite);
            color: var(--text-muted);
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 600;
            border: 1px solid var(--border);
        }

        /* BUTTONS */
        .btn {
            border-radius: 25px;
            padding: 10px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background: var(--primary);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(245, 158, 11, 0.3);
        }

        .btn-outline-secondary {
            border: 2px solid var(--text-muted);
            color: var(--text-muted);
            background: transparent;
        }

        .btn-outline-secondary:hover {
            background: var(--text-muted);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(108, 117, 125, 0.3);
        }

        .btn-outline-info {
            border: 2px solid var(--info);
            color: var(--info);
            background: transparent;
        }

        .btn-outline-info:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }

        .btn-outline-danger {
            border: 2px solid var(--danger);
            color: var(--danger);
            background: transparent;
        }

        .btn-outline-danger:hover {
            background: var(--danger);
            color: white;
            transform: translateY(-2px);
        }

        .action-buttons {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .action-buttons .btn {
            flex: 1;
        }

        /* API STATUS */
        .api-status {
            display: none;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }
        .api-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid var(--success);
        }
        .api-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid var(--danger);
        }

        /* TOOLTIP */
        .tooltip-info {
            color: var(--text-muted);
            font-size: 12px;
            margin-top: 4px;
        }

        /* INFO CARD */
        .info-card {
            background: rgba(245, 158, 11, 0.1);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 25px;
            border-left: 4px solid var(--primary);
            color: var(--text);
        }

        .info-card i {
            color: var(--primary);
        }

        /* LOADING OVERLAY */
        .loading-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            z-index: 9999;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            color: white;
        }

        .loading-overlay h5 {
            color: white;
            margin-top: 15px;
        }

        .loading-overlay p {
            color: rgba(255,255,255,0.8);
        }

        /* TOAST STYLES */
        #toast {
            position: fixed;
            top: 24px;
            right: 24px;
            width: 320px;
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 9999;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-row {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            background: rgba(0,0,0,.25);
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 4px 0 0;
            font-size: 13px;
            opacity: .9;
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-progress {
            height: 3px;
            border-radius: 4px;
            margin-top: 10px;
            background: rgba(255,255,255,.6);
            animation: toast-load 3s linear forwards;
        }

        @keyframes toast-load {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* DELETE BUTTON */
        .delete-section {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px dashed var(--border);
            text-align: center;
        }

        .delete-btn {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid var(--danger);
            padding: 8px 20px;
            border-radius: 25px;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .delete-btn:hover {
            background: var(--danger);
            color: white;
            border-color: var(--danger);
            transform: translateY(-2px);
        }

        /* MOBILE */
        @media (max-width: 768px) {
            .sidebar-wrapper {
                transform: translateX(-100%);
                width: 280px !important;
            }
            
            .sidebar-wrapper.mobile-open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                padding: 15px;
            }
            
            .main-content-card {
                padding: 20px;
            }
            
            .action-buttons {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <div class="sidebar-wrapper" id="sidebarWrapper">
            <%- include('../../partials/ram/sidebaar') %>
        </div>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <!-- Toast Container -->
            <div id="toast"></div>

            <!-- MAIN CONTENT CARD -->
            <div class="main-content-card">
                <!-- DEVICE HEADER -->
                <div class="device-header">
                    <div class="icon">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </div>
                    <h5>Edit Contact</h5>
                </div>

                <div class="device-sub">Update contact information</div>
                <div class="device-line"></div>

                <!-- INFO CARD -->
                <div class="info-card">
                    <div class="d-flex align-items-center">
                        <i class="fa fa-info-circle fs-5 me-3"></i>
                        <div>
                            <strong>Contact ID:</strong> <%= device._id %> <br>
                            <small class="text-muted">Created: <%= new Date(device.createdAt).toLocaleString() %></small>
                        </div>
                    </div>
                </div>

                <!-- API STATUS MESSAGE -->
                <div id="apiStatus" class="api-status"></div>

                <!-- FORM - Edit Contact -->
                <form method="POST" action="/devices/edit/<%= device._id %>" id="deviceForm">
                    <div class="row g-4">
                        <!-- Contact Name (Required) -->
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fa fa-tag fa-xs"></i>
                                Contact Name <span class="required">*</span>
                            </label>
                            <input type="text"
                                   name="name"
                                   id="deviceName"
                                   class="form-control"
                                   placeholder="e.g., John Doe, Office Phone"
                                   value="<%= device.name %>"
                                   required
                                   oninput="validateName()">
                            <div class="validation-icon" id="nameValidation"></div>
                            <div class="tooltip-info">Give a descriptive name for easy identification</div>
                        </div>

                        <!-- Phone Number (Required) -->
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fa fa-phone fa-xs"></i>
                                Phone Number <span class="required">*</span>
                            </label>
                            <div class="phone-wrapper">
                                <span class="country-code">+91</span>
                                <input type="text"
                                       name="phoneNumber"
                                       id="phoneNumber"
                                       class="form-control phone-input"
                                       placeholder="9876543210"
                                       value="<%= device.phoneNumber %>"
                                       required
                                       maxlength="10"
                                       oninput="validatePhone()">
                                <div class="validation-icon" id="phoneValidation"></div>
                            </div>
                            <div class="tooltip-info">Enter 10-digit Indian mobile number without country code</div>
                        </div>

                        <!-- WhatsApp Number (Optional) -->
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fab fa-whatsapp fa-xs text-success"></i>
                                WhatsApp Number
                            </label>
                            <div class="phone-wrapper">
                                <span class="country-code">+91</span>
                                <input type="text"
                                       name="whatsappNumber"
                                       id="whatsappNumber"
                                       class="form-control phone-input"
                                       placeholder="9876543210 (Optional)"
                                       value="<%= device.whatsappNumber || '' %>"
                                       maxlength="10"
                                       oninput="validateWhatsApp()">
                                <div class="validation-icon" id="whatsappValidation"></div>
                            </div>
                            <div class="tooltip-info">If different from phone number (leave blank if same)</div>
                        </div>

                        <!-- Email ID (Optional) -->
                        <div class="col-md-6">
                            <label class="form-label">
                                <i class="fa fa-envelope fa-xs"></i>
                                Email ID
                            </label>
                            <input type="email"
                                   name="email"
                                   id="email"
                                   class="form-control"
                                   placeholder="john@example.com (Optional)"
                                   value="<%= device.email || '' %>"
                                   oninput="validateEmail()">
                            <div class="validation-icon" id="emailValidation"></div>
                            <div class="tooltip-info">Enter a valid email address</div>
                        </div>

                        <!-- Status -->
                        <div class="col-12">
                            <label class="form-label">
                                <i class="fa fa-power-off fa-xs"></i>
                                Status
                            </label>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="status-option">
                                        <input class="form-check-input" type="radio" name="status" id="statusActive" value="active" <%= device.status === 'active' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="statusActive">
                                            <span class="badge-success">Active</span>
                                            <small class="d-block text-muted mt-1">Contact is active</small>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="status-option">
                                        <input class="form-check-input" type="radio" name="status" id="statusInactive" value="inactive" <%= device.status === 'inactive' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="statusInactive">
                                            <span class="badge-secondary">Inactive</span>
                                            <small class="d-block text-muted mt-1">Contact is paused</small>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Notes -->
                        <div class="col-12">
                            <label class="form-label">
                                <i class="fa fa-sticky-note fa-xs"></i>
                                Notes
                            </label>
                            <textarea name="notes"
                                      id="notes"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Optional notes about this contact (company, department, special instructions, etc.)"><%= device.notes || '' %></textarea>
                            <div class="tooltip-info">Add any additional information about this contact</div>
                        </div>
                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="action-buttons">
                        <a href="/devices" class="btn btn-outline-secondary">
                            <i class="fa fa-arrow-left"></i> Back to Contacts
                        </a>
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="fa fa-save"></i> Update Contact
                        </button>
                        <button type="button" class="btn btn-outline-info" onclick="updateViaAPI()">
                            <i class="fa fa-code"></i> Update via API
                        </button>
                    </div>
                </form>

                <!-- DELETE SECTION -->
                <div class="delete-section">
                    <button type="button" class="delete-btn" onclick="deleteContact()">
                        <i class="fa fa-trash-alt me-2"></i> Delete this contact
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- LOADING OVERLAY -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner-border text-warning mb-3" style="width:3rem;height:3rem;" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h5 id="loadingText">Updating Contact...</h5>
        <p class="text-light" id="loadingSubtext">Please wait while we update your contact</p>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR SYNC
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('mainSidebar');
            const sidebarWrapper = document.getElementById('sidebarWrapper');
            
            if (sidebar && sidebarWrapper) {
                if (sidebar.classList.contains('collapsed')) {
                    sidebarWrapper.classList.add('collapsed');
                }
                
                window.toggleCollapse = function() {
                    if (sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        sidebarWrapper.classList.remove('collapsed');
                    } else {
                        sidebar.classList.add('collapsed');
                        sidebarWrapper.classList.add('collapsed');
                    }
                };
                
                window.toggleMobileSidebar = function() {
                    if (sidebar.classList.contains('open')) {
                        sidebar.classList.remove('open');
                        sidebarWrapper.classList.remove('mobile-open');
                    } else {
                        sidebar.classList.add('open');
                        sidebarWrapper.classList.add('mobile-open');
                    }
                };
                
                window.closeMobileSidebar = function() {
                    sidebar.classList.remove('open');
                    sidebarWrapper.classList.remove('mobile-open');
                };
            }

            // Initialize validation
            validateName();
            validatePhone();
            validateWhatsApp();
            validateEmail();
            
            // Show welcome toast
            setTimeout(() => {
                showToast('Edit Contact', 'Update the contact information', 'info');
            }, 500);
        });

        // ======================
        // TOAST FUNCTION
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.className = '';
            toast.innerHTML = `
                <div class="toast-row">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.classList.add(`toast-${type}`, 'show');
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // VALIDATION FUNCTIONS
        // ======================
        function validateName() {
            const nameInput = document.getElementById('deviceName');
            const validationIcon = document.getElementById('nameValidation');
            const name = nameInput.value.trim();
            
            if (name.length < 2) {
                showValidation(validationIcon, 'invalid', 'Name must be at least 2 characters');
                return false;
            }
            
            if (name.length > 50) {
                showValidation(validationIcon, 'invalid', 'Name must be less than 50 characters');
                return false;
            }
            
            showValidation(validationIcon, 'valid', 'Valid name');
            return true;
        }

        function validatePhone() {
            const phoneInput = document.getElementById('phoneNumber');
            const validationIcon = document.getElementById('phoneValidation');
            let phone = phoneInput.value.trim();
            
            phoneInput.value = phone.replace(/\D/g, '');
            phone = phoneInput.value;
            
            if (phone.length !== 10) {
                showValidation(validationIcon, 'invalid', 'Must be 10 digits');
                return false;
            }
            
            if (!/^[6-9]\d{9}$/.test(phone)) {
                showValidation(validationIcon, 'invalid', 'Invalid Indian number');
                return false;
            }
            
            showValidation(validationIcon, 'valid', 'Valid phone number');
            return true;
        }

        function validateWhatsApp() {
            const whatsappInput = document.getElementById('whatsappNumber');
            const validationIcon = document.getElementById('whatsappValidation');
            
            if (!whatsappInput.value) {
                validationIcon.innerHTML = '';
                return true;
            }
            
            let whatsapp = whatsappInput.value.trim();
            whatsappInput.value = whatsapp.replace(/\D/g, '');
            whatsapp = whatsappInput.value;
            
            if (whatsapp.length !== 10) {
                showValidation(validationIcon, 'invalid', 'Must be 10 digits');
                return false;
            }
            
            if (!/^[6-9]\d{9}$/.test(whatsapp)) {
                showValidation(validationIcon, 'invalid', 'Invalid Indian number');
                return false;
            }
            
            showValidation(validationIcon, 'valid', 'Valid WhatsApp number');
            return true;
        }

        function validateEmail() {
            const emailInput = document.getElementById('email');
            const validationIcon = document.getElementById('emailValidation');
            
            if (!emailInput.value) {
                validationIcon.innerHTML = '';
                return true;
            }
            
            const email = emailInput.value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            
            if (!emailRegex.test(email)) {
                showValidation(validationIcon, 'invalid', 'Invalid email format');
                return false;
            }
            
            showValidation(validationIcon, 'valid', 'Valid email');
            return true;
        }

        function showValidation(iconElement, status, message) {
            iconElement.className = 'validation-icon ' + status;
            iconElement.innerHTML = status === 'valid' ? 
                '<i class="fa fa-check-circle"></i>' : 
                '<i class="fa fa-exclamation-circle"></i>';
            iconElement.title = message;
        }

        function validateForm() {
            const isNameValid = validateName();
            const isPhoneValid = validatePhone();
            const isWhatsAppValid = validateWhatsApp();
            const isEmailValid = validateEmail();
            
            if (!isNameValid || !isPhoneValid || !isWhatsAppValid || !isEmailValid) {
                showToast('Error', 'Please fix validation errors', 'error');
                return false;
            }
            
            return true;
        }

        function getFormData() {
            return {
                name: document.getElementById('deviceName').value.trim(),
                phoneNumber: document.getElementById('phoneNumber').value.trim(),
                whatsappNumber: document.getElementById('whatsappNumber').value.trim() || null,
                email: document.getElementById('email').value.trim() || null,
                notes: document.getElementById('notes').value.trim(),
                status: document.querySelector('input[name="status"]:checked').value
            };
        }

        // ======================
        // FORM SUBMISSION
        // ======================
        const form = document.getElementById('deviceForm');
        form.addEventListener('submit', function(e) {
            if (!validateForm()) {
                e.preventDefault();
                return;
            }
            
            showToast('Updating', 'Updating contact information...', 'info');
            showLoading('Updating Contact...', 'Please wait while we update your contact');
        });

        // ======================
        // API FUNCTIONS
        // ======================
        async function updateViaAPI() {
            if (!validateForm()) {
                return;
            }
            
            const formData = getFormData();
            const deviceId = '<%= device._id %>';
            
            showToast('API Request', 'Sending update via API...', 'info');
            showLoading('Updating via API...', 'Sending request to server');
            
            try {
                const response = await fetch('/api/devices/' + deviceId, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });
                
                const data = await response.json();
                
                hideLoading();
                
                if (data.success) {
                    showToast('Success', 'Contact updated successfully via API!', 'success');
                    showApiStatus('success', 'Contact updated successfully! Redirecting...');
                    
                    setTimeout(() => {
                        window.location.href = '/devices';
                    }, 2000);
                } else {
                    showToast('Error', data.message || 'Unknown error', 'error');
                    showApiStatus('error', `<strong>API Error:</strong> ${data.message || 'Unknown error'}`);
                }
            } catch (error) {
                hideLoading();
                showToast('Error', 'Network error: ' + error.message, 'error');
                showApiStatus('error', `<strong>Network Error:</strong> ${error.message}`);
                console.error('API Error:', error);
            }
        }

        // ======================
        // DELETE FUNCTION
        // ======================
        function deleteContact() {
            const deviceId = '<%= device._id %>';
            const deviceName = '<%= device.name %>';
            
            if (confirm(`Are you sure you want to delete contact: ${deviceName}? This action cannot be undone.`)) {
                showToast('Deleting', `Removing contact: ${deviceName}`, 'warning');
                showLoading('Deleting Contact...', 'Please wait');
                
                fetch('/api/devices/' + deviceId, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    
                    if (data.success) {
                        showToast('Deleted', 'Contact deleted successfully!', 'success');
                        
                        setTimeout(() => {
                            window.location.href = '/devices';
                        }, 1500);
                    } else {
                        showToast('Error', data.message || 'Failed to delete', 'error');
                    }
                })
                .catch(error => {
                    hideLoading();
                    showToast('Error', 'Network error: ' + error.message, 'error');
                    console.error('Delete Error:', error);
                });
            }
        }

        // ======================
        // API STATUS DISPLAY
        // ======================
        const apiStatus = document.getElementById('apiStatus');

        function showApiStatus(type, message) {
            apiStatus.className = `api-status api-${type}`;
            apiStatus.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="fa fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
                    <div>${message}</div>
                </div>
            `;
            apiStatus.style.display = 'block';
            
            setTimeout(() => {
                apiStatus.style.display = 'none';
            }, 5000);
        }

        // ======================
        // LOADING OVERLAY
        // ======================
        const loadingOverlay = document.getElementById('loadingOverlay');
        const loadingText = document.getElementById('loadingText');
        const loadingSubtext = document.getElementById('loadingSubtext');

        function showLoading(text, subtext) {
            loadingText.textContent = text;
            loadingSubtext.textContent = subtext;
            loadingOverlay.style.display = 'flex';
        }

        function hideLoading() {
            loadingOverlay.style.display = 'none';
        }

        // ======================
        // AUTO-SAVE DRAFT
        // ======================
        function saveDraft() {
            const draft = getFormData();
            localStorage.setItem('editDeviceDraft', JSON.stringify(draft));
        }

        // Load draft if exists
        function loadDraft() {
            const draft = localStorage.getItem('editDeviceDraft');
            if (draft) {
                try {
                    const data = JSON.parse(draft);
                    if (confirm('You have unsaved changes from a previous session. Would you like to restore them?')) {
                        document.getElementById('deviceName').value = data.name || '';
                        document.getElementById('phoneNumber').value = data.phoneNumber || '';
                        document.getElementById('whatsappNumber').value = data.whatsappNumber || '';
                        document.getElementById('email').value = data.email || '';
                        document.getElementById('notes').value = data.notes || '';
                        
                        if (data.status) {
                            document.querySelector(`input[name="status"][value="${data.status}"]`).checked = true;
                        }
                        
                        validateName();
                        validatePhone();
                        validateWhatsApp();
                        validateEmail();
                    } else {
                        localStorage.removeItem('editDeviceDraft');
                    }
                } catch (e) {
                    console.error('Error loading draft:', e);
                }
            }
        }

        // Clear draft on successful submit
        function clearDraft() {
            localStorage.removeItem('editDeviceDraft');
        }

        // ======================
        // EVENT LISTENERS
        // ======================
        document.getElementById('deviceName').addEventListener('input', function() {
            validateName();
            debounceSaveDraft();
        });
        
        document.getElementById('phoneNumber').addEventListener('input', function() {
            validatePhone();
            debounceSaveDraft();
        });
        
        document.getElementById('whatsappNumber').addEventListener('input', function() {
            validateWhatsApp();
            debounceSaveDraft();
        });
        
        document.getElementById('email').addEventListener('input', function() {
            validateEmail();
            debounceSaveDraft();
        });
        
        document.getElementById('notes').addEventListener('input', debounceSaveDraft);
        
        document.querySelectorAll('input[name="status"]').forEach(radio => {
            radio.addEventListener('change', debounceSaveDraft);
        });

        let draftTimer;
        function debounceSaveDraft() {
            clearTimeout(draftTimer);
            draftTimer = setTimeout(saveDraft, 1000);
        }

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            // Ctrl+Enter to submit via API
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                if (validateForm()) {
                    updateViaAPI();
                }
            }
            
            // Ctrl+S to submit form
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                if (validateForm()) {
                    form.submit();
                }
            }
            
            // Escape to go back
            if (e.key === 'Escape') {
                if (confirm('Are you sure you want to cancel? Unsaved changes will be lost.')) {
                    window.location.href = '/devices';
                }
            }
            
            // F1 for help
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Press Ctrl+Enter for API, Ctrl+S to save', 'info');
            }
        });

        // ======================
        // SAMPLE DATA ON DOUBLE CLICK
        // ======================
        document.getElementById('phoneNumber').addEventListener('dblclick', function() {
            const randomNum = '9' + Math.floor(Math.random() * 1000000000).toString().padStart(9, '0');
            this.value = randomNum;
            validatePhone();
            saveDraft();
            showToast('Sample', 'Generated sample phone number', 'info');
        });

        document.getElementById('whatsappNumber').addEventListener('dblclick', function() {
            const randomNum = '9' + Math.floor(Math.random() * 1000000000).toString().padStart(9, '0');
            this.value = randomNum;
            validateWhatsApp();
            saveDraft();
            showToast('Sample', 'Generated sample WhatsApp number', 'info');
        });

        document.getElementById('email').addEventListener('dblclick', function() {
            const names = ['john', 'jane', 'bob', 'alice', 'mike', 'sarah'];
            const randomName = names[Math.floor(Math.random() * names.length)];
            this.value = randomName + '@example.com';
            validateEmail();
            saveDraft();
            showToast('Sample', 'Generated sample email', 'info');
        });

        document.getElementById('deviceName').addEventListener('dblclick', function() {
            const names = ['John Doe', 'Jane Smith', 'Office Phone', 'Personal Device', 'Sales Team', 'Support Line'];
            const randomName = names[Math.floor(Math.random() * names.length)];
            this.value = randomName;
            validateName();
            saveDraft();
            showToast('Sample', 'Generated sample contact name', 'info');
        });
    </script>
</body>
</html>