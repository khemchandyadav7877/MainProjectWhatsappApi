<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>All Contacts - SSPAR Cloud</title>

<!-- Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Font Awesome -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

<style>
/* ===== THEME VARIABLES - EXACTLY LIKE FIRST TEMPLATE ===== */
:root {
    --primary: #667eea;
    --primary-dark: #5a67d8;
    --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
    --success: #10b981;
    --warning: #f59e0b;
    --danger: #ef4444;
    --info: #3b82f6;
    
    /* Light Mode */
    --bg-body: #f8fafc;
    --bg-white: #ffffff;
    --bg-offwhite: #f1f5f9;
    --bg-card: #ffffff;
    --text: #334155;
    --text-light: #64748b;
    --text-muted: #94a3b8;
    --dark: #0f172a;
    --border: #eef2f6;
    --shadow: 0 8px 25px rgba(0,0,0,0.03);
    --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
    
    /* Layout */
    --header-height: 70px;
    --sidebar-width: 280px;
    --sidebar-mini-width: 80px;
}

/* Dark Mode */
body.dark {
    --bg-body: #0f172a;
    --bg-white: #1e293b;
    --bg-offwhite: #334155;
    --bg-card: #1e293b;
    --text: #e2e8f0;
    --text-light: #cbd5e1;
    --text-muted: #94a3b8;
    --dark: #f8fafc;
    --border: #334155;
    --shadow: 0 8px 25px rgba(0,0,0,0.2);
    --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
}

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    overflow-x: hidden;
    background: var(--bg-body);
    font-family: 'Inter', 'Segoe UI', sans-serif;
    color: var(--text);
    transition: background-color 0.3s, color 0.3s;
}

/* ===== BORDER MODES - EXACTLY LIKE FIRST TEMPLATE ===== */
body.round-border .header-wrapper,
body.round-border .sidebar,
body.round-border .mid-content,
body.round-border .stat-card,
body.round-border .filter-box,
body.round-border .device-table,
body.round-border .device-checkbox,
body.round-border .badge-soft,
body.round-border .whatsapp-badge,
body.round-border .email-badge,
body.round-border .action-btn,
body.round-border .selected-counter,
body.round-border .btn,
body.round-border .form-control,
body.round-border .form-select,
body.round-border .stat-icon {
    border-radius: 20px !important;
}

body.round-border .stat-icon,
body.round-border .connection-dot {
    border-radius: 16px !important;
}

body.round-border .badge-active,
body.round-border .badge-inactive,
body.round-border .badge-connected,
body.round-border .badge-disconnected {
    border-radius: 50px !important;
}

body.no-radius .header-wrapper,
body.no-radius .sidebar,
body.no-radius .mid-content,
body.no-radius .stat-card,
body.no-radius .filter-box,
body.no-radius .device-table,
body.no-radius .device-checkbox,
body.no-radius .badge-soft,
body.no-radius .whatsapp-badge,
body.no-radius .email-badge,
body.no-radius .action-btn,
body.no-radius .selected-counter,
body.no-radius .btn,
body.no-radius .form-control,
body.no-radius .form-select,
body.no-radius .stat-icon,
body.no-radius .connection-dot,
body.no-radius .badge-active,
body.no-radius .badge-inactive,
body.no-radius .badge-connected,
body.no-radius .badge-disconnected {
    border-radius: 0 !important;
}

/* HEADER FIXED */
.header-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1030;
    background: var(--bg-white);
    box-shadow: var(--shadow);
    border-bottom: 1px solid var(--border);
}

/* MAIN LAYOUT - EXACTLY LIKE FIRST TEMPLATE */
.main-wrapper {
    margin-top: 70px;
    display: flex;
    width: 100%;
    min-height: calc(100vh - 70px);
    position: relative;
}

/* SIDEBAR - EXACTLY LIKE FIRST TEMPLATE */
.sidebar {
    width: var(--sidebar-width, 280px);
    background: var(--bg-white);
    border-right: 1px solid var(--border);
    height: calc(100vh - var(--header-height, 70px));
    position: fixed;
    left: 0;
    top: 70px;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1020;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overflow-x: hidden;
}

/* Sidebar Mini Mode */
.sidebar.mini {
    width: var(--sidebar-mini-width, 80px);
}

/* CONTENT WRAPPER - EXACTLY LIKE FIRST TEMPLATE */
.content-wrapper {
    flex: 1;
    margin-left: var(--sidebar-width, 280px);
    padding: 25px;
    transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: var(--bg-body);
    min-height: calc(100vh - 70px);
    width: calc(100% - var(--sidebar-width, 280px));
}

/* When sidebar has mini class, adjust content wrapper */
.sidebar.mini ~ .content-wrapper {
    margin-left: var(--sidebar-mini-width, 80px);
    width: calc(100% - var(--sidebar-mini-width, 80px));
}

/* MAIN CONTENT */
.mid-content {
    background: var(--bg-card);
    border-radius: 20px;
    padding: 30px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    min-height: 500px;
}

/* PAGE HEADER */
.page-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 8px;
}

.page-title i {
    color: var(--primary);
}

.sub-title {
    color: var(--text-muted);
    font-size: 14px;
}

/* STAT CARDS - IMPROVED */
.stat-card {
    background: var(--bg-card);
    border-radius: 20px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 15px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    transition: all 0.3s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--primary-gradient);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
}

.stat-card:hover::before {
    opacity: 1;
}

.stat-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    background: var(--primary-gradient);
    color: white;
    box-shadow: var(--shadow-lg);
}

.stat-card h4 {
    font-size: 28px;
    font-weight: 700;
    color: var(--dark);
    margin: 0;
    line-height: 1.2;
}

.stat-card small {
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
}

/* FILTER BOX - IMPROVED */
.filter-box {
    background: var(--bg-card);
    border-radius: 20px;
    padding: 25px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
}

.filter-tag {
    background: var(--primary-gradient);
    color: white;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 12px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-right: 10px;
    margin-bottom: 10px;
    box-shadow: var(--shadow);
}

.filter-tag a {
    color: white;
    opacity: 0.8;
    transition: opacity 0.2s;
}

.filter-tag a:hover {
    opacity: 1;
}

/* FORM CONTROLS - EXACTLY LIKE FIRST TEMPLATE */
.form-control, .form-select {
    border-radius: 12px;
    padding: 12px 20px;
    border: 1px solid var(--border);
    background: var(--bg-white);
    color: var(--text);
    font-size: 14px;
    transition: all 0.3s;
}

.form-control:focus, .form-select:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    outline: none;
    background: var(--bg-white);
    color: var(--text);
}

.form-control::placeholder {
    color: var(--text-muted);
    opacity: 0.7;
}

/* BUTTONS - EXACTLY LIKE FIRST TEMPLATE */
.btn {
    border-radius: 12px;
    padding: 12px 24px;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.3s ease;
}

.btn-primary {
    background: var(--primary-gradient);
    border: none;
    color: white;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.btn-outline-primary {
    border: 2px solid var(--primary);
    color: var(--primary);
    background: transparent;
}

.btn-outline-primary:hover {
    background: var(--primary);
    color: white;
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.btn-outline-secondary {
    border: 1px solid var(--border);
    color: var(--text);
    background: transparent;
}

.btn-outline-secondary:hover {
    background: var(--bg-offwhite);
    color: var(--dark);
    border-color: var(--primary);
    transform: translateY(-2px);
}

.btn-outline-danger {
    border: 1px solid var(--danger);
    color: var(--danger);
    background: transparent;
}

.btn-outline-danger:hover {
    background: var(--danger);
    color: white;
    transform: translateY(-2px);
}

/* TABLE - IMPROVED */
.device-table {
    background: var(--bg-card);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    margin-top: 25px;
}

.table {
    margin: 0;
}

.table th {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 2px solid var(--border);
    padding: 18px 16px;
    background: var(--bg-offwhite);
}

.table td {
    padding: 18px 16px;
    vertical-align: middle;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-size: 14px;
}

.table tr:hover {
    background: var(--bg-offwhite);
}

.table tr:last-child td {
    border-bottom: none;
}

/* BADGES */
.badge-soft {
    padding: 6px 14px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 12px;
    display: inline-block;
    text-decoration: none !important;
    transition: all 0.3s ease;
}

.badge-soft:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
}

.badge-active { 
    background: rgba(16, 185, 129, 0.1); 
    color: var(--success); 
}

.badge-inactive { 
    background: rgba(239, 68, 68, 0.1); 
    color: var(--danger); 
}

.badge-connected { 
    background: rgba(59, 130, 246, 0.1); 
    color: var(--info); 
}

.badge-disconnected { 
    background: rgba(107, 114, 128, 0.1); 
    color: var(--text-muted); 
}

/* WhatsApp badge */
.whatsapp-badge {
    background: rgba(37, 211, 102, 0.15);
    color: #25D366;
    padding: 6px 12px;
    border-radius: 50px;
    font-size: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
}

/* Email badge */
.email-badge {
    background: var(--bg-offwhite);
    color: var(--text-light);
    padding: 6px 12px;
    border-radius: 50px;
    font-size: 12px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-weight: 600;
}

/* ACTION BUTTONS - IMPROVED */
.action-btn {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    margin-right: 6px;
    transition: all 0.2s ease;
    font-size: 14px;
}

.action-btn:hover {
    transform: scale(1.1);
}

.btn-view { 
    background: rgba(16, 185, 129, 0.1); 
    color: var(--success); 
}

.btn-edit { 
    background: rgba(102, 126, 234, 0.1); 
    color: var(--primary); 
}

.btn-delete { 
    background: rgba(239, 68, 68, 0.1); 
    color: var(--danger); 
}

/* CHECKBOX - IMPROVED */
.device-checkbox {
    width: 22px;
    height: 22px;
    border-radius: 8px;
    border: 2px solid var(--border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    background: var(--bg-card);
}

.device-checkbox.checked {
    background: var(--primary-gradient);
    border-color: transparent;
}

.device-checkbox.checked::after {
    content: '✓';
    color: white;
    font-size: 12px;
    font-weight: bold;
}

/* SELECTED DEVICES COUNTER - IMPROVED */
.selected-counter {
    position: fixed;
    bottom: 30px;
    right: 30px;
    background: var(--primary-gradient);
    color: white;
    padding: 15px 25px;
    border-radius: 50px;
    box-shadow: var(--shadow-lg);
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
    z-index: 100;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    font-size: 14px;
}

.selected-counter:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(102, 126, 234, 0.3);
}

.selected-counter i {
    font-size: 16px;
}

/* TOAST - EXACTLY LIKE FIRST TEMPLATE */
#toast {
    position: fixed;
    top: 90px;
    right: 29px;
    width: 320px;
    padding: 16px 20px;
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    transform: translateY(-15px);
    transition: .3s ease;
    color: #fff;
    z-index: 1001;
}

#toast.show {
    opacity: 1;
    transform: translateY(0);
}

.toast-success { background: var(--success); }
.toast-error { background: var(--danger); }
.toast-info { background: var(--info); }
.toast-warning { background: var(--warning); color: #1f2937; }

.toast-content {
    display: flex;
    gap: 12px;
    align-items: flex-start;
}

.toast-icon {
    font-size: 20px;
}

.toast-text h4 {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
}

.toast-text p {
    margin: 5px 0 0;
    font-size: 13px;
    opacity: 0.9;
}

.toast-progress {
    height: 3px;
    background: rgba(255,255,255,0.6);
    margin-top: 12px;
    width: 100%;
    animation: progress 3s linear;
}

@keyframes progress {
    from { width: 100%; }
    to { width: 0%; }
}

/* LOADING OVERLAY - EXACTLY LIKE FIRST TEMPLATE */
.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    backdrop-filter: blur(5px);
}

.spinner {
    width: 50px;
    height: 50px;
    border: 5px solid var(--bg-offwhite);
    border-top: 5px solid var(--primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.loading-text {
    color: white;
    margin-top: 15px;
    font-size: 18px;
    font-weight: 600;
}

/* EMPTY STATE */
.empty-state {
    text-align: center;
    padding: 60px 20px;
}

.empty-state i {
    font-size: 64px;
    color: var(--text-muted);
    opacity: 0.3;
    margin-bottom: 20px;
}

.empty-state h5 {
    color: var(--text);
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 10px;
}

.empty-state p {
    color: var(--text-muted);
    margin-bottom: 25px;
}

/* RESPONSIVE - EXACTLY LIKE FIRST TEMPLATE */
@media (max-width: 1200px) {
    .content-wrapper {
        padding: 20px;
    }
    
    .mid-content {
        padding: 25px;
    }
}

@media (max-width: 992px) {
    .stat-card {
        padding: 20px;
    }
    
    .stat-icon {
        width: 48px;
        height: 48px;
        font-size: 20px;
    }
    
    .stat-card h4 {
        font-size: 24px;
    }
    
    .page-title {
        font-size: 24px;
    }
}

@media (max-width: 768px) {
    .sidebar {
        transform: translateX(-100%);
        width: var(--sidebar-width, 280px) !important;
        transition: transform 0.3s ease;
    }
    
    .sidebar.open {
        transform: translateX(0);
    }
    
    .sidebar.mini {
        transform: translateX(-100%);
        width: var(--sidebar-width, 280px) !important;
    }
    
    .sidebar.mini.open {
        transform: translateX(0);
    }
    
    .content-wrapper {
        margin-left: 0 !important;
        width: 100% !important;
        padding: 15px;
    }
    
    .sidebar.mini ~ .content-wrapper {
        margin-left: 0 !important;
        width: 100% !important;
    }
    
    .mid-content {
        padding: 20px;
    }
    
    .page-title {
        font-size: 22px;
    }
    
    .stat-card {
        padding: 16px;
    }
    
    .stat-icon {
        width: 44px;
        height: 44px;
        font-size: 18px;
    }
    
    .stat-card h4 {
        font-size: 20px;
    }
    
    .stat-card small {
        font-size: 12px;
    }
    
    .filter-box {
        padding: 20px;
    }
    
    .btn {
        padding: 10px 20px;
        font-size: 13px;
    }
    
    .selected-counter {
        bottom: 20px;
        right: 20px;
        padding: 12px 20px;
        font-size: 13px;
    }
    
    .device-table {
        overflow-x: auto;
    }
    
    .table {
        min-width: 900px;
    }
    
    .table th,
    .table td {
        padding: 14px 12px;
    }
}

@media (max-width: 576px) {
    .content-wrapper {
        padding: 10px;
    }
    
    .mid-content {
        padding: 15px;
    }
    
    .page-title {
        font-size: 20px;
    }
    
    .sub-title {
        font-size: 13px;
    }
    
    .stat-card {
        padding: 14px;
    }
    
    .stat-icon {
        width: 40px;
        height: 40px;
        font-size: 16px;
    }
    
    .stat-card h4 {
        font-size: 18px;
    }
    
    .filter-box {
        padding: 15px;
    }
    
    .btn {
        padding: 8px 16px;
        font-size: 12px;
    }
    
    .form-control, .form-select {
        padding: 10px 16px;
        font-size: 13px;
    }
    
    .selected-counter {
        bottom: 15px;
        right: 15px;
        padding: 10px 16px;
        font-size: 12px;
    }
    
    .action-btn {
        width: 32px;
        height: 32px;
        font-size: 12px;
    }
}
</style>
</head>

<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <%- include('../../partials/ram/sidebaar') %>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <div class="mid-content">
                <!-- Toast Container -->
                <div id="toast"></div>

                <!-- SELECTED DEVICES COUNTER (Floating) -->
                <div class="selected-counter" id="selectedCounter" style="display:none;" onclick="useSelectedInCampaign()">
                    <i class="fas fa-paper-plane"></i>
                    <span id="selectedCount">0</span> Selected - Use in Campaign
                </div>

                <!-- PAGE HEADER -->
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
                    <div>
                        <div class="page-title">
                            <i class="fas fa-address-book text-primary me-2"></i>
                            All Contacts
                        </div>
                        <div class="sub-title">Manage all contacts and devices</div>
                    </div>
                    <div class="mt-3 mt-md-0 d-flex flex-wrap gap-2">
                        <button onclick="selectAllDevices()" class="btn btn-outline-primary">
                            <i class="fas fa-check-square me-2"></i> Select All
                        </button>
                        <button onclick="deselectAllDevices()" class="btn btn-outline-secondary">
                            <i class="fas fa-square me-2"></i> Deselect All
                        </button>
                        <a href="/devices/add" class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i> Add Contact
                        </a>
                        <button onclick="location.reload()" class="btn btn-outline-secondary">
                            <i class="fas fa-sync-alt"></i>
                        </button>
                    </div>
                </div>

                <!-- STATS -->
                <div class="row g-4 mb-4">
                    <div class="col-sm-6 col-lg-3" onclick="filterByStatus('all')" style="cursor:pointer;">
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-mobile-alt"></i></div>
                            <div>
                                <h4 class="mb-0"><%= stats?.total || 0 %></h4>
                                <small>Total Contacts</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3" onclick="filterByStatus('active')" style="cursor:pointer;">
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                            <div>
                                <h4 class="mb-0"><%= stats?.active || 0 %></h4>
                                <small>Active</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3" onclick="filterByStatus('inactive')" style="cursor:pointer;">
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
                            <div>
                                <h4 class="mb-0"><%= stats?.inactive || 0 %></h4>
                                <small>Inactive</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3" onclick="useSelectedInCampaign()" style="cursor:pointer;">
                        <div class="stat-card">
                            <div class="stat-icon"><i class="fas fa-paper-plane"></i></div>
                            <div>
                                <h4 class="mb-0" id="selectedDevicesCount">0</h4>
                                <small>Selected</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FILTER -->
                <div class="filter-box mb-4">
                    <form method="get" id="filterForm">
                        <!-- Active Filters -->
                        <% if(filters && (filters.search || filters.status !== 'all')) { %>
                        <div class="mb-3">
                            <small class="text-muted d-block mb-2">Active Filters:</small>
                            <% if(filters.search) { %>
                            <span class="filter-tag">
                                <i class="fas fa-search"></i> "<%= filters.search %>"
                                <a href="javascript:void(0)" onclick="removeFilter('search')">
                                    <i class="fas fa-times"></i>
                                </a>
                            </span>
                            <% } %>
                            <% if(filters.status && filters.status !== 'all') { %>
                            <span class="filter-tag">
                                <i class="fas fa-filter"></i> <%= filters.status %>
                                <a href="javascript:void(0)" onclick="removeFilter('status')">
                                    <i class="fas fa-times"></i>
                                </a>
                            </span>
                            <% } %>
                            <a href="/devices" class="btn btn-sm btn-outline-danger">Clear All</a>
                        </div>
                        <% } %>

                        <input type="text" 
                               name="search" 
                               class="form-control mb-3" 
                               placeholder="Search by name, phone, email or WhatsApp number..." 
                               value="<%= filters?.search || '' %>"
                               onkeyup="debounceSearch()">

                        <div class="row g-3">
                            <div class="col-md-4">
                                <select name="status" class="form-select" onchange="this.form.submit()">
                                    <option value="all" <%= (!filters?.status || filters.status==='all') ? 'selected' : '' %>>All Status</option>
                                    <option value="active" <%= filters?.status==='active' ? 'selected' : '' %>>Active</option>
                                    <option value="inactive" <%= filters?.status==='inactive' ? 'selected' : '' %>>Inactive</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <select name="sort" class="form-select" onchange="this.form.submit()">
                                    <option value="newest" <%= (!filters?.sort || filters.sort==='newest') ? 'selected' : '' %>>Newest First</option>
                                    <option value="oldest" <%= filters?.sort==='oldest' ? 'selected' : '' %>>Oldest First</option>
                                    <option value="name" <%= filters?.sort==='name' ? 'selected' : '' %>>By Name (A-Z)</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-filter me-2"></i> Apply Filters
                                </button>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-end mt-3">
                            <div class="text-muted">
                                <small><i class="fas fa-users me-1"></i> <%= devices.length %> contact(s) found</small>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- DEVICE TABLE -->
                <div class="device-table">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width:50px;">
                                    <div class="device-checkbox" id="selectAllCheckbox" onclick="toggleSelectAll(this)"></div>
                                </th>
                                <th>Contact</th>
                                <th>Phone Number</th>
                                <th>WhatsApp</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Added</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>

                        <% if(devices && devices.length){ %>
                            <% devices.forEach(device => { %>
                            <tr data-device-id="<%= device._id %>">
                                <td>
                                    <div class="device-checkbox" onclick="toggleDeviceSelection(this, '<%= device._id %>', '<%= device.phoneNumber %>', '<%= device.name %>')"></div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <i class="fas fa-user-circle text-primary fs-4"></i>
                                        </div>
                                        <div>
                                            <strong class="d-block"><%= device.name %></strong>
                                            <small class="text-muted">ID: <%= device._id.toString().substring(0, 8) %>...</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-medium">
                                        <i class="fas fa-phone-alt text-muted me-1"></i>
                                        +91 <%= device.phoneNumber %>
                                    </div>
                                </td>
                                <td>
                                    <% if(device.whatsappNumber) { %>
                                        <span class="whatsapp-badge">
                                            <i class="fab fa-whatsapp"></i> +91 <%= device.whatsappNumber %>
                                        </span>
                                    <% } else { %>
                                        <span class="email-badge">
                                            <i class="fas fa-times"></i> Not set
                                        </span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if(device.email) { %>
                                        <span class="email-badge">
                                            <i class="fas fa-envelope"></i> <%= device.email %>
                                        </span>
                                    <% } else { %>
                                        <span class="text-muted">—</span>
                                    <% } %>
                                </td>
                                <td>
                                    <a href="/devices/status/<%= device._id %>" 
                                       class="badge-soft <%= device.status === 'active' ? 'badge-active' : 'badge-inactive' %>">
                                        <i class="fas fa-<%= device.status === 'active' ? 'check-circle' : 'times-circle' %> me-1"></i>
                                        <%= device.status === 'active' ? 'Active' : 'Inactive' %>
                                    </a>
                                </td>
                                <td>
                                    <div><%= new Date(device.createdAt).toLocaleDateString() %></div>
                                    <small class="text-muted"><%= new Date(device.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></small>
                                </td>
                                <td>
                                    <div class="d-flex">
                                        <a href="/devices/edit/<%= device._id %>" class="action-btn btn-edit" title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <a href="javascript:void(0)"
                                           onclick="deleteDevice('<%= device._id %>', '<%= device.name %>')"
                                           class="action-btn btn-delete" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="empty-state">
                                    <i class="fas fa-address-book"></i>
                                    <h5>No contacts found</h5>
                                    <% if(filters && (filters.search || filters.status !== 'all')) { %>
                                    <p class="text-muted">Try changing your filters</p>
                                    <a href="/devices" class="btn btn-primary">
                                        <i class="fas fa-times me-2"></i> Clear Filters
                                    </a>
                                    <% } else { %>
                                    <p class="text-muted">Add your first contact to get started</p>
                                    <a href="/devices/add" class="btn btn-primary">
                                        <i class="fas fa-plus me-2"></i> Add Contact
                                    </a>
                                    <% } %>
                                </td>
                            </tr>
                        <% } %>

                        </tbody>
                    </table>
                </div>

                <!-- SELECTED DEVICES ACTION -->
                <% if(devices && devices.length > 0) { %>
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <div class="text-muted">
                        <i class="fas fa-list me-1"></i> Showing <%= devices.length %> of <%= stats.total %> contacts
                    </div>
                    <button class="btn btn-primary" onclick="useSelectedInCampaign()">
                        <i class="fas fa-paper-plane me-2"></i> Use Selected (<span id="bottomSelectedCount">0</span>)
                    </button>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- LOADING OVERLAY -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="text-center">
            <div class="spinner"></div>
            <div class="loading-text">Loading...</div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR STATE SYNC - EXACTLY LIKE FIRST TEMPLATE
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE FIRST TEMPLATE
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);

            // Initialize selections
            updateSelectedCount();
            loadSavedSelections();
            addRowClickListeners();

            // Show welcome toast
            setTimeout(() => {
                const count = document.querySelectorAll('tbody tr').length;
                showToast('Contacts Loaded', `Found ${count} contacts`, 'info');
            }, 1000);
        });

        // ======================
        // ROW CLICK LISTENERS
        // ======================
        function addRowClickListeners() {
            document.querySelectorAll('tbody tr').forEach(row => {
                row.addEventListener('click', function(e) {
                    if (e.target.classList.contains('device-checkbox') || 
                        e.target.closest('.device-checkbox') ||
                        e.target.closest('.action-btn')) {
                        return;
                    }
                    
                    const checkbox = this.querySelector('.device-checkbox');
                    const deviceId = this.getAttribute('data-device-id');
                    const phoneCell = this.cells[2];
                    const nameCell = this.cells[1];
                    
                    if (phoneCell && nameCell) {
                        const phoneNumber = phoneCell.textContent.trim().replace('+91 ', '');
                        const name = nameCell.querySelector('strong').textContent.trim();
                        toggleDeviceSelection(checkbox, deviceId, phoneNumber, name);
                    }
                });
            });
        }

        // ======================
        // FILTER FUNCTIONS
        // ======================
        let searchTimer;
        function debounceSearch() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => {
                document.getElementById('filterForm').submit();
            }, 500);
        }

        function filterByStatus(status) {
            const form = document.getElementById('filterForm');
            form.elements['status'].value = status;
            form.submit();
            showToast('Filtering', `Showing ${status} contacts`, 'info');
        }

        function removeFilter(filterName) {
            const url = new URL(window.location.href);
            url.searchParams.delete(filterName);
            window.location.href = url.toString();
        }

        // ======================
        // DEVICE SELECTION FUNCTIONS
        // ======================
        let selectedDevices = new Map();

        function toggleDeviceSelection(checkbox, deviceId, phoneNumber, deviceName) {
            const fullPhoneNumber = '+91' + phoneNumber;
            
            if (selectedDevices.has(deviceId)) {
                selectedDevices.delete(deviceId);
                checkbox.classList.remove('checked');
                showToast('Removed', `${deviceName} removed from selection`, 'info');
            } else {
                selectedDevices.set(deviceId, {
                    phoneNumber: fullPhoneNumber,
                    name: deviceName
                });
                checkbox.classList.add('checked');
                showToast('Selected', `${deviceName} added to selection`, 'success');
            }
            
            updateSelectedCount();
            saveSelectionsToStorage();
            updateSelectAllCheckbox();
        }

        function toggleSelectAll(masterCheckbox) {
            const checkboxes = document.querySelectorAll('tbody .device-checkbox');
            const rows = document.querySelectorAll('tbody tr');
            
            if (!masterCheckbox.classList.contains('checked')) {
                showToast('Select All', 'Selecting all visible contacts', 'info');
                checkboxes.forEach((checkbox, index) => {
                    checkbox.classList.add('checked');
                    const row = rows[index];
                    const deviceId = row.getAttribute('data-device-id');
                    const phoneCell = row.cells[2];
                    const nameCell = row.cells[1];
                    
                    if (phoneCell && nameCell) {
                        const phoneNumber = phoneCell.textContent.trim().replace('+91 ', '');
                        const name = nameCell.querySelector('strong').textContent.trim();
                        selectedDevices.set(deviceId, {
                            phoneNumber: '+91' + phoneNumber,
                            name: name
                        });
                    }
                });
                masterCheckbox.classList.add('checked');
            } else {
                showToast('Deselect All', 'Clearing all selections', 'info');
                checkboxes.forEach((checkbox, index) => {
                    checkbox.classList.remove('checked');
                    const row = rows[index];
                    const deviceId = row.getAttribute('data-device-id');
                    selectedDevices.delete(deviceId);
                });
                masterCheckbox.classList.remove('checked');
            }
            
            updateSelectedCount();
            saveSelectionsToStorage();
        }

        function updateSelectAllCheckbox() {
            const masterCheckbox = document.getElementById('selectAllCheckbox');
            const checkboxes = document.querySelectorAll('tbody .device-checkbox');
            const checkedCheckboxes = document.querySelectorAll('tbody .device-checkbox.checked');
            
            if (checkboxes.length > 0 && checkedCheckboxes.length === checkboxes.length) {
                masterCheckbox.classList.add('checked');
            } else {
                masterCheckbox.classList.remove('checked');
            }
        }

        function selectAllDevices() {
            const checkboxes = document.querySelectorAll('tbody .device-checkbox');
            const rows = document.querySelectorAll('tbody tr');
            
            checkboxes.forEach((checkbox, index) => {
                checkbox.classList.add('checked');
                const row = rows[index];
                const deviceId = row.getAttribute('data-device-id');
                const phoneCell = row.cells[2];
                const nameCell = row.cells[1];
                
                if (phoneCell && nameCell) {
                    const phoneNumber = phoneCell.textContent.trim().replace('+91 ', '');
                    const name = nameCell.querySelector('strong').textContent.trim();
                    selectedDevices.set(deviceId, {
                        phoneNumber: '+91' + phoneNumber,
                        name: name
                    });
                }
            });
            
            document.getElementById('selectAllCheckbox').classList.add('checked');
            updateSelectedCount();
            saveSelectionsToStorage();
            
            showToast('Success', `Selected ${selectedDevices.size} contacts`, 'success');
        }

        function deselectAllDevices() {
            const checkboxes = document.querySelectorAll('.device-checkbox');
            checkboxes.forEach(checkbox => {
                checkbox.classList.remove('checked');
            });
            
            document.getElementById('selectAllCheckbox').classList.remove('checked');
            selectedDevices.clear();
            updateSelectedCount();
            saveSelectionsToStorage();
            
            showToast('Cleared', 'All selections cleared', 'info');
        }

        // ======================
        // SELECTED COUNT FUNCTIONS
        // ======================
        function updateSelectedCount() {
            const count = selectedDevices.size;
            document.getElementById('selectedDevicesCount').textContent = count;
            document.getElementById('bottomSelectedCount').textContent = count;
            document.getElementById('selectedCount').textContent = count;
            
            const counter = document.getElementById('selectedCounter');
            if (count > 0) {
                counter.style.display = 'flex';
            } else {
                counter.style.display = 'none';
            }
        }

        // ======================
        // CAMPAIGN FUNCTIONS
        // ======================
        function useSelectedInCampaign() {
            if (selectedDevices.size === 0) {
                showToast('Error', 'Please select at least one contact first!', 'error');
                return;
            }
            
            showToast('Processing', `Preparing ${selectedDevices.size} contacts for campaign...`, 'info');
            
            const selectedNumbers = Array.from(selectedDevices.values()).map(device => device.phoneNumber);
            const devicesData = Array.from(selectedDevices.entries()).map(([id, device]) => ({
                id: id,
                phoneNumber: device.phoneNumber,
                name: device.name
            }));
            
            localStorage.setItem('selectedCampaignDevices', JSON.stringify(devicesData));
            localStorage.setItem('selectedCampaignNumbers', JSON.stringify(selectedNumbers));
            
            showToast('Redirecting', 'Opening campaign page...', 'success');
            
            setTimeout(() => {
                window.location.href = '/campaign';
            }, 1000);
        }

        // ======================
        // DELETE FUNCTION
        // ======================
        function deleteDevice(deviceId, deviceName) {
            if (confirm(`Are you sure you want to delete contact: ${deviceName}?`)) {
                showToast('Deleting', `Removing contact: ${deviceName}`, 'warning');
                
                if (selectedDevices.has(deviceId)) {
                    selectedDevices.delete(deviceId);
                    updateSelectedCount();
                    saveSelectionsToStorage();
                }
                
                window.location.href = '/devices/delete/' + deviceId;
            }
        }

        // ======================
        // STORAGE FUNCTIONS
        // ======================
        function saveSelectionsToStorage() {
            const selections = Array.from(selectedDevices.entries());
            localStorage.setItem('deviceSelections', JSON.stringify(selections));
        }

        function loadSavedSelections() {
            try {
                const saved = localStorage.getItem('deviceSelections');
                if (saved) {
                    const selections = JSON.parse(saved);
                    selectedDevices = new Map(selections);
                    
                    const rows = document.querySelectorAll('tbody tr');
                    rows.forEach(row => {
                        const deviceId = row.getAttribute('data-device-id');
                        if (selectedDevices.has(deviceId)) {
                            const checkbox = row.querySelector('.device-checkbox');
                            if (checkbox) {
                                checkbox.classList.add('checked');
                            }
                        }
                    });
                    
                    updateSelectAllCheckbox();
                    updateSelectedCount();
                }
            } catch (e) {
                console.error('Error loading saved selections:', e);
            }
        }

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'a') {
                e.preventDefault();
                selectAllDevices();
            }
            
            if (e.key === 'Escape') {
                deselectAllDevices();
            }
            
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                useSelectedInCampaign();
            }
            
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Ctrl+A: Select All | Esc: Deselect | Ctrl+Enter: Use in Campaign', 'info');
            }
        });
    </script>
</body>
</html>