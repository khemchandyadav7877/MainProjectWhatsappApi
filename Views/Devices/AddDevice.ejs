<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Contact - SSPAR Cloud</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* ===== THEME VARIABLES - EXACTLY LIKE DASHBOARD ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f8fafc;
            --bg-white: #ffffff;
            --bg-offwhite: #f1f5f9;
            --bg-card: #ffffff;
            --text: #334155;
            --text-light: #64748b;
            --text-muted: #94a3b8;
            --dark: #0f172a;
            --border: #eef2f6;
            --shadow: 0 8px 25px rgba(0,0,0,0.03);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
            --sidebar-mini-width: 80px;
        }

        /* Dark Mode - EXACTLY LIKE DASHBOARD */
        body.dark {
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --text: #e2e8f0;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 8px 25px rgba(0,0,0,0.2);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: 'Inter', 'Segoe UI', sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES - EXACTLY LIKE DASHBOARD ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar,
        body.round-border .main-content-card,
        body.round-border .status-option,
        body.round-border .btn,
        body.round-border .form-control,
        body.round-border .form-select,
        body.round-border .country-code,
        body.round-border .quick-add-btn,
        body.round-border .modal-content,
        body.round-border #toast,
        body.round-border .device-icon,
        body.round-border .icon {
            border-radius: 20px !important;
        }

        body.round-border .icon {
            border-radius: 16px !important;
        }

        body.round-border .badge-success,
        body.round-border .badge-secondary,
        body.round-border .validation-icon i {
            border-radius: 50px !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar,
        body.no-radius .main-content-card,
        body.no-radius .status-option,
        body.no-radius .btn,
        body.no-radius .form-control,
        body.no-radius .form-select,
        body.no-radius .country-code,
        body.no-radius .quick-add-btn,
        body.no-radius .modal-content,
        body.no-radius #toast,
        body.no-radius .device-icon,
        body.no-radius .icon,
        body.no-radius .badge-success,
        body.no-radius .badge-secondary,
        body.no-radius .validation-icon i {
            border-radius: 0 !important;
        }

        /* HEADER FIXED - EXACTLY LIKE DASHBOARD */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
            transition: all 0.3s;
        }

        /* MAIN LAYOUT - EXACTLY LIKE DASHBOARD */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
            position: relative;
        }

        /* SIDEBAR - EXACTLY LIKE DASHBOARD */
        .sidebar {
            width: var(--sidebar-width, 280px);
            background: var(--bg-white);
            border-right: 1px solid var(--border);
            height: calc(100vh - var(--header-height, 70px));
            position: fixed;
            left: 0;
            top: 70px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1020;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }

        /* Sidebar Mini Mode */
        .sidebar.mini {
            width: var(--sidebar-mini-width, 80px);
        }

        /* CONTENT WRAPPER - EXACTLY LIKE DASHBOARD */
        .content-wrapper {
            flex: 1;
            margin-left: var(--sidebar-width, 280px);
            padding: 25px;
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
            width: calc(100% - var(--sidebar-width, 280px));
        }

        /* When sidebar has mini class, adjust content wrapper */
        .sidebar.mini ~ .content-wrapper {
            margin-left: var(--sidebar-mini-width, 80px);
            width: calc(100% - var(--sidebar-mini-width, 80px));
        }

        /* MAIN CONTENT CARD */
        .main-content-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 30px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            min-height: 500px;
        }

        /* DEVICE HEADER */
        .device-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .device-header .icon {
            width: 80px;
            height: 80px;
            background: var(--primary-gradient);
            color: #fff;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            margin: 0 auto 15px;
            box-shadow: var(--shadow-lg);
        }

        .device-header h5 {
            margin: 0;
            font-weight: 700;
            color: var(--dark);
            font-size: 28px;
        }

        .device-sub {
            text-align: center;
            color: var(--text-muted);
            margin-bottom: 15px;
            font-size: 14px;
        }

        .device-line {
            height: 3px;
            background: var(--primary-gradient);
            width: 100px;
            margin: 0 auto 30px;
            border-radius: 2px;
        }

        .form-label {
            font-weight: 600;
            color: var(--text-light);
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .form-label i {
            color: var(--primary);
        }

        .form-label .required {
            color: var(--danger);
            font-size: 12px;
        }

        .form-control, .form-select {
            border-radius: 12px;
            padding: 12px 16px;
            border: 1px solid var(--border);
            background: var(--bg-white);
            color: var(--text);
            font-size: 14px;
            transition: all 0.3s;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            outline: none;
            background: var(--bg-white);
            color: var(--text);
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.7;
        }

        /* PHONE INPUT */
        .phone-wrapper {
            position: relative;
        }

        .country-code {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            background: var(--primary);
            color: white;
            padding: 6px 14px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            z-index: 2;
        }

        .phone-input {
            padding-left: 85px !important;
        }

        /* VALIDATION ICON */
        .validation-icon {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 3;
        }

        .validation-icon.valid {
            color: var(--success);
        }

        .validation-icon.invalid {
            color: var(--danger);
        }

        /* STATUS RADIO */
        .status-option {
            background: var(--bg-offwhite);
            border-radius: 16px;
            padding: 16px;
            border: 2px solid transparent;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .status-option:hover {
            border-color: var(--primary);
            background: var(--bg-card);
        }

        .status-option input[type="radio"] {
            margin-right: 10px;
            accent-color: var(--primary);
        }

        .badge-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 12px;
        }

        .badge-secondary {
            background: var(--bg-offwhite);
            color: var(--text-muted);
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 600;
            border: 1px solid var(--border);
            font-size: 12px;
        }

        /* BUTTONS - LIKE DASHBOARD */
        .btn {
            border-radius: 12px;
            padding: 12px 30px;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background: var(--primary-gradient);
            border: none;
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .btn-outline-secondary {
            border: 1px solid var(--border);
            color: var(--text);
            background: transparent;
        }

        .btn-outline-secondary:hover {
            background: var(--bg-offwhite);
            color: var(--dark);
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .btn-outline-info {
            border: 1px solid var(--info);
            color: var(--info);
            background: transparent;
        }

        .btn-outline-info:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
        }

        .btn-outline-success {
            border: 1px solid var(--success);
            color: var(--success);
            background: transparent;
        }

        .btn-outline-success:hover {
            background: var(--success);
            color: white;
            transform: translateY(-2px);
        }

        .action-buttons {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .action-buttons .btn {
            flex: 1;
        }

        /* API STATUS */
        .api-status {
            display: none;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
        }
        .api-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid var(--success);
        }
        .api-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid var(--danger);
        }

        /* TOOLTIP */
        .tooltip-info {
            color: var(--text-muted);
            font-size: 12px;
            margin-top: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .tooltip-info i {
            color: var(--primary);
            font-size: 10px;
        }

        /* QUICK ADD FAB */
        .quick-add-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 56px;
            height: 56px;
            border-radius: 16px;
            background: var(--primary-gradient);
            color: white;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            box-shadow: var(--shadow-lg);
            cursor: pointer;
            z-index: 100;
            transition: all 0.3s ease;
        }
        .quick-add-btn:hover {
            transform: scale(1.1) translateY(-5px);
        }

        /* LOADING OVERLAY - EXACTLY LIKE DASHBOARD */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(5px);
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid var(--bg-offwhite);
            border-top: 5px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .loading-text {
            color: white;
            margin-top: 15px;
            font-size: 18px;
            font-weight: 600;
        }

        .loading-subtext {
            color: rgba(255,255,255,0.8);
            font-size: 14px;
        }

        /* TOAST - EXACTLY LIKE DASHBOARD */
        #toast {
            position: fixed;
            top: 90px;
            right: 29px;
            width: 320px;
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 1001;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-content {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            font-size: 20px;
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 5px 0 0;
            font-size: 13px;
            opacity: 0.9;
        }

        .toast-progress {
            height: 3px;
            background: rgba(255,255,255,0.6);
            margin-top: 10px;
            width: 100%;
            animation: progress 3s linear;
        }

        @keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* MODAL */
        .modal-content {
            background: var(--bg-card);
            color: var(--text);
            border: 1px solid var(--border);
            border-radius: 20px;
        }

        .modal-header {
            border-bottom: 1px solid var(--border);
            padding: 20px;
        }

        .modal-header .modal-title {
            color: var(--dark);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-body {
            padding: 20px;
        }

        .modal-footer {
            border-top: 1px solid var(--border);
            padding: 20px;
        }

        .btn-close {
            filter: var(--text) === '#e2e8f0' ? 'invert(1)' : 'none';
        }

        body.dark .btn-close {
            filter: invert(1);
        }

        /* MOBILE RESPONSIVE - EXACTLY LIKE DASHBOARD */
        @media (max-width: 1200px) {
            .action-buttons {
                flex-direction: row;
            }
        }

        @media (max-width: 992px) {
            .action-buttons {
                flex-direction: column;
            }
            
            .main-content-card {
                padding: 25px;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
                transition: transform 0.3s ease;
            }
            
            .sidebar.open {
                transform: translateX(0);
            }
            
            .sidebar.mini {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
            }
            
            .sidebar.mini.open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
                padding: 15px;
            }
            
            .sidebar.mini ~ .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
            }
            
            .main-content-card {
                padding: 20px;
            }
            
            .device-header h5 {
                font-size: 24px;
            }
            
            .device-header .icon {
                width: 60px;
                height: 60px;
                font-size: 24px;
            }
            
            .action-buttons {
                flex-direction: column;
            }

            .quick-add-btn {
                bottom: 20px;
                right: 20px;
                width: 48px;
                height: 48px;
                font-size: 18px;
            }
        }

        @media (max-width: 576px) {
            .content-wrapper {
                padding: 10px;
            }
            
            .main-content-card {
                padding: 15px;
            }
            
            .device-header h5 {
                font-size: 20px;
            }
            
            .form-label {
                font-size: 13px;
            }
            
            .btn {
                padding: 10px 20px;
                font-size: 13px;
            }
            
            .country-code {
                padding: 4px 10px;
                font-size: 12px;
            }
            
            .phone-input {
                padding-left: 75px !important;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <%- include('../../partials/ram/sidebaar') %>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <!-- Toast Container -->
            <div id="toast"></div>

            <!-- QUICK ADD FAB BUTTON -->
            <button class="quick-add-btn" onclick="openQuickAdd()" title="Quick Add Contact">
                <i class="fas fa-plus"></i>
            </button>

            <!-- MAIN CONTENT CARD -->
            <div class="main-content-card">
                <!-- DEVICE HEADER -->
                <div class="device-header">
                    <div class="icon">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <h5>Add New Contact</h5>
                    <div class="device-sub">Register a new contact to your WhatsApp campaigns</div>
                    <div class="device-line"></div>
                </div>

                <!-- API STATUS MESSAGE -->
                <div id="apiStatus" class="api-status"></div>

                <!-- FORM -->
                <form method="POST" action="/devices/add" id="deviceForm">
                    <div class="row g-4">
                        <!-- Contact Name (Required) -->
                        <div class="col-lg-6 col-md-12">
                            <label class="form-label">
                                <i class="fas fa-tag"></i>
                                Contact Name <span class="required">*</span>
                            </label>
                            <div class="position-relative">
                                <input type="text"
                                       name="name"
                                       id="deviceName"
                                       class="form-control"
                                       placeholder="e.g., John Doe, Office Phone"
                                       required
                                       oninput="validateName()">
                                <div class="validation-icon" id="nameValidation"></div>
                            </div>
                            <div class="tooltip-info">
                                <i class="fas fa-info-circle"></i>
                                Give a descriptive name for easy identification
                            </div>
                        </div>

                        <!-- Phone Number (Required) -->
                        <div class="col-lg-6 col-md-12">
                            <label class="form-label">
                                <i class="fas fa-phone"></i>
                                Phone Number <span class="required">*</span>
                            </label>
                            <div class="phone-wrapper">
                                <span class="country-code">+91</span>
                                <input type="text"
                                       name="phoneNumber"
                                       id="phoneNumber"
                                       class="form-control phone-input"
                                       placeholder="9876543210"
                                       required
                                       maxlength="10"
                                       oninput="validatePhone()">
                                <div class="validation-icon" id="phoneValidation"></div>
                            </div>
                            <div class="tooltip-info">
                                <i class="fas fa-info-circle"></i>
                                Enter 10-digit Indian mobile number
                            </div>
                        </div>

                        <!-- WhatsApp Number (Optional) -->
                        <div class="col-lg-6 col-md-12">
                            <label class="form-label">
                                <i class="fab fa-whatsapp" style="color: #25D366;"></i>
                                WhatsApp Number
                            </label>
                            <div class="phone-wrapper">
                                <span class="country-code">+91</span>
                                <input type="text"
                                       name="whatsappNumber"
                                       id="whatsappNumber"
                                       class="form-control phone-input"
                                       placeholder="9876543210 (Optional)"
                                       maxlength="10"
                                       oninput="validateWhatsApp()">
                                <div class="validation-icon" id="whatsappValidation"></div>
                            </div>
                            <div class="tooltip-info">
                                <i class="fas fa-info-circle"></i>
                                If different from phone number (leave blank if same)
                            </div>
                        </div>

                        <!-- Email ID (Optional) -->
                        <div class="col-lg-6 col-md-12">
                            <label class="form-label">
                                <i class="fas fa-envelope"></i>
                                Email ID
                            </label>
                            <div class="position-relative">
                                <input type="email"
                                       name="email"
                                       id="email"
                                       class="form-control"
                                       placeholder="john@example.com (Optional)"
                                       oninput="validateEmail()">
                                <div class="validation-icon" id="emailValidation"></div>
                            </div>
                            <div class="tooltip-info">
                                <i class="fas fa-info-circle"></i>
                                Enter a valid email address
                            </div>
                        </div>

                        <!-- Status -->
                        <div class="col-12">
                            <label class="form-label">
                                <i class="fas fa-power-off"></i>
                                Initial Status
                            </label>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="status-option">
                                        <input class="form-check-input" type="radio" name="status" id="statusActive" value="active" checked>
                                        <label class="form-check-label w-100" for="statusActive">
                                            <span class="badge-success">Active</span>
                                            <small class="d-block text-muted mt-2">Contact will be active and available for campaigns</small>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="status-option">
                                        <input class="form-check-input" type="radio" name="status" id="statusInactive" value="inactive">
                                        <label class="form-check-label w-100" for="statusInactive">
                                            <span class="badge-secondary">Inactive</span>
                                            <small class="d-block text-muted mt-2">Contact will be paused and not included in campaigns</small>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Notes -->
                        <div class="col-12">
                            <label class="form-label">
                                <i class="fas fa-sticky-note"></i>
                                Notes
                            </label>
                            <textarea name="notes"
                                      id="notes"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Optional notes about this contact (company, department, special instructions, etc.)"></textarea>
                            <div class="tooltip-info">
                                <i class="fas fa-info-circle"></i>
                                Add any additional information about this contact
                            </div>
                        </div>
                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="action-buttons">
                        <a href="/devices" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Back to Contacts
                        </a>
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="fas fa-save me-2"></i> Save Contact
                        </button>
                    </div>

                    <!-- API ALTERNATIVE -->
                    <div class="mt-5 pt-4 border-top text-center" style="border-color: var(--border) !important;">
                        <p class="text-muted mb-3">Or add via API for advanced integration</p>
                        <button type="button" class="btn btn-outline-info btn-sm me-2" onclick="addViaAPI()">
                            <i class="fas fa-code me-1"></i> Save via API
                        </button>
                        <button type="button" class="btn btn-outline-success btn-sm" onclick="testAPI()">
                            <i class="fas fa-play me-1"></i> Test API
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <!-- LOADING OVERLAY - EXACTLY LIKE DASHBOARD -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner"></div>
        <div class="loading-text" id="loadingText">Adding Contact...</div>
        <div class="loading-subtext" id="loadingSubtext">Please wait while we save your contact</div>
    </div>

    <!-- QUICK ADD MODAL -->
    <div class="modal fade" id="quickAddModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-bolt" style="color: var(--primary);"></i>
                        Quick Add Contact
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Contact Name <span class="required">*</span></label>
                        <input type="text" class="form-control" id="quickName" placeholder="John Doe">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone Number <span class="required">*</span></label>
                        <div class="phone-wrapper">
                            <span class="country-code">+91</span>
                            <input type="text" class="form-control phone-input" id="quickPhone" placeholder="9876543210">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email (Optional)</label>
                        <input type="email" class="form-control" id="quickEmail" placeholder="john@example.com">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-primary" onclick="quickAddViaAPI()">
                        <i class="fas fa-plus me-1"></i> Add Contact
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR STATE SYNC - EXACTLY LIKE DASHBOARD
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Focus on name field
            document.getElementById('deviceName').focus();
            
            // Load draft if exists
            loadDraft();
            
            // Show welcome toast
            setTimeout(() => {
                showToast('Add Contact', 'Fill in the details to add a new contact', 'info');
            }, 500);

            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);
        });

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE DASHBOARD
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // VALIDATION FUNCTIONS
        // ======================
        function validateName() {
            const nameInput = document.getElementById('deviceName');
            const validationIcon = document.getElementById('nameValidation');
            const name = nameInput.value.trim();
            
            if (name.length < 2) {
                showValidation(validationIcon, 'invalid', 'Name must be at least 2 characters');
                return false;
            }
            
            if (name.length > 50) {
                showValidation(validationIcon, 'invalid', 'Name must be less than 50 characters');
                return false;
            }
            
            showValidation(validationIcon, 'valid', 'Valid name');
            return true;
        }

        function validatePhone() {
            const phoneInput = document.getElementById('phoneNumber');
            const validationIcon = document.getElementById('phoneValidation');
            let phone = phoneInput.value.trim();
            
            phoneInput.value = phone.replace(/\D/g, '');
            phone = phoneInput.value;
            
            if (phone.length !== 10) {
                showValidation(validationIcon, 'invalid', 'Must be 10 digits');
                return false;
            }
            
            if (!/^[6-9]\d{9}$/.test(phone)) {
                showValidation(validationIcon, 'invalid', 'Invalid Indian number');
                return false;
            }
            
            showValidation(validationIcon, 'valid', 'Valid phone number');
            return true;
        }

        function validateWhatsApp() {
            const whatsappInput = document.getElementById('whatsappNumber');
            const validationIcon = document.getElementById('whatsappValidation');
            
            if (!whatsappInput.value) {
                validationIcon.innerHTML = '';
                return true;
            }
            
            let whatsapp = whatsappInput.value.trim();
            whatsappInput.value = whatsapp.replace(/\D/g, '');
            whatsapp = whatsappInput.value;
            
            if (whatsapp.length !== 10) {
                showValidation(validationIcon, 'invalid', 'Must be 10 digits');
                return false;
            }
            
            if (!/^[6-9]\d{9}$/.test(whatsapp)) {
                showValidation(validationIcon, 'invalid', 'Invalid Indian number');
                return false;
            }
            
            showValidation(validationIcon, 'valid', 'Valid WhatsApp number');
            return true;
        }

        function validateEmail() {
            const emailInput = document.getElementById('email');
            const validationIcon = document.getElementById('emailValidation');
            
            if (!emailInput.value) {
                validationIcon.innerHTML = '';
                return true;
            }
            
            const email = emailInput.value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            
            if (!emailRegex.test(email)) {
                showValidation(validationIcon, 'invalid', 'Invalid email format');
                return false;
            }
            
            showValidation(validationIcon, 'valid', 'Valid email');
            return true;
        }

        function showValidation(iconElement, status, message) {
            iconElement.className = 'validation-icon ' + status;
            iconElement.innerHTML = status === 'valid' ? 
                '<i class="fas fa-check-circle"></i>' : 
                '<i class="fas fa-exclamation-circle"></i>';
            iconElement.title = message;
        }

        function validateForm() {
            const isNameValid = validateName();
            const isPhoneValid = validatePhone();
            const isWhatsAppValid = validateWhatsApp();
            const isEmailValid = validateEmail();
            
            if (!isNameValid || !isPhoneValid || !isWhatsAppValid || !isEmailValid) {
                showToast('Error', 'Please fix validation errors', 'error');
                return false;
            }
            
            return true;
        }

        function getFormData() {
            return {
                name: document.getElementById('deviceName').value.trim(),
                phoneNumber: document.getElementById('phoneNumber').value.trim(),
                whatsappNumber: document.getElementById('whatsappNumber').value.trim() || null,
                email: document.getElementById('email').value.trim() || null,
                notes: document.getElementById('notes').value.trim(),
                status: document.querySelector('input[name="status"]:checked').value
            };
        }

        // ======================
        // FORM SUBMISSION
        // ======================
        const form = document.getElementById('deviceForm');
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            if (!validateForm()) {
                return;
            }
            
            showToast('Saving', 'Adding new contact...', 'info');
            showLoading('Adding Contact...', 'Please wait while we save your contact');
            
            // Clear draft after successful submission
            clearDraft();
            
            // Traditional form submission
            this.submit();
        });

        // ======================
        // API FUNCTIONS
        // ======================
        async function addViaAPI() {
            if (!validateForm()) {
                return;
            }
            
            const formData = getFormData();
            
            showToast('API Request', 'Sending via API...', 'info');
            showLoading('Adding via API...', 'Sending request to server');
            
            try {
                const response = await fetch('/api/devices', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });
                
                const data = await response.json();
                
                hideLoading();
                
                if (data.success) {
                    showToast('Success', 'Contact added successfully via API!', 'success');
                    showApiStatus('success', 'Contact added successfully! Redirecting...');
                    
                    clearDraft();
                    
                    setTimeout(() => {
                        window.location.href = '/devices';
                    }, 2000);
                } else {
                    showToast('Error', data.message || 'Unknown error', 'error');
                    showApiStatus('error', `<strong>API Error:</strong> ${data.message || 'Unknown error'}`);
                }
            } catch (error) {
                hideLoading();
                showToast('Error', 'Network error: ' + error.message, 'error');
                showApiStatus('error', `<strong>Network Error:</strong> ${error.message}`);
                console.error('API Error:', error);
            }
        }

        async function testAPI() {
            showToast('Testing API', 'Checking API connectivity...', 'info');
            showLoading('Testing API...', 'Checking API connectivity');
            
            try {
                const response = await fetch('/api/devices');
                const data = await response.json();
                
                hideLoading();
                
                const count = data.data?.length || data.length || 0;
                showToast('Success', `API connected! Found ${count} contacts`, 'success');
                showApiStatus('success', `
                    <strong>API Connection Successful!</strong><br>
                    Found ${count} contacts in system.
                `);
                
                console.log('API Test Response:', data);
            } catch (error) {
                hideLoading();
                showToast('Error', 'API test failed: ' + error.message, 'error');
                showApiStatus('error', `
                    <strong>API Test Failed:</strong> ${error.message}<br>
                    Make sure the server is running.
                `);
                console.error('API Test Error:', error);
            }
        }

        // ======================
        // QUICK ADD FUNCTIONS
        // ======================
        function openQuickAdd() {
            const modal = new bootstrap.Modal(document.getElementById('quickAddModal'));
            modal.show();
        }

        async function quickAddViaAPI() {
            const name = document.getElementById('quickName').value.trim();
            let phone = document.getElementById('quickPhone').value.trim().replace(/\D/g, '');
            const email = document.getElementById('quickEmail').value.trim() || null;
            
            if (!name) {
                showToast('Error', 'Please enter contact name', 'error');
                return;
            }
            
            if (!phone || phone.length !== 10) {
                showToast('Error', 'Please enter valid 10-digit phone number', 'error');
                return;
            }
            
            showToast('Quick Add', 'Adding contact via API...', 'info');
            showLoading('Quick Adding...', 'Adding contact via API');
            
            const contactData = {
                name: name,
                phoneNumber: phone,
                email: email,
                notes: 'Added via Quick Add',
                status: 'active'
            };
            
            try {
                const response = await fetch('/api/devices', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(contactData)
                });
                
                const data = await response.json();
                
                hideLoading();
                
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('quickAddModal')).hide();
                    
                    showToast('Success', `Contact "${name}" added successfully!`, 'success');
                    
                    document.getElementById('quickName').value = '';
                    document.getElementById('quickPhone').value = '';
                    document.getElementById('quickEmail').value = '';
                    
                    setTimeout(() => {
                        window.location.href = '/devices';
                    }, 1500);
                } else {
                    showToast('Error', data.message, 'error');
                }
            } catch (error) {
                hideLoading();
                showToast('Error', 'Network Error: ' + error.message, 'error');
                console.error('Quick Add Error:', error);
            }
        }

        // ======================
        // API STATUS DISPLAY
        // ======================
        const apiStatus = document.getElementById('apiStatus');

        function showApiStatus(type, message) {
            apiStatus.className = `api-status api-${type}`;
            apiStatus.innerHTML = `
                <div class="d-flex align-items-center">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
                    <div>${message}</div>
                </div>
            `;
            apiStatus.style.display = 'block';
            
            setTimeout(() => {
                apiStatus.style.display = 'none';
            }, 5000);
        }

        // ======================
        // LOADING OVERLAY
        // ======================
        const loadingOverlay = document.getElementById('loadingOverlay');
        const loadingText = document.getElementById('loadingText');
        const loadingSubtext = document.getElementById('loadingSubtext');

        function showLoading(text, subtext) {
            loadingText.textContent = text;
            loadingSubtext.textContent = subtext;
            loadingOverlay.style.display = 'flex';
        }

        function hideLoading() {
            loadingOverlay.style.display = 'none';
        }

        // ======================
        // DRAFT FUNCTIONS
        // ======================
        function saveDraft() {
            const draft = getFormData();
            localStorage.setItem('deviceDraft', JSON.stringify(draft));
        }

        function loadDraft() {
            const draft = localStorage.getItem('deviceDraft');
            if (draft) {
                try {
                    const data = JSON.parse(draft);
                    document.getElementById('deviceName').value = data.name || '';
                    document.getElementById('phoneNumber').value = data.phoneNumber || '';
                    document.getElementById('whatsappNumber').value = data.whatsappNumber || '';
                    document.getElementById('email').value = data.email || '';
                    document.getElementById('notes').value = data.notes || '';
                    
                    if (data.status) {
                        document.querySelector(`input[name="status"][value="${data.status}"]`).checked = true;
                    }
                    
                    validateName();
                    validatePhone();
                    validateWhatsApp();
                    validateEmail();
                    
                    if (data.name || data.phoneNumber) {
                        showToast('Draft Loaded', 'Loaded saved draft from previous session', 'info');
                    }
                } catch (e) {
                    console.error('Error loading draft:', e);
                }
            }
        }

        function clearDraft() {
            localStorage.removeItem('deviceDraft');
        }

        // ======================
        // EVENT LISTENERS
        // ======================
        document.getElementById('deviceName').addEventListener('input', function() {
            validateName();
            debounceSaveDraft();
        });
        
        document.getElementById('phoneNumber').addEventListener('input', function() {
            validatePhone();
            debounceSaveDraft();
        });
        
        document.getElementById('whatsappNumber').addEventListener('input', function() {
            validateWhatsApp();
            debounceSaveDraft();
        });
        
        document.getElementById('email').addEventListener('input', function() {
            validateEmail();
            debounceSaveDraft();
        });
        
        document.getElementById('notes').addEventListener('input', debounceSaveDraft);
        
        document.querySelectorAll('input[name="status"]').forEach(radio => {
            radio.addEventListener('change', debounceSaveDraft);
        });

        let draftTimer;
        function debounceSaveDraft() {
            clearTimeout(draftTimer);
            draftTimer = setTimeout(saveDraft, 1000);
        }

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                if (validateForm()) {
                    addViaAPI();
                }
            }
            
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                if (validateForm()) {
                    form.submit();
                }
            }
            
            if (e.key === 'Escape') {
                if (!confirm('Are you sure you want to cancel? Unsaved changes will be lost.')) {
                    return;
                }
                window.location.href = '/devices';
            }
            
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Press Ctrl+Enter for API, Ctrl+S to save', 'info');
            }
        });

        // Double-click to generate sample data
        document.getElementById('phoneNumber').addEventListener('dblclick', function() {
            if (!this.value) {
                const randomNum = '9' + Math.floor(Math.random() * 1000000000).toString().padStart(9, '0');
                this.value = randomNum;
                validatePhone();
                saveDraft();
                showToast('Sample', 'Generated sample phone number', 'info');
            }
        });

        document.getElementById('whatsappNumber').addEventListener('dblclick', function() {
            if (!this.value) {
                const randomNum = '9' + Math.floor(Math.random() * 1000000000).toString().padStart(9, '0');
                this.value = randomNum;
                validateWhatsApp();
                saveDraft();
                showToast('Sample', 'Generated sample WhatsApp number', 'info');
            }
        });

        document.getElementById('email').addEventListener('dblclick', function() {
            if (!this.value) {
                const names = ['john', 'jane', 'bob', 'alice', 'mike', 'sarah'];
                const randomName = names[Math.floor(Math.random() * names.length)];
                this.value = randomName + '@example.com';
                validateEmail();
                saveDraft();
                showToast('Sample', 'Generated sample email', 'info');
            }
        });

        document.getElementById('deviceName').addEventListener('dblclick', function() {
            if (!this.value) {
                const names = ['John Doe', 'Jane Smith', 'Office Phone', 'Personal Device', 'Sales Team', 'Support Line'];
                const randomName = names[Math.floor(Math.random() * names.length)];
                this.value = randomName;
                validateName();
                saveDraft();
                showToast('Sample', 'Generated sample contact name', 'info');
            }
        });
    </script>
</body>
</html>