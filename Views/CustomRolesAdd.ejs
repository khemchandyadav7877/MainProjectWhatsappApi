<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New User - Custom Roles</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        /* ===== THEME VARIABLES ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #ffffff;
            --bg-white: #ffffff;
            --bg-offwhite: #f8fafc;
            --bg-card: #ffffff;
            --text: #1e293b;
            --text-light: #475569;
            --text-muted: #64748b;
            --dark: #0f172a;
            --border: #e2e8f0;
            --shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            --shadow-sm: 0 4px 30px rgba(0, 0, 0, 0.1);
            
            --header-bg: rgba(255, 255, 255, 0.95);
            --sidebar-bg: #ffffff;
            --input-bg: #f8fafc;
            
            /* Layout */
            --header-height: 80px;
            --sidebar-width: 280px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --text: #f1f5f9;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            --shadow-sm: 0 4px 30px rgba(0, 0, 0, 0.3);
            
            --header-bg: rgba(30, 41, 59, 0.95);
            --sidebar-bg: #1e293b;
            --input-bg: #334155;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-body);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar-wrapper,
        body.round-border .form-container,
        body.round-border .form-header,
        body.round-border .back-btn,
        body.round-border .form-control,
        body.round-border .form-select,
        body.round-border .btn-primary,
        body.round-border .btn-secondary,
        body.round-border .role-badge,
        body.round-border .profile-status,
        body.round-border .toast-notification,
        body.round-border .input-wrapper,
        body.round-border .password-indicator,
        body.round-border .role-preview {
            border-radius: 20px !important;
        }

        body.round-border .match-bar,
        body.round-border .status-bar {
            border-radius: 10px !important;
        }

        body.round-border .toast-icon {
            border-radius: 50% !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar-wrapper,
        body.no-radius .form-container,
        body.no-radius .form-header,
        body.no-radius .back-btn,
        body.no-radius .form-control,
        body.no-radius .form-select,
        body.no-radius .btn-primary,
        body.no-radius .btn-secondary,
        body.no-radius .role-badge,
        body.no-radius .profile-status,
        body.no-radius .toast-notification,
        body.no-radius .input-wrapper,
        body.no-radius .password-indicator,
        body.no-radius .role-preview,
        body.no-radius .match-bar,
        body.no-radius .status-bar,
        body.no-radius .toast-icon {
            border-radius: 0 !important;
        }

        /* Modern Header */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--header-bg);
            backdrop-filter: blur(10px);
            box-shadow: var(--shadow-sm);
            border-bottom: 1px solid rgba(102, 126, 234, 0.1);
        }

        .main-wrapper {
            margin-top: 80px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 80px);
        }

        /* Modern Sidebar */
        .sidebar-wrapper {
            width: 280px;
            flex-shrink: 0;
            position: fixed;
            left: 0;
            top: 80px;
            bottom: 0;
            z-index: 1020;
            background: var(--sidebar-bg);
            border-right: 1px solid rgba(102, 126, 234, 0.1);
            box-shadow: 4px 0 20px rgba(0,0,0,0.02);
            transition: all 0.3s ease;
        }

        .content-wrapper {
            flex: 1;
            margin-left: 280px;
            padding: 30px;
            min-height: calc(100vh - 80px);
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 768px) {
            .sidebar-wrapper {
                transform: translateX(-100%);
                width: 280px !important;
            }
            .content-wrapper {
                margin-left: 0 !important;
            }
        }

        /* Premium Toast */
        #toast {
            position: fixed;
            top: 100px;
            right: 30px;
            width: 360px;
            padding: 16px 20px;
            border-radius: 16px;
            box-shadow: var(--shadow);
            opacity: 0;
            transform: translateX(30px);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            color: #fff;
            z-index: 9999;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
        }

        #toast.show {
            opacity: 1;
            transform: translateX(0);
        }

        .toast-success { background: linear-gradient(135deg, var(--success), #059669); }
        .toast-error { background: linear-gradient(135deg, var(--danger), #dc2626); }
        .toast-info { background: linear-gradient(135deg, var(--info), #2563eb); }

        /* Main Card - React Style */
        .form-container {
            max-width: 1000px;
            margin: 0 auto;
            background: var(--bg-card);
            border-radius: 30px;
            overflow: hidden;
            box-shadow: var(--shadow);
            animation: slideUp 0.5s ease-out;
            border: 1px solid var(--border);
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Header Section */
        .form-header {
            background: var(--primary-gradient);
            color: white;
            padding: 30px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .header-content h1 {
            margin: 0;
            font-size: 2.5rem;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .header-content .subtitle {
            margin: 8px 0 0;
            font-size: 1.1rem;
            opacity: 0.9;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .back-btn {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
            padding: 12px 24px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 600;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .back-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            color: white;
        }

        /* Form Body */
        .form-body {
            padding: 40px;
        }

        /* Section Title */
        .section-title {
            color: var(--dark);
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            padding-bottom: 15px;
            border-bottom: 2px solid var(--border);
        }

        .section-title i {
            color: var(--primary);
            font-size: 1.5rem;
        }

        /* Form Grid */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            margin-bottom: 30px;
        }

        @media (max-width: 640px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Form Field */
        .form-field {
            margin-bottom: 0;
        }

        .form-field label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-light);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-field label i {
            color: var(--primary);
            margin-right: 8px;
        }

        .required-star {
            color: var(--danger);
            margin-left: 4px;
        }

        /* Input Wrapper */
        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            z-index: 1;
        }

        .form-control, .form-select {
            width: 100%;
            padding: 14px 16px 14px 45px;
            border: 2px solid var(--border);
            border-radius: 14px;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s;
            background: var(--input-bg);
            color: var(--text);
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
            background: var(--bg-white);
            outline: none;
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.6;
        }

        /* Password Match Indicator */
        .password-indicator {
            margin-top: 10px;
        }

        .match-bar {
            height: 6px;
            background: var(--border);
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 8px;
        }

        .match-fill {
            height: 100%;
            width: 0;
            transition: all 0.3s;
        }

        .match-fill.match-green {
            background: linear-gradient(90deg, var(--success), #34d399);
            width: 100%;
        }

        .match-fill.match-red {
            background: linear-gradient(90deg, var(--danger), #f87171);
            width: 100%;
        }

        .match-text {
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .match-text i {
            font-size: 14px;
        }

        .text-success { color: var(--success); }
        .text-danger { color: var(--danger); }
        .text-muted { color: var(--text-muted); }

        /* Role Options Preview */
        .role-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
            padding: 10px;
            background: var(--bg-offwhite);
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .role-badge {
            padding: 6px 12px;
            background: var(--bg-white);
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            color: var(--text);
            border: 1px solid var(--border);
            transition: all 0.2s;
        }

        .role-badge:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        /* Action Buttons */
        .form-actions {
            margin-top: 40px;
            padding-top: 30px;
            border-top: 2px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        .btn-primary {
            background: var(--primary-gradient);
            color: white;
            border: none;
            padding: 14px 35px;
            border-radius: 14px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 10px 20px -5px rgba(102, 126, 234, 0.4);
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 20px 30px -5px rgba(102, 126, 234, 0.5);
        }

        .btn-primary:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            background: linear-gradient(135deg, var(--text-muted), var(--text-muted));
        }

        .btn-secondary {
            background: var(--bg-white);
            color: var(--text);
            border: 2px solid var(--border);
            padding: 14px 30px;
            border-radius: 14px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .btn-secondary:hover {
            background: var(--bg-offwhite);
            border-color: var(--text-muted);
            color: var(--text);
            transform: translateY(-2px);
        }

        /* Loading Spinner */
        .spinner {
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Profile Complete Bar */
        .profile-status {
            margin: 30px 0;
            padding: 20px;
            background: var(--bg-offwhite);
            border-radius: 16px;
            border: 1px solid var(--border);
        }

        .status-bar {
            height: 8px;
            background: var(--border);
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 10px;
        }

        .status-fill {
            height: 100%;
            width: 30%;
            background: var(--primary-gradient);
            border-radius: 10px;
            transition: width 0.3s;
        }

        .status-text {
            font-size: 14px;
            color: var(--text-muted);
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-text i {
            color: var(--primary);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .form-header {
                flex-direction: column;
                text-align: center;
            }
            
            .form-actions {
                flex-direction: column;
            }
            
            .btn-primary, .btn-secondary {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <div class="sidebar-wrapper" id="sidebarWrapper">
            <%- include('../partials/ram/sidebaar') %>
        </div>

        <!-- CONTENT -->
        <div class="content-wrapper">
            <!-- Toast for messages -->
            <div id="toast"></div>

            <!-- Main Form Container -->
            <div class="form-container">
                <!-- Header -->
                <div class="form-header">
                    <div class="header-content">
                        <h1>
                            <i class="fas fa-user-plus me-2"></i>
                            Add New User
                        </h1>
                        <p class="subtitle">
                            <i class="fas fa-info-circle"></i>
                            Create a new user with custom role and permissions
                        </p>
                    </div>
                    <a href="/CustomRoles" class="back-btn">
                        <i class="fas fa-arrow-left"></i>
                        Back to List
                    </a>
                </div>

                <!-- Form Body -->
                <div class="form-body">
                    <form action="/CustomRoles/create" method="POST" id="createUserForm">
                        <!-- Personal Information Section -->
                        <div class="section-title">
                            <i class="fas fa-user-circle"></i>
                            Personal Information
                        </div>

                        <div class="form-grid">
                            <!-- First Name -->
                            <div class="form-field">
                                <label>
                                    <i class="fas fa-user"></i>
                                    First Name <span class="required-star">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <i class="fas fa-user input-icon"></i>
                                    <input 
                                        type="text" 
                                        name="firstName" 
                                        class="form-control" 
                                        required 
                                        placeholder="Enter first name"
                                        onkeyup="updateProfileStatus()"
                                    >
                                </div>
                            </div>

                            <!-- Last Name -->
                            <div class="form-field">
                                <label>
                                    <i class="fas fa-user"></i>
                                    Last Name <span class="required-star">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <i class="fas fa-user input-icon"></i>
                                    <input 
                                        type="text" 
                                        name="lastName" 
                                        class="form-control" 
                                        required 
                                        placeholder="Enter last name"
                                        onkeyup="updateProfileStatus()"
                                    >
                                </div>
                            </div>

                            <!-- Email -->
                            <div class="form-field">
                                <label>
                                    <i class="fas fa-envelope"></i>
                                    Email <span class="required-star">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <i class="fas fa-envelope input-icon"></i>
                                    <input 
                                        type="email" 
                                        name="email" 
                                        class="form-control" 
                                        required 
                                        placeholder="user@example.com"
                                        onkeyup="updateProfileStatus()"
                                    >
                                </div>
                            </div>

                            <!-- Mobile Number -->
                            <div class="form-field">
                                <label>
                                    <i class="fas fa-phone"></i>
                                    Mobile Number
                                </label>
                                <div class="input-wrapper">
                                    <i class="fas fa-phone input-icon"></i>
                                    <input 
                                        type="tel" 
                                        name="contactNumber" 
                                        class="form-control" 
                                        placeholder="9876543210"
                                        onkeyup="updateProfileStatus()"
                                    >
                                </div>
                            </div>

                            <!-- Date of Birth -->
                            <div class="form-field">
                                <label>
                                    <i class="fas fa-calendar"></i>
                                    Date of Birth
                                </label>
                                <div class="input-wrapper">
                                    <i class="fas fa-calendar input-icon"></i>
                                    <input 
                                        type="date" 
                                        name="dob" 
                                        class="form-control"
                                        onchange="updateProfileStatus()"
                                    >
                                </div>
                            </div>

                            <!-- Role -->
                            <div class="form-field">
                                <label>
                                    <i class="fas fa-tag"></i>
                                    Role <span class="required-star">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <i class="fas fa-tag input-icon"></i>
                                    <select 
                                        name="role" 
                                        class="form-select" 
                                        required
                                        onchange="updateProfileStatus()"
                                    >
                                        <option value="">Select Role</option>
                                        <option value="SuperAdmin">👑 Super Admin</option>
                                        <option value="Educator">📚 Educator</option>
                                        <option value="Trainer">🎯 Trainer</option>
                                        <option value="Student">🎓 Student</option>
                                        <option value="user">👤 User</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Role Preview -->
                        <div class="role-preview">
                            <span class="role-badge">👑 Super Admin</span>
                            <span class="role-badge">📚 Educator</span>
                            <span class="role-badge">🎯 Trainer</span>
                            <span class="role-badge">🎓 Student</span>
                            <span class="role-badge">👤 User</span>
                        </div>

                        <!-- Security Section -->
                        <div class="section-title" style="margin-top: 40px;">
                            <i class="fas fa-shield-alt"></i>
                            Security
                        </div>

                        <div class="form-grid">
                            <!-- Password -->
                            <div class="form-field">
                                <label>
                                    <i class="fas fa-lock"></i>
                                    Password <span class="required-star">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <i class="fas fa-lock input-icon"></i>
                                    <input 
                                        type="password" 
                                        name="password" 
                                        id="password"
                                        class="form-control" 
                                        required 
                                        minlength="6"
                                        placeholder="••••••••"
                                        onkeyup="checkPasswordMatch()"
                                    >
                                </div>
                            </div>

                            <!-- Confirm Password -->
                            <div class="form-field">
                                <label>
                                    <i class="fas fa-check-circle"></i>
                                    Confirm Password <span class="required-star">*</span>
                                </label>
                                <div class="input-wrapper">
                                    <i class="fas fa-check-circle input-icon"></i>
                                    <input 
                                        type="password" 
                                        name="confirmPassword" 
                                        id="confirmPassword"
                                        class="form-control" 
                                        required 
                                        minlength="6"
                                        placeholder="••••••••"
                                        onkeyup="checkPasswordMatch()"
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Password Match Indicator -->
                        <div class="password-indicator" id="passwordIndicator">
                            <div class="match-bar">
                                <div class="match-fill" id="matchFill"></div>
                            </div>
                            <div class="match-text text-muted" id="matchText">
                                <i class="fas fa-info-circle"></i>
                                Enter both passwords to continue
                            </div>
                        </div>

                        <!-- Profile Status -->
                        <div class="profile-status">
                            <div class="status-bar">
                                <div class="status-fill" id="statusFill" style="width: 30%;"></div>
                            </div>
                            <div class="status-text" id="statusText">
                                <i class="fas fa-chart-line"></i>
                                Profile Completion: <span id="completionPercent">30</span>%
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="form-actions">
                            <button type="reset" class="btn-secondary" onclick="window.location.href='/CustomRoles'">
                                <i class="fas fa-times me-2"></i>
                                Cancel
                            </button>
                            <button type="submit" class="btn-primary" id="submitBtn" disabled>
                                <i class="fas fa-save me-2"></i>
                                Create User
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // ===== Password Match Check =====
        function checkPasswordMatch() {
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirmPassword').value;
            const matchFill = document.getElementById('matchFill');
            const matchText = document.getElementById('matchText');
            const submitBtn = document.getElementById('submitBtn');
            
            if (password && confirm) {
                if (password === confirm) {
                    // Passwords match
                    matchFill.className = 'match-fill match-green';
                    matchText.innerHTML = '<i class="fas fa-check-circle text-success"></i> <span class="text-success">✓ Passwords match - Perfect!</span>';
                    submitBtn.disabled = false;
                } else {
                    // Passwords don't match
                    matchFill.className = 'match-fill match-red';
                    matchText.innerHTML = '<i class="fas fa-exclamation-circle text-danger"></i> <span class="text-danger">✗ Passwords do not match</span>';
                    submitBtn.disabled = true;
                }
            } else {
                // One or both passwords empty
                matchFill.className = 'match-fill';
                matchFill.style.width = '0';
                matchText.innerHTML = '<i class="fas fa-info-circle text-muted"></i> <span class="text-muted">Enter both passwords to continue</span>';
                submitBtn.disabled = true;
            }
            
            // Update profile status
            updateProfileStatus();
        }

        // ===== Profile Completion Status =====
        function updateProfileStatus() {
            const fields = {
                firstName: document.querySelector('[name="firstName"]').value,
                lastName: document.querySelector('[name="lastName"]').value,
                email: document.querySelector('[name="email"]').value,
                role: document.querySelector('[name="role"]').value,
                password: document.getElementById('password').value,
                confirmPassword: document.getElementById('confirmPassword').value
            };
            
            let completed = 0;
            const total = 6; // Total required fields
            
            if (fields.firstName) completed++;
            if (fields.lastName) completed++;
            if (fields.email) completed++;
            if (fields.role) completed++;
            if (fields.password && fields.password.length >= 6) completed++;
            if (fields.confirmPassword && fields.password === fields.confirmPassword) completed++;
            
            const percentage = Math.round((completed / total) * 100);
            
            document.getElementById('statusFill').style.width = percentage + '%';
            document.getElementById('completionPercent').textContent = percentage;
        }

        // ===== Show Toast Messages =====
        document.addEventListener('DOMContentLoaded', function() {
            const urlParams = new URLSearchParams(window.location.search);
            const message = urlParams.get('message');
            const messageType = urlParams.get('messageType');
            
            if (message) {
                showToast(
                    messageType === 'success' ? '🎉 Success!' : messageType === 'error' ? '❌ Error!' : 'ℹ️ Info',
                    message, 
                    messageType
                );
            }
        });

        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            const icons = {
                'success': '<i class="fas fa-check-circle" style="font-size: 24px;"></i>',
                'error': '<i class="fas fa-times-circle" style="font-size: 24px;"></i>',
                'info': '<i class="fas fa-info-circle" style="font-size: 24px;"></i>'
            };
            
            toast.innerHTML = `
                <div style="display: flex; gap: 16px; align-items: center;">
                    <div style="font-size: 24px;">${icons[type]}</div>
                    <div style="flex: 1;">
                        <h4 style="margin: 0 0 4px; font-size: 16px; font-weight: 700;">${title}</h4>
                        <p style="margin: 0; font-size: 14px; opacity: 0.9;">${message}</p>
                    </div>
                </div>
                <div style="height: 4px; background: rgba(255,255,255,0.3); border-radius: 2px; margin-top: 12px; overflow: hidden;">
                    <div style="height: 100%; background: white; width: 100%; animation: progress 3s linear;"></div>
                </div>
            `;
            
            toast.className = `toast-${type} show`;
            
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ===== Form Submit Loading State =====
        document.getElementById('createUserForm').addEventListener('submit', function(e) {
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Creating User...';
        });

        // ===== Real-time Validation =====
        document.querySelectorAll('input, select').forEach(element => {
            element.addEventListener('input', updateProfileStatus);
            element.addEventListener('change', updateProfileStatus);
        });

        // ===== Add animation styles =====
        const style = document.createElement('style');
        style.textContent = `
            @keyframes progress {
                from { width: 100%; }
                to { width: 0%; }
            }
            
            @keyframes pulse {
                0% { transform: scale(1); }
                50% { transform: scale(1.05); }
                100% { transform: scale(1); }
            }
            
            .btn-primary:not(:disabled):hover {
                animation: pulse 0.5s;
            }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>