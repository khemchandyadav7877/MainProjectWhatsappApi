<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - SSPAR Cloud</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ===== THEME VARIABLES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f8fafc;
            --bg-white: #ffffff;
            --bg-offwhite: #f1f5f9;
            --bg-card: #ffffff;
            --text: #334155;
            --text-light: #64748b;
            --text-muted: #94a3b8;
            --dark: #0f172a;
            --border: #eef2f6;
            --shadow: 0 8px 25px rgba(0,0,0,0.03);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
            --sidebar-mini-width: 80px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --text: #e2e8f0;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 8px 25px rgba(0,0,0,0.2);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: 'Inter', 'Segoe UI', sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar,
        body.round-border .mid-content,
        body.round-border .password-card,
        body.round-border .input-group,
        body.round-border .form-control,
        body.round-border .btn-submit,
        body.round-border .btn-outline-primary,
        body.round-border .alert,
        body.round-border .info-box,
        body.round-border .toast-notification,
        body.round-border .strength-bar,
        body.round-border .validation-rules {
            border-radius: 20px !important;
        }

        body.round-border .input-group-text,
        body.round-border .toggle-password {
            border-radius: 20px 0 0 20px !important;
        }

        body.round-border .toggle-password {
            border-radius: 0 20px 20px 0 !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar,
        body.no-radius .mid-content,
        body.no-radius .password-card,
        body.no-radius .input-group,
        body.no-radius .form-control,
        body.no-radius .btn-submit,
        body.no-radius .btn-outline-primary,
        body.no-radius .alert,
        body.no-radius .info-box,
        body.no-radius .toast-notification,
        body.no-radius .input-group-text,
        body.no-radius .toggle-password,
        body.no-radius .strength-bar,
        body.no-radius .validation-rules {
            border-radius: 0 !important;
        }

        /* Header */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        /* MAIN LAYOUT - EXACTLY LIKE PREVIOUS TEMPLATES */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
            position: relative;
        }

        /* SIDEBAR - EXACTLY LIKE PREVIOUS TEMPLATES */
        .sidebar {
            width: var(--sidebar-width, 280px);
            background: var(--bg-white);
            border-right: 1px solid var(--border);
            height: calc(100vh - var(--header-height, 70px));
            position: fixed;
            left: 0;
            top: 70px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1020;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }

        /* Sidebar Mini Mode */
        .sidebar.mini {
            width: var(--sidebar-mini-width, 80px);
        }

        /* CONTENT WRAPPER - EXACTLY LIKE PREVIOUS TEMPLATES */
        .content-wrapper {
            flex: 1;
            margin-left: var(--sidebar-width, 280px);
            padding: 25px;
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
            width: calc(100% - var(--sidebar-width, 280px));
        }

        /* When sidebar has mini class, adjust content wrapper */
        .sidebar.mini ~ .content-wrapper {
            margin-left: var(--sidebar-mini-width, 80px);
            width: calc(100% - var(--sidebar-mini-width, 80px));
        }

        .mid-content {
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
                transition: transform 0.3s ease;
            }
            
            .sidebar.open {
                transform: translateX(0);
            }
            
            .sidebar.mini {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
            }
            
            .sidebar.mini.open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
                padding: 15px;
            }
            
            .sidebar.mini ~ .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
            }
        }

        /* Toast - EXACTLY LIKE PREVIOUS TEMPLATES */
        #toast {
            position: fixed;
            top: 90px;
            right: 29px;
            width: 320px;
            padding: 16px 20px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 1001;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-content {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            font-size: 20px;
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 5px 0 0;
            font-size: 13px;
            opacity: 0.9;
        }

        .toast-progress {
            height: 3px;
            background: rgba(255,255,255,0.6);
            margin-top: 12px;
            width: 100%;
            animation: progress 3s linear;
        }

        @keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* Loading Overlay */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(5px);
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid var(--bg-offwhite);
            border-top: 5px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .loading-text {
            color: white;
            margin-top: 15px;
            font-size: 18px;
            font-weight: 600;
        }

        /* Page Header - Matching Edit Profile */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .page-title {
            font-size: 28px;
            font-weight: 700;
            color: var(--dark);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-title i {
            color: var(--primary);
        }

        .page-subtitle {
            color: var(--text-muted);
            margin: 5px 0 0;
            font-size: 15px;
        }

        /* Password Card - Matching Edit Profile Card */
        .password-card {
            background: var(--bg-card);
            border-radius: 20px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border);
            overflow: hidden;
            animation: slideUp 0.5s ease-out;
            max-width: 800px;
            margin: 0 auto;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Password Card Header - Matching Edit Profile Header */
        .password-header {
            background: var(--primary-gradient);
            padding: 30px 35px;
            color: white;
        }

        .password-header h2 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .password-header p {
            margin: 8px 0 0;
            opacity: 0.95;
            font-size: 15px;
        }

        /* Password Body - Matching Edit Profile Body */
        .password-body {
            padding: 40px 35px;
        }

        @media (max-width: 640px) {
            .password-body {
                padding: 25px 20px;
            }
        }

        /* Form Elements - Matching Edit Profile */
        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            font-weight: 600;
            font-size: 13px;
            color: var(--text-light);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .form-label i {
            color: var(--primary);
            margin-right: 6px;
            width: 16px;
        }

        .input-group {
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s;
            background: var(--bg-white);
        }

        .input-group:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .input-group-text {
            background: var(--bg-offwhite);
            border: none;
            color: var(--text-muted);
            padding: 12px 16px;
            font-size: 14px;
        }

        .form-control {
            border: none;
            padding: 12px 16px;
            font-size: 14px;
            background: var(--bg-white);
            color: var(--text);
        }

        .form-control:focus {
            outline: none;
            box-shadow: none;
            background: var(--bg-white);
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.7;
        }

        .toggle-password {
            cursor: pointer;
            background: var(--bg-offwhite);
            border: none;
            color: var(--text-muted);
            padding: 12px 16px;
            display: flex;
            align-items: center;
            transition: all 0.2s;
        }

        .toggle-password:hover {
            color: var(--primary);
        }

        /* Password strength indicator */
        .password-strength {
            margin-top: 10px;
            font-size: 13px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .strength-bar {
            height: 6px;
            border-radius: 10px;
            margin-top: 6px;
            transition: all 0.3s;
            background: var(--border);
        }

        /* Validation Rules - Matching Edit Profile section */
        .validation-rules {
            margin-top: 15px;
            padding: 20px;
            background: var(--bg-offwhite);
            border-radius: 16px;
            border: 1px solid var(--border);
        }

        .section-subtitle {
            font-size: 16px;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-subtitle i {
            color: var(--primary);
        }

        .rule-item {
            font-size: 13px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .rule-item i {
            width: 18px;
            font-size: 14px;
        }

        /* Match Message */
        .match-message {
            margin-top: 8px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Buttons - Matching Edit Profile */
        .btn {
            padding: 12px 28px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 16px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
        }

        .btn-submit {
            background: var(--primary-gradient);
            color: white;
            width: 100%;
            justify-content: center;
            margin-top: 25px;
            box-shadow: var(--shadow);
        }

        .btn-submit:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-outline-primary {
            background: transparent;
            border: 1px solid var(--primary);
            color: var(--primary);
            padding: 12px 28px;
        }

        .btn-outline-primary:hover {
            background: var(--primary-gradient);
            color: white;
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        /* Alert Messages */
        .alert {
            border-radius: 16px;
            padding: 16px 20px;
            margin-bottom: 25px;
            border: none;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border-left: 4px solid var(--success);
        }

        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border-left: 4px solid var(--danger);
        }

        .alert-info {
            background: rgba(59, 130, 246, 0.1);
            color: var(--info);
            border-left: 4px solid var(--info);
        }

        /* Info Box - Matching Edit Profile */
        .info-box {
            background: var(--bg-offwhite);
            border-radius: 16px;
            padding: 20px;
            margin-top: 25px;
            font-size: 14px;
            color: var(--text-muted);
            border: 1px dashed var(--border);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .info-box i {
            color: var(--primary);
            font-size: 20px;
        }

        .info-box strong {
            color: var(--text-light);
        }

        /* Footer - Matching Edit Profile */
        .password-footer {
            padding: 25px 35px;
            background: var(--bg-offwhite);
            border-top: 1px solid var(--border);
        }

        @media (max-width: 640px) {
            .password-footer {
                padding: 20px;
            }
        }

        /* Valid/Invalid classes */
        .valid {
            color: var(--success) !important;
        }

        .invalid {
            color: var(--danger) !important;
        }

        .text-muted {
            color: var(--text-muted) !important;
        }

        /* Responsive - Matching Edit Profile */
        @media (max-width: 992px) {
            .page-title {
                font-size: 24px;
            }
            
            .password-header h2 {
                font-size: 24px;
            }
        }

        @media (max-width: 768px) {
            .content-wrapper {
                padding: 15px;
            }
            
            .password-header {
                padding: 25px 20px;
            }
            
            .password-header h2 {
                font-size: 22px;
            }
            
            .page-header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .btn-outline-primary {
                width: 100%;
                justify-content: center;
            }
        }

        @media (max-width: 576px) {
            .content-wrapper {
                padding: 10px;
            }
            
            .password-header {
                padding: 20px;
            }
            
            .password-header h2 {
                font-size: 20px;
            }
            
            .password-header p {
                font-size: 14px;
            }
            
            .btn {
                padding: 10px 20px;
                font-size: 14px;
            }
            
            .input-group-text,
            .form-control,
            .toggle-password {
                padding: 10px 12px;
            }
            
            .validation-rules {
                padding: 15px;
            }
            
            .rule-item {
                font-size: 12px;
            }
            
            #toast {
                width: calc(100% - 30px);
                left: 15px;
                right: 15px;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- Toast Container -->
    <div id="toast"></div>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="text-center">
            <div class="spinner"></div>
            <div class="loading-text">Updating Password...</div>
        </div>
    </div>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <%- include('../../partials/ram/sidebaar') %>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <div class="mid-content">
                <!-- Page Header -->
                <div class="page-header">
                    <div>
                        <h1 class="page-title">
                            <i class="fas fa-key"></i>
                            Change Password
                        </h1>
                        <p class="page-subtitle">Update your account password for better security</p>
                    </div>
                    <button class="btn btn-outline-primary" onclick="goBack()">
                        <i class="fas fa-arrow-left"></i> Back to Profile
                    </button>
                </div>

                <!-- Password Change Card -->
                <div class="password-card">
                    <div class="password-header">
                        <h2><i class="fas fa-lock"></i> Change Password</h2>
                        <p>Create a strong password to secure your account</p>
                    </div>

                    <div class="password-body">
                        <!-- Show messages if any (from server) -->
                        <% if (locals.message) { %>
                            <div class="alert alert-<%= messageType === 'error' ? 'error' : 'success' %>">
                                <i class="fas fa-<%= messageType === 'error' ? 'exclamation-circle' : 'check-circle' %>"></i>
                                <%= message %>
                            </div>
                        <% } %>

                        <form id="passwordForm" action="/change-password" method="POST" onsubmit="return validateForm(event)">
                            <!-- Old Password -->
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-lock"></i>
                                    Current Password
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                    <input type="password" class="form-control" id="oldPassword" name="oldPassword" placeholder="Enter current password" required>
                                    <span class="toggle-password" onclick="togglePassword('oldPassword')">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                            </div>

                            <!-- New Password -->
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-key"></i>
                                    New Password
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-key"></i></span>
                                    <input type="password" class="form-control" id="newPassword" name="newPassword" placeholder="Enter new password" required>
                                    <span class="toggle-password" onclick="togglePassword('newPassword')">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                                
                                <!-- Password strength indicator -->
                                <div class="password-strength">
                                    <span>Password strength:</span>
                                    <span id="strengthText">Not entered</span>
                                </div>
                                <div class="strength-bar" id="strengthBar"></div>
                                
                                <!-- Validation rules -->
                                <div class="validation-rules">
                                    <div class="section-subtitle">
                                        <i class="fas fa-shield-alt"></i> Password Requirements
                                    </div>
                                    <div class="rule-item" id="lengthCheck">
                                        <i class="fas fa-circle text-muted"></i>
                                        <span>At least 8 characters</span>
                                    </div>
                                    <div class="rule-item" id="upperCheck">
                                        <i class="fas fa-circle text-muted"></i>
                                        <span>At least one uppercase letter</span>
                                    </div>
                                    <div class="rule-item" id="lowerCheck">
                                        <i class="fas fa-circle text-muted"></i>
                                        <span>At least one lowercase letter</span>
                                    </div>
                                    <div class="rule-item" id="numberCheck">
                                        <i class="fas fa-circle text-muted"></i>
                                        <span>At least one number</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Confirm Password -->
                            <div class="form-group">
                                <label class="form-label">
                                    <i class="fas fa-check-circle"></i>
                                    Confirm New Password
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
                                    <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Confirm new password" required>
                                    <span class="toggle-password" onclick="togglePassword('confirmPassword')">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                </div>
                                <div class="match-message" id="matchMessage">
                                    <i class="fas fa-circle text-muted"></i>
                                    <span class="text-muted">Passwords must match</span>
                                </div>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" class="btn btn-submit" id="submitBtn" disabled>
                                <i class="fas fa-save"></i> Update Password
                            </button>
                        </form>

                        <!-- Info Box -->
                        <div class="info-box">
                            <i class="fas fa-shield-alt"></i>
                            <div>
                                <strong>Security Tip:</strong> Use a strong, unique password that you don't use elsewhere. Enable two-factor authentication for additional security.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // ======================
        // SIDEBAR STATE SYNC - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);

            // Initialize validation
            updateSubmitButton();
            
            // Show welcome toast
            setTimeout(() => {
                showToast('Welcome', 'Change your password securely', 'info');
            }, 1000);
        });

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOADING OVERLAY FUNCTIONS
        // ======================
        function showLoading(text = 'Processing...') {
            const overlay = document.getElementById('loadingOverlay');
            document.querySelector('.loading-text').textContent = text;
            overlay.style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        // ======================
        // NAVIGATION
        // ======================
        function goBack() {
            window.location.href = '/profile';
        }

        // ======================
        // PASSWORD FUNCTIONS
        // ======================
        
        // Toggle password visibility
        function togglePassword(fieldId) {
            const field = document.getElementById(fieldId);
            const icon = field.nextElementSibling?.querySelector('i') || field.parentElement.querySelector('.toggle-password i');
            
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        // Password strength check
        function checkPasswordStrength(password) {
            const lengthCheck = document.getElementById('lengthCheck');
            const upperCheck = document.getElementById('upperCheck');
            const lowerCheck = document.getElementById('lowerCheck');
            const numberCheck = document.getElementById('numberCheck');
            const strengthText = document.getElementById('strengthText');
            const strengthBar = document.getElementById('strengthBar');

            // Update icons
            const lengthValid = password.length >= 8;
            const upperValid = /[A-Z]/.test(password);
            const lowerValid = /[a-z]/.test(password);
            const numberValid = /[0-9]/.test(password);

            updateCheck(lengthCheck, lengthValid);
            updateCheck(upperCheck, upperValid);
            updateCheck(lowerCheck, lowerValid);
            updateCheck(numberCheck, numberValid);

            // Calculate strength
            const validCount = [lengthValid, upperValid, lowerValid, numberValid].filter(Boolean).length;
            let strength = 0;
            let text = '';
            let color = '';

            if (password.length === 0) {
                strength = 0;
                text = 'Not entered';
                color = 'var(--border)';
            } else if (validCount === 4) {
                strength = 100;
                text = 'Strong';
                color = 'var(--success)';
            } else if (validCount >= 2) {
                strength = 50;
                text = 'Medium';
                color = 'var(--warning)';
            } else {
                strength = 25;
                text = 'Weak';
                color = 'var(--danger)';
            }

            strengthText.textContent = text;
            strengthBar.style.width = strength + '%';
            strengthBar.style.background = color;
        }

        function updateCheck(element, isValid) {
            const icon = element.querySelector('i');
            if (isValid) {
                icon.className = 'fas fa-check-circle valid';
                element.classList.add('valid');
            } else {
                icon.className = 'fas fa-circle text-muted';
                element.classList.remove('valid');
            }
        }

        // Password match check
        function checkPasswordMatch() {
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;
            const matchMessage = document.getElementById('matchMessage');
            const icon = matchMessage.querySelector('i');
            const text = matchMessage.querySelector('span');

            if (confirmPass.length === 0) {
                icon.className = 'fas fa-circle text-muted';
                text.className = 'text-muted';
                text.textContent = 'Passwords must match';
            } else if (newPass === confirmPass) {
                icon.className = 'fas fa-check-circle valid';
                text.className = 'valid';
                text.textContent = '✓ Passwords match';
            } else {
                icon.className = 'fas fa-times-circle invalid';
                text.className = 'invalid';
                text.textContent = '✗ Passwords do not match';
            }
        }

        // Validate form before submit
        function validateForm(event) {
            event.preventDefault();
            
            const oldPass = document.getElementById('oldPassword').value;
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;

            if (!oldPass || !newPass || !confirmPass) {
                showToast('Error', 'Please fill all fields', 'error');
                return false;
            }

            // Check password strength
            const lengthValid = newPass.length >= 8;
            const upperValid = /[A-Z]/.test(newPass);
            const lowerValid = /[a-z]/.test(newPass);
            const numberValid = /[0-9]/.test(newPass);
            
            if (!lengthValid || !upperValid || !lowerValid || !numberValid) {
                showToast('Error', 'Password does not meet security requirements', 'error');
                return false;
            }

            if (newPass !== confirmPass) {
                showToast('Error', 'New passwords do not match', 'error');
                return false;
            }

            // Show loading
            showLoading('Updating password...');
            
            // Submit the form
            document.getElementById('passwordForm').submit();
            return true;
        }

        // Update submit button state
        function updateSubmitButton() {
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;
            const oldPass = document.getElementById('oldPassword').value;
            const submitBtn = document.getElementById('submitBtn');

            const lengthValid = newPass.length >= 8;
            const upperValid = /[A-Z]/.test(newPass);
            const lowerValid = /[a-z]/.test(newPass);
            const numberValid = /[0-9]/.test(newPass);
            const matchValid = newPass === confirmPass && newPass.length > 0;

            const allValid = oldPass.length > 0 && lengthValid && upperValid && lowerValid && numberValid && matchValid;
            submitBtn.disabled = !allValid;
        }

        // Event listeners
        document.getElementById('newPassword').addEventListener('input', function() {
            checkPasswordStrength(this.value);
            checkPasswordMatch();
            updateSubmitButton();
        });

        document.getElementById('confirmPassword').addEventListener('input', function() {
            checkPasswordMatch();
            updateSubmitButton();
        });

        document.getElementById('oldPassword').addEventListener('input', updateSubmitButton);

        // ======================
        // THEME FUNCTIONS
        // ======================
        function toggleTheme() {
            if (document.body.classList.contains('dark')) {
                document.body.classList.remove('dark');
                document.body.classList.add('light');
                localStorage.setItem('theme', 'light');
                showToast('Theme Updated', 'Light mode activated', 'info');
            } else {
                document.body.classList.remove('light');
                document.body.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                showToast('Theme Updated', 'Dark mode activated', 'info');
            }
        }

        function toggleBorder() {
            if (document.body.classList.contains('round-border')) {
                document.body.classList.remove('round-border');
                document.body.classList.add('no-radius');
                localStorage.setItem('border', 'no-radius');
                showToast('Border Style', 'Square corners activated', 'info');
            } else {
                document.body.classList.remove('no-radius');
                document.body.classList.add('round-border');
                localStorage.setItem('border', 'round-border');
                showToast('Border Style', 'Rounded corners activated', 'info');
            }
        }

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Fill all fields with valid password to enable submit', 'info');
            }
            
            if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                e.preventDefault();
                const submitBtn = document.getElementById('submitBtn');
                if (!submitBtn.disabled) {
                    document.getElementById('passwordForm').requestSubmit();
                }
            }
        });
    </script>
</body>
</html>