<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - SSPAR Cloud</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* ===== THEME VARIABLES ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f8fafc;
            --bg-white: #ffffff;
            --bg-offwhite: #f8fafc;
            --bg-card: #ffffff;
            --text: #1e293b;
            --text-light: #334155;
            --text-muted: #64748b;
            --dark: #0f172a;
            --border: #e2e8f0;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            --shadow-lg: 0 10px 20px rgba(102, 126, 234, 0.3);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --text: #f1f5f9;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            --shadow-lg: 0 10px 20px rgba(102, 126, 234, 0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-body);
            color: var(--text);
            overflow-x: hidden;
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar-wrapper,
        body.round-border .main-content,
        body.round-border .password-card,
        body.round-border .input-group,
        body.round-border .form-control,
        body.round-border .btn-submit,
        body.round-border .alert,
        body.round-border .info-box,
        body.round-border .btn-outline-primary,
        body.round-border .toast-notification {
            border-radius: 20px !important;
        }

        body.round-border .input-group-text,
        body.round-border .toggle-password {
            border-radius: 20px 0 0 20px !important;
        }

        body.round-border .strength-bar {
            border-radius: 10px !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar-wrapper,
        body.no-radius .main-content,
        body.no-radius .password-card,
        body.no-radius .input-group,
        body.no-radius .form-control,
        body.no-radius .btn-submit,
        body.no-radius .alert,
        body.no-radius .info-box,
        body.no-radius .btn-outline-primary,
        body.no-radius .toast-notification,
        body.no-radius .input-group-text,
        body.no-radius .toggle-password,
        body.no-radius .strength-bar {
            border-radius: 0 !important;
        }

        /* HEADER FIXED */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        /* MAIN LAYOUT */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
        }

        /* SIDEBAR WRAPPER */
        .sidebar-wrapper {
            width: 280px;
            flex-shrink: 0;
            position: fixed;
            left: 0;
            top: 70px;
            bottom: 0;
            z-index: 1020;
            transition: width 0.3s ease;
            background: var(--bg-white);
            border-right: 1px solid var(--border);
        }

        .sidebar-wrapper.collapsed {
            width: 80px;
        }

        /* CONTENT WRAPPER */
        .content-wrapper {
            flex: 1;
            margin-left: 280px;
            padding: 20px;
            transition: margin-left 0.3s ease;
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
        }

        .sidebar-wrapper.collapsed + .content-wrapper {
            margin-left: 80px;
        }

        /* MOBILE */
        @media (max-width: 768px) {
            .sidebar-wrapper {
                transform: translateX(-100%);
                width: 280px !important;
            }
            
            .sidebar-wrapper.mobile-open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                padding: 15px;
            }
        }

        /* Password Card */
        .password-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 2rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            max-width: 500px;
            margin: 0 auto;
        }

        .page-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 0.5rem;
        }

        .page-subtitle {
            color: var(--text-muted);
            margin-bottom: 2rem;
            font-size: 0.95rem;
        }

        /* Form Elements */
        .form-label {
            font-weight: 600;
            font-size: 0.875rem;
            color: var(--text-light);
            margin-bottom: 0.5rem;
        }

        .input-group {
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.2s;
            background: var(--bg-white);
        }

        .input-group:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

        .input-group-text {
            background: var(--bg-offwhite);
            border: none;
            color: var(--text-muted);
            padding: 0.75rem 1rem;
        }

        .form-control {
            border: none;
            padding: 0.75rem 1rem;
            font-size: 0.875rem;
            background: var(--bg-white);
            color: var(--text);
        }

        .form-control:focus {
            outline: none;
            box-shadow: none;
            background: var(--bg-white);
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.7;
        }

        .toggle-password {
            cursor: pointer;
            background: var(--bg-offwhite);
            border: none;
            color: var(--text-muted);
            padding: 0.75rem 1rem;
            display: flex;
            align-items: center;
        }

        .toggle-password:hover {
            color: var(--primary);
        }

        /* Validation Icons */
        .validation-icon {
            margin-left: 0.5rem;
            font-size: 0.875rem;
        }

        .valid {
            color: var(--success);
        }

        .invalid {
            color: var(--danger);
        }

        .text-muted {
            color: var(--text-muted) !important;
        }

        .password-strength {
            margin-top: 0.5rem;
            font-size: 0.75rem;
        }

        .strength-bar {
            height: 4px;
            border-radius: 2px;
            margin-top: 0.25rem;
            transition: all 0.3s;
        }

        /* Submit Button */
        .btn-submit {
            background: var(--primary-gradient);
            color: white;
            border: none;
            border-radius: 10px;
            padding: 0.875rem 2rem;
            font-weight: 600;
            font-size: 0.875rem;
            transition: all 0.3s;
            width: 100%;
            margin-top: 1rem;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .btn-submit:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Alert Messages */
        .alert {
            border-radius: 10px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            border: none;
            font-size: 0.875rem;
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
        }

        /* Info Box */
        .info-box {
            background: var(--bg-offwhite);
            border-radius: 10px;
            padding: 1rem;
            margin-top: 1.5rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            border: 1px dashed var(--border);
        }

        .info-box i {
            color: var(--primary);
            margin-right: 0.5rem;
        }

        /* Buttons */
        .btn-outline-primary {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 0.5rem 1.5rem;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-outline-primary:hover {
            background: var(--primary);
            color: white;
            transform: translateY(-2px);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .content-wrapper {
                margin-left: 0;
                padding: 1rem;
            }

            .password-card {
                padding: 1.5rem;
            }

            .d-flex.justify-content-between {
                flex-direction: column;
                gap: 1rem;
                align-items: flex-start !important;
            }

            .btn-outline-primary {
                width: 100%;
            }
        }

        @media (max-width: 480px) {
            .content-wrapper {
                padding: 0.75rem;
            }

            .password-card {
                padding: 1.25rem;
            }

            .page-title {
                font-size: 1.5rem;
            }

            .input-group-text,
            .form-control,
            .toggle-password {
                padding: 0.6rem 0.75rem;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <div class="sidebar-wrapper" id="sidebarWrapper">
            <%- include('../../partials/ram/sidebaar') %>
        </div>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <div class="container-fluid px-0">
                <!-- Page Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1 class="page-title">Change Password</h1>
                        <p class="page-subtitle">Update your account password</p>
                    </div>
                    <button class="btn btn-outline-primary" onclick="window.location.href='/profile'">
                        <i class="fas fa-arrow-left me-2"></i>Back to Profile
                    </button>
                </div>

                <!-- Password Change Card -->
                <div class="password-card">
                    <!-- Show messages if any (from server) -->
                    <% if (locals.message) { %>
                        <div class="alert alert-<%= messageType === 'error' ? 'error' : 'success' %>">
                            <i class="fas fa-<%= messageType === 'error' ? 'exclamation-circle' : 'check-circle' %> me-2"></i>
                            <%= message %>
                        </div>
                    <% } %>

                    <form id="passwordForm" action="/change-password" method="POST" onsubmit="return validateForm()">
                        <!-- Old Password -->
                        <div class="mb-3">
                            <label class="form-label">Current Password</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                <input type="password" class="form-control" id="oldPassword" name="oldPassword" required>
                                <span class="toggle-password" onclick="togglePassword('oldPassword')">
                                    <i class="fas fa-eye"></i>
                                </span>
                            </div>
                        </div>

                        <!-- New Password -->
                        <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-key"></i></span>
                                <input type="password" class="form-control" id="newPassword" name="newPassword" required>
                                <span class="toggle-password" onclick="togglePassword('newPassword')">
                                    <i class="fas fa-eye"></i>
                                </span>
                            </div>
                            <!-- Password strength indicator -->
                            <div class="password-strength" id="passwordStrength">
                                <span>Password strength: </span>
                                <span id="strengthText">Not entered</span>
                            </div>
                            <div class="strength-bar" id="strengthBar" style="width: 0%; background: var(--border);"></div>
                            
                            <!-- Validation rules -->
                            <div class="mt-2 small">
                                <div id="lengthCheck" class="text-muted">
                                    <i class="fas fa-circle validation-icon"></i> At least 8 characters
                                </div>
                                <div id="upperCheck" class="text-muted">
                                    <i class="fas fa-circle validation-icon"></i> At least one uppercase letter
                                </div>
                                <div id="lowerCheck" class="text-muted">
                                    <i class="fas fa-circle validation-icon"></i> At least one lowercase letter
                                </div>
                                <div id="numberCheck" class="text-muted">
                                    <i class="fas fa-circle validation-icon"></i> At least one number
                                </div>
                            </div>
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-3">
                            <label class="form-label">Confirm New Password</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-check-circle"></i></span>
                                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
                                <span class="toggle-password" onclick="togglePassword('confirmPassword')">
                                    <i class="fas fa-eye"></i>
                                </span>
                            </div>
                            <div id="matchMessage" class="small mt-1 text-muted">
                                <i class="fas fa-circle"></i> Passwords must match
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn-submit" id="submitBtn">
                            <i class="fas fa-save me-2"></i>Update Password
                        </button>
                    </form>

                    <!-- Info Box -->
                    <div class="info-box">
                        <i class="fas fa-shield-alt"></i>
                        <strong>Security Tip:</strong> Use a strong, unique password that you don't use elsewhere.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ============================================
        // SIDEBAR SYNC
        // ============================================
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('mainSidebar');
            const sidebarWrapper = document.getElementById('sidebarWrapper');
            
            if (sidebar && sidebarWrapper) {
                if (sidebar.classList.contains('collapsed')) {
                    sidebarWrapper.classList.add('collapsed');
                }
                
                window.toggleCollapse = function() {
                    if (sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        sidebarWrapper.classList.remove('collapsed');
                    } else {
                        sidebar.classList.add('collapsed');
                        sidebarWrapper.classList.add('collapsed');
                    }
                };
                
                window.toggleMobileSidebar = function() {
                    if (sidebar.classList.contains('open')) {
                        sidebar.classList.remove('open');
                        sidebarWrapper.classList.remove('mobile-open');
                    } else {
                        sidebar.classList.add('open');
                        sidebarWrapper.classList.add('mobile-open');
                    }
                };
                
                window.closeMobileSidebar = function() {
                    sidebar.classList.remove('open');
                    sidebarWrapper.classList.remove('mobile-open');
                };
            }

            // Initialize validation
            updateSubmitButton();
        });

        // ============================================
        // CHANGE PASSWORD - CLIENT SIDE VALIDATION
        // ============================================

        // Toggle password visibility
        function togglePassword(fieldId) {
            const field = document.getElementById(fieldId);
            const icon = field.nextElementSibling.querySelector('i');
            if (field.type === 'password') {
                field.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                field.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        // Password strength check
        function checkPasswordStrength(password) {
            const lengthCheck = document.getElementById('lengthCheck');
            const upperCheck = document.getElementById('upperCheck');
            const lowerCheck = document.getElementById('lowerCheck');
            const numberCheck = document.getElementById('numberCheck');
            const strengthText = document.getElementById('strengthText');
            const strengthBar = document.getElementById('strengthBar');

            // Update icons
            const lengthValid = password.length >= 8;
            const upperValid = /[A-Z]/.test(password);
            const lowerValid = /[a-z]/.test(password);
            const numberValid = /[0-9]/.test(password);

            updateCheck(lengthCheck, lengthValid);
            updateCheck(upperCheck, upperValid);
            updateCheck(lowerCheck, lowerValid);
            updateCheck(numberCheck, numberValid);

            // Calculate strength
            const validCount = [lengthValid, upperValid, lowerValid, numberValid].filter(Boolean).length;
            let strength = 0;
            let text = '';
            let color = '';

            if (password.length === 0) {
                strength = 0;
                text = 'Not entered';
                color = 'var(--border)';
            } else if (validCount === 4) {
                strength = 100;
                text = 'Strong';
                color = 'var(--success)';
            } else if (validCount >= 2) {
                strength = 50;
                text = 'Medium';
                color = 'var(--warning)';
            } else {
                strength = 25;
                text = 'Weak';
                color = 'var(--danger)';
            }

            strengthText.textContent = text;
            strengthBar.style.width = strength + '%';
            strengthBar.style.background = color;
        }

        function updateCheck(element, isValid) {
            const icon = element.querySelector('i');
            if (isValid) {
                icon.className = 'fas fa-check-circle valid';
                element.classList.remove('text-muted');
                element.classList.add('valid');
            } else {
                icon.className = 'fas fa-circle';
                element.classList.add('text-muted');
                element.classList.remove('valid');
            }
        }

        // Password match check
        function checkPasswordMatch() {
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;
            const matchMessage = document.getElementById('matchMessage');
            const icon = matchMessage.querySelector('i');

            if (confirmPass.length === 0) {
                icon.className = 'fas fa-circle';
                matchMessage.classList.add('text-muted');
                matchMessage.classList.remove('valid', 'invalid');
            } else if (newPass === confirmPass) {
                icon.className = 'fas fa-check-circle valid';
                matchMessage.classList.remove('text-muted', 'invalid');
                matchMessage.classList.add('valid');
            } else {
                icon.className = 'fas fa-times-circle invalid';
                matchMessage.classList.remove('text-muted', 'valid');
                matchMessage.classList.add('invalid');
            }
        }

        // Validate form before submit
        function validateForm() {
            const oldPass = document.getElementById('oldPassword').value;
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;

            if (!oldPass || !newPass || !confirmPass) {
                alert('Please fill all fields');
                return false;
            }

            // Check password strength
            const lengthValid = newPass.length >= 8;
            const upperValid = /[A-Z]/.test(newPass);
            const lowerValid = /[a-z]/.test(newPass);
            const numberValid = /[0-9]/.test(newPass);
            if (!lengthValid || !upperValid || !lowerValid || !numberValid) {
                alert('Password does not meet security requirements');
                return false;
            }

            if (newPass !== confirmPass) {
                alert('New passwords do not match');
                return false;
            }

            return true;
        }

        // Event listeners
        document.getElementById('newPassword').addEventListener('input', function() {
            checkPasswordStrength(this.value);
            checkPasswordMatch();
            updateSubmitButton();
        });

        document.getElementById('confirmPassword').addEventListener('input', function() {
            checkPasswordMatch();
            updateSubmitButton();
        });

        document.getElementById('oldPassword').addEventListener('input', updateSubmitButton);

        // Auto-disable submit if any rule fails
        function updateSubmitButton() {
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;
            const oldPass = document.getElementById('oldPassword').value;
            const submitBtn = document.getElementById('submitBtn');

            const lengthValid = newPass.length >= 8;
            const upperValid = /[A-Z]/.test(newPass);
            const lowerValid = /[a-z]/.test(newPass);
            const numberValid = /[0-9]/.test(newPass);
            const matchValid = newPass === confirmPass && newPass.length > 0;

            const allValid = oldPass.length > 0 && lengthValid && upperValid && lowerValid && numberValid && matchValid;
            submitBtn.disabled = !allValid;
        }
    </script>
</body>
</html>