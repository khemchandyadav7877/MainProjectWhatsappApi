        // State
        let currentLogs = [...sampleLogs];
        let currentPage = 1;
        let currentRoleFilter = 'all';
        const rowsPerPage = 5;
        let charts = {};

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            console.log('🚀 User Logs page initializing...');
            initializeCharts();
            updateRoleCounts();
            renderTable();
            updateStats();
            showToast('Logs loaded successfully!', 'success');
        });

        // Initialize Charts
        function initializeCharts() {
            // Login Activity Chart (Line Chart)
            const loginCtx = document.getElementById('loginChart').getContext('2d');
            charts.login = new Chart(loginCtx, {
                type: 'line',
                data: {
                    labels: ['Day 1', 'Day 2', 'Day 3', 'Day 4', 'Day 5', 'Day 6', 'Today'],
                    datasets: [{
                        label: 'Logins',
                        data: [12, 19, 15, 17, 24, 22, 24],
                        borderColor: '#667eea',
                        backgroundColor: 'rgba(102, 126, 234, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });

            // Activity Distribution Chart (Pie Chart)
            const activityCtx = document.getElementById('activityChart').getContext('2d');
            charts.activity = new Chart(activityCtx, {
                type: 'doughnut',
                data: {
                    labels: ['SuperAdmin', 'Educator', 'Trainer', 'Student'],
                    datasets: [{
                        data: [25, 35, 20, 40],
                        backgroundColor: ['#4f46e5', '#3b82f6', '#10b981', '#f59e0b'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '60%',
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        }

        // Update role counts
        function updateRoleCounts() {
            const superadminCount = sampleLogs.filter(log => log.role === 'SuperAdmin').length;
            const educatorCount = sampleLogs.filter(log => log.role === 'Educator').length;
            const trainerCount = sampleLogs.filter(log => log.role === 'Trainer').length;
            const studentCount = sampleLogs.filter(log => log.role === 'Student').length;
            
            document.getElementById('superadminCount').textContent = superadminCount;
            document.getElementById('educatorCount').textContent = educatorCount;
            document.getElementById('trainerCount').textContent = trainerCount;
            document.getElementById('studentCount').textContent = studentCount;
            document.getElementById('totalUsers').textContent = sampleLogs.length;
        }

        // Filter by role
        function filterByRole(role) {
            currentRoleFilter = role;
            currentPage = 1;
            
            // Update active class on stat cards
            document.querySelectorAll('.stat-card').forEach(card => {
                card.classList.remove('active');
            });
            document.getElementById(`stat${role === 'all' ? 'All' : role}`).classList.add('active');
            
            // Update role tabs
            document.querySelectorAll('.role-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            if (role === 'all') {
                document.querySelector('.role-tab.all').classList.add('active');
            } else {
                document.querySelector(`.role-tab.${role.toLowerCase()}`).classList.add('active');
            }
            
            // Update active role label
            const roleLabel = document.getElementById('activeRoleLabel');
            if (role === 'all') {
                roleLabel.textContent = 'All Users';
                roleLabel.className = 'badge bg-primary ms-2';
            } else {
                roleLabel.textContent = role;
                roleLabel.className = `badge ms-2 bg-${getRoleColorClass(role)}`;
            }
            
            // Filter logs
            if (role === 'all') {
                currentLogs = [...sampleLogs];
            } else {
                currentLogs = sampleLogs.filter(log => log.role === role);
            }
            
            renderTable();
            showToast(`Showing ${role === 'all' ? 'all users' : role} logs`, 'success');
        }

        // Get role color class
        function getRoleColorClass(role) {
            switch(role) {
                case 'SuperAdmin': return 'primary';
                case 'Educator': return 'info';
                case 'Trainer': return 'success';
                case 'Student': return 'warning';
                default: return 'secondary';
            }
        }

        // Render Table
        function renderTable() {
            const tbody = document.getElementById('logsTableBody');
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            const pageLogs = currentLogs.slice(start, end);

            if (pageLogs.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="9" class="empty-state">
                            <i class="fas fa-history empty-icon"></i>
                            <p>No logs found for ${currentRoleFilter === 'all' ? 'any user' : currentRoleFilter}</p>
                        </td>
                    </tr>
                `;
                return;
            }

            let html = '';
            pageLogs.forEach(log => {
                const actionIcon = log.action === 'login' ? 'fa-sign-in-alt' : 
                                 log.action === 'logout' ? 'fa-sign-out-alt' : 'fa-clock';
                
                const statusClass = log.status === 'active' ? 'status-active' : 
                                   log.status === 'completed' ? 'status-logout' : 'status-login';
                
                const statusText = log.status === 'active' ? 'Active Session' :
                                  log.status === 'completed' ? 'Completed' : 'Logged In';

                html += `
                    <tr>
                        <td>
                            <div class="fw-semibold">${moment(log.timestamp).format('MMM DD, YYYY')}</div>
                            <small class="text-muted">${moment(log.timestamp).format('hh:mm:ss A')}</small>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="user-badge">
                                    <i class="fas fa-user-circle"></i>
                                    ${log.user}
                                </div>
                                <div>
                                    <small class="text-muted">${log.email}</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge" style="background: ${getRoleColor(log.role)}; color: white;">
                                ${log.role}
                            </span>
                        </td>
                        <td>
                            <span class="status-badge ${log.action === 'login' ? 'status-login' : 'status-logout'}">
                                <i class="fas ${actionIcon} me-1"></i>
                                ${log.action === 'login' ? 'Login' : log.action === 'logout' ? 'Logout' : 'Session'}
                            </span>
                        </td>
                        <td>
                            <span class="ip-address">
                                <i class="fas fa-network-wired me-1"></i>${log.ip}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <i class="fas ${getDeviceIcon(log.device)} device-icon"></i>
                                <span>${log.device}</span>
                            </div>
                        </td>
                        <td>
                            <div class="location">
                                <i class="fas fa-map-marker-alt"></i>
                                ${log.location}
                            </div>
                        </td>
                        <td>
                            <span class="duration">
                                <i class="fas fa-hourglass-half me-1"></i>${log.duration}
                            </span>
                        </td>
                        <td>
                            <span class="status-badge ${statusClass}">
                                <i class="fas ${log.status === 'active' ? 'fa-circle' : 'fa-check-circle'} me-1"></i>
                                ${statusText}
                            </span>
                        </td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;
            renderPagination();
        }

        // Get role color
        function getRoleColor(role) {
            switch(role) {
                case 'SuperAdmin': return '#4f46e5';
                case 'Educator': return '#3b82f6';
                case 'Trainer': return '#10b981';
                case 'Student': return '#f59e0b';
                default: return '#6b7280';
            }
        }

        // Get device icon
        function getDeviceIcon(device) {
            if (device.includes('Windows')) return 'fa-windows';
            if (device.includes('macOS')) return 'fa-apple';
            if (device.includes('Linux') || device.includes('Ubuntu')) return 'fa-linux';
            if (device.includes('Android')) return 'fa-android';
            if (device.includes('iOS') || device.includes('iPhone')) return 'fa-apple';
            return 'fa-desktop';
        }

        // Render Pagination
        function renderPagination() {
            const totalPages = Math.ceil(currentLogs.length / rowsPerPage);
            const pageNumbers = document.getElementById('pageNumbers');
            
            if (totalPages <= 1) {
                document.querySelector('.pagination').style.display = 'none';
                return;
            }
            
            document.querySelector('.pagination').style.display = 'flex';
            
            let html = '';
            
            if (totalPages <= 5) {
                for (let i = 1; i <= totalPages; i++) {
                    html += `<button class="page-btn ${currentPage === i ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                }
            } else {
                if (currentPage <= 3) {
                    for (let i = 1; i <= 4; i++) {
                        html += `<button class="page-btn ${currentPage === i ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                    }
                    html += `<span>...</span>`;
                    html += `<button class="page-btn" onclick="goToPage(${totalPages})">${totalPages}</button>`;
                } else if (currentPage >= totalPages - 2) {
                    html += `<button class="page-btn" onclick="goToPage(1)">1</button>`;
                    html += `<span>...</span>`;
                    for (let i = totalPages - 3; i <= totalPages; i++) {
                        html += `<button class="page-btn ${currentPage === i ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                    }
                } else {
                    html += `<button class="page-btn" onclick="goToPage(1)">1</button>`;
                    html += `<span>...</span>`;
                    for (let i = currentPage - 1; i <= currentPage + 1; i++) {
                        html += `<button class="page-btn ${currentPage === i ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                    }
                    html += `<span>...</span>`;
                    html += `<button class="page-btn" onclick="goToPage(${totalPages})">${totalPages}</button>`;
                }
            }
            
            pageNumbers.innerHTML = html;
            
            document.getElementById('prevPage').disabled = currentPage === 1;
            document.getElementById('nextPage').disabled = currentPage === totalPages;
        }

        // Page navigation
        function goToPage(page) {
            currentPage = page;
            renderTable();
        }

        function changePage(direction) {
            if (direction === 'prev' && currentPage > 1) {
                currentPage--;
            } else if (direction === 'next' && currentPage < Math.ceil(currentLogs.length / rowsPerPage)) {
                currentPage++;
            }
            renderTable();
        }

        // Update stats
        function updateStats() {
            document.getElementById('totalSessions').textContent = '1,234';
            document.getElementById('avgSessionTime').textContent = '45m 30s';
            document.getElementById('peakHour').textContent = '10:00 AM';
        }

        // Apply filters
        function applyFilters() {
            showLoading();
            
            const user = document.getElementById('userSelect').value;
            const action = document.getElementById('actionSelect').value;
            const dateFrom = document.getElementById('dateFrom').value;
            const dateTo = document.getElementById('dateTo').value;
            
            // Start with role-filtered logs
            let filtered = currentRoleFilter === 'all' ? [...sampleLogs] : 
                          sampleLogs.filter(log => log.role === currentRoleFilter);
            
            // Apply additional filters
            filtered = filtered.filter(log => {
                if (user && !log.email.includes(user)) return false;
                if (action && log.action !== action) return false;
                
                const logDate = moment(log.timestamp).format('YYYY-MM-DD');
                if (dateFrom && logDate < dateFrom) return false;
                if (dateTo && logDate > dateTo) return false;
                
                return true;
            });
            
            currentLogs = filtered;
            currentPage = 1;
            renderTable();
            
            setTimeout(hideLoading, 500);
            
            // Show active filters
            showActiveFilters(user, action, dateFrom, dateTo);
            
            showToast(`Found ${filtered.length} logs`, 'success');
        }

        // Show active filters
        function showActiveFilters(user, action, dateFrom, dateTo) {
            const container = document.getElementById('activeFilters');
            let html = '';
            
            if (currentRoleFilter !== 'all') {
                html += `
                    <span class="active-filter">
                        <i class="fas fa-user-tag"></i> Role: ${currentRoleFilter}
                        <span class="remove" onclick="filterByRole('all')">&times;</span>
                    </span>
                `;
            }
            
            if (user) {
                const userName = user.split('@')[0];
                html += `
                    <span class="active-filter">
                        <i class="fas fa-user"></i> User: ${userName}
                        <span class="remove" onclick="document.getElementById('userSelect').value=''; applyFilters();">&times;</span>
                    </span>
                `;
            }
            
            if (action) {
                html += `
                    <span class="active-filter">
                        <i class="fas fa-${action === 'login' ? 'sign-in-alt' : action === 'logout' ? 'sign-out-alt' : 'clock'}"></i> 
                        Action: ${action}
                        <span class="remove" onclick="document.getElementById('actionSelect').value=''; applyFilters();">&times;</span>
                    </span>
                `;
            }
            
            if (dateFrom && dateFrom !== '2024-01-01') {
                html += `
                    <span class="active-filter">
                        <i class="fas fa-calendar"></i> From: ${dateFrom}
                        <span class="remove" onclick="document.getElementById('dateFrom').value='2024-01-01'; applyFilters();">&times;</span>
                    </span>
                `;
            }
            
            if (dateTo && dateTo !== '2024-12-31') {
                html += `
                    <span class="active-filter">
                        <i class="fas fa-calendar"></i> To: ${dateTo}
                        <span class="remove" onclick="document.getElementById('dateTo').value='2024-12-31'; applyFilters();">&times;</span>
                    </span>
                `;
            }
            
            container.innerHTML = html;
        }

        // Reset filters
        function resetFilters() {
            document.getElementById('userSelect').value = '';
            document.getElementById('actionSelect').value = '';
            document.getElementById('dateFrom').value = '2024-01-01';
            document.getElementById('dateTo').value = '2024-12-31';
            document.getElementById('activeFilters').innerHTML = '';
            
            filterByRole('all');
        }

        // Refresh logs
        function refreshLogs() {
            showLoading();
            
            setTimeout(() => {
                filterByRole(currentRoleFilter);
                hideLoading();
                showToast('Logs refreshed!', 'success');
            }, 1000);
        }

        // Export to CSV
        function exportToCSV() {
            const headers = ['Timestamp', 'User', 'Email', 'Role', 'Action', 'IP Address', 'Device', 'Location', 'Duration', 'Status'];
            
            const rows = currentLogs.map(log => [
                log.timestamp,
                log.user,
                log.email,
                log.role,
                log.action,
                log.ip,
                log.device,
                log.location,
                log.duration,
                log.status
            ]);
            
            let csvContent = headers.join(',') + '\n' + 
                rows.map(row => row.map(cell => `"${cell}"`).join(',')).join('\n');
            
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.setAttribute('download', `user_logs_${currentRoleFilter}_${moment().format('YYYY-MM-DD')}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            showToast('CSV exported successfully!', 'success');
        }

        // Export logs
        function exportLogs() {
            exportToCSV();
        }

        // Loading functions
        function showLoading() {
            document.getElementById('loadingOverlay').style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        // Toast notification
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            
            toast.style.display = 'block';
            toast.className = `toast-notification toast-${type}`;
            toast.innerHTML = `
                <div class="toast-icon">
                    <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i>
                </div>
                <div>
                    <div class="fw-semibold">${type === 'success' ? 'Success' : 'Info'}</div>
                    <small>${message}</small>
                </div>
            `;
            
            setTimeout(() => {
                toast.style.display = 'none';
            }, 3000);
        }

        // Auto-refresh every 30 seconds (demo)
        setInterval(() => {
            console.log('🔄 Auto-refreshing logs...');
            // In real app, you would fetch new data here
        }, 30000);
    </script>
