<script>
    // Settings panel functions
    function openSettings() {
        document.getElementById("settingsPanel").classList.add("active");
        document.getElementById("settingsOverlay").classList.add("active");
    }

    function closeSettings() {
        document.getElementById("settingsPanel").classList.remove("active");
        document.getElementById("settingsOverlay").classList.remove("active");
    }

    // Close panel when pressing Escape key
    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
            closeSettings();
        }
    });

    // Load saved navbar style from localStorage on page load
    document.addEventListener("DOMContentLoaded", function() {
        const savedStyle = localStorage.getItem('navbarStyle');
        if (savedStyle) {
            // Apply the saved style to sidebar
            const sidebar = document.querySelector('.sidebar');
            if (sidebar) {
                sidebar.classList.remove('transparent', 'inverted', 'card', 'vibrant');
                sidebar.classList.add(savedStyle);
            }
        }
    });
</script>

