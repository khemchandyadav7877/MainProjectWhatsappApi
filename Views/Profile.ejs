<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - <%= user?.firstName || 'User' %></title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ===== THEME VARIABLES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f8fafc;
            --bg-white: #ffffff;
            --bg-offwhite: #f1f5f9;
            --bg-card: #ffffff;
            --text: #334155;
            --text-light: #64748b;
            --text-muted: #94a3b8;
            --dark: #0f172a;
            --border: #eef2f6;
            --shadow: 0 8px 25px rgba(0,0,0,0.03);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
            --shadow-xl: 0 20px 40px rgba(102, 126, 234, 0.15);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
            --sidebar-mini-width: 80px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --text: #e2e8f0;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 8px 25px rgba(0,0,0,0.2);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
            --shadow-xl: 0 20px 40px rgba(102, 126, 234, 0.25);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: 'Inter', 'Segoe UI', sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar,
        body.round-border .profile-card,
        body.round-border .info-item,
        body.round-border .btn-edit,
        body.round-border .btn-back,
        body.round-border .profile-avatars,
        body.round-border .role-badge,
        body.round-border .status-badge {
            border-radius: 20px !important;
        }

        body.round-border .profile-avatars {
            border-radius: 16px !important;
        }

        body.round-border .role-badge,
        body.round-border .status-badge {
            border-radius: 50px !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar,
        body.no-radius .profile-card,
        body.no-radius .info-item,
        body.no-radius .btn-edit,
        body.no-radius .btn-back,
        body.no-radius .profile-avatars,
        body.no-radius .role-badge,
        body.no-radius .status-badge {
            border-radius: 0 !important;
        }

        /* Header */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        /* MAIN LAYOUT - EXACTLY LIKE PREVIOUS TEMPLATES */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
            position: relative;
        }

        /* SIDEBAR - EXACTLY LIKE PREVIOUS TEMPLATES */
        .sidebar {
            width: var(--sidebar-width, 280px);
            background: var(--bg-white);
            border-right: 1px solid var(--border);
            height: calc(100vh - var(--header-height, 70px));
            position: fixed;
            left: 0;
            top: 70px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1020;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }

        /* Sidebar Mini Mode */
        .sidebar.mini {
            width: var(--sidebar-mini-width, 80px);
        }

        /* CONTENT WRAPPER - EXACTLY LIKE PREVIOUS TEMPLATES */
        .content-wrapper {
            flex: 1;
            margin-left: var(--sidebar-width, 280px);
            padding: 25px;
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
            width: calc(100% - var(--sidebar-width, 280px));
        }

        /* When sidebar has mini class, adjust content wrapper */
        .sidebar.mini ~ .content-wrapper {
            margin-left: var(--sidebar-mini-width, 80px);
            width: calc(100% - var(--sidebar-mini-width, 80px));
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
                transition: transform 0.3s ease;
            }
            
            .sidebar.open {
                transform: translateX(0);
            }
            
            .sidebar.mini {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
            }
            
            .sidebar.mini.open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
                padding: 15px;
            }
            
            .sidebar.mini ~ .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
            }
        }

        /* Profile Container */
        .profile-container {
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        /* Profile Card */
        .profile-card {
            background: var(--bg-card);
            border-radius: 20px;
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border);
            overflow: hidden;
            animation: slideUp 0.5s ease-out;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Profile Header - FIXED */
        .profile-header {
            background: var(--primary-gradient);
            padding: 40px 35px;
            position: relative;
            display: flex;
            align-items: center;
            gap: 35px;
            flex-wrap: wrap;
        }

        /* FIXED: Avatar wrapper with proper dimensions */
        .profile-avatars-wrappers {
            position: relative;
            display: inline-block;
            width: 160px;
            height: 160px;
            flex-shrink: 0; /* Prevent shrinking */
        }

        /* FIXED: Avatar with proper size */
        .profile-avatars {
            width: 160px !important;
            height: 160px !important;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 72px;
            color: white;
            background: var(--primary-gradient);
            border: 4px solid rgba(255,255,255,0.3);
            box-shadow: var(--shadow-xl);
            transition: all 0.3s ease;
            background-size: cover !important;
            background-position: center !important;
            background-repeat: no-repeat !important;
            object-fit: cover;
        }

        /* For users with avatar images */
        .profile-avatars[style*="background-image"] {
            background-size: cover !important;
        }

        .profile-avatars:hover {
            transform: scale(1.05);
        }

        /* Profile Title */
        .profile-title h1 {
            margin: 0;
            font-size: 36px;
            font-weight: 700;
            color: white;
            line-height: 1.2;
        }

        .profile-title p {
            margin: 8px 0 0;
            opacity: 0.95;
            font-size: 18px;
            color: white;
        }

        .role-badge {
            display: inline-block;
            padding: 8px 20px;
            background: rgba(255,255,255,0.2);
            border-radius: 50px;
            font-size: 15px;
            font-weight: 600;
            margin-top: 15px;
            color: white;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.3);
        }

        .role-badge i {
            margin-right: 6px;
        }

        /* Profile Body */
        .profile-body {
            padding: 40px 35px;
        }

        @media (max-width: 640px) {
            .profile-body {
                padding: 25px 20px;
            }
        }

        .info-section {
            margin-bottom: 40px;
        }

        .info-section:last-child {
            margin-bottom: 0;
        }

        .info-title {
            font-size: 20px;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .info-title i {
            color: var(--primary);
            font-size: 22px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        @media (max-width: 768px) {
            .info-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
            }
        }

        @media (max-width: 640px) {
            .info-grid {
                grid-template-columns: 1fr;
            }
        }

        .info-item {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            padding: 18px;
            background: var(--bg-offwhite);
            border-radius: 16px;
            transition: all 0.2s ease;
            border: 1px solid var(--border);
        }

        .info-item:hover {
            border-color: var(--primary);
            background: var(--bg-card);
            box-shadow: var(--shadow);
            transform: translateY(-2px);
        }

        .info-icon {
            width: 48px;
            height: 48px;
            background: var(--bg-card);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: var(--primary);
            border: 1px solid var(--border);
            flex-shrink: 0;
        }

        .info-content {
            flex: 1;
        }

        .info-label {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            font-weight: 600;
        }

        .info-value {
            font-size: 18px;
            font-weight: 500;
            color: var(--dark);
            word-break: break-word;
            line-height: 1.4;
        }

        .info-value.email {
            color: var(--primary);
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 600;
            margin-left: 8px;
        }

        .status-active {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        /* Profile Footer */
        .profile-footer {
            padding: 25px 35px;
            background: var(--bg-offwhite);
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            flex-wrap: wrap;
        }

        @media (max-width: 640px) {
            .profile-footer {
                padding: 20px;
                flex-direction: column;
            }
            
            .profile-footer .btn {
                width: 100%;
                justify-content: center;
            }
        }

        /* Buttons */
        .btn {
            padding: 12px 28px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 16px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
        }

        .btn-edit {
            background: var(--bg-card);
            color: var(--primary);
            border: 1px solid var(--primary);
        }

        .btn-edit:hover {
            background: var(--primary-gradient);
            color: white;
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .btn-back {
            background: var(--primary-gradient);
            color: white;
        }

        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        /* Responsive sizes for avatar */
        @media (max-width: 992px) {
            .profile-avatars-wrappers {
                width: 140px;
                height: 140px;
            }
            
            .profile-avatars {
                width: 140px !important;
                height: 140px !important;
                font-size: 60px;
            }
            
            .profile-title h1 {
                font-size: 30px;
            }
            
            .profile-title p {
                font-size: 16px;
            }
        }

        @media (max-width: 768px) {
            .profile-header {
                padding: 25px 20px;
                gap: 25px;
            }
            
            .profile-avatars-wrappers {
                width: 120px;
                height: 120px;
            }
            
            .profile-avatars {
                width: 120px !important;
                height: 120px !important;
                font-size: 48px;
            }
            
            .profile-title h1 {
                font-size: 26px;
            }
            
            .info-item {
                padding: 15px;
            }
            
            .info-value {
                font-size: 16px;
            }
        }

        @media (max-width: 640px) {
            .profile-header {
                flex-direction: column;
                text-align: center;
                padding: 30px 25px;
                gap: 20px;
            }
        }

        @media (max-width: 576px) {
            .content-wrapper {
                padding: 10px;
            }
            
            .profile-header {
                padding: 20px 15px;
            }
            
            .profile-avatars-wrappers {
                width: 100px;
                height: 100px;
            }
            
            .profile-avatars {
                width: 100px !important;
                height: 100px !important;
                font-size: 40px;
            }
            
            .profile-title h1 {
                font-size: 22px;
            }
            
            .role-badge {
                padding: 6px 15px;
                font-size: 13px;
            }
            
            .info-title {
                font-size: 18px;
            }
            
            .info-icon {
                width: 40px;
                height: 40px;
                font-size: 18px;
            }
            
            .btn {
                padding: 10px 20px;
                font-size: 14px;
            }
        }

        /* Toast - EXACTLY LIKE PREVIOUS TEMPLATES */
        #toast {
            position: fixed;
            top: 90px;
            right: 29px;
            width: 320px;
            padding: 16px 20px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 1001;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-content {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            font-size: 20px;
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 5px 0 0;
            font-size: 13px;
            opacity: 0.9;
        }

        .toast-progress {
            height: 3px;
            background: rgba(255,255,255,0.6);
            margin-top: 12px;
            width: 100%;
            animation: progress 3s linear;
        }

        @keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* Loading Overlay */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(5px);
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid var(--bg-offwhite);
            border-top: 5px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .loading-text {
            color: white;
            margin-top: 15px;
            font-size: 18px;
            font-weight: 600;
        }

        /* Text utilities */
        .text-muted {
            color: var(--text-muted) !important;
        }

        .text-primary {
            color: var(--primary) !important;
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <%- include('../partials/ram/sidebaar') %>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <!-- Toast Container -->
            <div id="toast"></div>

            <!-- Loading Overlay -->
            <div class="loading-overlay" id="loadingOverlay">
                <div class="text-center">
                    <div class="spinner"></div>
                    <div class="loading-text">Processing...</div>
                </div>
            </div>

            <div class="profile-container">
                <!-- Profile Card -->
                <div class="profile-card">
                    <!-- Profile Header with Avatar - FIXED -->
                    <div class="profile-header">
                        <div class="profile-avatar-wrapper">
                            <!-- Profile Avatar - Fixed size 160x160 -->
                            <div class="profile-avatar" id="profileAvatar"
                                <% if (user.avatar) { %>
                                    style="background-image: url('<%= user.avatar %>'); background-size: cover; background-position: center; background-repeat: no-repeat; width: 160px; height: 160px;"
                                <% } else { %>
                                    style="background: var(--primary-gradient); width: 160px; height: 160px;"
                                <% } %>>
                                <% if (!user.avatar) { %>
                                    <%= (user?.firstName || user?.email || 'U').charAt(0).toUpperCase() %>
                                <% } %>
                            </div>
                        </div>
                        <div class="profile-title">
                            <h1><%= user?.firstName || '' %> <%= user?.lastName || '' %></h1>
                            <p><%= user?.email || '' %></p>
                            <span class="role-badge">
                                <i class="fas fa-user-tag"></i> <%= user?.role || 'User' %>
                            </span>
                        </div>
                    </div>

                    <!-- Profile Body -->
                    <div class="profile-body">
                        <!-- Personal Information -->
                        <div class="info-section">
                            <div class="info-title"><i class="fas fa-user-circle"></i> Personal Information</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-user"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Full Name</div>
                                        <div class="info-value"><%= user?.firstName || 'Not set' %> <%= user?.lastName || '' %></div>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-phone-alt"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Contact</div>
                                        <div class="info-value"><%= user?.contactNumber || 'Not provided' %></div>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-birthday-cake"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Date of Birth</div>
                                        <div class="info-value"><%= user?.dob ? new Date(user.dob).toLocaleDateString() : 'Not provided' %></div>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-venus-mars"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Gender</div>
                                        <div class="info-value"><%= user?.gender || 'Not specified' %></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Contact Information -->
                        <div class="info-section">
                            <div class="info-title"><i class="fas fa-envelope"></i> Contact Information</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-envelope"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Email</div>
                                        <div class="info-value email">
                                            <%= user?.email || 'Not set' %>
                                            <span class="status-badge status-active"><i class="fas fa-check-circle"></i> Verified</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Address</div>
                                        <div class="info-value"><%= user?.address || 'Not provided' %></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Account Information -->
                        <div class="info-section">
                            <div class="info-title"><i class="fas fa-shield-alt"></i> Account Information</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-clock"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Member Since</div>
                                        <div class="info-value"><%= user?.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'Recent' %></div>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-history"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Last Updated</div>
                                        <div class="info-value"><%= user?.updatedAt ? new Date(user.updatedAt).toLocaleDateString() : 'Never' %></div>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-globe"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">Last Login</div>
                                        <div class="info-value"><%= user?.lastLogin ? new Date(user.lastLogin).toLocaleString() : 'Just now' %></div>
                                    </div>
                                </div>
                                <div class="info-item">
                                    <div class="info-icon"><i class="fas fa-fingerprint"></i></div>
                                    <div class="info-content">
                                        <div class="info-label">User ID</div>
                                        <div class="info-value"><small><%= user?._id || 'N/A' %></small></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer - Edit button -->
                    <div class="profile-footer">
                        <button class="btn btn-edit" onclick="openEditProfile()"><i class="fas fa-edit"></i> Edit Profile</button>
                        <button class="btn btn-back" onclick="goBack()"><i class="fas fa-arrow-left"></i> Back to Dashboard</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR STATE SYNC - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);

            // Handle URL messages
            const urlParams = new URLSearchParams(window.location.search);
            const message = urlParams.get('message');
            const messageType = urlParams.get('messageType');
            
            if (message) {
                showToast(
                    messageType === 'success' ? 'Success' : 'Notification', 
                    decodeURIComponent(message), 
                    messageType || 'info'
                );
                
                // Clean URL
                const url = new URL(window.location);
                url.searchParams.delete('message');
                url.searchParams.delete('messageType');
                window.history.replaceState({}, document.title, url);
            }

            // Welcome toast
            setTimeout(() => {
                showToast('Welcome', 'Welcome to your profile, <%= user?.firstName || 'User' %>!', 'info');
            }, 500);
            
            // FIX: Ensure avatar has correct size
            const avatar = document.getElementById('profileAvatar');
            if (avatar) {
                if (avatar.style.backgroundImage) {
                    avatar.style.backgroundSize = 'cover';
                    avatar.style.backgroundPosition = 'center';
                    avatar.style.backgroundRepeat = 'no-repeat';
                }
            }
        });

        function goBack() {
            window.location.href = '/dashboard';
        }

        function openEditProfile() {
            // Open edit profile in new page
            window.location.href = '/profile/edit';
        }

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                goBack();
            }
            
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Press Esc to go back | Click Edit Profile to modify', 'info');
            }
        });

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOADING OVERLAY FUNCTIONS
        // ======================
        function showLoading(text = 'Processing...') {
            const overlay = document.getElementById('loadingOverlay');
            document.querySelector('.loading-text').textContent = text;
            overlay.style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        // ======================
        // THEME FUNCTIONS
        // ======================
        function toggleTheme() {
            if (document.body.classList.contains('dark')) {
                document.body.classList.remove('dark');
                document.body.classList.add('light');
                localStorage.setItem('theme', 'light');
                showToast('Theme Updated', 'Light mode activated', 'info');
            } else {
                document.body.classList.remove('light');
                document.body.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                showToast('Theme Updated', 'Dark mode activated', 'info');
            }
        }

        function toggleBorder() {
            if (document.body.classList.contains('round-border')) {
                document.body.classList.remove('round-border');
                document.body.classList.add('no-radius');
                localStorage.setItem('border', 'no-radius');
                showToast('Border Style', 'Square corners activated', 'info');
            } else {
                document.body.classList.remove('no-radius');
                document.body.classList.add('round-border');
                localStorage.setItem('border', 'round-border');
                showToast('Border Style', 'Rounded corners activated', 'info');
            }
        }
    </script>
</body>
</html>