    <script>
        // ======================
        // SIDEBAR SYNC
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('mainSidebar');
            const sidebarWrapper = document.getElementById('sidebarWrapper');
            
            if (sidebar && sidebarWrapper) {
                if (sidebar.classList.contains('collapsed')) {
                    sidebarWrapper.classList.add('collapsed');
                }
                
                const originalToggleCollapse = window.toggleCollapse;
                
                window.toggleCollapse = function() {
                    if (originalToggleCollapse) {
                        originalToggleCollapse();
                    }
                    
                    setTimeout(() => {
                        if (sidebar.classList.contains('collapsed')) {
                            sidebarWrapper.classList.add('collapsed');
                        } else {
                            sidebarWrapper.classList.remove('collapsed');
                        }
                    }, 10);
                };
                
                const originalToggleMobile = window.toggleMobileSidebar;
                
                window.toggleMobileSidebar = function() {
                    if (originalToggleMobile) {
                        originalToggleMobile();
                    }
                    
                    setTimeout(() => {
                        if (sidebar.classList.contains('open')) {
                            sidebarWrapper.classList.add('mobile-open');
                        } else {
                            sidebarWrapper.classList.remove('mobile-open');
                        }
                    }, 10);
                };
                
                const originalCloseMobile = window.closeMobileSidebar;
                
                window.closeMobileSidebar = function() {
                    if (originalCloseMobile) {
                        originalCloseMobile();
                    }
                    
                    sidebarWrapper.classList.remove('mobile-open');
                };
            }

            // Initialize form
            updatePreview();
            updateSummary();
        });

        // ======================
        // TOAST FUNCTION
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'success') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.className = '';
            toast.innerHTML = `
                <div class="toast-row">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.classList.add(`toast-${type}`, 'show');
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // STEP NAVIGATION
        // ======================
        let currentStep = 1;

        function showStep(step) {
            for (let i = 1; i <= 5; i++) {
                document.getElementById(`step${i}`).style.display = 'none';
                document.getElementById(`step${i}-indicator`).classList.remove('active');
                if (i < step) {
                    document.getElementById(`step${i}-indicator`).classList.add('completed');
                } else {
                    document.getElementById(`step${i}-indicator`).classList.remove('completed');
                }
            }
            
            document.getElementById(`step${step}`).style.display = 'block';
            document.getElementById(`step${step}-indicator`).classList.add('active');
            currentStep = step;
        }

        function nextStep(step) {
            if (validateStep(currentStep)) {
                showStep(step);
                window.scrollTo(0, 0);
            }
        }

        function prevStep(step) {
            showStep(step);
            window.scrollTo(0, 0);
        }

        function validateStep(step) {
            if (step === 1) {
                if (!document.getElementById('campaignName').value) {
                    showToast('Error', 'Please enter campaign name', 'error');
                    return false;
                }
            }
            return true;
        }

        // ======================
        // PLATFORM SELECTION
        // ======================
        function selectPlatform(platform) {
            document.querySelectorAll('.platform-card').forEach(card => {
                card.classList.remove('selected');
            });
            event.currentTarget.classList.add('selected');
            document.getElementById('platform').value = platform;
            updateSummary();
        }

        function selectObjective(objective) {
            document.querySelectorAll('.objective-card').forEach(card => {
                card.classList.remove('selected');
            });
            event.currentTarget.classList.add('selected');
            document.getElementById('objective').value = objective;
            updateSummary();
        }

        function selectAdFormat(format) {
            document.querySelectorAll('[onclick*="selectAdFormat"]').forEach(card => {
                card.classList.remove('selected');
            });
            event.currentTarget.classList.add('selected');
            document.getElementById('adFormat').value = format;
        }

        // ======================
        // LOCATION TARGETING
        // ======================
        function removeLocation(location) {
            // Remove location tag
            showToast('Removed', `${location} removed from targeting`, 'info');
        }

        // ======================
        // BUDGET
        // ======================
        function toggleBudgetType() {
            const type = document.getElementById('budgetType').value;
            document.getElementById('budgetLabel').textContent = type === 'daily' ? 'Daily Budget (₹)' : 'Lifetime Budget (₹)';
            updateBudgetSummary();
        }

        function updateBudgetFromSlider() {
            const value = document.getElementById('budgetSlider').value;
            document.getElementById('budgetAmount').value = value;
            updateBudgetSummary();
        }

        function updateBudgetSummary() {
            const amount = document.getElementById('budgetAmount').value;
            const type = document.getElementById('budgetType').value;
            
            // Show warning for low budget
            if (amount < 500) {
                document.getElementById('budgetWarning').style.display = 'block';
            } else {
                document.getElementById('budgetWarning').style.display = 'none';
            }
            
            // Update estimated reach
            const reach = Math.floor(amount * 12) + 'K - ' + Math.floor(amount * 45) + 'K people';
            document.getElementById('estimatedReach').value = reach;
            
            updateSummary();
        }

        // ======================
        // SCHEDULE
        // ======================
        function toggleTimeSlots() {
            const value = document.getElementById('adScheduling').value;
            document.getElementById('timeSlots').style.display = value === 'specific' ? 'block' : 'none';
        }

        function toggleTimeSlot(element) {
            element.classList.toggle('selected');
        }

        // ======================
        // MEDIA UPLOAD
        // ======================
        function handleMediaUpload(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    document.getElementById('previewImage').src = e.target.result;
                    document.getElementById('mediaPreview').style.display = 'block';
                    document.getElementById('previewMedia').innerHTML = `<img src="${e.target.result}" style="max-width: 100%; max-height: 200px;">`;
                    document.getElementById('uploadArea').style.display = 'none';
                };
                
                reader.readAsDataURL(input.files[0]);
                showToast('Uploaded', 'File uploaded successfully', 'success');
            }
        }

        // ======================
        // PREVIEW
        // ======================
        function updatePreview() {
            const title = document.getElementById('adHeadline').value;
            const description = document.getElementById('adPrimaryText').value;
            const cta = document.getElementById('adCTA').value;
            
            document.getElementById('previewTitle').textContent = title;
            document.getElementById('previewDescription').textContent = description;
            document.getElementById('previewCTA').textContent = cta.replace(/([A-Z])/g, ' $1').trim();
            
            // Update character count
            document.getElementById('primaryTextCount').textContent = description.length + ' characters';
        }

        function changePreviewDevice(device) {
            document.querySelectorAll('.device-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.currentTarget.classList.add('active');
            
            const preview = document.getElementById('livePreview');
            if (device === 'mobile') {
                preview.style.maxWidth = '320px';
                preview.style.margin = '0 auto';
            } else {
                preview.style.maxWidth = '100%';
            }
        }

        // ======================
        // SUMMARY
        // ======================
        function updateSummary() {
            document.getElementById('summaryName').textContent = document.getElementById('campaignName').value || 'Summer Sale 2024';
            
            const platform = document.getElementById('platform').value;
            document.getElementById('summaryPlatform').textContent = platform.charAt(0).toUpperCase() + platform.slice(1);
            
            const objective = document.getElementById('objective').value;
            document.getElementById('summaryObjective').textContent = objective.replace(/([A-Z])/g, ' $1').trim();
            
            const ageMin = document.getElementById('ageMin').value;
            const ageMax = document.getElementById('ageMax').value;
            document.getElementById('summaryAudience').textContent = `${ageMin}-${ageMax}, All genders`;
            
            const budget = document.getElementById('budgetAmount').value;
            const budgetType = document.getElementById('budgetType').value;
            document.getElementById('summaryBudget').textContent = `₹${budget}/${budgetType === 'daily' ? 'day' : 'total'}`;
            
            const startDate = new Date(document.getElementById('startDate').value).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            const endDate = new Date(document.getElementById('endDate').value).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            document.getElementById('summarySchedule').textContent = `${startDate} - ${endDate}`;
        }

        // ======================
        // CAMPAIGN LAUNCH
        // ======================
        function launchCampaign() {
            if (!document.getElementById('termsCheck').checked) {
                showToast('Error', 'Please accept terms and conditions', 'error');
                return;
            }
            
            document.getElementById('loadingOverlay').style.display = 'flex';
            
            // Simulate API call
            setTimeout(() => {
                document.getElementById('loadingOverlay').style.display = 'none';
                showToast('Success!', 'Campaign launched successfully!', 'success');
                
                setTimeout(() => {
                    window.location.href = '/ads';
                }, 2000);
            }, 3000);
        }

        function saveAsDraft() {
            showToast('Saved', 'Campaign saved as draft', 'success');
        }
    </script>
</body>
</html>