<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WhatsApp Campaign - SSPAR Cloud</title>

<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    /* ===== THEME VARIABLES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
    :root {
        --primary: #667eea;
        --primary-dark: #5a67d8;
        --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --info: #3b82f6;
        --whatsapp: #25D366;
        
        /* Light Mode */
        --bg-body: #f8fafc;
        --bg-white: #ffffff;
        --bg-offwhite: #f1f5f9;
        --bg-card: #ffffff;
        --text: #334155;
        --text-light: #64748b;
        --text-muted: #94a3b8;
        --dark: #0f172a;
        --border: #eef2f6;
        --shadow: 0 8px 25px rgba(0,0,0,0.03);
        --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
        
        /* Layout */
        --header-height: 70px;
        --sidebar-width: 280px;
        --sidebar-mini-width: 80px;
    }

    /* Dark Mode */
    body.dark {
        --bg-body: #0f172a;
        --bg-white: #1e293b;
        --bg-offwhite: #334155;
        --bg-card: #1e293b;
        --text: #e2e8f0;
        --text-light: #cbd5e1;
        --text-muted: #94a3b8;
        --dark: #f8fafc;
        --border: #334155;
        --shadow: 0 8px 25px rgba(0,0,0,0.2);
        --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
    }

    /* RESET */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        overflow-x: hidden;
        background: var(--bg-body);
        font-family: 'Inter', 'Segoe UI', sans-serif;
        color: var(--text);
        transition: background-color 0.3s, color 0.3s;
    }

    /* ===== BORDER MODES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
    body.round-border .header-wrapper,
    body.round-border .sidebar,
    body.round-border .mid-content,
    body.round-border .header,
    body.round-border .device-info,
    body.round-border .step-circle,
    body.round-border .step-content,
    body.round-border .form-control,
    body.round-border .btn,
    body.round-border .groups-section,
    body.round-border .group-card,
    body.round-border .selected-group-banner,
    body.round-border .excel-upload-container,
    body.round-border .excel-upload-box,
    body.round-border .excel-instructions,
    body.round-border .media-upload,
    body.round-border .file-preview,
    body.round-border .media-option,
    body.round-border .schedule-option,
    body.round-border .campaign-table,
    body.round-border .status-badge,
    body.round-border .summary-item,
    body.round-border .role-badge,
    body.round-border .toast-notification,
    body.round-border .modal-content {
        border-radius: 20px !important;
    }

    body.round-border .step-circle {
        border-radius: 50% !important;
    }

    body.round-border .excel-preview-table {
        border-radius: 12px !important;
        overflow: hidden;
    }

    body.no-radius .header-wrapper,
    body.no-radius .sidebar,
    body.no-radius .mid-content,
    body.no-radius .header,
    body.no-radius .device-info,
    body.no-radius .step-circle,
    body.no-radius .step-content,
    body.no-radius .form-control,
    body.no-radius .btn,
    body.no-radius .groups-section,
    body.no-radius .group-card,
    body.no-radius .selected-group-banner,
    body.no-radius .excel-upload-container,
    body.no-radius .excel-upload-box,
    body.no-radius .excel-instructions,
    body.no-radius .media-upload,
    body.no-radius .file-preview,
    body.no-radius .media-option,
    body.no-radius .schedule-option,
    body.no-radius .campaign-table,
    body.no-radius .status-badge,
    body.no-radius .summary-item,
    body.no-radius .role-badge,
    body.no-radius .toast-notification,
    body.no-radius .modal-content,
    body.no-radius .excel-preview-table,
    body.no-radius .step-circle {
        border-radius: 0 !important;
    }

    /* HEADER FIXED */
    .header-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1030;
        background: var(--bg-white);
        box-shadow: var(--shadow);
        border-bottom: 1px solid var(--border);
    }

    /* MAIN LAYOUT - EXACTLY LIKE PREVIOUS TEMPLATES */
    .main-wrapper {
        margin-top: 70px;
        display: flex;
        width: 100%;
        min-height: calc(100vh - 70px);
        position: relative;
    }

    /* SIDEBAR - EXACTLY LIKE PREVIOUS TEMPLATES */
    .sidebar {
        width: var(--sidebar-width, 280px);
        background: var(--bg-white);
        border-right: 1px solid var(--border);
        height: calc(100vh - var(--header-height, 70px));
        position: fixed;
        left: 0;
        top: 70px;
        transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 1020;
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        overflow-x: hidden;
    }

    /* Sidebar Mini Mode */
    .sidebar.mini {
        width: var(--sidebar-mini-width, 80px);
    }

    /* CONTENT WRAPPER - EXACTLY LIKE PREVIOUS TEMPLATES */
    .content-wrapper {
        flex: 1;
        margin-left: var(--sidebar-width, 280px);
        padding: 25px;
        transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        background: var(--bg-body);
        min-height: calc(100vh - 70px);
        width: calc(100% - var(--sidebar-width, 280px));
    }

    /* When sidebar has mini class, adjust content wrapper */
    .sidebar.mini ~ .content-wrapper {
        margin-left: var(--sidebar-mini-width, 80px);
        width: calc(100% - var(--sidebar-mini-width, 80px));
    }

    /* MAIN CONTENT */
    .mid-content {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 30px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        min-height: 500px;
    }

    /* MOBILE */
    @media (max-width: 768px) {
        .sidebar {
            transform: translateX(-100%);
            width: var(--sidebar-width, 280px) !important;
            transition: transform 0.3s ease;
        }
        
        .sidebar.open {
            transform: translateX(0);
        }
        
        .sidebar.mini {
            transform: translateX(-100%);
            width: var(--sidebar-width, 280px) !important;
        }
        
        .sidebar.mini.open {
            transform: translateX(0);
        }
        
        .content-wrapper {
            margin-left: 0 !important;
            width: 100% !important;
            padding: 15px;
        }
        
        .sidebar.mini ~ .content-wrapper {
            margin-left: 0 !important;
            width: 100% !important;
        }
        
        .mid-content {
            padding: 20px;
        }
    }

    /* =========================
       MODERN TOAST STYLES
    ========================= */
    #toast {
        position: fixed;
        top: 90px;
        right: 29px;
        width: 320px;
        padding: 16px 20px;
        border-radius: 12px;
        box-shadow: var(--shadow-lg);
        opacity: 0;
        transform: translateY(-15px);
        transition: .3s ease;
        color: #fff;
        z-index: 1001;
    }

    #toast.show {
        opacity: 1;
        transform: translateY(0);
    }

    .toast-content {
        display: flex;
        gap: 12px;
        align-items: flex-start;
    }

    .toast-icon {
        font-size: 20px;
    }

    .toast-text h4 {
        margin: 0;
        font-size: 14px;
        font-weight: 600;
    }

    .toast-text p {
        margin: 5px 0 0;
        font-size: 13px;
        opacity: 0.9;
    }

    /* Toast Colors */
    .toast-success { background: var(--success); }
    .toast-error { background: var(--danger); }
    .toast-info { background: var(--info); }
    .toast-warning { background: var(--warning); color: #1f2937; }

    /* Progress bar */
    .toast-progress {
        height: 3px;
        border-radius: 4px;
        margin-top: 12px;
        background: rgba(255,255,255,.6);
        animation: toast-load 3s linear forwards;
    }

    .toast-warning .toast-progress {
        background: rgba(0,0,0,.4);
    }

    @keyframes toast-load {
        from { width: 100%; }
        to { width: 0%; }
    }

    /* Header */
    .header {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 30px;
        margin-bottom: 30px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
    }

    .header h1 {
        color: var(--dark);
        font-size: 32px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 15px;
        font-weight: 700;
    }

    .header h1 i {
        color: var(--primary);
    }

    .header p {
        color: var(--text-muted);
        font-size: 16px;
        line-height: 1.6;
    }

    .role-badge {
        font-size: 11px;
        padding: 3px 8px;
        border-radius: 12px;
        font-weight: 600;
        display: inline-block;
    }
    
    .role-superadmin {
        background: #8b5cf6;
        color: white;
    }
    
    .role-educator {
        background: #3b82f6;
        color: white;
    }
    
    .role-trainer {
        background: #f59e0b;
        color: white;
    }
    
    .role-student {
        background: #10b981;
        color: white;
    }
    
    .role-user {
        background: var(--text-muted);
        color: white;
    }

    /* Device info */
    .device-info {
        background: rgba(102, 126, 234, 0.1);
        padding: 12px 20px;
        border-radius: 12px;
        margin-bottom: 25px;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--text);
        border: 1px solid var(--border);
    }

    .device-info i {
        color: var(--primary);
    }

    /* Process Steps */
    .process-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .steps-indicator {
        display: flex;
        justify-content: space-between;
        margin-bottom: 50px;
        position: relative;
    }

    .steps-indicator::before {
        content: '';
        position: absolute;
        top: 25px;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--border);
        z-index: 1;
    }

    .step {
        text-align: center;
        position: relative;
        z-index: 2;
        flex: 1;
    }

    .step-circle {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: var(--bg-white);
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: bold;
        margin: 0 auto 15px;
        transition: all 0.3s;
        border: 3px solid var(--border);
        box-shadow: var(--shadow);
    }

    .step.active .step-circle {
        background: var(--primary-gradient);
        border-color: var(--primary);
        color: white;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
    }

    .step.completed .step-circle {
        background: var(--whatsapp);
        border-color: var(--whatsapp);
        color: white;
    }

    .step-label {
        color: var(--text-muted);
        font-weight: 600;
        font-size: 14px;
    }

    .step.active .step-label {
        color: var(--primary);
        font-weight: 700;
    }

    /* Step Content */
    .step-content {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 40px;
        box-shadow: var(--shadow);
        margin-bottom: 30px;
        display: none;
        border: 1px solid var(--border);
    }

    .step-content.active {
        display: block;
        animation: slideIn 0.5s ease;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .step-title {
        color: var(--dark);
        font-size: 28px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        font-weight: 700;
    }

    .step-title i {
        color: var(--primary);
    }

    .step-description {
        color: var(--text-muted);
        font-size: 16px;
        line-height: 1.6;
        margin-bottom: 30px;
    }

    /* Form Elements */
    .form-group {
        margin-bottom: 25px;
    }

    .form-group label {
        display: block;
        color: var(--dark);
        font-weight: 600;
        margin-bottom: 10px;
        font-size: 15px;
    }

    .form-control {
        width: 100%;
        padding: 12px 20px;
        border: 1px solid var(--border);
        border-radius: 12px;
        font-size: 14px;
        transition: all 0.3s;
        background: var(--bg-white);
        color: var(--text);
    }

    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        background: var(--bg-white);
    }

    .form-control::placeholder {
        color: var(--text-muted);
        opacity: 0.7;
    }

    .select-wrapper {
        position: relative;
    }

    .select-wrapper i {
        position: absolute;
        right: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        pointer-events: none;
    }

    select.form-control {
        appearance: none;
        cursor: pointer;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }

    .number-hint {
        display: inline-block;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        margin-top: 10px;
    }

    .hint-whatsapp {
        background: rgba(37, 211, 102, 0.1);
        color: var(--whatsapp);
        border-left: 3px solid var(--whatsapp);
    }

    .hint-phone {
        background: rgba(79, 70, 229, 0.1);
        color: var(--primary);
        border-left: 3px solid var(--primary);
    }

    /* Groups Section */
    .groups-section {
        background: rgba(102, 126, 234, 0.05);
        border-radius: 20px;
        padding: 25px;
        margin: 30px 0;
        border: 1px solid var(--border);
    }

    .groups-section h3 {
        color: var(--dark);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .groups-section h3 i {
        color: var(--primary);
    }

    .groups-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 15px;
        max-height: 400px;
        overflow-y: auto;
        padding: 10px;
    }

    .group-card {
        background: var(--bg-card);
        border: 2px solid var(--border);
        border-radius: 16px;
        padding: 20px;
        cursor: pointer;
        transition: all 0.3s;
        position: relative;
    }

    .group-card:hover {
        border-color: var(--primary);
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
    }

    .group-card.selected {
        border-color: var(--whatsapp);
        background: rgba(37, 211, 102, 0.1);
    }

    .group-card.selected::before {
        content: '\f00c';
        font-family: 'Font Awesome 6 Free';
        font-weight: 900;
        position: absolute;
        top: -10px;
        right: -10px;
        background: var(--whatsapp);
        color: white;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        box-shadow: 0 3px 10px rgba(37, 211, 102, 0.3);
    }

    .group-card h4 {
        color: var(--dark);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 18px;
    }

    .group-card h4 i {
        color: var(--primary);
    }

    .group-card p {
        color: var(--text-muted);
        font-size: 14px;
        margin-bottom: 15px;
        line-height: 1.5;
    }

    .group-card .group-stats {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
    }

    .group-card .badge {
        background: var(--primary-gradient);
        color: white;
        padding: 5px 10px;
        border-radius: 20px;
    }

    .group-card .date {
        color: var(--text-muted);
    }

    /* Selected Group Info */
    .selected-group-banner {
        background: rgba(37, 211, 102, 0.1);
        border-radius: 12px;
        padding: 15px;
        margin-top: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-left: 4px solid var(--whatsapp);
        color: var(--text);
    }

    .selected-group-banner.hidden {
        display: none;
    }

    .selected-group-banner .group-info {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .selected-group-banner .group-info i {
        color: var(--whatsapp);
        font-size: 24px;
    }

    .selected-group-banner .group-details h4 {
        color: var(--dark);
        margin: 0;
    }

    .selected-group-banner .group-details p {
        color: var(--text-muted);
        margin: 5px 0 0;
        font-size: 14px;
    }

    .selected-group-banner .clear-btn {
        background: transparent;
        border: 2px solid var(--whatsapp);
        color: var(--whatsapp);
        padding: 8px 15px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s;
        font-weight: 600;
    }

    .selected-group-banner .clear-btn:hover {
        background: var(--whatsapp);
        color: white;
    }

    /* Excel Upload */
    .excel-upload-container {
        margin: 20px 0;
        padding: 20px;
        background: var(--bg-offwhite);
        border-radius: 16px;
        border: 2px dashed var(--border);
    }

    .excel-upload-box {
        text-align: center;
        padding: 40px 20px;
        cursor: pointer;
        transition: all 0.3s;
        border-radius: 12px;
        background: var(--bg-white);
    }

    .excel-upload-box:hover {
        background: rgba(102, 126, 234, 0.1);
        border-color: var(--primary);
    }

    .excel-upload-box i {
        font-size: 48px;
        color: #1d6f42;
        margin-bottom: 15px;
    }

    .excel-upload-box h4 {
        color: var(--dark);
        margin-bottom: 10px;
    }

    .excel-upload-box p {
        color: var(--text-muted);
        margin-bottom: 15px;
    }

    .excel-upload-box small {
        color: var(--text-muted);
        display: block;
        margin-top: 10px;
    }

    /* Excel Instructions */
    .excel-instructions {
        background: rgba(16, 185, 129, 0.1);
        padding: 15px;
        border-radius: 12px;
        margin: 20px 0;
        border-left: 4px solid var(--success);
        color: var(--text);
    }

    .excel-instructions h5 {
        color: var(--success);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .excel-instructions ul {
        margin-left: 20px;
        color: var(--text-muted);
    }

    .excel-instructions li {
        margin-bottom: 8px;
    }

    /* Excel Preview Table */
    .excel-preview {
        margin: 20px 0;
        display: none;
    }

    .excel-preview-table {
        width: 100%;
        border-collapse: collapse;
        background: var(--bg-white);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .excel-preview-table th {
        background: #1d6f42;
        color: white;
        padding: 12px 15px;
        text-align: left;
        font-weight: 600;
    }

    .excel-preview-table td {
        padding: 10px 15px;
        border-bottom: 1px solid var(--border);
        color: var(--text);
    }

    .excel-preview-table tr:hover {
        background: var(--bg-offwhite);
    }

    /* Contact Control Buttons */
    .contact-controls {
        display: flex;
        gap: 10px;
        margin: 15px 0;
        flex-wrap: wrap;
    }

    /* Media Upload */
    .media-upload {
        border: 2px dashed var(--border);
        border-radius: 12px;
        padding: 30px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
        background: var(--bg-offwhite);
        margin: 20px 0;
    }

    .media-upload:hover {
        border-color: var(--primary);
        background: rgba(102, 126, 234, 0.1);
    }

    .media-upload i {
        font-size: 48px;
        color: var(--primary);
        margin-bottom: 15px;
    }

    /* File Preview */
    .file-preview {
        background: rgba(16, 185, 129, 0.1);
        padding: 15px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 15px;
        margin-top: 15px;
        border: 1px solid var(--border);
    }

    .file-preview i {
        font-size: 24px;
        color: var(--success);
    }

    .file-info {
        flex: 1;
    }

    .file-info strong {
        display: block;
        margin-bottom: 5px;
        color: var(--dark);
    }

    .file-info div {
        color: var(--text-muted);
    }

    /* Media Options */
    .media-options-container {
        margin: 20px 0;
        padding: 20px;
        background: var(--bg-offwhite);
        border-radius: 16px;
        border: 1px solid var(--border);
    }

    .media-option {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
        padding: 15px;
        background: var(--bg-white);
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s;
        border: 2px solid var(--border);
    }

    .media-option:hover {
        border-color: var(--primary);
        background: rgba(102, 126, 234, 0.1);
    }

    .media-option.selected {
        border-color: var(--whatsapp);
        background: rgba(37, 211, 102, 0.1);
    }

    .media-option input[type="checkbox"] {
        margin-right: 15px;
        width: 20px;
        height: 20px;
        cursor: pointer;
        accent-color: var(--whatsapp);
    }

    .media-option-content {
        flex: 1;
    }

    .media-option-content h4 {
        margin: 0 0 5px 0;
        color: var(--dark);
    }

    .media-option-content p {
        margin: 0;
        color: var(--text-muted);
        font-size: 14px;
    }

    .media-option-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: var(--primary-gradient);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 15px;
    }

    /* Message Checkbox */
    .message-checkbox-container {
        margin: 15px 0;
        padding: 15px;
        background: var(--bg-offwhite);
        border-radius: 12px;
        border: 1px solid var(--border);
    }

    .message-checkbox {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .message-checkbox input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: var(--primary);
    }

    .message-checkbox label {
        color: var(--dark);
        font-weight: 600;
        cursor: pointer;
        user-select: none;
    }

    /* Hide message textarea when checkbox unchecked */
    .message-container {
        transition: all 0.3s;
    }

    .message-container.hidden {
        opacity: 0.5;
        pointer-events: none;
    }

    /* Buttons - EXACTLY LIKE PREVIOUS TEMPLATES */
    .btn {
        padding: 12px 24px;
        border: none;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-primary {
        background: var(--primary-gradient);
        color: white;
    }

    .btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
    }

    .btn-success {
        background: linear-gradient(135deg, var(--whatsapp) 0%, #1EBEA5 100%);
        color: white;
    }

    .btn-success:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(37, 211, 102, 0.3);
    }

    .btn-secondary {
        background: var(--bg-white);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .btn-secondary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
    }

    .btn-outline {
        background: transparent;
        border: 1px solid var(--primary);
        color: var(--primary);
        padding: 10px 22px;
    }

    .btn-outline:hover:not(:disabled) {
        background: var(--primary-gradient);
        color: white;
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
    }

    .btn-warning {
        background: var(--warning);
        color: white;
    }

    .btn-warning:hover:not(:disabled) {
        background: #e68900;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(255, 152, 0, 0.3);
    }

    .btn-excel {
        background: linear-gradient(135deg, #1d6f42 0%, var(--success) 100%);
        color: white;
    }

    .btn-excel:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(29, 111, 66, 0.3);
    }

    .btn-group {
        background: linear-gradient(135deg, #9b59b6 0%, #8e44ad 100%);
        color: white;
    }

    .btn-group:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(155, 89, 182, 0.3);
    }

    .btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .action-buttons {
        display: flex;
        justify-content: space-between;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid var(--border);
    }

    /* Campaign Summary */
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .summary-item {
        background: var(--bg-offwhite);
        padding: 15px;
        border-radius: 12px;
        border-left: 4px solid var(--primary);
        border: 1px solid var(--border);
    }

    .summary-item small {
        color: var(--text-muted);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .summary-item p {
        font-weight: bold;
        font-size: 16px;
        margin-top: 5px;
        color: var(--dark);
    }

    /* Progress Bar */
    .progress-container {
        margin: 20px 0;
    }

    .progress-bar {
        height: 10px;
        background: var(--border);
        border-radius: 5px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: var(--primary-gradient);
        width: 0%;
        transition: width 0.5s ease;
    }

    .progress-text {
        display: flex;
        justify-content: space-between;
        margin-top: 5px;
        font-size: 14px;
        color: var(--text-muted);
    }

    /* Table Styles */
    .campaign-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
        background: var(--bg-white);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .campaign-table th {
        background: var(--bg-offwhite);
        padding: 15px;
        text-align: left;
        color: var(--text-muted);
        font-weight: 600;
        border-bottom: 2px solid var(--border);
    }

    .campaign-table td {
        padding: 15px;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
        color: var(--text);
    }

    .status-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-scheduled { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
    .status-sending { background: rgba(59, 130, 246, 0.1); color: var(--info); }
    .status-completed { background: rgba(16, 185, 129, 0.1); color: var(--success); }
    .status-failed { background: rgba(239, 68, 68, 0.1); color: var(--danger); }
    .status-cancelled { background: var(--bg-offwhite); color: var(--text-muted); }

    /* Schedule Options */
    .schedule-options {
        display: flex;
        gap: 20px;
        margin: 15px 0;
    }

    .schedule-option {
        flex: 1;
        padding: 20px;
        border: 2px solid var(--border);
        border-radius: 12px;
        cursor: pointer;
        text-align: center;
        background: var(--bg-white);
        color: var(--text);
        transition: all 0.3s;
    }

    .schedule-option:hover {
        border-color: var(--primary);
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
    }

    .schedule-option.active {
        border-color: var(--whatsapp);
        background: rgba(37, 211, 102, 0.1);
    }

    .schedule-option i {
        font-size: 24px;
        margin-bottom: 10px;
        display: block;
        color: var(--primary);
    }

    .schedule-option h3 {
        margin: 0 0 5px;
        font-size: 18px;
        color: var(--dark);
    }

    .schedule-option p {
        margin: 0;
        color: var(--text-muted);
        font-size: 13px;
    }

    .schedule-datetime {
        display: none;
        margin-top: 20px;
    }

    .schedule-datetime.show {
        display: block;
    }

    .datetime-inputs {
        display: flex;
        gap: 15px;
    }

    .datetime-inputs input {
        flex: 1;
    }

    /* Hidden File Input */
    .hidden-file-input {
        display: none;
    }

    /* Contact Count Badge */
    #contactsCount {
        position: absolute;
        top: 15px;
        right: 15px;
        background: var(--primary-gradient);
        color: white;
        padding: 3px 10px;
        border-radius: 15px;
        font-size: 12px;
    }

    /* Refresh Button */
    .refresh-groups {
        text-align: right;
        margin-bottom: 15px;
    }

    /* Loading Overlay */
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        backdrop-filter: blur(5px);
    }

    .spinner {
        width: 50px;
        height: 50px;
        border: 5px solid var(--bg-offwhite);
        border-top: 5px solid var(--primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* Responsive */
    @media (max-width: 992px) {
        .header h1 {
            font-size: 28px;
        }
        
        .step-title {
            font-size: 24px;
        }
        
        .schedule-options {
            flex-direction: column;
        }
    }

    @media (max-width: 768px) {
        .step {
            flex: none;
            width: 100%;
            margin-bottom: 20px;
        }
        
        .steps-indicator {
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .steps-indicator::before {
            display: none;
        }
        
        .action-buttons {
            flex-direction: column;
            gap: 15px;
        }
        
        .btn {
            width: 100%;
            justify-content: center;
        }
        
        .contact-controls {
            flex-direction: column;
        }
        
        .contact-controls .btn {
            width: 100%;
        }
        
        .summary-grid {
            grid-template-columns: 1fr;
        }
        
        .datetime-inputs {
            flex-direction: column;
        }

        .groups-grid {
            grid-template-columns: 1fr;
        }

        .selected-group-banner {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }

        .selected-group-banner .group-info {
            flex-direction: column;
        }

        .header {
            padding: 20px;
        }
        
        .step-content {
            padding: 25px;
        }
    }

    @media (max-width: 576px) {
        .content-wrapper {
            padding: 10px;
        }
        
        .mid-content {
            padding: 15px;
        }
        
        .header h1 {
            font-size: 22px;
        }
        
        .step-title {
            font-size: 20px;
        }
        
        .form-control {
            padding: 10px 16px;
        }
        
        .btn {
            padding: 10px 20px;
        }
        
        .groups-section,
        .excel-upload-container,
        .media-options-container {
            padding: 15px;
        }
        
        .group-card {
            padding: 15px;
        }
        
        .excel-upload-box {
            padding: 25px 15px;
        }
    }
</style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <%- include('../partials/ram/sidebaar') %>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <div class="mid-content">
                <!-- Toast Container -->
                <div id="toast"></div>

                <!-- Header -->
                <div class="header">
                    <div>
                        <h1><i class="fab fa-whatsapp"></i> WhatsApp Campaign</h1>
                        <p>Complete step-by-step process to send WhatsApp messages to multiple contacts</p>
                    </div>
                </div>

                <!-- Device Info -->
                <div class="device-info">
                    <i class="fas fa-info-circle"></i>
                    <span>
                        <strong><%= devices.length %></strong> device(s) available 
                        <% if (user.role === 'SuperAdmin') { %>
                            (all users - SuperAdmin view)
                        <% } else { %>
                            (your devices only)
                        <% } %>
                    </span>
                </div>

                <!-- Scheduled Campaigns Section -->
                <% if(locals.scheduledCampaigns && scheduledCampaigns && scheduledCampaigns.length > 0) { %>
                    <div class="bg-card p-4 mb-4" style="border-radius: 20px; border: 1px solid var(--border);">
                        <h2 style="color: var(--dark); margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-clock"></i> Scheduled Campaigns (<%= scheduledCampaigns.length %>)
                        </h2>
                        
                        <div class="table-responsive">
                            <table class="campaign-table">
                                <thead>
                                    <tr>
                                        <th>Campaign Name</th>
                                        <th>Scheduled Time</th>
                                        <th>Contacts</th>
                                        <th>Device</th>
                                        <th>Status</th>
                                        <% if (user.role === 'SuperAdmin') { %>
                                            <th>Created By</th>
                                        <% } %>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% scheduledCampaigns.forEach(campaign => { %>
                                    <tr>
                                        <td>
                                            <strong><%= campaign.campaignName %></strong>
                                            <div>
                                                <small style="color: var(--text-muted);">
                                                    <%= campaign.messageType === 'media' ? 'Media' : 'Text' %>
                                                </small>
                                            </div>
                                        </td>
                                        <td>
                                            <div><strong><%= new Date(campaign.scheduledAt).toLocaleString() %></strong></div>
                                        </td>
                                        <td>
                                            <span class="badge-soft" style="background: rgba(16, 185, 129, 0.1); color: var(--success); padding: 5px 10px;">
                                                <%= campaign.totalContacts %> contacts
                                            </span>
                                        </td>
                                        <td><%= campaign.deviceId.substring(0, 8) %>...</td>
                                        <td>
                                            <span class="status-badge status-scheduled">
                                                <i class="fas fa-clock"></i> Scheduled
                                            </span>
                                        </td>
                                        <% if (user.role === 'SuperAdmin') { %>
                                            <td>
                                                <span class="role-badge role-<%= campaign.createdByRole?.toLowerCase() || 'user' %>">
                                                    <%= campaign.createdByRole || 'Unknown' %>
                                                </span>
                                                <small class="d-block text-muted"><%= campaign.createdByEmail || 'N/A' %></small>
                                            </td>
                                        <% } %>
                                        <td>
                                            <button class="btn btn-outline" style="padding: 5px 15px;" onclick="cancelCampaign('<%= campaign.campaignId %>')">
                                                <i class="fas fa-times"></i> Cancel
                                            </button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } %>

                <div class="process-container">
                    <!-- Steps Indicator -->
                    <div class="steps-indicator">
                        <div class="step active" id="step1-indicator">
                            <div class="step-circle">1</div>
                            <div class="step-label">Device</div>
                        </div>
                        <div class="step" id="step2-indicator">
                            <div class="step-circle">2</div>
                            <div class="step-label">Contacts</div>
                        </div>
                        <div class="step" id="step3-indicator">
                            <div class="step-circle">3</div>
                            <div class="step-label">Message</div>
                        </div>
                        <div class="step" id="step4-indicator">
                            <div class="step-circle">4</div>
                            <div class="step-label">Send</div>
                        </div>
                    </div>

                    <!-- Step 1: Device Setup -->
                    <div class="step-content active" id="step1">
                        <h2 class="step-title"><i class="fas fa-mobile-alt"></i> Select WhatsApp Device</h2>
                        <p class="step-description">Choose your WhatsApp device and configure basic settings.</p>
                        
                        <div class="form-group">
                            <label><i class="fas fa-phone"></i> Select WhatsApp Device</label>
                            <div class="select-wrapper">
                                <select class="form-control" id="channel" required>
                                    <% if(devices && devices.length){ %>
                                        <% devices.forEach(d => { %>
                                            <option value="<%= d.deviceId %>">
                                                <%= d.whatsappName || d.whatsappNumber || d.phone || 'WhatsApp Device' %> (<%= d.status %>)
                                                <% if (user.role === 'SuperAdmin' && d.createdByEmail) { %>
                                                    - <%= d.createdByEmail %>
                                                <% } %>
                                            </option>
                                        <% }) %>
                                    <% } else { %>
                                        <option value="" disabled selected>No device connected</option>
                                    <% } %>
                                </select>
                                <i class="fas fa-chevron-down"></i>
                            </div>
                            <% if(devices && devices.length){ %>
                                <small style="color: var(--text-muted); margin-top: 5px; display: block;">
                                    <i class="fas fa-info-circle"></i> Select the device you want to use for sending messages
                                </small>
                            <% } else { %>
                                <small style="color: var(--danger); margin-top: 5px; display: block;">
                                    <i class="fas fa-exclamation-triangle"></i> No WhatsApp device found. Please connect a device first.
                                </small>
                            <% } %>
                        </div>

                        <div class="form-group">
                            <label><i class="fas fa-clock"></i> Delay Between Messages (Seconds)</label>
                            <input type="number" class="form-control" id="interval" value="5" min="1" max="30" required>
                            <small style="color: var(--text-muted); margin-top: 5px; display: block;">
                                <i class="fas fa-info-circle"></i> Recommended: 5-10 seconds to avoid WhatsApp blocking
                            </small>
                        </div>

                        <div class="action-buttons">
                            <div></div>
                            <button class="btn btn-primary" onclick="nextStep(2)">
                                Next Step <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Step 2: Contacts -->
                    <div class="step-content" id="step2">
                        <h2 class="step-title"><i class="fas fa-address-book"></i> Select Contacts</h2>
                        <p class="step-description">Choose contacts for your WhatsApp campaign.</p>

                        <!-- GROUPS SECTION -->
                        <div class="groups-section">
                            <h3><i class="fas fa-layer-group"></i> Select from Existing Groups</h3>
                            
                            <div class="refresh-groups">
                                <button class="btn btn-outline" onclick="loadGroups()">
                                    <i class="fas fa-sync-alt"></i> Refresh Groups
                                </button>
                            </div>

                            <div id="groupsGrid" class="groups-grid">
                                <!-- Groups will be loaded here -->
                                <div style="text-align: center; padding: 40px; color: var(--text-muted); grid-column: 1/-1;">
                                    <i class="fas fa-spinner fa-spin" style="font-size: 30px;"></i>
                                    <p style="margin-top: 15px;">Loading groups...</p>
                                </div>
                            </div>

                            <!-- Selected Group Banner -->
                            <div id="selectedGroupBanner" class="selected-group-banner hidden">
                                <div class="group-info">
                                    <i class="fas fa-check-circle"></i>
                                    <div class="group-details">
                                        <h4 id="selectedGroupName"></h4>
                                        <p id="selectedGroupStats"></p>
                                    </div>
                                </div>
                                <button class="clear-btn" onclick="clearSelectedGroup()">
                                    <i class="fas fa-times"></i> Clear Selection
                                </button>
                            </div>
                        </div>

                        <!-- Excel Upload Section -->
                        <div class="excel-upload-container">
                            <h4 style="color: var(--dark); margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                                <i class="fas fa-file-excel"></i> Upload Excel/CSV File
                            </h4>
                            
                            <div class="excel-upload-box" onclick="document.getElementById('excelFileInput').click()">
                                <i class="fas fa-file-excel"></i>
                                <h4>Click to upload Excel/CSV file</h4>
                                <p>Upload Excel (.xlsx, .xls) or CSV (.csv) file containing phone numbers</p>
                                <button class="btn btn-excel">
                                    <i class="fas fa-upload"></i> Upload Excel File
                                </button>
                                <small>Max file size: 10MB</small>
                            </div>
                            
                            <input type="file" id="excelFileInput" class="hidden-file-input" accept=".xlsx,.xls,.csv" onchange="handleExcelUpload(event)">
                            
                            <div class="excel-instructions">
                                <h5><i class="fas fa-info-circle"></i> Excel File Format Instructions:</h5>
                                <ul>
                                    <li>File should contain a column with phone numbers</li>
                                    <li>Phone numbers should be in 10-digit format (e.g., 9876543210)</li>
                                    <li>If you have WhatsApp numbers, include them in a separate column</li>
                                    <li>Supported formats: Excel (.xlsx, .xls) or CSV (.csv)</li>
                                    <li>First row can be headers (optional)</li>
                                </ul>
                            </div>
                            
                            <!-- Excel Preview -->
                            <div id="excelPreview" class="excel-preview">
                                <h5 style="color: var(--dark); margin-bottom: 10px;">Preview (First 10 rows):</h5>
                                <div class="table-responsive">
                                    <table class="excel-preview-table">
                                        <thead id="excelPreviewHeader"></thead>
                                        <tbody id="excelPreviewBody"></tbody>
                                    </table>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span id="excelRowCount"></span>
                                    <button class="btn btn-outline" onclick="useExcelNumbers()">
                                        <i class="fas fa-check"></i> Use These Numbers
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- OR Divider -->
                        <div class="position-relative my-4">
                            <hr class="bg-muted">
                            <span class="position-absolute top-50 start-50 translate-middle px-3 bg-card" style="color: var(--text-muted);">OR</span>
                        </div>

                        <div class="form-group position-relative">
                            <label><i class="fas fa-mobile-alt"></i> Phone Numbers / WhatsApp Numbers</label>
                            <textarea id="numbers" class="form-control" rows="8"
                            placeholder="Example: 9876543210, 9123456789
Or paste numbers with any separator (comma, space, new line)" required></textarea>
                            <div id="contactsCount">
                                <span id="countNumber">0</span> contacts
                            </div>
                        </div>

                        <!-- Contact Control Buttons -->
                        <div class="contact-controls">
                            <button type="button" class="btn btn-outline" onclick="fetchContacts()">
                                <i class="fas fa-database"></i> All Contacts
                            </button>
                            <button type="button" class="btn btn-outline" onclick="selectAllContacts()">
                                <i class="fas fa-check-double"></i> Select All
                            </button>
                            <button type="button" class="btn btn-outline" onclick="clearAllContacts()">
                                <i class="fas fa-trash"></i> Clear All
                            </button>
                            <button type="button" class="btn btn-outline" onclick="validateNumbers()">
                                <i class="fas fa-check-circle"></i> Validate
                            </button>
                            <button type="button" class="btn btn-outline" onclick="removeDuplicates()">
                                <i class="fas fa-filter"></i> Remove Duplicates
                            </button>
                        </div>

                        <div class="action-buttons">
                            <button class="btn btn-outline" onclick="prevStep(1)">
                                <i class="fas fa-arrow-left"></i> Previous
                            </button>
                            <button class="btn btn-primary" onclick="nextStep(3)">
                                Next Step <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Step 3: Message -->
                    <div class="step-content" id="step3">
                        <h2 class="step-title"><i class="fas fa-edit"></i> Compose Message</h2>
                        <p class="step-description">Choose what you want to send - text message or media.</p>

                        <!-- Media Options -->
                        <div class="media-options-container">
                            <h4 style="color: var(--dark); margin-bottom: 20px;">Choose what to send:</h4>
                            
                            <!-- Option 1: Only Text Message -->
                            <div class="media-option selected" id="textOnlyOption" onclick="selectMediaOption('textOnly')">
                                <div class="media-option-icon">
                                    <i class="fas fa-comment"></i>
                                </div>
                                <input type="checkbox" id="textOnlyCheckbox" checked>
                                <div class="media-option-content">
                                    <h4>Send Only Message</h4>
                                    <p>Send text message without any media attachment</p>
                                </div>
                            </div>
                            
                            <!-- Option 2: Media with optional message -->
                            <div class="media-option" id="mediaOption" onclick="selectMediaOption('media')">
                                <div class="media-option-icon">
                                    <i class="fas fa-paperclip"></i>
                                </div>
                                <input type="checkbox" id="mediaCheckbox">
                                <div class="media-option-content">
                                    <h4>Send Media (Image/Video/PDF)</h4>
                                    <p>Send media files with optional text message</p>
                                </div>
                            </div>
                        </div>

                        <!-- Media Upload Section (Hidden by default) -->
                        <div id="mediaUploadSection" style="display: none;">
                            <div class="form-group">
                                <label><i class="fas fa-upload"></i> Upload Media (Required)</label>
                                <div class="media-upload" onclick="document.getElementById('mediaFile').click()">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <p class="mb-2">Click to upload image/video/document</p>
                                    <small style="color: var(--text-muted);">Supported: Images (JPG, PNG, GIF), Videos (MP4, AVI), Documents (PDF, DOC, TXT)</small>
                                    <input type="file" id="mediaFile" style="display: none;" onchange="handleMediaUpload(event)" accept="image/*,video/*,.pdf,.doc,.docx,.txt">
                                </div>
                                <div id="mediaPreview"></div>
                            </div>

                            <!-- Message Checkbox for Media Option -->
                            <div id="messageCheckboxContainer" class="message-checkbox-container" style="display: none;">
                                <div class="message-checkbox">
                                    <input type="checkbox" id="includeMessageCheckbox" checked>
                                    <label for="includeMessageCheckbox">Include text message with media</label>
                                </div>
                            </div>
                        </div>

                        <!-- Message Container -->
                        <div id="messageContainer" class="form-group message-container">
                            <label><i class="fas fa-comment"></i> Message Content</label>
                            <textarea id="message" class="form-control" rows="8"
                            placeholder="Type your campaign message here..." required></textarea>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div class="d-flex gap-2 flex-wrap">
                                    <button type="button" class="btn btn-outline" onclick="insertVariable('{{name}}')" style="padding: 5px 10px;">
                                        <i class="fas fa-user"></i> Name
                                    </button>
                                    <button type="button" class="btn btn-outline" onclick="insertVariable('{{phone}}')" style="padding: 5px 10px;">
                                        <i class="fas fa-phone"></i> Phone
                                    </button>
                                    <button type="button" class="btn btn-outline" onclick="insertVariable('{{date}}')" style="padding: 5px 10px;">
                                        <i class="fas fa-calendar"></i> Date
                                    </button>
                                </div>
                                <span id="charCount" style="color: var(--text-muted);">0/1000</span>
                            </div>
                        </div>

                        <div class="action-buttons">
                            <button class="btn btn-outline" onclick="prevStep(2)">
                                <i class="fas fa-arrow-left"></i> Previous
                            </button>
                            <button class="btn btn-primary" onclick="nextStep(4)">
                                Next Step <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Step 4: Send -->
                    <div class="step-content" id="step4">
                        <h2 class="step-title"><i class="fas fa-paper-plane"></i> Schedule & Send</h2>
                        <p class="step-description">Choose when to send your WhatsApp campaign.</p>
                        
                        <!-- Schedule Options -->
                        <div class="form-group">
                            <label><i class="fas fa-clock"></i> Send Now or Schedule</label>
                            <div class="schedule-options">
                                <div class="schedule-option active" id="scheduleNow" onclick="selectSchedule('now')">
                                    <i class="fas fa-bolt"></i>
                                    <h3>Send Now</h3>
                                    <p>Immediately start sending</p>
                                </div>
                                <div class="schedule-option" id="scheduleLater" onclick="selectSchedule('later')">
                                    <i class="far fa-clock"></i>
                                    <h3>Schedule Later</h3>
                                    <p>Send at specific time</p>
                                </div>
                            </div>
                        </div>

                        <div id="scheduleDateTime" class="schedule-datetime">
                            <div class="datetime-inputs">
                                <div class="form-group">
                                    <label><i class="fas fa-calendar"></i> Select Date</label>
                                    <input type="date" class="form-control" id="scheduleDate" min="<%= new Date().toISOString().split('T')[0] %>">
                                </div>
                                <div class="form-group">
                                    <label><i class="fas fa-clock"></i> Select Time</label>
                                    <input type="time" class="form-control" id="scheduleTime" value="<%= new Date().getHours().toString().padStart(2, '0') %>:<%= (new Date().getMinutes()+5).toString().padStart(2, '0') %>">
                                </div>
                            </div>
                            <small style="color: var(--text-muted); margin-top: 5px; display: block;">
                                <i class="fas fa-info-circle"></i> Campaign will be sent automatically at scheduled time
                            </small>
                        </div>
                        
                        <!-- Campaign Summary -->
                        <div style="background: var(--bg-offwhite); border-radius: 16px; padding: 30px; margin: 30px 0;">
                            <h3 style="color: var(--dark); margin-bottom: 20px;">Campaign Summary</h3>
                            
                            <div class="summary-grid">
                                <div class="summary-item">
                                    <small>Device</small>
                                    <p id="summaryDevice">--</p>
                                </div>
                                <div class="summary-item">
                                    <small>Contacts</small>
                                    <p id="summaryContacts">0</p>
                                </div>
                                <div class="summary-item">
                                    <small>Message Type</small>
                                    <p id="summaryType">Text</p>
                                </div>
                                <div class="summary-item">
                                    <small>Media</small>
                                    <p id="summaryMedia">None</p>
                                </div>
                                <div class="summary-item">
                                    <small>Schedule</small>
                                    <p id="summarySchedule">Send Now</p>
                                </div>
                                <div class="summary-item">
                                    <small>Interval</small>
                                    <p id="summaryInterval">5 seconds</p>
                                </div>
                            </div>
                            
                            <!-- Media Preview in Summary -->
                            <div id="summaryMediaPreview" style="display: none; margin-top: 20px; padding: 15px; background: var(--bg-white); border-radius: 12px; border: 1px solid var(--border);">
                                <h4 style="color: var(--dark); margin-bottom: 10px;">Media Attachment</h4>
                                <div id="summaryMediaContent"></div>
                            </div>
                        </div>

                        <!-- Progress Bar (Hidden by default) -->
                        <div id="progressContainer" class="progress-container" style="display: none;">
                            <div class="progress-bar">
                                <div class="progress-fill" id="progressFill"></div>
                            </div>
                            <div class="progress-text">
                                <span>Progress: <span id="progressPercent">0%</span></span>
                                <span><span id="progressSent">0</span>/<span id="progressTotal">0</span> sent</span>
                            </div>
                        </div>

                        <div class="action-buttons">
                            <button class="btn btn-outline" onclick="prevStep(3)">
                                <i class="fas fa-arrow-left"></i> Previous
                            </button>
                            <div class="d-flex gap-3">
                                <button type="button" id="testBtn" class="btn btn-secondary" onclick="testCampaign()">
                                    <i class="fas fa-vial"></i> Test
                                </button>
                                <button class="btn btn-warning" id="scheduleBtn" onclick="scheduleCampaign()">
                                    <i class="far fa-clock"></i> Schedule
                                </button>
                                <button class="btn btn-success" id="sendBtn" onclick="sendCampaignNow()">
                                    <i class="fab fa-whatsapp"></i> Send Now
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="text-center">
            <div class="spinner"></div>
            <div class="loading-text">Processing...</div>
        </div>
    </div>

    <!-- ExcelJS Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR SYNC - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);
            
            // Initialize campaign data
            initializeCampaign();
            
            // Load groups
            loadGroups();
            
            // Show welcome toast
            setTimeout(() => {
                showToast('Welcome', 'Start creating your WhatsApp campaign!', 'info');
            }, 1000);
        });

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOADING OVERLAY FUNCTIONS
        // ======================
        function showLoading(text = 'Processing...') {
            const overlay = document.getElementById('loadingOverlay');
            document.querySelector('.loading-text').textContent = text;
            overlay.style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        // ======================
        // GLOBAL VARIABLES
        // ======================
        let currentStep = 1;
        let campaignData = { 
            channel: '', 
            numbers: [], 
            message: '', 
            mediaData: null, 
            interval: 5,
            scheduleType: 'now',
            scheduleDate: '',
            scheduleTime: '',
            sendOption: 'textOnly',
            includeMessageWithMedia: true,
            selectedGroup: null
        };

        // Excel data storage
        let excelData = {
            numbers: [],
            headers: [],
            rows: []
        };

        // Groups data
        let allGroups = [];
        let selectedGroupId = null;

        // ======================
        // INITIALIZATION
        // ======================
        function initializeCampaign() {
            campaignData.channel = document.getElementById('channel').value;
            document.getElementById('channel').addEventListener('change', function() {
                campaignData.channel = this.value;
            });
            
            document.getElementById('message').addEventListener('input', function() {
                campaignData.message = this.value;
                updateSummary();
                updateCharCount();
            });
            
            // Schedule date/time change listeners
            document.getElementById('scheduleDate').addEventListener('change', function() {
                campaignData.scheduleDate = this.value;
                updateSummary();
            });
            
            document.getElementById('scheduleTime').addEventListener('change', function() {
                campaignData.scheduleTime = this.value;
                updateSummary();
            });
            
            // Update contact count
            document.getElementById('numbers').addEventListener('input', function() {
                updateContactCount();
                updateSummary();
            });
            
            // Message checkbox listener
            document.getElementById('includeMessageCheckbox').addEventListener('change', function() {
                campaignData.includeMessageWithMedia = this.checked;
                updateSummary();
                updateMessageFieldState();
            });
            
            // Initialize contact count
            updateContactCount();
        }

        // ======================
        // STEP NAVIGATION
        // ======================
        function nextStep(step) {
            if (validateCurrentStep()) {
                document.getElementById(`step${currentStep}`).classList.remove('active');
                document.getElementById(`step${currentStep}-indicator`).classList.remove('active');
                
                currentStep = step;
                document.getElementById(`step${currentStep}`).classList.add('active');
                document.getElementById(`step${currentStep}-indicator`).classList.add('active');
                
                // Update indicators for completed steps
                for (let i = 1; i < step; i++) {
                    const indicator = document.getElementById(`step${i}-indicator`);
                    if (indicator) {
                        indicator.classList.add('completed');
                    }
                }
                
                // Update summary if step 4
                if (step === 4) {
                    updateSummary();
                }
                
                // Show toast for step change
                const stepNames = ['', 'Device', 'Contacts', 'Message', 'Send'];
                showToast('Step ' + step, stepNames[step], 'info');
            }
        }

        function prevStep(step) {
            document.getElementById(`step${currentStep}`).classList.remove('active');
            document.getElementById(`step${currentStep}-indicator`).classList.remove('active');
            
            currentStep = step;
            document.getElementById(`step${currentStep}`).classList.add('active');
            document.getElementById(`step${currentStep}-indicator`).classList.add('active');
            
            // Show toast
            const stepNames = ['', 'Device', 'Contacts', 'Message', 'Send'];
            showToast('Step ' + step, stepNames[step], 'info');
        }

        function validateCurrentStep() {
            if (currentStep === 1) {
                const device = document.getElementById('channel').value;
                if (!device) {
                    showToast('Error', 'Please select a WhatsApp device', 'error');
                    return false;
                }
                campaignData.channel = device;
                return true;
            } else if (currentStep === 2) {
                const numbers = getNumbersArray();
                if (numbers.length === 0 && excelData.numbers.length === 0) {
                    showToast('Error', 'Please add at least one contact number', 'error');
                    return false;
                }
                return true;
            } else if (currentStep === 3) {
                if (campaignData.sendOption === 'textOnly') {
                    const message = document.getElementById('message').value.trim();
                    if (!message) {
                        showToast('Error', 'Please enter a message', 'error');
                        return false;
                    }
                } else if (campaignData.sendOption === 'media') {
                    if (!campaignData.mediaData) {
                        showToast('Error', 'Please upload media file', 'error');
                        return false;
                    }
                    if (campaignData.includeMessageWithMedia) {
                        const message = document.getElementById('message').value.trim();
                        if (!message) {
                            showToast('Error', 'Please enter a message', 'error');
                            return false;
                        }
                    }
                }
                return true;
            }
            return true;
        }

        // ======================
        // CONTACT MANAGEMENT
        // ======================
        function getNumbersArray() {
            const numbersText = document.getElementById('numbers').value;
            return numbersText.split(/[,\n\s]+/)
                .map(n => n.trim().replace(/\D/g, ''))
                .filter(n => n.length >= 10)
                .map(n => n.length === 10 ? n : n.slice(-10));
        }

        function updateContactCount() {
            const numbers = getNumbersArray();
            document.getElementById('countNumber').textContent = numbers.length;
            return numbers.length;
        }

        function selectAllContacts() {
            const numbers = document.getElementById('numbers');
            numbers.select();
            showToast('Selected', 'All numbers selected', 'info');
        }

        function clearAllContacts() {
            document.getElementById('numbers').value = '';
            clearSelectedGroup();
            updateContactCount();
            showToast('Cleared', 'All numbers removed', 'info');
        }

        function validateNumbers() {
            const numbers = getNumbersArray();
            const invalidNumbers = numbers.filter(n => n.length !== 10);
            
            if (invalidNumbers.length > 0) {
                showToast('Warning', `Found ${invalidNumbers.length} invalid numbers`, 'warning');
                const validNumbers = numbers.filter(n => n.length === 10);
                document.getElementById('numbers').value = validNumbers.join(',\n');
                updateContactCount();
            } else {
                showToast('Valid', 'All numbers are valid (10 digits)', 'success');
            }
        }

        function removeDuplicates() {
            const numbers = getNumbersArray();
            const uniqueNumbers = [...new Set(numbers)];
            
            if (numbers.length !== uniqueNumbers.length) {
                document.getElementById('numbers').value = uniqueNumbers.join(',\n');
                updateContactCount();
                showToast('Cleaned', `Removed ${numbers.length - uniqueNumbers.length} duplicates`, 'success');
            } else {
                showToast('Info', 'No duplicates found', 'info');
            }
        }

        // ======================
        // FETCH ALL CONTACTS
        // ======================
        async function fetchContacts() {
            try {
                showToast('Fetching', 'Loading contacts from database...', 'info');
                
                const response = await fetch('/api/contacts');
                const data = await response.json();
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                if (data.status && data.contacts && data.contacts.length > 0) {
                    // Try to use WhatsApp numbers first, fallback to phone
                    let phones = data.contacts.map(c => {
                        if (c.whatsappNumber) {
                            let whatsapp = c.whatsappNumber.replace(/\D/g, '');
                            if (whatsapp.startsWith('91')) whatsapp = whatsapp.substring(2);
                            return whatsapp.length === 10 ? whatsapp : null;
                        } else if (c.phoneNumber) {
                            let phone = c.phoneNumber.replace(/\D/g, '');
                            if (phone.startsWith('91')) phone = phone.substring(2);
                            return phone.length === 10 ? phone : null;
                        }
                        return null;
                    }).filter(n => n && n.length === 10);
                    
                    const uniqueNumbers = [...new Set(phones)];
                    if (uniqueNumbers.length > 0) {
                        document.getElementById('numbers').value = uniqueNumbers.join(',\n');
                        
                        // Clear selected group if any
                        clearSelectedGroup();
                        
                        updateContactCount();
                        showToast('Success', `Loaded ${uniqueNumbers.length} contacts (using WhatsApp numbers where available)`, 'success');
                    } else {
                        showToast('Warning', 'No valid 10-digit numbers found in contacts', 'warning');
                    }
                } else if (data.contacts && data.contacts.length === 0) {
                    showToast('Info', 'No contacts found in database', 'info');
                } else {
                    showToast('Error', data.msg || 'Failed to fetch contacts', 'error');
                }
            } catch (err) {
                console.error('Fetch contacts error:', err);
                showToast('Error', 'Failed to fetch contacts: ' + err.message, 'error');
                
                // Fallback demo data for testing
                if (confirm('Server error. Would you like to load sample contacts for testing?')) {
                    const sampleNumbers = ['9876543210', '8765432109', '7654321098', '6543210987', '5432109876'];
                    document.getElementById('numbers').value = sampleNumbers.join(',\n');
                    updateContactCount();
                    showToast('Info', 'Sample contacts loaded for testing', 'info');
                }
            }
        }

        // ======================
        // GROUPS FUNCTIONS
        // ======================
        async function loadGroups() {
            const groupsGrid = document.getElementById('groupsGrid');
            
            try {
                const response = await fetch('/api/groups');
                const data = await response.json();
                
                if (!data.success || data.count === 0) {
                    groupsGrid.innerHTML = `
                        <div style="text-align: center; padding: 40px; color: var(--text-muted); grid-column: 1/-1;">
                            <i class="fas fa-layer-group" style="font-size: 48px; color: #d1d5db; margin-bottom: 15px;"></i>
                            <h4>No Groups Found</h4>
                            <p>Create groups first in Contact Groups page</p>
                            <button class="btn btn-primary" onclick="window.location.href='/contactgroup'" style="margin-top: 15px;">
                                <i class="fas fa-plus"></i> Create Group
                            </button>
                        </div>
                    `;
                    return;
                }
                
                allGroups = data.data;
                
                groupsGrid.innerHTML = data.data.map(group => `
                    <div class="group-card" onclick="selectGroup('${group.id}', '${group.name}', ${group.totalContacts})">
                        <h4><i class="fas fa-users"></i> ${group.name}</h4>
                        <p>${group.description || 'No description'}</p>
                        <div class="group-stats">
                            <span class="badge">${group.totalContacts} contacts</span>
                            <span class="date"><i class="far fa-clock"></i> ${new Date(group.createdAt).toLocaleDateString()}</span>
                        </div>
                    </div>
                `).join('');
                
            } catch (error) {
                console.error('Error loading groups:', error);
                groupsGrid.innerHTML = `
                    <div style="text-align: center; padding: 40px; color: var(--text-muted); grid-column: 1/-1;">
                        <i class="fas fa-exclamation-circle" style="font-size: 48px; color: var(--danger); margin-bottom: 15px;"></i>
                        <h4>Failed to load groups</h4>
                        <p>Please try again</p>
                        <button class="btn btn-outline" onclick="loadGroups()" style="margin-top: 15px;">
                            <i class="fas fa-sync-alt"></i> Retry
                        </button>
                    </div>
                `;
            }
        }

        async function selectGroup(groupId, groupName, totalContacts) {
            try {
                showToast('Loading', `Loading contacts from ${groupName}...`, 'info');
                
                // Remove selected class from all cards
                document.querySelectorAll('.group-card').forEach(card => {
                    card.classList.remove('selected');
                });
                
                // Add selected class to clicked card
                event.currentTarget.classList.add('selected');
                
                // Fetch group details with contacts
                const response = await fetch(`/api/groups/${groupId}`);
                const data = await response.json();
                
                if (data.success) {
                    const group = data.data;
                    
                    // Extract WhatsApp numbers if available, otherwise use phone numbers
                    let phoneNumbers = [];
                    
                    phoneNumbers = group.contacts.map(contact => {
                        // First try to get WhatsApp number
                        if (contact.whatsappNumber) {
                            let whatsapp = contact.whatsappNumber.replace(/\D/g, '');
                            return whatsapp.length === 10 ? whatsapp : null;
                        } 
                        // Fallback to phone number
                        else if (contact.phoneNumber) {
                            let phone = contact.phoneNumber.replace(/\D/g, '');
                            return phone.length === 10 ? phone : null;
                        }
                        return null;
                    }).filter(phone => phone !== null);
                    
                    // Update textarea with numbers
                    const numbersTextarea = document.getElementById('numbers');
                    numbersTextarea.value = phoneNumbers.join(',\n');
                    
                    // Update campaign data
                    campaignData.selectedGroup = {
                        id: groupId,
                        name: groupName,
                        contacts: group.contacts
                    };
                    selectedGroupId = groupId;
                    
                    // Show selected group banner
                    const banner = document.getElementById('selectedGroupBanner');
                    document.getElementById('selectedGroupName').textContent = groupName;
                    document.getElementById('selectedGroupStats').textContent = `${phoneNumbers.length} numbers loaded`;
                    banner.classList.remove('hidden');
                    
                    // Update contact count
                    updateContactCount();
                    
                    showToast('Success', `Loaded ${phoneNumbers.length} numbers from ${groupName}`, 'success');
                }
            } catch (error) {
                console.error('Error loading group contacts:', error);
                showToast('Error', 'Failed to load group contacts', 'error');
            }
        }

        function clearSelectedGroup() {
            campaignData.selectedGroup = null;
            selectedGroupId = null;
            
            // Hide banner
            document.getElementById('selectedGroupBanner').classList.add('hidden');
            
            // Remove selected class from all cards
            document.querySelectorAll('.group-card').forEach(card => {
                card.classList.remove('selected');
            });
            
            // Don't clear numbers - let user decide
            showToast('Info', 'Group selection cleared', 'info');
        }

        // ======================
        // EXCEL FUNCTIONS
        // ======================
        async function handleExcelUpload(event) {
            const file = event.target.files[0];
            if (!file) return;

            if (file.size > 10 * 1024 * 1024) {
                showToast('Error', 'File size must be less than 10MB', 'error');
                return;
            }

            showToast('Processing', 'Reading Excel file...', 'info');

            try {
                const data = await readExcelFile(file);
                if (data.numbers.length > 0) {
                    excelData = data;
                    displayExcelPreview();
                    showToast('Success', `Found ${data.numbers.length} phone numbers in Excel file`, 'success');
                } else {
                    showToast('Warning', 'No phone numbers found in the Excel file', 'warning');
                }
            } catch (error) {
                console.error('Excel parsing error:', error);
                showToast('Error', 'Failed to read Excel file: ' + error.message, 'error');
            }
        }

        function readExcelFile(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    try {
                        const data = e.target.result;
                        const workbook = XLSX.read(data, { type: 'binary' });
                        const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
                        const jsonData = XLSX.utils.sheet_to_json(firstSheet, { header: 1 });
                        
                        const headers = jsonData[0] || [];
                        const rows = jsonData.slice(1);
                        
                        let phoneColumnIndex = -1;
                        let whatsappColumnIndex = -1;
                        let phoneNumbers = [];
                        
                        // First look for WhatsApp column
                        headers.forEach((header, index) => {
                            if (header && typeof header === 'string') {
                                const lowerHeader = header.toLowerCase();
                                if (lowerHeader.includes('whatsapp')) {
                                    whatsappColumnIndex = index;
                                }
                            }
                        });
                        
                        // Then look for phone column
                        headers.forEach((header, index) => {
                            if (header && typeof header === 'string') {
                                const lowerHeader = header.toLowerCase();
                                if (lowerHeader.includes('phone') || 
                                    lowerHeader.includes('mobile') || 
                                    lowerHeader.includes('number') ||
                                    lowerHeader.includes('contact')) {
                                    phoneColumnIndex = index;
                                }
                            }
                        });
                        
                        // If WhatsApp column found, use that
                        if (whatsappColumnIndex !== -1) {
                            rows.forEach(row => {
                                if (row[whatsappColumnIndex]) {
                                    const phone = row[whatsappColumnIndex].toString().trim();
                                    const cleanPhone = phone.replace(/\D/g, '');
                                    if (cleanPhone.length >= 10) {
                                        const finalPhone = cleanPhone.length > 10 ? cleanPhone.slice(-10) : cleanPhone;
                                        if (finalPhone.length === 10) {
                                            phoneNumbers.push(finalPhone);
                                        }
                                    }
                                }
                            });
                        } else if (phoneColumnIndex !== -1) {
                            // Fallback to phone column
                            rows.forEach(row => {
                                if (row[phoneColumnIndex]) {
                                    const phone = row[phoneColumnIndex].toString().trim();
                                    const cleanPhone = phone.replace(/\D/g, '');
                                    if (cleanPhone.length >= 10) {
                                        const finalPhone = cleanPhone.length > 10 ? cleanPhone.slice(-10) : cleanPhone;
                                        if (finalPhone.length === 10) {
                                            phoneNumbers.push(finalPhone);
                                        }
                                    }
                                }
                            });
                        } else {
                            // Auto-detect
                            headers.forEach((header, index) => {
                                const numbersCount = rows.filter(row => {
                                    const value = row[index];
                                    return value && /^\d{10,}$/.test(value.toString().trim());
                                }).length;
                                
                                if (numbersCount > rows.length * 0.5) {
                                    phoneColumnIndex = index;
                                }
                            });
                            
                            if (phoneColumnIndex !== -1) {
                                rows.forEach(row => {
                                    if (row[phoneColumnIndex]) {
                                        const phone = row[phoneColumnIndex].toString().trim();
                                        const cleanPhone = phone.replace(/\D/g, '');
                                        if (cleanPhone.length >= 10) {
                                            const finalPhone = cleanPhone.length > 10 ? cleanPhone.slice(-10) : cleanPhone;
                                            if (finalPhone.length === 10) {
                                                phoneNumbers.push(finalPhone);
                                            }
                                        }
                                    }
                                });
                            }
                        }
                        
                        const uniqueNumbers = [...new Set(phoneNumbers)];
                        
                        resolve({
                            numbers: uniqueNumbers,
                            headers: headers,
                            rows: rows,
                            phoneColumnIndex: phoneColumnIndex,
                            whatsappColumnIndex: whatsappColumnIndex
                        });
                    } catch (error) {
                        reject(error);
                    }
                };
                
                reader.onerror = function(error) {
                    reject(error);
                };
                
                reader.readAsBinaryString(file);
            });
        }

        function displayExcelPreview() {
            const previewDiv = document.getElementById('excelPreview');
            const headerElem = document.getElementById('excelPreviewHeader');
            const bodyElem = document.getElementById('excelPreviewBody');
            const rowCountElem = document.getElementById('excelRowCount');
            
            if (!excelData.headers.length || !excelData.rows.length) {
                previewDiv.style.display = 'none';
                return;
            }
            
            previewDiv.style.display = 'block';
            
            let headerHtml = '<tr>';
            excelData.headers.forEach((header, index) => {
                const isPhoneColumn = index === excelData.phoneColumnIndex;
                const isWhatsAppColumn = index === excelData.whatsappColumnIndex;
                let style = '';
                if (isWhatsAppColumn) {
                    style = 'background:#25D366; color:white;';
                } else if (isPhoneColumn) {
                    style = 'background:#4CAF50;';
                }
                headerHtml += `<th style="${style}">${header || `Column ${index + 1}`}</th>`;
            });
            headerHtml += '</tr>';
            headerElem.innerHTML = headerHtml;
            
            let bodyHtml = '';
            const maxRows = Math.min(10, excelData.rows.length);
            for (let i = 0; i < maxRows; i++) {
                const row = excelData.rows[i];
                bodyHtml += '<tr>';
                excelData.headers.forEach((header, index) => {
                    const value = row[index] || '';
                    const isWhatsAppColumn = index === excelData.whatsappColumnIndex;
                    const isPhoneColumn = index === excelData.phoneColumnIndex;
                    let style = '';
                    if (isWhatsAppColumn) {
                        style = 'background:#e8f5e9; font-weight:bold; color:#25D366;';
                    } else if (isPhoneColumn) {
                        style = 'background:#e8f5e9;';
                    }
                    bodyHtml += `<td style="${style}">${value}</td>`;
                });
                bodyHtml += '</tr>';
            }
            bodyElem.innerHTML = bodyHtml;
            
            rowCountElem.innerHTML = `<strong>${excelData.numbers.length}</strong> phone numbers found (showing first ${maxRows} rows)`;
        }

        function useExcelNumbers() {
            if (excelData.numbers.length === 0) {
                showToast('Error', 'No phone numbers found in Excel file', 'error');
                return;
            }
            
            const numbersTextarea = document.getElementById('numbers');
            numbersTextarea.value = excelData.numbers.join(',\n');
            
            // Clear selected group if any
            clearSelectedGroup();
            
            updateContactCount();
            
            document.getElementById('excelPreview').style.display = 'none';
            document.getElementById('excelFileInput').value = '';
            
            showToast('Success', `Added ${excelData.numbers.length} numbers from Excel file`, 'success');
        }

        // ======================
        // MEDIA OPTIONS
        // ======================
        function selectMediaOption(option) {
            document.getElementById('textOnlyOption').classList.remove('selected');
            document.getElementById('mediaOption').classList.remove('selected');
            document.getElementById('textOnlyCheckbox').checked = false;
            document.getElementById('mediaCheckbox').checked = false;
            
            document.getElementById(`${option}Option`).classList.add('selected');
            document.getElementById(`${option}Checkbox`).checked = true;
            
            campaignData.sendOption = option;
            
            if (option === 'textOnly') {
                document.getElementById('mediaUploadSection').style.display = 'none';
                document.getElementById('messageCheckboxContainer').style.display = 'none';
                document.getElementById('messageContainer').classList.remove('hidden');
                document.getElementById('message').disabled = false;
                document.getElementById('message').required = true;
                campaignData.mediaData = null;
                document.getElementById('mediaPreview').innerHTML = '';
                document.getElementById('mediaFile').value = '';
            } else {
                document.getElementById('mediaUploadSection').style.display = 'block';
                document.getElementById('messageCheckboxContainer').style.display = 'block';
                updateMessageFieldState();
            }
            
            updateSummary();
            
            showToast('Option Selected', option === 'textOnly' ? 'Text message only' : 'Media with optional message', 'info');
        }

        function updateMessageFieldState() {
            const messageContainer = document.getElementById('messageContainer');
            const messageTextarea = document.getElementById('message');
            
            if (campaignData.sendOption === 'media') {
                if (campaignData.includeMessageWithMedia) {
                    messageContainer.classList.remove('hidden');
                    messageTextarea.disabled = false;
                    messageTextarea.required = true;
                } else {
                    messageContainer.classList.add('hidden');
                    messageTextarea.disabled = true;
                    messageTextarea.required = false;
                    campaignData.message = '';
                }
            }
        }

        // ======================
        // MEDIA UPLOAD
        // ======================
        document.getElementById('mediaFile').addEventListener('change', async function(e) {
            const file = e.target.files[0];
            if(!file) return;
            
            if(file.size > 50 * 1024 * 1024) {
                showToast('Error', 'File size must be less than 50MB', 'error');
                return;
            }
            
            const formData = new FormData();
            formData.append('media', file);
            
            try {
                showToast('Uploading...', 'Uploading media file...', 'info');
                const res = await fetch('/upload-media', { method: 'POST', body: formData });
                const data = await res.json();
                
                if(data.status) {
                    campaignData.mediaData = data;
                    displayMediaPreview(data);
                    updateSummary();
                    showToast('Success', 'Media uploaded successfully!', 'success');
                } else {
                    showToast('Error', data.msg, 'error');
                }
            } catch(err) {
                console.error('Upload error:', err);
                showToast('Error', 'Upload failed: ' + err.message, 'error');
            }
        });

        function displayMediaPreview(data) {
            let icon = 'fa-file';
            let typeName = 'Document';
            
            if(data.fileType === 'image') {
                icon = 'fa-image';
                typeName = 'Image';
            } else if(data.fileType === 'video') {
                icon = 'fa-video';
                typeName = 'Video';
            } else if(data.mimeType?.includes('pdf')) {
                icon = 'fa-file-pdf';
                typeName = 'PDF';
            }
            
            const size = (data.fileSize / 1024).toFixed(1);
            
            document.getElementById('mediaPreview').innerHTML = `
                <div class="file-preview">
                    <div>
                        <i class="fas ${icon}" style="font-size: 32px;"></i>
                    </div>
                    <div class="file-info">
                        <strong>${data.originalName || data.fileName}</strong>
                        <div>${typeName} • ${size} KB</div>
                    </div>
                    <button class="btn btn-outline" onclick="removeMedia()" style="padding: 5px 10px;">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            `;
        }

        function removeMedia() {
            campaignData.mediaData = null;
            document.getElementById('mediaPreview').innerHTML = '';
            document.getElementById('mediaFile').value = '';
            updateSummary();
            showToast('Info', 'Media removed', 'info');
        }

        // ======================
        // MESSAGE EDITOR
        // ======================
        function insertVariable(variable) {
            const textarea = document.getElementById('message');
            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;
            const text = textarea.value;
            
            textarea.value = text.substring(0, start) + variable + text.substring(end);
            textarea.focus();
            textarea.selectionStart = textarea.selectionEnd = start + variable.length;
            
            campaignData.message = textarea.value;
            updateCharCount();
            updateSummary();
            
            showToast('Variable Added', variable + ' added to message', 'info');
        }

        function updateCharCount() {
            const message = document.getElementById('message').value;
            const count = message.length;
            document.getElementById('charCount').textContent = `${count}/1000`;
            
            if (count > 900) {
                document.getElementById('charCount').style.color = 'var(--danger)';
            } else if (count > 800) {
                document.getElementById('charCount').style.color = 'var(--warning)';
            } else {
                document.getElementById('charCount').style.color = 'var(--text-muted)';
            }
        }

        // ======================
        // SCHEDULE FUNCTIONS
        // ======================
        function selectSchedule(type) {
            campaignData.scheduleType = type;
            
            document.getElementById('scheduleNow').classList.remove('active');
            document.getElementById('scheduleLater').classList.remove('active');
            document.getElementById('schedule' + (type === 'now' ? 'Now' : 'Later')).classList.add('active');
            
            const datetimeDiv = document.getElementById('scheduleDateTime');
            if(type === 'later') {
                datetimeDiv.classList.add('show');
                if(!campaignData.scheduleDate) {
                    const tomorrow = new Date();
                    tomorrow.setDate(tomorrow.getDate() + 1);
                    campaignData.scheduleDate = tomorrow.toISOString().split('T')[0];
                    document.getElementById('scheduleDate').value = campaignData.scheduleDate;
                }
                if(!campaignData.scheduleTime) {
                    campaignData.scheduleTime = '10:00';
                    document.getElementById('scheduleTime').value = campaignData.scheduleTime;
                }
            } else {
                datetimeDiv.classList.remove('show');
            }
            
            updateSummary();
            showToast('Schedule', type === 'now' ? 'Send Now selected' : 'Schedule Later selected', 'info');
        }

        // ======================
        // SUMMARY FUNCTIONS
        // ======================
        function updateSummary() {
            const nums = getNumbersArray();
            campaignData.numbers = nums;
            
            const deviceSelect = document.getElementById('channel');
            const deviceText = deviceSelect.options[deviceSelect.selectedIndex]?.text || '--';
            document.getElementById('summaryDevice').textContent = deviceText;
            
            document.getElementById('summaryContacts').textContent = nums.length;
            
            if(campaignData.sendOption === 'textOnly') {
                document.getElementById('summaryType').textContent = 'Text Message Only';
                document.getElementById('summaryMedia').textContent = 'None';
                document.getElementById('summaryMediaPreview').style.display = 'none';
            } else {
                if(campaignData.mediaData) {
                    document.getElementById('summaryType').textContent = 'Media (' + campaignData.mediaData.fileType + ')';
                    document.getElementById('summaryMedia').textContent = campaignData.mediaData.originalName || campaignData.mediaData.fileName;
                    
                    document.getElementById('summaryMediaPreview').style.display = 'block';
                    document.getElementById('summaryMediaContent').innerHTML = `
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <i class="fas fa-paperclip" style="color: var(--primary);"></i>
                            <span>${campaignData.mediaData.originalName}</span>
                            <small style="color: var(--text-muted); margin-left: auto;">
                                ${(campaignData.mediaData.fileSize / 1024).toFixed(1)} KB
                            </small>
                        </div>
                    `;
                } else {
                    document.getElementById('summaryType').textContent = 'Media (Not Uploaded)';
                    document.getElementById('summaryMedia').textContent = 'None';
                    document.getElementById('summaryMediaPreview').style.display = 'none';
                }
            }
            
            if(campaignData.scheduleType === 'now') {
                document.getElementById('summarySchedule').textContent = 'Send Now';
            } else {
                const scheduleTime = new Date(`${campaignData.scheduleDate}T${campaignData.scheduleTime}`);
                document.getElementById('summarySchedule').textContent = scheduleTime.toLocaleString();
            }
            
            const interval = document.getElementById('interval').value;
            document.getElementById('summaryInterval').textContent = interval + ' seconds';
        }

        // ======================
        // TEST FUNCTION
        // ======================
        async function testCampaign() {
            const nums = getNumbersArray();
            if(nums.length === 0) {
                showToast('Error', 'Add numbers first', 'error');
                return;
            }
            
            const testData = {
                channel: campaignData.channel,
                number: nums[0]
            };
            
            if (campaignData.sendOption === 'textOnly') {
                if (!campaignData.message.trim()) {
                    showToast('Error', 'Add message first', 'error');
                    return;
                }
                testData.message = campaignData.message;
            } else {
                if (!campaignData.mediaData) {
                    showToast('Error', 'Upload media first', 'error');
                    return;
                }
                testData.mediaUrl = campaignData.mediaData?.fileUrl;
                if (campaignData.includeMessageWithMedia) {
                    testData.message = campaignData.message;
                }
            }
            
            try {
                showToast('Testing', 'Sending test message...', 'info');
                const res = await fetch('/send-test', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(testData)
                });
                
                const data = await res.json();
                showToast(data.status ? 'Success' : 'Error', data.msg, data.status ? 'success' : 'error');
            } catch(err) {
                showToast('Error', 'Test failed: ' + err.message, 'error');
            }
        }

        // ======================
        // CAMPAIGN SEND FUNCTIONS
        // ======================
        async function sendCampaignNow() {
            await sendOrScheduleCampaign('now');
        }

        async function scheduleCampaign() {
            if(campaignData.scheduleType === 'later') {
                if(!campaignData.scheduleDate || !campaignData.scheduleTime) {
                    showToast('Error', 'Please select date and time', 'error');
                    return;
                }
                
                const scheduleTime = new Date(`${campaignData.scheduleDate}T${campaignData.scheduleTime}`);
                const now = new Date();
                
                if(scheduleTime <= now) {
                    showToast('Error', 'Schedule time must be in the future', 'error');
                    return;
                }
            }
            
            await sendOrScheduleCampaign(campaignData.scheduleType);
        }

        async function sendOrScheduleCampaign(scheduleType) {
            if(!campaignData.numbers.length) {
                showToast('Error', 'Add numbers', 'error');
                return;
            }
            
            if (campaignData.sendOption === 'textOnly') {
                if(!campaignData.message.trim()) {
                    showToast('Error', 'Add message', 'error');
                    return;
                }
            } else {
                if(!campaignData.mediaData) {
                    showToast('Error', 'Upload media file', 'error');
                    return;
                }
                if (campaignData.includeMessageWithMedia && !campaignData.message.trim()) {
                    showToast('Error', 'Add message (checkbox is checked)', 'error');
                    return;
                }
            }
            
            const payload = {
                channel: campaignData.channel,
                numbers: campaignData.numbers,
                interval: document.getElementById('interval').value,
                schedule: scheduleType === 'now' ? 'now' : 'later',
                scheduledDate: campaignData.scheduleDate,
                scheduledTime: campaignData.scheduleTime
            };
            
            if (campaignData.sendOption === 'textOnly') {
                payload.message = campaignData.message;
            } else {
                payload.mediaUrl = campaignData.mediaData?.fileUrl;
                if (campaignData.includeMessageWithMedia) {
                    payload.message = campaignData.message;
                }
            }

            // Add campaign name based on selected group
            if (campaignData.selectedGroup) {
                payload.campaignName = campaignData.selectedGroup.name;
            } else {
                const date = new Date().toLocaleString();
                payload.campaignName = `Campaign ${date}`;
            }
            
            try {
                if(scheduleType === 'now') {
                    showToast('Sending', 'Sending campaign now...', 'info');
                } else {
                    const scheduleTime = new Date(`${campaignData.scheduleDate}T${campaignData.scheduleTime}`);
                    showToast('Scheduling', `Scheduling campaign for ${scheduleTime.toLocaleString()}...`, 'warning');
                }
                
                const res = await fetch('/send-campaign', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                const data = await res.json();
                if(data.status) {
                    if(data.scheduled) {
                        showToast('Scheduled', `Campaign scheduled successfully! It will start at ${new Date(data.scheduledAt).toLocaleString()}`, 'success');
                        setTimeout(() => location.reload(), 2000);
                    } else {
                        showToast('Success', `Campaign completed: ${data.sent} sent, ${data.failed} failed`, 'success');
                        // Auto reset to step 1 after successful send
                        setTimeout(() => resetToStep1(), 2000);
                    }
                } else {
                    showToast('Error', data.msg, 'error');
                }
            } catch(err) {
                showToast('Error', 'Send failed: ' + err.message, 'error');
            }
        }

        function resetToStep1() {
            // Clear form data
            document.getElementById('numbers').value = '';
            document.getElementById('message').value = '';
            document.getElementById('mediaPreview').innerHTML = '';
            document.getElementById('mediaFile').value = '';
            document.getElementById('excelPreview').style.display = 'none';
            document.getElementById('excelFileInput').value = '';
            
            // Reset campaign data
            campaignData.numbers = [];
            campaignData.message = '';
            campaignData.mediaData = null;
            campaignData.selectedGroup = null;
            
            // Clear selected group banner
            clearSelectedGroup();
            
            // Reset to step 1
            document.getElementById(`step${currentStep}`).classList.remove('active');
            document.getElementById(`step${currentStep}-indicator`).classList.remove('active');
            
            currentStep = 1;
            document.getElementById(`step1`).classList.add('active');
            document.getElementById(`step1-indicator`).classList.add('active');
            
            // Reset completed indicators
            for (let i = 2; i <= 4; i++) {
                const indicator = document.getElementById(`step${i}-indicator`);
                if (indicator) {
                    indicator.classList.remove('completed');
                }
            }
            
            // Update contact count
            updateContactCount();
            
            showToast('Success', 'Campaign completed! Ready for next campaign', 'success');
        }

        // ======================
        // CANCEL CAMPAIGN
        // ======================
        async function cancelCampaign(campaignId) {
            if(!confirm('Are you sure you want to cancel this scheduled campaign?')) return;
            
            try {
                const res = await fetch(`/cancel-campaign/${campaignId}`, {
                    method: 'POST'
                });
                
                const data = await res.json();
                showToast(data.status ? 'Success' : 'Error', data.msg, data.status ? 'success' : 'error');
                
                if(data.status) {
                    setTimeout(() => location.reload(), 1000);
                }
            } catch(err) {
                showToast('Error', 'Cancel failed: ' + err.message, 'error');
            }
        }

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Follow the steps to create your campaign', 'info');
            }
        });
    </script>
</body>
</html>