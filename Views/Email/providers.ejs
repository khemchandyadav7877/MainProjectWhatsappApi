<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add SMTP Provider</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/email/providers">
                <i class="fas fa-arrow-left"></i> Back to Providers
            </a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">
                            <i class="fas fa-plus-circle"></i> Add New SMTP Provider
                        </h4>
                    </div>
                    <div class="card-body">
                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-triangle"></i> <%= error %>
                            </div>
                        <% } %>

                        <form method="POST" action="/email/add-provider">
                            <!-- Provider Type -->
                            <div class="mb-3">
                                <label class="form-label">Provider Type *</label>
                                <select name="provider_type" class="form-select" required>
                                    <option value="">-- Select Provider --</option>
                                    <option value="sendgrid">SendGrid</option>
                                    <option value="aws_ses">AWS SES</option>
                                    <option value="mailgun">Mailgun</option>
                                    <option value="gmail">Gmail / G Suite</option>
                                    <option value="office365">Office 365</option>
                                    <option value="custom">Custom SMTP</option>
                                </select>
                            </div>

                            <!-- Provider Name -->
                            <div class="mb-3">
                                <label class="form-label">Provider Name *</label>
                                <input type="text" name="name" class="form-control" 
                                       placeholder="e.g., Production SendGrid" required>
                            </div>

                            <!-- SMTP Details -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">SMTP Host *</label>
                                    <input type="text" name="host" class="form-control" 
                                           placeholder="smtp.sendgrid.net" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Port *</label>
                                    <input type="number" name="port" class="form-control" 
                                           placeholder="587" required>
                                </div>
                            </div>

                            <!-- Credentials -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Username / API Key *</label>
                                    <input type="text" name="username" class="form-control" 
                                           placeholder="Enter username or API key" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Password / Secret Key *</label>
                                    <input type="password" name="password" class="form-control" 
                                           placeholder="Enter password" required>
                                </div>
                            </div>

                            <!-- Encryption -->
                            <div class="mb-3">
                                <label class="form-label">Encryption</label>
                                <select name="encryption" class="form-select">
                                    <option value="tls" selected>TLS/STARTTLS (Recommended)</option>
                                    <option value="ssl">SSL</option>
                                    <option value="none">None</option>
                                </select>
                            </div>

                            <!-- From Details -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">From Email *</label>
                                    <input type="email" name="from_email" class="form-control" 
                                           placeholder="noreply@yourdomain.com" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">From Name *</label>
                                    <input type="text" name="from_name" class="form-control" 
                                           placeholder="Your Company Name" required>
                                </div>
                            </div>

                            <!-- Daily Limit -->
                            <div class="mb-4">
                                <label class="form-label">Daily Email Limit</label>
                                <input type="number" name="daily_limit" class="form-control" 
                                       placeholder="10000" value="10000">
                                <div class="form-text">
                                    Maximum emails to send per day from this provider
                                </div>
                            </div>

                            <!-- Submit Buttons -->
                            <div class="d-flex justify-content-between">
                                <a href="/email/providers" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Save Provider
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Help Section -->
                <div class="card mt-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle"></i> Common Provider Settings
                        </h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Provider</th>
                                    <th>Host</th>
                                    <th>Port</th>
                                    <th>Encryption</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>SendGrid</td>
                                    <td>smtp.sendgrid.net</td>
                                    <td>587</td>
                                    <td>TLS</td>
                                </tr>
                                <tr>
                                    <td>AWS SES</td>
                                    <td>email-smtp.us-east-1.amazonaws.com</td>
                                    <td>587</td>
                                    <td>STARTTLS</td>
                                </tr>
                                <tr>
                                    <td>Mailgun</td>
                                    <td>smtp.mailgun.org</td>
                                    <td>587</td>
                                    <td>TLS</td>
                                </tr>
                                <tr>
                                    <td>Gmail</td>
                                    <td>smtp.gmail.com</td>
                                    <td>587</td>
                                    <td>TLS</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Auto-fill based on provider selection
        document.querySelector('select[name="provider_type"]').addEventListener('change', function() {
            const provider = this.value;
            const config = {
                'sendgrid': { host: 'smtp.sendgrid.net', port: 587, encryption: 'tls' },
                'aws_ses': { host: 'email-smtp.us-east-1.amazonaws.com', port: 587, encryption: 'tls' },
                'mailgun': { host: 'smtp.mailgun.org', port: 587, encryption: 'tls' },
                'gmail': { host: 'smtp.gmail.com', port: 587, encryption: 'tls' },
                'office365': { host: 'smtp.office365.com', port: 587, encryption: 'tls' }
            };

            if (config[provider]) {
                document.querySelector('input[name="host"]').value = config[provider].host;
                document.querySelector('input[name="port"]').value = config[provider].port;
                document.querySelector('select[name="encryption"]').value = config[provider].encryption;
            }
        });
    </script>
</body>
</html>