<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Campaign</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/email/campaigns">
                <i class="fas fa-arrow-left"></i> Back to Campaigns
            </a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">
                    <i class="fas fa-bullhorn"></i> Create Email Campaign
                </h4>
            </div>
            <div class="card-body">
                <form method="POST" action="/email/create-campaign">
                    <!-- Campaign Details -->
                    <div class="mb-4">
                        <h5><i class="fas fa-info-circle text-primary"></i> Campaign Details</h5>
                        <div class="mb-3">
                            <label class="form-label">Campaign Name *</label>
                            <input type="text" name="campaign_name" class="form-control" 
                                   placeholder="e.g., Black Friday Sale 2024" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Campaign Type</label>
                            <select name="campaign_type" class="form-select">
                                <option value="marketing">Marketing</option>
                                <option value="newsletter">Newsletter</option>
                                <option value="transactional">Transactional</option>
                                <option value="notification">Notification</option>
                            </select>
                        </div>
                    </div>

                    <!-- Select Provider -->
                    <div class="mb-4">
                        <h5><i class="fas fa-server text-primary"></i> Select SMTP Provider</h5>
                        <div class="mb-3">
                            <label class="form-label">Choose Provider *</label>
                            <select name="provider_id" class="form-select" required>
                                <option value="">-- Select Provider --</option>
                                <option value="1">SendGrid (Limit: 100,000/day | Sent: 45,230)</option>
                                <option value="2">AWS SES (Limit: 50,000/day | Sent: 12,500)</option>
                                <option value="3">Mailgun (Limit: 10,000/day | Sent: 1,500)</option>
                            </select>
                            <div class="form-text">
                                Remaining today: <span id="remainingEmails">0</span> emails
                            </div>
                        </div>
                    </div>

                    <!-- Select Recipients -->
                    <div class="mb-4">
                        <h5><i class="fas fa-users text-primary"></i> Select Recipients</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email List *</label>
                                <select name="list_id" class="form-select" required>
                                    <option value="">-- Select List --</option>
                                    <option value="1">All Customers (5,432 contacts)</option>
                                    <option value="2">Newsletter Subscribers (12,345 contacts)</option>
                                    <option value="3">VIP Customers (234 contacts)</option>
                                    <option value="4">Inactive Users (3,450 contacts)</option>
                                </select>
                                <div class="form-text">
                                    <span id="listCount">0</span> contacts in this list
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Or Enter Emails Manually</label>
                                <textarea name="manual_emails" class="form-control" rows="3" 
                                          placeholder="Enter emails (one per line or comma separated)
john@example.com
jane@example.com"></textarea>
                                <div class="form-text">
                                    Leave empty if using list
                                </div>
                            </div>
                        </div>
                        
                        <!-- Email Count -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Number of Emails to Send *</label>
                                <input type="number" name="email_count" id="emailCount" 
                                       class="form-control" value="0" min="1" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Test Email (Optional)</label>
                                <input type="email" name="test_email" class="form-control" 
                                       placeholder="your@email.com">
                                <div class="form-text">
                                    Send test before actual campaign
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Email Content -->
                    <div class="mb-4">
                        <h5><i class="fas fa-envelope text-primary"></i> Email Content</h5>
                        
                        <!-- From Details -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">From Email *</label>
                                <input type="email" name="from_email" class="form-control" 
                                       value="noreply@company.com" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">From Name *</label>
                                <input type="text" name="from_name" class="form-control" 
                                       value="Company Name" required>
                            </div>
                        </div>

                        <!-- Subject -->
                        <div class="mb-3">
                            <label class="form-label">Subject *</label>
                            <input type="text" name="subject" class="form-control" 
                                   placeholder="Special Offer Inside!" required>
                        </div>

                        <!-- Body -->
                        <div class="mb-3">
                            <label class="form-label">Email Body *</label>
                            <textarea name="body" class="form-control" rows="12" required>
Dear {first_name},

We have an exciting offer just for you!

**Special Discount:** Get 20% off on your next purchase.
Use code: WELCOME20

Offer valid until: {current_date}

Best regards,
{company} Team

---
You're receiving this email because you subscribed to our newsletter.
<a href="{unsubscribe_link}">Unsubscribe</a>
                            </textarea>
                            <div class="form-text">
                                Available variables: {first_name}, {last_name}, {email}, {company}, 
                                {current_date}, {unsubscribe_link}
                            </div>
                        </div>
                    </div>

                    <!-- Schedule -->
                    <div class="mb-4">
                        <h5><i class="fas fa-clock text-primary"></i> Schedule</h5>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="radio" name="schedule_type" 
                                   value="now" id="scheduleNow" checked>
                            <label class="form-check-label" for="scheduleNow">
                                Send immediately
                            </label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="radio" name="schedule_type" 
                                   value="scheduled" id="scheduleLater">
                            <label class="form-check-label" for="scheduleLater">
                                Schedule for later
                            </label>
                        </div>
                        <div class="row mb-3" id="scheduleDateTime" style="display: none;">
                            <div class="col-md-6">
                                <label class="form-label">Date</label>
                                <input type="date" name="schedule_date" class="form-control">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Time</label>
                                <input type="time" name="schedule_time" class="form-control">
                            </div>
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="d-flex justify-content-between">
                        <a href="/email/campaigns" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        <div>
                            <button type="button" class="btn btn-warning" onclick="sendTest()">
                                <i class="fas fa-vial"></i> Send Test
                            </button>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane"></i> Launch Campaign
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Show/hide schedule date time
        document.querySelectorAll('input[name="schedule_type"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const scheduleDiv = document.getElementById('scheduleDateTime');
                scheduleDiv.style.display = this.value === 'scheduled' ? 'flex' : 'none';
            });
        });

        // Update email count when list selected
        const listCounts = {
            '1': 5432,
            '2': 12345,
            '3': 234,
            '4': 3450
        };

        document.querySelector('select[name="list_id"]').addEventListener('change', function() {
            const count = listCounts[this.value] || 0;
            document.getElementById('listCount').textContent = count;
            document.getElementById('emailCount').value = count;
        });

        // Provider limits
        const providerLimits = {
            '1': { limit: 100000, sent: 45230 },
            '2': { limit: 50000, sent: 12500 },
            '3': { limit: 10000, sent: 1500 }
        };

        document.querySelector('select[name="provider_id"]').addEventListener('change', function() {
            const provider = providerLimits[this.value];
            if (provider) {
                const remaining = provider.limit - provider.sent;
                document.getElementById('remainingEmails').textContent = remaining;
            }
        });

        // Send test email
        function sendTest() {
            const testEmail = document.querySelector('input[name="test_email"]').value;
            if (!testEmail) {
                alert('Please enter test email address');
                return;
            }
            
            // Disable button and show loading
            const btn = event.target;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
            btn.disabled = true;
            
            // Simulate API call
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.disabled = false;
                alert(`Test email sent to ${testEmail}`);
            }, 2000);
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            // Trigger change events to set initial values
            document.querySelector('select[name="list_id"]').dispatchEvent(new Event('change'));
            document.querySelector('select[name="provider_id"]').dispatchEvent(new Event('change'));
        });
    </script>
</body>
</html>