        .bt2{background:linear-gradient(135deg,#DCFCE7,#BBF7D0);}
        .bt3{background:linear-gradient(135deg,#FEF3C7,#FDE68A);}
        .blog-tag-chip { position:absolute; top:14px; left:14px; background:var(--sky-dark); color:#fff; padding:4px 12px; border-radius:50px; font-size:0.7rem; font-weight:800; letter-spacing:0.5px; }
        .blog-body { padding:1.5rem; flex:1; display:flex; flex-direction:column; }
