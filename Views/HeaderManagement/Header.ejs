<script>
    // ===== DARK MODE =====
    const html = document.documentElement;
    const dmToggle = document.getElementById('dmToggle');
    const dmIcon = document.getElementById('dmIcon');

    // Load saved preference
    if (localStorage.getItem('theme') === 'dark') {
        html.classList.add('dark');
        dmIcon.className = 'fas fa-sun';
    }

    dmToggle.addEventListener('click', () => {
        const isDark = html.classList.toggle('dark');
        dmIcon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
    // Navbar scroll
    window.addEventListener('scroll', () => {
        document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50);
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
            const t = document.querySelector(a.getAttribute('href'));
            if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
        });
    });

    // Hamburger
    document.getElementById('hamburger').addEventListener('click', function() {
        const m = document.getElementById('navMenu');
        const open = m.style.display === 'flex';
        m.style.display = open ? 'none' : 'flex';
        if (!open) {
            const isDark = document.documentElement.classList.contains('dark');
            Object.assign(m.style, {
                flexDirection:'column', position:'fixed', top:'72px', left:'0', right:'0',
                background: isDark ? 'rgba(22,27,34,0.99)' : 'rgba(255,255,255,0.98)',
                padding:'2rem', gap:'1.5rem',
                borderBottom:'1px solid rgba(56,189,248,0.2)', zIndex:'999',
                boxShadow:'0 10px 40px rgba(56,189,248,0.1)'
            });
        }
    });

    // Dashboard tab switcher
    function switchTab(el) {
        document.querySelectorAll('.prev-tab').forEach(t => t.classList.remove('active'));
        el.classList.add('active');
    }

    // FAQ toggle
    function toggleFaq(el) {
        const isOpen = el.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(f => {
            f.classList.remove('open');
            f.querySelector('.faq-a').classList.remove('open');
        });
        if (!isOpen) { el.classList.add('open'); el.querySelector('.faq-a').classList.add('open'); }
    }

    // Pricing toggle
    let yearly = false;
    function togglePrice() {
        yearly = !yearly;
        document.getElementById('tgSw').classList.toggle('on', yearly);
        document.getElementById('lblM').classList.toggle('on', !yearly);
        document.getElementById('lblY').classList.toggle('on', yearly);
        document.querySelectorAll('.amt').forEach(el => {
            const v = yearly ? el.dataset.y : el.dataset.m;
            if (v) el.textContent = v;
        });
        document.getElementById('w1').textContent = yearly ? 'Was $49/mo — Save 30%' : 'Billed monthly';
        document.getElementById('w2').textContent = yearly ? 'Was $199/mo — Save 30%' : 'Billed monthly';
    }

    // Testimonial slider
    const testimonials = [
        { av:'JD', txt:'This platform has revolutionized how we communicate with customers. Delivery rate is exceptional and the API integrates in minutes.', name:'John Doe', pos:'CEO, TechCorp' },
        { av:'JS', txt:"The best WhatsApp API solution we've found. Scalable, reliable, and their support team goes above and beyond every time!", name:'Jane Smith', pos:'CTO, InnovateLabs' },
        { av:'MJ', txt:"We've seen a 40% increase in customer engagement since switching to WaBlast Pro. The analytics alone are worth the price.", name:'Mike Johnson', pos:'Product Manager, GrowthCo' },
        { av:'SW', txt:'Setup was so easy — we were live in 15 minutes. The chatbot handles 80% of our support queries automatically now.', name:'Sarah Wilson', pos:'Marketing Director, BrandInc' }
    ];
    let currT = 0;
    const tDots = document.querySelectorAll('.testi-dot');
    function showT(i) {
        const t = testimonials[i];
        document.getElementById('tAv').textContent = t.av;
        document.getElementById('tTxt').textContent = `"${t.txt}"`;
        document.getElementById('tName').textContent = t.name;
        document.getElementById('tPos').textContent = t.pos;
        tDots.forEach((d, idx) => d.classList.toggle('active', idx === i));
    }
    tDots.forEach((d, i) => d.addEventListener('click', () => { currT = i; showT(currT); }));
    setInterval(() => { currT = (currT + 1) % testimonials.length; showT(currT); }, 5000);

    // Scroll reveal
    const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('vis'); obs.unobserve(e.target); } });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

</body>
</html>
