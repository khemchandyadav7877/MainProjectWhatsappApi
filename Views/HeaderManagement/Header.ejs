        /* ===== REVIEWS ===== */
        .rev-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-top:4rem; }
        .rev-card { background:var(--bg-card); border:1px solid var(--border-color2); border-radius:22px; padding:2rem; transition:all 0.3s; box-shadow:0 2px 15px rgba(56,189,248,0.06); }
        .rev-card:hover { transform:translateY(-5px); border-color:rgba(56,189,248,0.3); box-shadow:0 20px 50px rgba(56,189,248,0.1); }
        .rev-stars { color:#F59E0B; letter-spacing:3px; font-size:0.92rem; margin-bottom:1rem; }
        .rev-text { color:var(--color-text2); font-size:0.9rem; line-height:1.72; margin-bottom:1.5rem; font-style:italic; }
        .rev-author { display:flex; align-items:center; gap:12px; }
        .rev-av { width:44px; height:44px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.95rem; flex-shrink:0; }
        .rev-name { font-weight:700; font-size:0.9rem; color:var(--color-dark); }
        .rev-role { color:var(--color-muted); font-size:0.77rem; }
        .rev-platform { margin-left:auto; }
        .rev-platform i { color:var(--green); font-size:1.2rem; }

        /* Testimonial Slider */
        .testi-slider { max-width:800px; margin:4rem auto 0; }
        .testi-card { background:var(--bg-card); border:1px solid var(--border-color); padding:2.5rem; border-radius:28px; box-shadow:0 10px 40px rgba(56,189,248,0.1); text-align:center; }
        .testi-av { width:80px; height:80px; background:linear-gradient(135deg,var(--sky-deeper),var(--sky)); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; color:#fff; font-size:1.8rem; font-weight:800; }
        .testi-text { font-size:1.05rem; color:var(--color-text2); line-height:1.8; margin-bottom:1.5rem; font-style:italic; }
        .testi-name { font-weight:700; color:var(--color-dark); margin-bottom:4px; }
        .testi-pos { color:var(--color-muted); font-size:0.88rem; }
        .testi-dots { display:flex; justify-content:center; gap:0.5rem; margin-top:2rem; }
        .testi-dot { width:10px; height:10px; background:var(--offwhite3-val); border-radius:50%; cursor:pointer; transition:all 0.3s; border:1px solid var(--border-color); }
        .testi-dot.active { background:var(--sky-dark); width:30px; border-radius:10px; border-color:var(--sky-dark); }

        /* ===== FAQ ===== */
        .faq-wrap { max-width:780px; margin:4rem auto 0; }
        .faq-item { background:var(--bg-card); border:1px solid var(--border-color2); border-radius:16px; margin-bottom:1rem; overflow:hidden; transition:border-color 0.3s, background 0.3s; box-shadow:0 2px 10px rgba(56,189,248,0.05); }
        .faq-item.open { border-color:rgba(56,189,248,0.4); box-shadow:0 8px 30px rgba(56,189,248,0.1); }
        .faq-q { padding:1.3rem 1.5rem; cursor:pointer; display:flex; align-items:center; justify-content:space-between; font-weight:600; font-size:0.97rem; color:var(--color-dark); user-select:none; transition:color 0.2s; }
        .faq-q:hover { color:var(--sky-dark); }
        .faq-ic { width:30px; height:30px; border-radius:50%; background:var(--sky-pale); border:1px solid rgba(56,189,248,0.3); display:flex; align-items:center; justify-content:center; flex-shrink:0; color:var(--sky-dark); font-size:1rem; transition:transform 0.3s, background 0.3s; }
        .faq-item.open .faq-ic { transform:rotate(45deg); background:var(--sky-dark); color:#fff; }
        .faq-a { max-height:0; overflow:hidden; transition:max-height 0.4s ease, padding 0.3s; padding:0 1.5rem; color:var(--color-text2); font-size:0.9rem; line-height:1.75; }
        .faq-a.open { max-height:250px; padding:0 1.5rem 1.3rem; }

        /* ===== BLOG ===== */
        .blog-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.8rem; margin-top:4rem; }
        .blog-card { background:var(--bg-card); border:1px solid var(--border-color2); border-radius:22px; overflow:hidden; transition:all 0.35s; text-decoration:none; color:var(--color-text); display:flex; flex-direction:column; box-shadow:0 2px 15px rgba(56,189,248,0.06); }
        .blog-card:hover { transform:translateY(-8px); border-color:rgba(56,189,248,0.35); box-shadow:0 25px 60px rgba(56,189,248,0.12); }
        .blog-thumb { height:190px; display:flex; align-items:center; justify-content:center; font-size:3.5rem; position:relative; overflow:hidden; }
