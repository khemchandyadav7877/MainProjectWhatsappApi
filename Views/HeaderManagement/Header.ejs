        .btn-plan-fill { background:linear-gradient(135deg,var(--sky-deeper),var(--sky)); color:#fff; box-shadow:0 8px 25px rgba(56,189,248,0.3); }
        .btn-plan-fill:hover { transform:translateY(-2px); box-shadow:0 14px 35px rgba(56,189,248,0.45); }
        .guar-strip { display:flex; align-items:center; justify-content:center; gap:1rem; margin-top:3rem; padding:1.2rem 2rem; border-radius:16px; background:rgba(16,185,129,0.07); border:1px solid rgba(16,185,129,0.2); max-width:580px; margin-left:auto; margin-right:auto; }
