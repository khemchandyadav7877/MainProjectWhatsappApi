        .about-tiles { background:linear-gradient(145deg,var(--sky-pale),var(--offwhite)); border:1px solid rgba(56,189,248,0.25); border-radius:28px; padding:2.5rem; display:grid; grid-template-columns:1fr 1fr; gap:1rem; position:relative; box-shadow:0 10px 40px rgba(56,189,248,0.1); }
