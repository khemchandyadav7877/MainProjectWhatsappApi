<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WaBlast Pro – WhatsApp Automation Platform</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --sky: #38BDF8;
            --sky-dark: #0EA5E9;
            --sky-deeper: #0284C7;
            --sky-light: #BAE6FD;
            --sky-pale: #E0F2FE;
            --offwhite: #F8F7F4;
            --offwhite2: #F1EFE9;
            --offwhite3: #EAE8E0;
            --white: #FFFFFF;
            --dark: #0C1A2E;
            --dark2: #112240;
            --text: #1E3A5F;
            --text2: #3B5A80;
            --muted: #7A9BB5;
            --border: rgba(56,189,248,0.2);
            --border2: rgba(56,189,248,0.12);
            --card: #FFFFFF;
            --green: #10B981;

            /* Dark mode semantic tokens (light defaults) */
            --bg-body: #F8F7F4;
            --bg-white-sec: #FFFFFF;
            --bg-offwhite-sec: #F8F7F4;
            --bg-pale-sec: #E0F2FE;
            --bg-card: #FFFFFF;
            --bg-navbar: rgba(248,247,244,0.92);
            --bg-navbar-scrolled: rgba(255,255,255,0.97);
            --bg-trusted: #FFFFFF;
            --bg-input: #FFFFFF;
            --color-text: #1E3A5F;
            --color-text2: #3B5A80;
            --color-muted: #7A9BB5;
            --color-dark: #0C1A2E;
            --color-logo-text: #0C1A2E;
            --border-color: rgba(56,189,248,0.2);
            --border-color2: rgba(56,189,248,0.12);
            --hamburger-color: #0C1A2E;
            --footer-bg: #0C1A2E;
            --footer-text: #64748B;
            --hero-bg-from: #FFFFFF;
            --hero-bg-via: #E0F2FE;
            --hero-bg-to: #F8F7F4;
            --offwhite3-val: #EAE8E0;
        }

        /* ===== DARK MODE VARIABLES ===== */
        html.dark {
            --sky-pale: rgba(56,189,248,0.12);
            --offwhite: #0D1117;
            --offwhite2: #161B22;
            --offwhite3: #21262D;
            --white: #161B22;
            --dark: #E6EDF3;
            --dark2: #1A2233;
            --text: #C9D1D9;
            --text2: #8B949E;
            --muted: #6E7681;
            --border: rgba(56,189,248,0.18);
            --border2: rgba(56,189,248,0.1);
            --card: #161B22;

            --bg-body: #0D1117;
            --bg-white-sec: #161B22;
            --bg-offwhite-sec: #0D1117;
            --bg-pale-sec: #111820;
            --bg-card: #161B22;
            --bg-navbar: rgba(13,17,23,0.95);
            --bg-navbar-scrolled: rgba(22,27,34,0.98);
            --bg-trusted: #161B22;
            --color-text: #C9D1D9;
            --color-text2: #8B949E;
            --color-muted: #6E7681;
            --color-dark: #E6EDF3;
            --color-logo-text: #E6EDF3;
            --border-color: rgba(56,189,248,0.18);
            --border-color2: rgba(56,189,248,0.1);
            --hamburger-color: #E6EDF3;
            --footer-bg: #080D13;
            --footer-text: #4B5563;
            --hero-bg-from: #0D1117;
            --hero-bg-via: #0D1825;
            --hero-bg-to: #0D1117;
            --offwhite3-val: #21262D;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-body);
            color: var(--color-text);
            overflow-x: hidden;
            transition: background 0.3s, color 0.3s;
        }

        ::-webkit-scrollbar { width: 7px; }
        ::-webkit-scrollbar-track { background: var(--offwhite2); }
        ::-webkit-scrollbar-thumb { background: var(--sky-dark); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--sky); }

        /* Animations */
        @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-14px)} }
        @keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.05)} }
        @keyframes fadeUp { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
        @keyframes fadeDown { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
        @keyframes shimmer { 0%{background-position:-200% center} 100%{background-position:200% center} }
        @keyframes spin { to{transform:rotate(360deg)} }

        /* ===== NAVBAR ===== */
        .navbar {
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            background: var(--bg-navbar);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border-color);
            padding: 0 5%; height: 72px;
            display: flex; align-items: center; justify-content: space-between;
            transition: all 0.3s;
        }
        .navbar.scrolled {
            height: 62px;
            background: var(--bg-navbar-scrolled);
            box-shadow: 0 4px 30px rgba(56,189,248,0.12);
        }
        .logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .logo-icon {
            width: 44px; height: 44px; border-radius: 14px;
            background: linear-gradient(135deg, var(--sky-dark), var(--sky));
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 6px 20px rgba(56,189,248,0.35);
            animation: float 3s ease-in-out infinite; flex-shrink: 0;
        }
        .logo-icon i { font-size: 22px; color: #fff; }
        .logo-text { font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 800; color: var(--color-logo-text); transition: color 0.3s; }
        .logo-text span { background: linear-gradient(90deg, var(--sky-dark), var(--sky)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

        .nav-menu { display: flex; align-items: center; gap: 2rem; }
        .nav-link {
            text-decoration: none; color: var(--color-text2);
            font-weight: 500; font-size: 0.95rem; transition: all 0.3s; position: relative;
        }
        .nav-link::after { content:''; position:absolute; bottom:-5px; left:0; width:0; height:2px; background:linear-gradient(90deg,var(--sky-dark),var(--sky)); transition:width 0.3s; }
        .nav-link:hover { color: var(--sky-dark); }
        .nav-link:hover::after { width: 100%; }

        .btn-nav-login {
            padding: 8px 20px; background: transparent; color: var(--sky-dark);
            border: 1.5px solid var(--sky-dark); border-radius: 50px;
            font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.3s; text-decoration: none;
        }
        .btn-nav-login:hover { background: var(--sky-pale); }
        .btn-nav-signup {
            padding: 9px 22px; background: linear-gradient(135deg, var(--sky-dark), var(--sky));
            color: #fff; border: none; border-radius: 50px;
            font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.3s;
            text-decoration: none; box-shadow: 0 6px 20px rgba(56,189,248,0.3);
            display: flex; align-items: center; gap: 6px;
        }
        .btn-nav-signup:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(56,189,248,0.45); }
        .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
        .hamburger span { width: 24px; height: 2px; background: var(--hamburger-color); border-radius: 2px; transition: background 0.3s; }

        /* ===== DARK MODE TOGGLE ===== */
        .dm-toggle {
            width: 42px; height: 42px; border-radius: 50%;
            background: var(--sky-pale); border: 1.5px solid var(--border-color);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.3s; flex-shrink: 0;
            color: var(--sky-deeper); font-size: 1.05rem;
        }
        .dm-toggle:hover { background: var(--sky-dark); color: #fff; border-color: var(--sky-dark); transform: rotate(20deg); }

        /* ===== HERO ===== */
        .hero {
            min-height: 100vh; padding: 140px 5% 100px;
            position: relative; overflow: hidden; display: flex; align-items: center;
            background: linear-gradient(160deg, var(--hero-bg-from) 0%, var(--hero-bg-via) 40%, var(--hero-bg-to) 100%);
            transition: background 0.3s;
        }
        .hero-blob1 {
            position: absolute; top: -100px; right: -100px;
            width: 600px; height: 600px; border-radius: 50%;
            background: radial-gradient(circle, rgba(56,189,248,0.18) 0%, transparent 70%);
            pointer-events: none;
        }
        .hero-blob2 {
            position: absolute; bottom: -80px; left: -80px;
            width: 450px; height: 450px; border-radius: 50%;
            background: radial-gradient(circle, rgba(14,165,233,0.1) 0%, transparent 70%);
            pointer-events: none;
        }
        .hero-dots {
            position: absolute; inset: 0;
            background-image: radial-gradient(rgba(56,189,248,0.15) 1.5px, transparent 1.5px);
            background-size: 32px 32px; pointer-events: none;
        }
        .hero-container {
            max-width: 1380px; margin: 0 auto; width: 100%;
            display: grid; grid-template-columns: 1.15fr 0.85fr;
            gap: 4rem; align-items: center; position: relative; z-index: 2;
        }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 6px 18px; background: var(--sky-pale);
            border: 1px solid rgba(56,189,248,0.3); border-radius: 50px;
            font-size: 0.85rem; font-weight: 600; color: var(--sky-deeper);
            margin-bottom: 1.5rem; animation: fadeDown 0.6s ease both;
        }
        .badge-dot { width: 7px; height: 7px; background: var(--sky-dark); border-radius: 50%; animation: blink 1.5s infinite; }
        .hero-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(2.6rem, 5.5vw, 4.8rem); font-weight: 800; line-height: 1.08;
            color: var(--color-dark); margin-bottom: 1.4rem; animation: fadeUp 0.7s 0.1s ease both;
        }
        .hero-title .grad {
            background: linear-gradient(90deg, var(--sky-deeper), var(--sky));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            animation: pulse 3s ease-in-out infinite;
        }
        .hero-desc {
            font-size: clamp(1rem, 1.8vw, 1.15rem); color: var(--color-text2);
            line-height: 1.75; margin-bottom: 2rem; max-width: 560px;
            animation: fadeUp 0.7s 0.2s ease both;
        }
        .hero-stats { display: flex; gap: 2.5rem; margin-bottom: 2.5rem; animation: fadeUp 0.7s 0.3s ease both; }
        .hero-stat-num { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; color: var(--sky-deeper); margin-bottom: 3px; }
        .hero-stat-label { font-size: 0.85rem; color: var(--muted); }
        .hero-buttons { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp 0.7s 0.4s ease both; }
        .btn-primary {
            padding: 14px 32px; background: linear-gradient(135deg, var(--sky-deeper), var(--sky));
            color: #fff; border: none; border-radius: 50px; font-weight: 700; font-size: 1.05rem;
            cursor: pointer; display: flex; align-items: center; gap: 9px; transition: all 0.3s;
            box-shadow: 0 10px 30px rgba(56,189,248,0.35); text-decoration: none;
        }
        .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(56,189,248,0.5); }
        .btn-outline {
            padding: 14px 32px; background: transparent; color: var(--sky-dark);
            border: 1.5px solid var(--sky-dark); border-radius: 50px; font-weight: 600;
            font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 9px;
            transition: all 0.3s; text-decoration: none;
        }
        .btn-outline:hover { background: var(--sky-pale); }

        /* Hero Dashboard */
        .hero-image { position: relative; animation: fadeUp 0.7s 0.3s ease both; }
        .hero-img-wrap {
            background: linear-gradient(145deg, #fff, var(--offwhite2));
            border: 1px solid rgba(56,189,248,0.25); border-radius: 28px; padding: 1.5rem;
            box-shadow: 0 30px 70px rgba(56,189,248,0.15), 0 0 0 1px rgba(56,189,248,0.08);
            animation: float 6s ease-in-out infinite;
        }
        .hero-dashboard { background: var(--dark2); border-radius: 18px; overflow: hidden; }
        .dash-top {
            background: var(--dark); padding: 12px 16px;
            display: flex; align-items: center; gap: 7px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .dash-dot { width: 10px; height: 10px; border-radius: 50%; }
        .dash-dot.r{background:#FF5F57;} .dash-dot.y{background:#FFBD2E;} .dash-dot.g{background:#28CA41;}
        .dash-label { margin-left: 8px; font-size: 0.72rem; color: #6B7280; }
        .dash-body { padding: 1.2rem; }
        .dash-row { display: grid; grid-template-columns: repeat(2,1fr); gap: 0.6rem; margin-bottom: 0.8rem; }
        .dash-tile {
            background: rgba(56,189,248,0.12); border: 1px solid rgba(56,189,248,0.2);
            border-radius: 12px; padding: 0.8rem; text-align: center;
        }
        .dash-tile .dn { font-family:'Syne',sans-serif; font-size:1.3rem; font-weight:800; color:var(--sky); }
        .dash-tile .dl { font-size:0.68rem; color:#94A3B8; margin-top:2px; }
        .dash-msgs { background: rgba(255,255,255,0.04); border-radius: 12px; padding: 0.8rem; }
        .dash-msg { display:flex; align-items:center; gap:9px; padding:7px 0; border-bottom:1px solid rgba(255,255,255,0.05); }
        .dash-msg:last-child{border-bottom:none;}
        .dash-av {
            width:30px; height:30px; border-radius:50%;
            background:linear-gradient(135deg, var(--sky-dark), var(--sky));
            display:flex; align-items:center; justify-content:center;
            font-size:0.65rem; font-weight:700; color:#fff; flex-shrink:0;
        }
        .dash-mt .dn { font-size:0.75rem; font-weight:600; color:#fff; }
        .dash-mt .dm { font-size:0.68rem; color:#94A3B8; }
        .dash-ck { color: var(--green); font-size:0.72rem; }
        .hero-float {
            position:absolute; bottom:-10px; left:-30px;
            background: rgba(255,255,255,0.97);
            border:1px solid rgba(56,189,248,0.3); padding:12px 16px; border-radius:16px;
            display:flex; align-items:center; gap:12px; backdrop-filter:blur(12px);
            box-shadow:0 10px 40px rgba(56,189,248,0.15);
        }
        .hero-float i { font-size:1.7rem; color: var(--green); }
        .hero-float h4 { font-size:0.88rem; font-weight:700; color: var(--dark); margin-bottom:2px; }
        .hero-float p { font-size:0.72rem; color: var(--muted); }

        /* ===== TRUSTED BY ===== */
        .trusted {
            background: var(--bg-trusted);
            border-top: 1px solid var(--border-color2); border-bottom: 1px solid var(--border-color2);
            padding: 2.5rem 5%; text-align: center; transition: background 0.3s;
        }
        .trusted p { color: var(--color-muted); font-size: 0.82rem; margin-bottom: 1.8rem; letter-spacing: 1.5px; text-transform: uppercase; }
        .trusted-logos { display: flex; justify-content: center; align-items: center; gap: 2rem; flex-wrap: wrap; }
        .trusted-logo {
            padding: 7px 18px; background: var(--offwhite2);
            border: 1px solid var(--border-color); border-radius: 10px;
            color: var(--color-muted); font-weight: 700; font-family: 'Syne', sans-serif;
            font-size: 0.9rem; transition: all 0.3s;
        }
        .trusted-logo:hover { border-color: var(--sky-dark); color: var(--sky-dark); background: var(--sky-pale); }

        /* ===== SECTION COMMONS ===== */
        .sec { padding: 100px 5%; transition: background 0.3s; }
        .sec-white { background: var(--bg-white-sec); }
        .sec-offwhite { background: var(--bg-offwhite-sec); }
        .sec-pale { background: var(--bg-pale-sec); }

        .sec-tag {
            display: inline-block; background: var(--sky-pale);
            border: 1px solid rgba(56,189,248,0.35); color: var(--sky-deeper);
            padding: 5px 15px; border-radius: 50px; font-size: 0.78rem;
            font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 1rem;
        }
        .sec-title {
            font-family: 'Syne', sans-serif; font-size: clamp(1.9rem,4vw,3rem);
            font-weight: 800; line-height: 1.15; color: var(--color-dark); margin-bottom: 1rem;
        }
        .sec-sub { color: var(--color-text2); font-size: 1.05rem; line-height: 1.75; max-width: 580px; }
        .tc { text-align: center; }
        .tc .sec-sub { margin: 0 auto; }
        .gt { background: linear-gradient(90deg, var(--sky-deeper), var(--sky)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

        /* ===== FEATURES ===== */
        .feat-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1.5rem; margin-top: 4rem; }
        .feat-card {
            background: var(--bg-card); border: 1px solid var(--border-color2);
            border-radius: 22px; padding: 2rem; transition: all 0.35s;
            position: relative; overflow: hidden;
            box-shadow: 0 2px 15px rgba(56,189,248,0.06);
        }
        .feat-card::before {
            content:''; position:absolute; top:0; left:0; right:0; height:3px;
            background: linear-gradient(90deg, var(--sky-deeper), var(--sky));
            transform:scaleX(0); transition:transform 0.35s; transform-origin:left;
        }
        .feat-card:hover::before { transform:scaleX(1); }
        .feat-card:hover { transform:translateY(-8px); border-color:rgba(56,189,248,0.35); box-shadow:0 20px 50px rgba(56,189,248,0.12); }
        .feat-icon {
            width:54px; height:54px; border-radius:16px;
            background: var(--sky-pale); border:1px solid rgba(56,189,248,0.25);
            display:flex; align-items:center; justify-content:center; margin-bottom:1.2rem; font-size:1.4rem;
        }
        .feat-card h3 { font-family:'Syne',sans-serif; font-size:1.08rem; font-weight:700; color:var(--color-dark); margin-bottom:0.7rem; }
        .feat-card p { color:var(--color-text2); font-size:0.87rem; line-height:1.65; margin-bottom:1.2rem; }
        .feat-link { color:var(--sky-dark); text-decoration:none; font-weight:600; font-size:0.87rem; display:flex; align-items:center; gap:5px; transition:gap 0.2s; }
        .feat-link:hover { gap:10px; }

        /* ===== DASHBOARD PREVIEW ===== */
        .dash-preview {
            padding: 100px 5%;
            background: linear-gradient(135deg, var(--dark) 0%, var(--dark2) 100%);
            position: relative; overflow: hidden;
        }
        .dash-preview::before {
            content:''; position:absolute; inset:0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='30' cy='30' r='1.5' fill='rgba(56,189,248,0.08)'/%3E%3C/svg%3E");
        }
        .prev-wrap { max-width:1200px; margin:0 auto; position:relative; z-index:2; }
        .prev-head { text-align:center; margin-bottom:3rem; }
        .prev-head h2 { font-family:'Syne',sans-serif; font-size:clamp(1.9rem,3.5vw,2.8rem); font-weight:800; color:#fff; margin-bottom:1rem; }
        .prev-head p { color:#94A3B8; font-size:1.05rem; }
        .prev-card {
            background: rgba(255,255,255,0.04); backdrop-filter:blur(10px);
            border:1px solid rgba(56,189,248,0.2); border-radius:28px; padding:2rem;
            box-shadow:0 30px 80px rgba(0,0,0,0.3);
        }
        .prev-tabs { display:flex; gap:0.8rem; margin-bottom:2rem; border-bottom:1px solid rgba(255,255,255,0.07); padding-bottom:1rem; flex-wrap:wrap; }
        .prev-tab { padding:7px 18px; color:#64748B; cursor:pointer; border-radius:10px; transition:all 0.3s; font-size:0.9rem; }
        .prev-tab.active { background:rgba(56,189,248,0.15); color:var(--sky); }
        .prev-tab:hover { color: var(--sky-light); }
        .prev-content { display:grid; grid-template-columns:1fr 1fr; gap:2rem; }
        .msg-list { background:rgba(255,255,255,0.03); border-radius:18px; padding:1.5rem; }
        .msg-item { display:flex; align-items:center; gap:1rem; padding:1rem 0; border-bottom:1px solid rgba(255,255,255,0.05); }
        .msg-item:last-child{border-bottom:none;}
        .msg-av { width:40px; height:40px; background:linear-gradient(135deg,var(--sky-dark),var(--sky)); border-radius:50%; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-size:0.82rem; flex-shrink:0; }
        .msg-info { flex:1; }
        .msg-info h4 { color:#fff; font-size:0.92rem; margin-bottom:3px; }
        .msg-info p { color:#94A3B8; font-size:0.82rem; }
        .msg-time { color:#64748B; font-size:0.75rem; text-align:right; }
        .stats-g { display:grid; grid-template-columns:repeat(2,1fr); gap:1rem; }
        .stat-b { background:rgba(255,255,255,0.04); border:1px solid rgba(56,189,248,0.15); border-radius:18px; padding:1.5rem; text-align:center; transition:all 0.3s; }
        .stat-b:hover { border-color:rgba(56,189,248,0.4); background:rgba(56,189,248,0.08); }
        .stat-b h3 { font-family:'Syne',sans-serif; font-size:2rem; font-weight:800; background:linear-gradient(90deg,var(--sky-dark),var(--sky)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom:6px; }
        .stat-b p { color:#94A3B8; font-size:0.85rem; }

        /* ===== PLANS ===== */
        .price-toggle { display:flex; align-items:center; justify-content:center; gap:1rem; margin-top:2rem; }
        .tg-label { font-size:0.95rem; color:var(--color-muted); }
        .tg-label.on { color:var(--color-dark); font-weight:600; }
