<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>WhatsApp API · Sign In</title>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Font - Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    
    <style>
        /* Reset & Base */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            width: 100%;
            overflow: hidden;
            position: fixed;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: rgb(136, 137, 160);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        /* Main Container - Fixed Height, No Scroll */
        .login-container {
            width: 100%;
            max-width: 1000px;
            height: 600px;
            max-height: 90vh;
            display: flex;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.35);
            background: white;
            position: relative;
        }

        /* ===== LEFT PANEL - WhatsApp Branding ===== */
        .brand-panel {
            flex: 1.2;
            background: linear-gradient(160deg, #075E54, #128C7E, #25D366);
            padding: 48px 40px;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .brand-panel::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.1) 0%, transparent 50%);
            pointer-events: none;
        }

        .brand-panel::after {
            content: "";
            position: absolute;
            bottom: -50px;
            right: -50px;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

        .brand-content {
            position: relative;
            z-index: 2;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .whatsapp-icon {
            font-size: 56px;
            color: white;
            margin-bottom: 32px;
            filter: drop-shadow(0 10px 20px rgba(0,0,0,0.2));
            display: inline-block;
        }

        .brand-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: white;
            line-height: 1.2;
            margin-bottom: 16px;
            letter-spacing: -0.02em;
        }

        .brand-description {
            color: rgba(255,255,255,0.9);
            font-size: 1rem;
            line-height: 1.5;
            margin-bottom: 40px;
            max-width: 360px;
            opacity: 0.95;
        }

        .features-list {
            list-style: none;
            margin-top: auto;
            margin-bottom: 0;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 22px;
        }

        .feature-item:last-child {
            margin-bottom: 0;
        }

        .feature-icon {
            width: 42px;
            height: 42px;
            background: rgba(255,255,255,0.15);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: white;
            backdrop-filter: blur(4px);
            flex-shrink: 0;
        }

        .feature-text {
            font-size: 0.95rem;
            font-weight: 500;
            color: white;
        }

        .feature-text small {
            display: block;
            font-size: 0.75rem;
            opacity: 0.8;
            margin-top: 2px;
            font-weight: 400;
        }

        /* ===== RIGHT PANEL - Login Form ===== */
        .form-panel {
            flex: 0.9;
            background: white;
            padding: 48px 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-y: auto;
        }

        .form-panel::-webkit-scrollbar {
            width: 0;
            background: transparent;
        }

        .form-content {
            width: 100%;
            max-width: 340px;
            margin: 0 auto;
        }

        .logo-wrapper {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #075E54, #128C7E);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            box-shadow: 0 10px 20px rgba(7, 94, 84, 0.25);
        }

        .logo-wrapper i {
            font-size: 30px;
            color: white;
        }

        .welcome-header {
            text-align: center;
            margin-bottom: 28px;
        }

        .welcome-header h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 6px;
            letter-spacing: -0.02em;
        }

        .welcome-header p {
            color: #64748b;
            font-size: 0.9rem;
            font-weight: 400;
        }

        /* Form Elements */
        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: #334155;
            margin-bottom: 6px;
            letter-spacing: 0.3px;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            color: #94a3b8;
            font-size: 0.95rem;
            transition: color 0.2s;
            z-index: 2;
        }

        .form-input {
            width: 100%;
            height: 48px;
            padding: 0 14px 0 42px;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;
            background: white;
            transition: all 0.25s ease;
            color: #1e293b;
        }

        .form-input:focus {
            outline: none;
            border-color: #25D366;
            box-shadow: 0 0 0 4px rgba(37, 211, 102, 0.1);
        }

        .form-input:focus + .input-icon {
            color: #25D366;
        }

        .form-input::placeholder {
            color: #94a3b8;
            font-weight: 400;
            font-size: 0.9rem;
            opacity: 0.7;
        }

        .password-wrapper {
            position: relative;
        }

        .toggle-password {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94a3b8;
            cursor: pointer;
            font-size: 1rem;
            padding: 0;
            z-index: 2;
            transition: color 0.2s;
            display: flex;
            align-items: center;
        }

        .toggle-password:hover {
            color: #25D366;
        }

        .options-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 16px 0 24px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            position: relative;
        }

        .remember-me input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #25D366;
        }

        .remember-me span {
            font-size: 0.85rem;
            color: #475569;
            font-weight: 500;
        }

        /* Remember Me Tooltip */
        .remember-tooltip {
            position: relative;
            display: inline-block;
            margin-left: 5px;
        }

        .remember-tooltip i {
            color: #94a3b8;
            font-size: 0.8rem;
            cursor: help;
        }

        .remember-tooltip:hover::after {
            content: "Stay logged in for 1 year";
            position: absolute;
            bottom: 150%;
            left: 50%;
            transform: translateX(-50%);
            background: #1e293b;
            color: white;
            padding: 5px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            white-space: nowrap;
            z-index: 10;
        }

        .forgot-link {
            color: #128C7E;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            transition: color 0.2s;
        }

        .forgot-link:hover {
            color: #075E54;
            text-decoration: underline;
        }

        .login-btn {
            width: 100%;
            height: 52px;
            background: linear-gradient(135deg, #075E54, #128C7E);
            border: none;
            border-radius: 16px;
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.25s ease;
            box-shadow: 0 8px 18px rgba(7, 94, 84, 0.3);
            margin-bottom: 20px;
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 22px rgba(7, 94, 84, 0.4);
        }

        .login-btn:active {
            transform: translateY(0);
        }

        .login-btn i {
            font-size: 1.1rem;
        }

        .login-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        .back-home {
            text-align: center;
            margin-top: 0.5rem;
        }

        .back-home a {
            color: #64748b;
            text-decoration: none;
            font-size: 0.85rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: color 0.2s;
            padding: 6px 0;
        }

        .back-home a:hover {
            color: #25D366;
        }

        .back-home i {
            font-size: 0.75rem;
        }

        /* Toast Container - EXACT WhatsApp Scan Style */
        #toast {
            position: fixed;
            top: 24px;
            right: 24px;
            width: 320px;
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 9999;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-row {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            background: rgba(0,0,0,.25);
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 4px 0 0;
            font-size: 13px;
            opacity: .9;
        }

        .toast-success { background: #10b981; }
        .toast-error { background: #ef4444; }
        .toast-info { background: #3b82f6; }
        .toast-warning { background: #f59e0b; color: #1f2937; }

        .toast-progress {
            height: 3px;
            border-radius: 4px;
            margin-top: 10px;
            background: rgba(255,255,255,.6);
            animation: toast-load 3s linear forwards;
        }

        @keyframes toast-load {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* ===== RESPONSIVE FIXES ===== */
        @media (max-width: 900px) {
            .login-container {
                height: 580px;
            }
            
            .brand-panel {
                padding: 40px 30px;
            }
            
            .form-panel {
                padding: 40px 30px;
            }
        }

        @media (max-width: 768px) {
            .login-container {
                flex-direction: column;
                height: auto;
                min-height: 0;
                max-width: 450px;
                max-height: 95vh;
            }

            body {
                overflow: hidden;
                padding: 12px;
            }

            .brand-panel {
                padding: 28px 24px 20px;
            }

            .whatsapp-icon {
                font-size: 46px;
                margin-bottom: 20px;
            }

            .brand-title {
                font-size: 1.7rem;
                margin-bottom: 8px;
            }

            .brand-description {
                font-size: 0.9rem;
                margin-bottom: 24px;
            }

            .feature-item {
                margin-bottom: 16px;
            }

            .feature-icon {
                width: 38px;
                height: 38px;
                font-size: 16px;
            }

            .feature-text {
                font-size: 0.85rem;
            }

            .form-panel {
                padding: 28px 24px;
            }

            .logo-wrapper {
                width: 56px;
                height: 56px;
                margin-bottom: 12px;
            }

            .logo-wrapper i {
                font-size: 26px;
            }

            .welcome-header h2 {
                font-size: 1.5rem;
            }

            .form-input {
                height: 46px;
            }

            .login-btn {
                height: 48px;
            }
        }

        @media (max-width: 480px) {
            body {
                padding: 8px;
            }

            .login-container {
                border-radius: 24px;
            }

            .brand-panel {
                padding: 24px 20px 16px;
            }

            .whatsapp-icon {
                font-size: 40px;
                margin-bottom: 16px;
            }

            .brand-title {
                font-size: 1.5rem;
            }

            .brand-description {
                font-size: 0.85rem;
                margin-bottom: 20px;
            }

            .feature-item {
                gap: 12px;
                margin-bottom: 14px;
            }

            .feature-icon {
                width: 34px;
                height: 34px;
                border-radius: 12px;
                font-size: 14px;
            }

            .feature-text {
                font-size: 0.8rem;
            }

            .feature-text small {
                font-size: 0.7rem;
            }

            .form-panel {
                padding: 24px 20px;
            }

            .logo-wrapper {
                width: 52px;
                height: 52px;
                border-radius: 14px;
            }

            .welcome-header {
                margin-bottom: 22px;
            }

            .welcome-header h2 {
                font-size: 1.4rem;
            }

            .form-group {
                margin-bottom: 16px;
            }

            .form-input {
                height: 44px;
                padding: 0 12px 0 38px;
                font-size: 0.9rem;
                border-radius: 14px;
            }

            .input-icon {
                left: 12px;
                font-size: 0.9rem;
            }

            .options-row {
                margin: 12px 0 20px;
            }

            .remember-me span {
                font-size: 0.8rem;
            }

            .forgot-link {
                font-size: 0.8rem;
            }

            .login-btn {
                height: 46px;
                font-size: 0.95rem;
                border-radius: 14px;
            }
        }

        @media (max-width: 375px) and (max-height: 670px) {
            .brand-panel {
                padding: 20px 16px 12px;
            }

            .whatsapp-icon {
                font-size: 36px;
                margin-bottom: 12px;
            }

            .brand-title {
                font-size: 1.3rem;
            }

            .brand-description {
                font-size: 0.8rem;
                margin-bottom: 16px;
            }

            .feature-item {
                margin-bottom: 10px;
            }

            .feature-icon {
                width: 30px;
                height: 30px;
                font-size: 12px;
            }

            .form-panel {
                padding: 20px 16px;
            }

            .logo-wrapper {
                width: 46px;
                height: 46px;
            }

            .welcome-header h2 {
                font-size: 1.3rem;
            }
        }

        @media (max-height: 600px) and (orientation: landscape) {
            .login-container {
                height: 520px;
            }

            .brand-panel {
                padding: 24px 20px;
            }

            .whatsapp-icon {
                font-size: 40px;
                margin-bottom: 16px;
            }

            .feature-item {
                margin-bottom: 12px;
            }
        }
    </style>
</head>
<body>
    <!-- Toast Container - EXACT WhatsApp Scan Style -->
    <div id="toast"></div>

    <!-- Main Login Container -->
    <div class="login-container">
        <!-- LEFT PANEL - WhatsApp Branding -->
        <div class="brand-panel">
            <div class="brand-content">
                <div class="whatsapp-icon">
                    <i class="fab fa-whatsapp"></i>
                </div>
                
                <h1 class="brand-title">WhatsApp<br>Business API</h1>
                <p class="brand-description">
                    Connect with customers seamlessly through WhatsApp's official business platform.
                </p>

                <ul class="features-list">
                    <li class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-rocket"></i>
                        </div>
                        <div class="feature-text">
                            High Throughput
                            <small>Send thousands of messages</small>
                        </div>
                    </li>
                    <li class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <div class="feature-text">
                            End-to-end Encrypted
                            <small>Your conversations are safe</small>
                        </div>
                    </li>
                    <li class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="feature-text">
                            Analytics Dashboard
                            <small>Track your campaign performance</small>
                        </div>
                    </li>
                    <li class="feature-item">
                        <div class="feature-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="feature-text">
                            24/7 Automated Responses
                            <small>Never miss a customer query</small>
                        </div>
                    </li>
                </ul>
            </div>
        </div>

        <!-- RIGHT PANEL - Login Form -->
        <div class="form-panel">
            <div class="form-content">
                <!-- Logo & Welcome -->
                <div class="logo-wrapper">
                    <i class="fab fa-whatsapp"></i>
                </div>
                <div class="welcome-header">
                    <h2>Welcome Back</h2>
                    <p>Sign in to your dashboard</p>
                </div>

                <!-- Login Form -->
                <form class="login-form" id="loginForm" method="POST" action="/login">
                    <!-- Email Field -->
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <div class="input-wrapper">
                            <i class="far fa-envelope input-icon"></i>
                            <input type="email" 
                                   class="form-input" 
                                   id="email" 
                                   name="email"
                                   placeholder="name@company.com"
                                   autocomplete="email"
                                   value="<%= typeof email !== 'undefined' ? email : '' %>"
                                   required>
                        </div>
                    </div>

                    <!-- Password Field -->
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <div class="input-wrapper password-wrapper">
                            <i class="fas fa-lock input-icon"></i>
                            <input type="password" 
                                   class="form-input" 
                                   id="password" 
                                   name="password"
                                   placeholder="········"
                                   autocomplete="current-password"
                                   required>
                            <button type="button" class="toggle-password" onclick="togglePassword()" tabindex="-1">
                                <i class="far fa-eye" id="toggleIcon"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Remember Me & Forgot Password -->
                    <div class="options-row">
                        <div class="remember-me">
                            <input type="checkbox" id="remember" name="remember" <%= typeof remember !== 'undefined' && remember ? 'checked' : '' %>>
                            <span>Remember me</span>
                            <div class="remember-tooltip">
                                <i class="fas fa-info-circle"></i>
                            </div>
                        </div>
                        <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                    </div>

                    <!-- Hidden field to ensure remember is sent even when unchecked -->
                    <input type="hidden" name="remember" value="off">
                    <script>
                        // Fix for checkbox: if checked, override hidden value
                        document.getElementById('remember')?.addEventListener('change', function() {
                            if (this.checked) {
                                this.name = 'remember';
                                this.value = 'on';
                            } else {
                                this.name = 'remember';
                                this.value = 'off';
                            }
                        });
                    </script>

                    <!-- Login Button -->
                    <button type="submit" class="login-btn" id="loginBtn">
                        <i class="fas fa-arrow-right-to-bracket"></i>
                        <span>Sign In</span>
                    </button>

                    <!-- Back to Home Link -->
                    <div class="back-home">
                        <a href="/">
                            <i class="fas fa-arrow-left"></i>
                            Back to Home
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Password Toggle Function
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const toggleIcon = document.getElementById('toggleIcon');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        }

        // EXACT WhatsApp Scan Toast Function
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            if (window.toastTimeout) {
                clearTimeout(window.toastTimeout);
            }
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.className = '';
            toast.innerHTML = `
                <div class="toast-row">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.classList.add(`toast-${type}`, 'show');
            
            window.toastTimeout = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // Check URL for server messages
        document.addEventListener('DOMContentLoaded', function() {
            const urlParams = new URLSearchParams(window.location.search);
            const message = urlParams.get('message');
            const messageType = urlParams.get('messageType');
            
            if (message && messageType) {
                let title = 'Information';
                if (messageType === 'success') title = 'Success';
                if (messageType === 'error') title = 'Error';
                if (messageType === 'warning') title = 'Warning';
                
                showToast(title, decodeURIComponent(message), messageType);
                
                // Clean URL
                const newUrl = window.location.pathname;
                window.history.replaceState({}, document.title, newUrl);
            }
            
            // Auto-focus on email field
            document.getElementById('email').focus();
        });

        // Handle form submission with validation
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const submitBtn = document.getElementById('loginBtn');
            
            // Validate both fields are filled
            if (!email || !password) {
                e.preventDefault();
                showToast('Error', 'Please fill in both email and password fields', 'error');
                return;
            }
            
            // Validate email format
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                e.preventDefault();
                showToast('Error', 'Please enter a valid email address', 'error');
                return;
            }
            
            // Validate password length
            if (password.length < 6) {
                e.preventDefault();
                showToast('Error', 'Password must be at least 6 characters long', 'error');
                return;
            }

            // Show loading state
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> <span>Signing In...</span>';
            submitBtn.disabled = true;
        });

        // Keyboard shortcut: Ctrl+Enter to submit
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                document.getElementById('loginForm').submit();
            }
        });

        // Prevent body scroll on mobile when input focused
        if ('ontouchstart' in window) {
            document.querySelectorAll('input').forEach(input => {
                input.addEventListener('focus', () => {
                    document.body.style.overflow = 'hidden';
                });
                input.addEventListener('blur', () => {
                    document.body.style.overflow = 'hidden';
                });
            });
        }

        console.log('✅ Login page loaded with WhatsApp scan style toast notifications');
    </script>
</body>
</html>