    <script>
        let currentMessageType = 'template';
        let selectedTemplate = 'hello_world';

        function selectMessageType(type) {
            currentMessageType = type;
            document.querySelectorAll('.message-type').forEach(el => {
                el.classList.remove('active');
            });
            event.currentTarget.classList.add('active');
            
            if(type === 'template') {
                document.getElementById('templateSection').style.display = 'block';
            } else {
                document.getElementById('templateSection').style.display = 'none';
            }
        }

        function selectTemplate(template) {
            selectedTemplate = template;
            document.querySelectorAll('.template-item').forEach(el => {
                el.style.background = '#f9f9f9';
            });
            event.currentTarget.style.background = '#e8f5e9';
        }

        function sendMessage() {
            const wabaId = document.getElementById('wabaId').value;
            const phoneId = document.getElementById('phoneId').value;
            const token = document.getElementById('accessToken').value;
            
            let apiResponse = document.getElementById('apiResponse');
            
            if(currentMessageType === 'template') {
                apiResponse.textContent = JSON.stringify({
                    messaging_product: "whatsapp",
                    contacts: [{
                        input: "919876543210",
                        wa_id: "919876543210"
                    }],
                    messages: [{
                        id: "wamid.HBgMOTE5ODc2NTQzMjEwFQIAERgSN0U5RkY3NzU1QzZFQjhEMDk2QA=="
                    }]
                }, null, 2);
                
                // Add to webhook
                addWebhookEvent('message.sent', {
                    template: selectedTemplate,
                    status: 'sent'
                });
            } else {
                apiResponse.textContent = JSON.stringify({
                    messaging_product: "whatsapp",
                    contacts: [{
                        input: "919876543210",
                        wa_id: "919876543210"
                    }],
                    messages: [{
                        id: "wamid.HBgMOTE5ODc2NTQzMjEwFQIAERgSN0U5RkY3NzU1QzZFQjhEMDk2QA=="
                    }]
                }, null, 2);
            }
            
            alert('Message sent successfully! Check webhook for status updates.');
        }

        function sendChatMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            
            if(message) {
                const messageWindow = document.getElementById('messageWindow');
                const time = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                
                const messageDiv = document.createElement('div');
                messageDiv.className = 'message sent';
                messageDiv.innerHTML = `
                    <div class="message-content">${message}</div>
                    <span class="message-time">${time}</span>
                    <span class="message-status"><i class="fas fa-check"></i> Sent</span>
                `;
                
                messageWindow.appendChild(messageDiv);
                messageWindow.scrollTop = messageWindow.scrollHeight;
                input.value = '';
                
                // Add to webhook
                addWebhookEvent('message.sent', {
                    text: message,
                    status: 'sent'
                });
                
                // Simulate delivery after 2 seconds
                setTimeout(() => {
                    messageDiv.querySelector('.message-status').innerHTML = '<i class="fas fa-check-double"></i> Delivered';
                    addWebhookEvent('message.delivered', { message_id: 'wamid.xxx' });
                }, 2000);
                
                // Simulate read after 5 seconds
                setTimeout(() => {
                    messageDiv.querySelector('.message-status').innerHTML = '<i class="fas fa-check-double"></i> Read';
                    addWebhookEvent('message.read', { message_id: 'wamid.xxx' });
                }, 5000);
            }
        }

        function addWebhookEvent(type, data) {
            const webhookData = document.getElementById('webhookData');
            const time = new Date().toLocaleString();
            
            const eventDiv = document.createElement('div');
            eventDiv.className = 'event';
            
            let badgeClass = 'badge-success';
            if(type.includes('delivered')) badgeClass = 'badge-warning';
            if(type.includes('read')) badgeClass = 'badge-success';
            
            eventDiv.innerHTML = `
                <span class="timestamp">${time}</span>
                <span class="badge ${badgeClass}">${type}</span>
                <pre style="color: #00ff00; margin-top: 10px;">
${JSON.stringify(data, null, 2)}
                </pre>
            `;
            
            webhookData.insertBefore(eventDiv, webhookData.firstChild);
            
            // Keep only last 10 events
            if(webhookData.children.length > 10) {
                webhookData.removeChild(webhookData.lastChild);
            }
        }

        function toggleWebhook(mode) {
            document.querySelectorAll('.webhook-toggle button').forEach(btn => {
                btn.classList.remove('active');
            });
            event.currentTarget.classList.add('active');
            
            if(mode === 'test') {
                document.getElementById('webhookData').innerHTML = `
                    <div class="event">
                        <span class="timestamp">Test Mode</span>
                        <span class="badge badge-success">webhook.verified</span>
                        <pre style="color: #00ff00; margin-top: 10px;">
{
  "hub.mode": "subscribe",
  "hub.challenge": "123456789",
  "hub.verify_token": "your_verify_token"
}
                        </pre>
                    </div>
                `;
            }
        }

        // Initialize with sample data
        window.onload = function() {
            // Add periodic webhook events
            setInterval(() => {
                const events = ['message.received', 'message.delivered', 'message.read'];
                const randomEvent = events[Math.floor(Math.random() * events.length)];
                
                addWebhookEvent(randomEvent, {
                    timestamp: new Date().toISOString(),
                    message_id: "wamid." + Math.random().toString(36).substring(7)
                });
            }, 10000);
        };
    </script>
