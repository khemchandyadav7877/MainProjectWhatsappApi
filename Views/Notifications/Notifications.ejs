<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SuperAdmin - Notifications</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ===== THEME VARIABLES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --primary-gradient: linear-gradient(135deg, #667eea, #764ba2);
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            --whatsapp: #25D366;
            
            /* Light Mode */
            --bg-body: #f8fafc;
            --bg-white: #ffffff;
            --bg-offwhite: #f1f5f9;
            --bg-card: #ffffff;
            --bg-hover: #f8fafc;
            --text: #334155;
            --text-light: #64748b;
            --text-muted: #94a3b8;
            --dark: #0f172a;
            --border: #eef2f6;
            --shadow: 0 8px 25px rgba(0,0,0,0.03);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.1);
            
            /* Status Colors */
            --unread-bg: rgba(16, 185, 129, 0.1);
            --unread-border: var(--success);
            --sent-bg: rgba(139, 92, 246, 0.1);
            --sent-border: #8b5cf6;
            --received-bg: rgba(59, 130, 246, 0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
            --sidebar-mini-width: 80px;
        }

        /* Dark Mode */
        body.dark {
            --primary: #818cf8;
            --primary-gradient: linear-gradient(135deg, #818cf8, #a78bfa);
            
            --bg-body: #0f172a;
            --bg-white: #1e293b;
            --bg-offwhite: #334155;
            --bg-card: #1e293b;
            --bg-hover: #2d3a4f;
            --text: #e2e8f0;
            --text-light: #cbd5e1;
            --text-muted: #94a3b8;
            --dark: #f8fafc;
            --border: #334155;
            --shadow: 0 8px 25px rgba(0,0,0,0.2);
            --shadow-lg: 0 15px 35px rgba(102, 126, 234, 0.2);
            
            --unread-bg: rgba(16, 185, 129, 0.2);
            --sent-bg: rgba(139, 92, 246, 0.2);
            --received-bg: rgba(59, 130, 246, 0.2);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: 'Inter', 'Segoe UI', sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES - EXACTLY LIKE PREVIOUS TEMPLATES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar,
        body.round-border .mid-content,
        body.round-border .stat-card,
        body.round-border .filters-bar,
        body.round-border .notification-item,
        body.round-border .filter-btn,
        body.round-border .search-box input,
        body.round-border .modal-content,
        body.round-border .message-bubble,
        body.round-border .action-btn,
        body.round-border .avatar,
        body.round-border .btn,
        body.round-border .form-control {
            border-radius: 20px !important;
        }

        body.round-border .avatar,
        body.round-border .stat-icon,
        body.round-border .theme-toggle,
        body.round-border .border-toggle {
            border-radius: 16px !important;
        }

        body.round-border .role-badge {
            border-radius: 50px !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar,
        body.no-radius .mid-content,
        body.no-radius .stat-card,
        body.no-radius .filters-bar,
        body.no-radius .notification-item,
        body.no-radius .filter-btn,
        body.no-radius .search-box input,
        body.no-radius .modal-content,
        body.no-radius .message-bubble,
        body.no-radius .action-btn,
        body.no-radius .avatar,
        body.no-radius .btn,
        body.no-radius .form-control,
        body.no-radius .stat-icon,
        body.no-radius .theme-toggle,
        body.no-radius .border-toggle,
        body.no-radius .role-badge {
            border-radius: 0 !important;
        }

        /* Header Styles */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        /* MAIN LAYOUT - EXACTLY LIKE PREVIOUS TEMPLATES */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
            position: relative;
        }

        /* SIDEBAR - EXACTLY LIKE PREVIOUS TEMPLATES */
        .sidebar {
            width: var(--sidebar-width, 280px);
            background: var(--bg-white);
            border-right: 1px solid var(--border);
            height: calc(100vh - var(--header-height, 70px));
            position: fixed;
            left: 0;
            top: 70px;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1020;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            overflow-x: hidden;
        }

        /* Sidebar Mini Mode */
        .sidebar.mini {
            width: var(--sidebar-mini-width, 80px);
        }

        /* CONTENT WRAPPER - EXACTLY LIKE PREVIOUS TEMPLATES */
        .content-wrapper {
            flex: 1;
            margin-left: var(--sidebar-width, 280px);
            padding: 25px;
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
            width: calc(100% - var(--sidebar-width, 280px));
        }

        /* When sidebar has mini class, adjust content wrapper */
        .sidebar.mini ~ .content-wrapper {
            margin-left: var(--sidebar-mini-width, 80px);
            width: calc(100% - var(--sidebar-mini-width, 80px));
        }

        .mid-content {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 30px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            min-height: 500px;
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
                transition: transform 0.3s ease;
            }
            
            .sidebar.open {
                transform: translateX(0);
            }
            
            .sidebar.mini {
                transform: translateX(-100%);
                width: var(--sidebar-width, 280px) !important;
            }
            
            .sidebar.mini.open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
                padding: 15px;
            }
            
            .sidebar.mini ~ .content-wrapper {
                margin-left: 0 !important;
                width: 100% !important;
            }
            
            .mid-content {
                padding: 20px;
            }
        }

        /* Header Actions */
        .header-actions {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .theme-toggle {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-offwhite);
            color: var(--text);
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.3s;
        }

        .theme-toggle:hover {
            background: var(--primary-gradient);
            color: white;
            border-color: transparent;
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .border-toggle {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-offwhite);
            color: var(--text);
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.3s;
        }

        .border-toggle:hover {
            background: var(--primary-gradient);
            color: white;
            border-color: transparent;
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 5px 15px;
            background: var(--bg-offwhite);
            border-radius: 30px;
            border: 1px solid var(--border);
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            background: var(--primary-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 16px;
        }

        .user-info {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .user-role {
            font-size: 11px;
            color: var(--text-muted);
        }

        /* Stats Cards - IMPROVED */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 25px;
        }

        .stat-card {
            background: var(--bg-card);
            padding: 24px;
            border-radius: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: var(--primary-gradient);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }

        .stat-card:hover::before {
            opacity: 1;
        }

        .stat-card.active {
            border: 2px solid var(--primary);
            background: var(--bg-offwhite);
        }

        .stat-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            background: var(--primary-gradient);
            box-shadow: var(--shadow-lg);
        }

        .stat-info small {
            font-size: 12px;
            color: var(--text-muted);
            display: block;
            margin-bottom: 5px;
        }

        .stat-info h3 {
            font-size: 28px;
            font-weight: 700;
            color: var(--dark);
            margin: 0;
            line-height: 1.2;
        }

        /* Filters Bar */
        .filters-bar {
            background: var(--bg-card);
            padding: 25px;
            border-radius: 20px;
            margin-bottom: 25px;
            border: 1px solid var(--border);
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter-group {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 10px 20px;
            border: 1px solid var(--border);
            background: var(--bg-white);
            color: var(--text);
            border-radius: 12px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .filter-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
            transform: translateY(-2px);
        }

        .filter-btn.active {
            background: var(--primary-gradient);
            color: white;
            border-color: transparent;
        }

        .search-box {
            flex: 1;
            position: relative;
            min-width: 250px;
        }

        .search-box i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
            z-index: 1;
        }

        .search-box input {
            width: 100%;
            padding: 12px 16px 12px 45px;
            border: 1px solid var(--border);
            border-radius: 12px;
            font-size: 14px;
            background: var(--bg-white);
            color: var(--text);
            transition: all 0.3s;
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            background: var(--bg-white);
        }

        .search-box input::placeholder {
            color: var(--text-muted);
            opacity: 0.7;
        }

        /* Buttons - EXACTLY LIKE PREVIOUS TEMPLATES */
        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-primary {
            background: var(--primary-gradient);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .btn-outline {
            background: transparent;
            color: var(--text);
            border: 1px solid var(--border);
        }

        .btn-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--bg-offwhite);
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        /* Notifications Container */
        .notifications-container {
            background: var(--bg-card);
            border-radius: 20px;
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .notification-item {
            padding: 24px;
            border-bottom: 1px solid var(--border);
            display: flex;
            gap: 20px;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .notification-item:hover {
            background: var(--bg-hover);
        }

        .notification-item.unread {
            background: var(--unread-bg);
            border-left: 4px solid var(--unread-border);
        }

        .notification-item.sent {
            background: var(--sent-bg);
            border-left: 4px solid var(--sent-border);
        }

        .notification-avatar {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 20px;
            flex-shrink: 0;
            background: var(--primary-gradient);
            box-shadow: var(--shadow);
        }

        .notification-content {
            flex: 1;
        }

        .notification-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .sender-info {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .sender-name {
            font-weight: 600;
            color: var(--dark);
            font-size: 16px;
        }

        .role-badge {
            font-size: 11px;
            padding: 4px 12px;
            border-radius: 50px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .role-badge.educator {
            background: rgba(59, 130, 246, 0.1);
            color: var(--info);
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .role-badge.sent {
            background: rgba(139, 92, 246, 0.1);
            color: #8b5cf6;
            border: 1px solid rgba(139, 92, 246, 0.2);
        }

        .role-badge.superadmin {
            background: rgba(102, 126, 234, 0.1);
            color: var(--primary);
            border: 1px solid rgba(102, 126, 234, 0.2);
        }

        .time {
            color: var(--text-muted);
            font-size: 12px;
        }

        .message-text {
            color: var(--text);
            font-size: 14px;
            margin-bottom: 12px;
            line-height: 1.6;
        }

        .reply-indicator {
            background: var(--bg-offwhite);
            padding: 12px 16px;
            border-radius: 12px;
            margin-top: 10px;
            font-size: 13px;
            border-left: 3px solid var(--primary);
            color: var(--text-light);
        }

        .reply-indicator i {
            color: var(--primary);
            margin-right: 8px;
        }

        .notification-meta {
            display: flex;
            gap: 20px;
            color: var(--text-muted);
            font-size: 12px;
            margin-bottom: 15px;
        }

        .notification-meta i {
            margin-right: 5px;
            color: var(--primary);
        }

        .notification-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .action-btn {
            padding: 8px 16px;
            border: none;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .action-btn.reply {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid transparent;
        }

        .action-btn.reply:hover:not(:disabled) {
            background: var(--success);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(16, 185, 129, 0.3);
        }

        .action-btn.mark-read {
            background: rgba(59, 130, 246, 0.1);
            color: var(--info);
            border: 1px solid transparent;
        }

        .action-btn.mark-read:hover {
            background: var(--info);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3);
        }

        .action-btn.delete {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid transparent;
        }

        .action-btn.delete:hover {
            background: var(--danger);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(239, 68, 68, 0.3);
        }

        .action-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Modal Styles */
        .modal-content {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
        }

        .modal-header {
            border-bottom: 1px solid var(--border);
            padding: 20px 25px;
        }

        .modal-title {
            color: var(--dark);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 18px;
        }

        .modal-body {
            padding: 25px;
        }

        .modal-footer {
            border-top: 1px solid var(--border);
            padding: 20px 25px;
        }

        .btn-close {
            filter: var(--close-btn-invert);
        }

        body.dark .btn-close {
            filter: invert(1);
        }

        /* Conversation Thread */
        .conversation-thread {
            max-height: 300px;
            overflow-y: auto;
            padding: 20px;
            background: var(--bg-offwhite);
            border-radius: 16px;
            margin-bottom: 20px;
        }

        .message-bubble {
            padding: 12px 16px;
            border-radius: 16px;
            margin-bottom: 15px;
            max-width: 80%;
            position: relative;
        }

        .message-bubble.incoming {
            background: var(--bg-white);
            border: 1px solid var(--border);
            margin-right: auto;
        }

        .message-bubble.outgoing {
            background: var(--primary-gradient);
            color: white;
            margin-left: auto;
        }

        .message-sender {
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 5px;
            opacity: 0.8;
        }

        .message-time {
            font-size: 9px;
            margin-top: 5px;
            opacity: 0.7;
            text-align: right;
        }

        textarea.form-control {
            width: 100%;
            padding: 15px;
            border: 1px solid var(--border);
            border-radius: 12px;
            background: var(--bg-white);
            color: var(--text);
            font-size: 14px;
            resize: vertical;
            min-height: 100px;
        }

        textarea.form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            background: var(--bg-white);
        }

        textarea.form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.7;
        }

        /* Toast Notification - EXACTLY LIKE PREVIOUS TEMPLATES */
        #toast {
            position: fixed;
            top: 90px;
            right: 29px;
            width: 320px;
            padding: 16px 20px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 1001;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-content {
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .toast-icon {
            font-size: 20px;
        }

        .toast-text h4 {
            margin: 0;
            font-size: 14px;
            font-weight: 600;
        }

        .toast-text p {
            margin: 5px 0 0;
            font-size: 13px;
            opacity: 0.9;
        }

        .toast-progress {
            height: 3px;
            background: rgba(255,255,255,0.6);
            margin-top: 12px;
            width: 100%;
            animation: progress 3s linear;
        }

        @keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 64px;
            margin-bottom: 20px;
            color: var(--border);
        }

        .empty-state h3 {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 10px;
            color: var(--dark);
        }

        .empty-state p {
            max-width: 400px;
            margin: 0 auto 20px;
            color: var(--text-muted);
        }

        /* Loading Spinner */
        .loading-spinner {
            text-align: center;
            padding: 60px;
            color: var(--text-muted);
        }

        .loading-spinner i {
            font-size: 40px;
            margin-bottom: 15px;
            color: var(--primary);
        }

        .loading-spinner p {
            color: var(--text-muted);
            font-size: 14px;
        }

        /* Quick Actions */
        .quick-actions {
            margin-bottom: 0;
        }

        /* Loading Overlay */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            backdrop-filter: blur(5px);
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid var(--bg-offwhite);
            border-top: 5px solid var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Responsive */
        @media (max-width: 1200px) {
            .stats-grid {
                gap: 15px;
            }
            
            .stat-card {
                padding: 20px;
            }
            
            .stat-icon {
                width: 48px;
                height: 48px;
                font-size: 20px;
            }
            
            .stat-info h3 {
                font-size: 24px;
            }
        }

        @media (max-width: 992px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .filters-bar {
                flex-direction: column;
                align-items: stretch;
            }
            
            .filter-group {
                justify-content: center;
            }
            
            .search-box {
                width: 100%;
            }
            
            .btn-outline {
                width: 100%;
                justify-content: center;
            }
        }

        @media (max-width: 768px) {
            .stats-grid {
                gap: 10px;
            }
            
            .stat-card {
                padding: 16px;
            }
            
            .stat-icon {
                width: 44px;
                height: 44px;
                font-size: 18px;
            }
            
            .stat-info h3 {
                font-size: 20px;
            }
            
            .stat-info small {
                font-size: 11px;
            }
            
            .filters-bar {
                padding: 20px;
            }
            
            .notification-item {
                padding: 20px;
                flex-direction: column;
                gap: 15px;
            }
            
            .notification-avatar {
                width: 48px;
                height: 48px;
                font-size: 18px;
            }
            
            .notification-header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .notification-actions {
                width: 100%;
            }
            
            .action-btn {
                flex: 1;
                justify-content: center;
            }
            
            .message-bubble {
                max-width: 90%;
            }
        }

        @media (max-width: 576px) {
            .content-wrapper {
                padding: 10px;
            }
            
            .mid-content {
                padding: 15px;
            }
            
            .stats-grid {
                grid-template-columns: 1fr;
            }
            
            .stat-card {
                padding: 15px;
            }
            
            .filter-group {
                flex-direction: column;
                width: 100%;
            }
            
            .filter-btn {
                width: 100%;
                text-align: center;
            }
            
            .notification-item {
                padding: 15px;
            }
            
            .notification-actions {
                flex-direction: column;
            }
            
            .action-btn {
                width: 100%;
            }
            
            .modal-dialog {
                margin: 10px;
            }
            
            .modal-body {
                padding: 15px;
            }
            
            .conversation-thread {
                padding: 15px;
            }
            
            .message-bubble {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- Toast Notification -->
    <div id="toast"></div>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <%- include('../../partials/ram/sidebaar') %>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <div class="mid-content">
                <!-- Page Header -->
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
                    <h4 class="page-title mb-3 mb-md-0">
                        <i class="fas fa-bell me-2" style="color: var(--primary);"></i>
                        Notifications Center
                    </h4>
                    <div class="quick-actions">
                        <button class="btn btn-primary" onclick="openNewMessageModal()">
                            <i class="fas fa-plus me-2"></i> New Message
                        </button>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="stats-grid">
                    <div class="stat-card active" onclick="setFilter('all')">
                        <div class="stat-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="stat-info">
                            <small>Total Messages</small>
                            <h3 id="totalCount">0</h3>
                        </div>
                    </div>
                    <div class="stat-card" onclick="setFilter('unread')">
                        <div class="stat-icon">
                            <i class="fas fa-envelope-open"></i>
                        </div>
                        <div class="stat-info">
                            <small>Unread</small>
                            <h3 id="unreadCount">0</h3>
                        </div>
                    </div>
                    <div class="stat-card" onclick="setFilter('educator')">
                        <div class="stat-icon">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <div class="stat-info">
                            <small>From Educators</small>
                            <h3 id="educatorCount">0</h3>
                        </div>
                    </div>
                    <div class="stat-card" onclick="setFilter('sent')">
                        <div class="stat-icon">
                            <i class="fas fa-paper-plane"></i>
                        </div>
                        <div class="stat-info">
                            <small>Sent</small>
                            <h3 id="sentCount">0</h3>
                        </div>
                    </div>
                </div>

                <!-- Filters Bar -->
                <div class="filters-bar">
                    <div class="filter-group">
                        <button class="filter-btn active" onclick="setFilter('all')">All</button>
                        <button class="filter-btn" onclick="setFilter('unread')">Unread</button>
                        <button class="filter-btn" onclick="setFilter('educator')">From Educators</button>
                        <button class="filter-btn" onclick="setFilter('sent')">Sent</button>
                    </div>
                    
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="searchInput" placeholder="Search notifications..." onkeyup="handleSearch()">
                    </div>

                    <button class="btn btn-outline" onclick="markAllAsRead()">
                        <i class="fas fa-check-double me-2"></i> Mark All Read
                    </button>
                </div>

                <!-- Notifications List -->
                <div class="notifications-container" id="notificationsList">
                    <div class="loading-spinner" id="loadingSpinner">
                        <i class="fas fa-spinner fa-spin"></i>
                        <p>Loading notifications...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="text-center">
            <div class="spinner"></div>
            <div class="loading-text mt-3 text-white">Processing...</div>
        </div>
    </div>

    <!-- Reply Modal -->
    <div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-reply me-2" style="color: var(--primary);"></i>
                        Reply to Conversation
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="conversation-thread" id="conversationThread"></div>
                    <textarea class="form-control" id="replyMessage" placeholder="Type your reply here..." rows="4"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-primary" onclick="sendReply()">
                        <i class="fas fa-paper-plane me-2"></i> Send Reply
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- New Message Modal -->
    <div class="modal fade" id="newMessageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-plus-circle me-2" style="color: var(--primary);"></i>
                        New Message
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <textarea class="form-control" id="newMessage" placeholder="Type your message to educators..." rows="5"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i> Cancel
                    </button>
                    <button type="button" class="btn btn-primary" onclick="sendNewMessage()">
                        <i class="fas fa-paper-plane me-2"></i> Send Message
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Global Variables
        let notifications = [];
        let currentFilter = 'all';
        let selectedId = null;
        let replyModal, newMessageModal;

        // ======================
        // SIDEBAR STATE SYNC - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        function syncSidebarState() {
            const sidebar = document.getElementById('sidebar');
            const contentWrapper = document.getElementById('contentWrapper');
            
            if (!sidebar || !contentWrapper) return;
            
            const isMini = sidebar.classList.contains('mini');
            
            if (isMini) {
                contentWrapper.style.marginLeft = 'var(--sidebar-mini-width, 80px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-mini-width, 80px))';
            } else {
                contentWrapper.style.marginLeft = 'var(--sidebar-width, 280px)';
                contentWrapper.style.width = 'calc(100% - var(--sidebar-width, 280px))';
            }
        }

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Bootstrap modals
            replyModal = new bootstrap.Modal(document.getElementById('replyModal'));
            newMessageModal = new bootstrap.Modal(document.getElementById('newMessageModal'));
            
            // Load notifications
            fetchNotifications();
            
            // Auto refresh every 10 seconds
            setInterval(fetchNotifications, 10000);
            
            // Listen for sidebar state changes
            window.addEventListener('storage', function(e) {
                if (e.key === 'sidebarMini' || e.key === 'sidebar-update-time') {
                    const sidebar = document.getElementById('sidebar');
                    if (sidebar) {
                        const savedState = localStorage.getItem('sidebarMini') === 'true';
                        if (savedState) {
                            sidebar.classList.add('mini');
                        } else {
                            sidebar.classList.remove('mini');
                        }
                        syncSidebarState();
                    }
                }
            });

            window.addEventListener('resize', function() {
                syncSidebarState();
            });

            setTimeout(syncSidebarState, 100);
            
            // Show welcome toast
            setTimeout(() => {
                showToast('Welcome', 'SuperAdmin notifications loaded', 'info');
            }, 1000);
        });

        // ======================
        // TOAST FUNCTION - EXACTLY LIKE PREVIOUS TEMPLATES
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.innerHTML = `
                <div class="toast-content">
                    <div class="toast-icon">${icon}</div>
                    <div class="toast-text">
                        <h4>${title}</h4>
                        <p>${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.className = `toast-${type} show`;
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOADING OVERLAY FUNCTIONS
        // ======================
        function showLoading(text = 'Processing...') {
            const overlay = document.getElementById('loadingOverlay');
            document.querySelector('.loading-text').textContent = text;
            overlay.style.display = 'flex';
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        // ======================
        // NOTIFICATION FUNCTIONS
        // ======================
        async function fetchNotifications() {
            try {
                const search = document.getElementById('searchInput').value;
                const res = await fetch(`/api/notifications?filter=${currentFilter}&search=${search}`);
                const data = await res.json();
                
                if (data.success) {
                    notifications = data.notifications;
                    
                    // Update stats
                    document.getElementById('totalCount').innerText = data.stats.total || 0;
                    document.getElementById('unreadCount').innerText = data.stats.unread || 0;
                    document.getElementById('educatorCount').innerText = data.stats.educator || 0;
                    document.getElementById('sentCount').innerText = data.stats.sent || 0;
                    
                    renderList();
                }
            } catch (error) {
                console.error('Error fetching notifications:', error);
                showToast('Error', 'Failed to load notifications', 'error');
            }
        }

        function renderList() {
            const container = document.getElementById('notificationsList');
            const spinner = document.getElementById('loadingSpinner');
            
            if (!notifications.length) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-bell-slash"></i>
                        <h3>No notifications</h3>
                        <p>You don't have any notifications yet. New messages will appear here.</p>
                        <button class="btn btn-primary mt-3" onclick="openNewMessageModal()">
                            <i class="fas fa-plus me-2"></i> Send First Message
                        </button>
                    </div>
                `;
                return;
            }

            let html = '';
            
            notifications.forEach(n => {
                if (n.type === 'sent') {
                    html += `
                        <div class="notification-item sent">
                            <div class="notification-avatar">
                                <i class="fas fa-user-shield"></i>
                            </div>
                            <div class="notification-content">
                                <div class="notification-header">
                                    <div class="sender-info">
                                        <span class="sender-name">You</span>
                                        <span class="role-badge sent">Sent</span>
                                    </div>
                                    <span class="time">${formatTime(n.createdAt)}</span>
                                </div>
                                <div class="message-text">${n.message}</div>
                                <div class="notification-actions">
                                    <button class="action-btn delete" onclick="deleteNotif('${n._id}')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                } else {
                    html += `
                        <div class="notification-item ${n.isRead ? '' : 'unread'}" onclick="openNotif('${n._id}')">
                            <div class="notification-avatar">
                                ${n.senderName?.charAt(0) || 'E'}
                            </div>
                            <div class="notification-content">
                                <div class="notification-header">
                                    <div class="sender-info">
                                        <span class="sender-name">${n.senderName || 'Educator'}</span>
                                        <span class="role-badge educator">Educator</span>
                                    </div>
                                    <span class="time">${formatTime(n.createdAt)}</span>
                                </div>
                                <div class="message-text">${n.message}</div>
                                ${n.reply ? `
                                    <div class="reply-indicator">
                                        <i class="fas fa-reply"></i> 
                                        Replied: ${n.reply.message}
                                    </div>
                                ` : ''}
                                <div class="notification-meta">
                                    <span><i class="fas fa-phone-alt"></i> ${n.senderPhone || 'N/A'}</span>
                                </div>
                                <div class="notification-actions" onclick="event.stopPropagation()">
                                    <button class="action-btn reply" onclick="openReply('${n._id}')" ${n.reply ? 'disabled' : ''}>
                                        <i class="fas fa-reply"></i> ${n.reply ? 'Replied' : 'Reply'}
                                    </button>
                                    ${!n.isRead ? `
                                        <button class="action-btn mark-read" onclick="markRead('${n._id}')">
                                            <i class="fas fa-check"></i> Mark Read
                                        </button>
                                    ` : ''}
                                    <button class="action-btn delete" onclick="deleteNotif('${n._id}')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                }
            });
            
            container.innerHTML = html;
            spinner.style.display = 'none';
        }

        function formatTime(timestamp) {
            const date = new Date(timestamp);
            const now = new Date();
            const diff = now - date;
            
            // Today
            if (diff < 24 * 60 * 60 * 1000) {
                return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            }
            // This week
            if (diff < 7 * 24 * 60 * 60 * 1000) {
                return date.toLocaleDateString([], { weekday: 'short' });
            }
            // Older
            return date.toLocaleDateString([], { month: 'short', day: 'numeric' });
        }

        // ======================
        // FILTER FUNCTIONS
        // ======================
        function setFilter(filter) {
            currentFilter = filter;
            
            // Update active state
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            
            // Update stat cards
            document.querySelectorAll('.stat-card').forEach((card, index) => {
                card.classList.remove('active');
            });
            
            // Find and activate corresponding stat card
            const statCards = document.querySelectorAll('.stat-card');
            if (filter === 'all') statCards[0].classList.add('active');
            else if (filter === 'unread') statCards[1].classList.add('active');
            else if (filter === 'educator') statCards[2].classList.add('active');
            else if (filter === 'sent') statCards[3].classList.add('active');
            
            fetchNotifications();
            showToast('Filter Applied', `Showing ${filter} notifications`, 'info');
        }

        function handleSearch() {
            clearTimeout(window.searchTimeout);
            window.searchTimeout = setTimeout(fetchNotifications, 500);
        }

        // ======================
        // MODAL FUNCTIONS
        // ======================
        function openNewMessageModal() {
            document.getElementById('newMessage').value = '';
            newMessageModal.show();
        }

        function openReply(id) {
            selectedId = id;
            const n = notifications.find(x => x._id === id);
            
            let threadHtml = `
                <div class="message-bubble incoming">
                    <div class="message-sender">${n.senderName} (Educator)</div>
                    <div>${n.message}</div>
                    <div class="message-time">${new Date(n.createdAt).toLocaleString()}</div>
                </div>
            `;
            
            if (n.reply) {
                threadHtml += `
                    <div class="message-bubble outgoing">
                        <div class="message-sender">You (SuperAdmin)</div>
                        <div>${n.reply.message}</div>
                        <div class="message-time">${new Date(n.reply.repliedAt).toLocaleString()}</div>
                    </div>
                `;
            }
            
            document.getElementById('conversationThread').innerHTML = threadHtml;
            document.getElementById('replyMessage').value = '';
            
            replyModal.show();
        }

        function openNotif(id) {
            const n = notifications.find(x => x._id === id);
            if (!n.isRead) markRead(id);
            openReply(id);
        }

        // ======================
        // API FUNCTIONS
        // ======================
        async function sendNewMessage() {
            const msg = document.getElementById('newMessage').value.trim();
            if (!msg) {
                showToast('Error', 'Please enter a message', 'error');
                return;
            }
            
            showToast('Sending', 'Sending message...', 'info');
            
            try {
                const res = await fetch('/api/notifications/new', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg })
                });
                
                const data = await res.json();
                
                if (data.success) {
                    showToast('Success', 'Message sent successfully!', 'success');
                    newMessageModal.hide();
                    fetchNotifications();
                } else {
                    showToast('Error', data.error || 'Failed to send message', 'error');
                }
            } catch (error) {
                console.error('Error sending message:', error);
                showToast('Error', 'Failed to send message', 'error');
            }
        }

        async function sendReply() {
            const msg = document.getElementById('replyMessage').value.trim();
            if (!msg || !selectedId) {
                showToast('Error', 'Please enter a reply', 'error');
                return;
            }
            
            showToast('Sending', 'Sending reply...', 'info');
            
            try {
                const res = await fetch('/api/notifications/reply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ notificationId: selectedId, message: msg })
                });
                
                const data = await res.json();
                
                if (data.success) {
                    showToast('Success', 'Reply sent successfully!', 'success');
                    replyModal.hide();
                    fetchNotifications();
                } else {
                    showToast('Error', data.error || 'Failed to send reply', 'error');
                }
            } catch (error) {
                console.error('Error sending reply:', error);
                showToast('Error', 'Failed to send reply', 'error');
            }
        }

        async function markRead(id) {
            try {
                await fetch(`/api/notifications/${id}/read`, { method: 'PUT' });
                showToast('Success', 'Marked as read', 'success');
                fetchNotifications();
            } catch (error) {
                console.error('Error marking as read:', error);
                showToast('Error', 'Failed to mark as read', 'error');
            }
        }

        async function markAllAsRead() {
            if (!confirm('Mark all notifications as read?')) return;
            
            showToast('Processing', 'Marking all as read...', 'info');
            
            try {
                await fetch('/api/notifications/read-all', { method: 'PUT' });
                showToast('Success', 'All notifications marked as read', 'success');
                fetchNotifications();
            } catch (error) {
                console.error('Error marking all as read:', error);
                showToast('Error', 'Failed to mark all as read', 'error');
            }
        }

        async function deleteNotif(id) {
            if (!confirm('Are you sure you want to delete this notification?')) return;
            
            try {
                await fetch(`/api/notifications/${id}`, { method: 'DELETE' });
                notifications = notifications.filter(n => n._id !== id);
                renderList();
                showToast('Success', 'Notification deleted', 'success');
            } catch (error) {
                console.error('Error deleting notification:', error);
                showToast('Error', 'Failed to delete notification', 'error');
            }
        }

        // ======================
        // THEME FUNCTIONS
        // ======================
        function toggleTheme() {
            if (document.body.classList.contains('dark')) {
                document.body.classList.remove('dark');
                document.body.classList.add('light');
                localStorage.setItem('theme', 'light');
                showToast('Theme Updated', 'Light mode activated', 'info');
            } else {
                document.body.classList.remove('light');
                document.body.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                showToast('Theme Updated', 'Dark mode activated', 'info');
            }
        }

        function toggleBorder() {
            if (document.body.classList.contains('round-border')) {
                document.body.classList.remove('round-border');
                document.body.classList.add('no-radius');
                localStorage.setItem('border', 'no-radius');
                showToast('Border Style', 'Square corners activated', 'info');
            } else {
                document.body.classList.remove('no-radius');
                document.body.classList.add('round-border');
                localStorage.setItem('border', 'round-border');
                showToast('Border Style', 'Rounded corners activated', 'info');
            }
        }

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Press Ctrl+N for new message | Ctrl+F for search', 'info');
            }
            
            if ((e.ctrlKey || e.metaKey) && e.key === 'n') {
                e.preventDefault();
                openNewMessageModal();
            }
            
            if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
                e.preventDefault();
                document.getElementById('searchInput').focus();
            }
        });
    </script>
</body>
</html>