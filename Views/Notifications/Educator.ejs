<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Educator - Notifications</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ===== THEME VARIABLES ===== */
        :root {
            --primary: #075e54;
            --primary-dark: #054c44;
            --primary-light: #128c7e;
            --success: #25d366;
            --warning: #f59e0b;
            --danger: #f44336;
            --info: #3b82f6;
            
            /* Light Mode - WhatsApp Inspired */
            --bg-body: #e5e5e5;
            --bg-white: #ffffff;
            --bg-offwhite: #f0f2f5;
            --bg-card: #ffffff;
            --bg-hover: #f5f5f5;
            --text: #1e293b;
            --text-light: #334155;
            --text-muted: #64748b;
            --dark: #0f172a;
            --border: #e2e8f0;
            --shadow: 0 2px 5px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.1);
            
            /* Status Colors */
            --unread-bg: #dcf8c6;
            --unread-border: #25d366;
            --sent-bg: #fff3e0;
            --sent-border: #ff9800;
            --superadmin-bg: #f3e5f5;
            --superadmin-border: #9c27b0;
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
        }

        /* Dark Mode - WhatsApp Dark Theme */
        body.dark {
            --primary: #00a884;
            --primary-dark: #008f72;
            --primary-light: #00b98f;
            
            --bg-body: #111b21;
            --bg-white: #1f2c33;
            --bg-offwhite: #2a3942;
            --bg-card: #1f2c33;
            --bg-hover: #2a3942;
            --text: #e9edef;
            --text-light: #d1d7db;
            --text-muted: #8696a0;
            --dark: #f0f2f5;
            --border: #2a3942;
            --shadow: 0 2px 5px rgba(0,0,0,0.3);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.5);
            
            --unread-bg: #1f2c33;
            --unread-border: #00a884;
            --sent-bg: #1f2c33;
            --sent-border: #ff9800;
            --superadmin-bg: #1f2c33;
            --superadmin-border: #9c27b0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar-wrapper,
        body.round-border .mid-content,
        body.round-border .notification-item,
        body.round-border .stat-card,
        body.round-border .filter-btn,
        body.round-border .search-box input,
        body.round-border .modal-content,
        body.round-border .message-bubble,
        body.round-border .action-btn,
        body.round-border .avatar {
            border-radius: 12px !important;
        }

        body.round-border .avatar {
            border-radius: 50% !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar-wrapper,
        body.no-radius .mid-content,
        body.no-radius .notification-item,
        body.no-radius .stat-card,
        body.no-radius .filter-btn,
        body.no-radius .search-box input,
        body.no-radius .modal-content,
        body.no-radius .message-bubble,
        body.no-radius .action-btn,
        body.no-radius .avatar {
            border-radius: 0 !important;
        }

        /* Header Styles */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
        }

        .sidebar-wrapper {
            width: 280px;
            flex-shrink: 0;
            position: fixed;
            left: 0;
            top: 70px;
            bottom: 0;
            z-index: 1020;
            transition: width 0.3s ease;
            background: var(--bg-white);
            border-right: 1px solid var(--border);
        }

        .sidebar-wrapper.collapsed {
            width: 80px;
        }

        .content-wrapper {
            flex: 1;
            margin-left: 280px;
            padding: 20px;
            transition: margin-left 0.3s ease;
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
        }

        .sidebar-wrapper.collapsed + .content-wrapper {
            margin-left: 80px;
        }

        .mid-content {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 24px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
        }

        @media (max-width: 768px) {
            .sidebar-wrapper {
                transform: translateX(-100%);
                width: 280px !important;
            }
            
            .sidebar-wrapper.mobile-open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
            }
            
            .mid-content {
                padding: 16px;
            }
        }

        /* Header Actions */
        .header-actions {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .theme-toggle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-offwhite);
            color: var(--text);
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.3s;
        }

        .theme-toggle:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .border-toggle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-offwhite);
            color: var(--text);
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.3s;
        }

        .border-toggle:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 5px 15px;
            background: var(--bg-offwhite);
            border-radius: 30px;
            border: 1px solid var(--border);
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 16px;
        }

        .user-info {
            display: flex;
            flex-direction: column;
        }

        .user-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
        }

        .user-role {
            font-size: 11px;
            color: var(--text-muted);
        }

        /* Stats Cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 25px;
        }

        .stat-card {
            background: var(--bg-white);
            padding: 20px;
            border-radius: 12px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 15px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary);
        }

        .stat-card.active {
            border: 2px solid var(--primary);
            background: var(--bg-offwhite);
        }

        .stat-icon {
            width: 55px;
            height: 55px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
        }

        .stat-icon.all { background: var(--primary); }
        .stat-icon.unread { background: var(--danger); }
        .stat-icon.superadmin { background: #9c27b0; }
        .stat-icon.sent { background: #ff9800; }

        .stat-info small {
            font-size: 12px;
            color: var(--text-muted);
            display: block;
            margin-bottom: 5px;
        }

        .stat-info h3 {
            font-size: 24px;
            font-weight: 700;
            color: var(--text);
            margin: 0;
        }

        /* Filters Bar */
        .filters-bar {
            background: var(--bg-white);
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 25px;
            border: 1px solid var(--border);
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            align-items: center;
        }

        .filter-group {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .filter-btn {
            padding: 8px 16px;
            border: 1px solid var(--border);
            background: var(--bg-white);
            color: var(--text);
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .filter-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .filter-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .search-box {
            flex: 1;
            position: relative;
            min-width: 250px;
        }

        .search-box i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 14px;
        }

        .search-box input {
            width: 100%;
            padding: 10px 16px 10px 40px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 14px;
            background: var(--bg-offwhite);
            color: var(--text);
            transition: all 0.3s;
        }

        .search-box input:focus {
            outline: none;
            border-color: var(--primary);
            background: var(--bg-white);
            box-shadow: 0 0 0 3px rgba(7, 94, 84, 0.1);
        }

        .btn-primary {
            padding: 10px 20px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.3s;
            white-space: nowrap;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(7, 94, 84, 0.3);
        }

        .btn-outline {
            padding: 10px 20px;
            background: transparent;
            color: var(--text);
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--bg-offwhite);
        }

        /* Notifications Container */
        .notifications-container {
            background: var(--bg-white);
            border-radius: 12px;
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .notification-item {
            padding: 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            gap: 15px;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .notification-item:hover {
            background: var(--bg-hover);
        }

        .notification-item.unread {
            background: var(--unread-bg);
            border-left: 4px solid var(--unread-border);
        }

        .notification-item.sent {
            background: var(--sent-bg);
            border-left: 4px solid var(--sent-border);
        }

        .notification-avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 20px;
            flex-shrink: 0;
        }

        .avatar.superadmin { background: #9c27b0; }
        .avatar.sent { background: #ff9800; }

        .notification-content {
            flex: 1;
        }

        .notification-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 5px;
        }

        .sender-info {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .sender-name {
            font-weight: 600;
            color: var(--text);
            font-size: 15px;
        }

        .role-badge {
            font-size: 10px;
            padding: 3px 8px;
            border-radius: 12px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .role-badge.superadmin {
            background: rgba(156, 39, 176, 0.1);
            color: #9c27b0;
            border: 1px solid rgba(156, 39, 176, 0.2);
        }

        .role-badge.sent {
            background: rgba(255, 152, 0, 0.1);
            color: #ff9800;
            border: 1px solid rgba(255, 152, 0, 0.2);
        }

        .time {
            color: var(--text-muted);
            font-size: 11px;
        }

        .message-text {
            color: var(--text);
            font-size: 14px;
            margin-bottom: 10px;
            line-height: 1.5;
        }

        .reply-indicator {
            background: var(--bg-offwhite);
            padding: 12px;
            border-radius: 8px;
            margin-top: 8px;
            font-size: 13px;
            border-left: 3px solid var(--primary);
            color: var(--text-light);
        }

        .reply-indicator i {
            color: var(--primary);
            margin-right: 8px;
        }

        .notification-meta {
            display: flex;
            gap: 20px;
            color: var(--text-muted);
            font-size: 12px;
            margin-bottom: 12px;
        }

        .notification-meta i {
            margin-right: 5px;
            color: var(--primary);
        }

        .notification-actions {
            display: flex;
            gap: 8px;
        }

        .action-btn {
            padding: 6px 12px;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .action-btn.reply {
            background: var(--primary);
            color: white;
        }

        .action-btn.reply:hover {
            background: var(--primary-dark);
        }

        .action-btn.mark-read {
            background: var(--bg-offwhite);
            color: var(--text);
            border: 1px solid var(--border);
        }

        .action-btn.mark-read:hover {
            background: var(--info);
            color: white;
            border-color: var(--info);
        }

        .action-btn.delete {
            background: var(--bg-offwhite);
            color: var(--danger);
            border: 1px solid var(--border);
        }

        .action-btn.delete:hover {
            background: var(--danger);
            color: white;
            border-color: var(--danger);
        }

        .action-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Modal Styles */
        .modal-content {
            background: var(--bg-white);
            border: 1px solid var(--border);
            border-radius: 16px;
        }

        .modal-header {
            border-bottom: 1px solid var(--border);
            padding: 20px;
        }

        .modal-title {
            color: var(--text);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-body {
            padding: 20px;
        }

        .modal-footer {
            border-top: 1px solid var(--border);
            padding: 20px;
        }

        .btn-close {
            filter: invert(var(--close-btn-invert));
        }

        body.dark .btn-close {
            filter: invert(1);
        }

        /* Conversation Thread */
        .conversation-thread {
            max-height: 300px;
            overflow-y: auto;
            padding: 15px;
            background: var(--bg-offwhite);
            border-radius: 12px;
            margin-bottom: 15px;
        }

        .message-bubble {
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 15px;
            max-width: 80%;
            position: relative;
        }

        .message-bubble.incoming {
            background: var(--bg-white);
            border: 1px solid var(--border);
            margin-right: auto;
        }

        .message-bubble.outgoing {
            background: var(--primary);
            color: white;
            margin-left: auto;
        }

        .message-sender {
            font-size: 11px;
            font-weight: 600;
            margin-bottom: 5px;
            opacity: 0.8;
        }

        .message-time {
            font-size: 9px;
            margin-top: 5px;
            opacity: 0.7;
            text-align: right;
        }

        textarea {
            width: 100%;
            padding: 15px;
            border: 1px solid var(--border);
            border-radius: 12px;
            background: var(--bg-offwhite);
            color: var(--text);
            font-size: 14px;
            resize: vertical;
            min-height: 100px;
            margin: 15px 0;
        }

        textarea:focus {
            outline: none;
            border-color: var(--primary);
            background: var(--bg-white);
        }

        /* Toast Notification */
        .toast-notification {
            position: fixed;
            top: 90px;
            right: 20px;
            min-width: 300px;
            max-width: 400px;
            padding: 15px 20px;
            border-radius: 12px;
            background: var(--bg-white);
            border-left: 4px solid;
            box-shadow: var(--shadow-lg);
            z-index: 9999;
            transform: translateX(400px);
            transition: transform 0.3s ease;
            border: 1px solid var(--border);
        }

        .toast-notification.show {
            transform: translateX(0);
        }

        .toast-notification.success { border-left-color: var(--success); }
        .toast-notification.error { border-left-color: var(--danger); }
        .toast-notification.info { border-left-color: var(--info); }
        .toast-notification.warning { border-left-color: var(--warning); }

        .toast-content {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .toast-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .toast-icon.success { color: var(--success); }
        .toast-icon.error { color: var(--danger); }
        .toast-icon.info { color: var(--info); }
        .toast-icon.warning { color: var(--warning); }

        .toast-text {
            flex: 1;
        }

        .toast-title {
            font-weight: 600;
            color: var(--text);
            margin-bottom: 5px;
            font-size: 14px;
        }

        .toast-message {
            color: var(--text-muted);
            font-size: 12px;
        }

        .toast-progress {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: rgba(255,255,255,0.3);
            animation: progress 3s linear forwards;
        }

        @keyframes progress {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-muted);
        }

        .empty-state i {
            font-size: 60px;
            margin-bottom: 20px;
            color: var(--border);
        }

        .empty-state h3 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 10px;
            color: var(--text);
        }

        .empty-state p {
            max-width: 400px;
            margin: 0 auto;
        }

        /* Loading Spinner */
        .loading-spinner {
            text-align: center;
            padding: 40px;
            color: var(--text-muted);
        }

        .loading-spinner i {
            font-size: 30px;
            margin-bottom: 15px;
            color: var(--primary);
        }

        /* Quick Actions */
        .quick-actions {
            margin-bottom: 20px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .filters-bar {
                flex-direction: column;
            }

            .filter-group {
                width: 100%;
                justify-content: center;
            }

            .search-box {
                width: 100%;
            }

            .btn-primary {
                width: 100%;
                justify-content: center;
            }

            .notification-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 5px;
            }

            .notification-actions {
                flex-wrap: wrap;
            }

            .action-btn {
                flex: 1;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
        })();
    </script>

    <!-- Toast Notification -->
    <div class="toast-notification" id="toastNotification">
        <div class="toast-content">
            <div class="toast-icon" id="toastIcon">
                <i class="fas fa-info-circle"></i>
            </div>
            <div class="toast-text">
                <div class="toast-title" id="toastTitle">Notification</div>
                <div class="toast-message" id="toastMessage">Message here</div>
            </div>
        </div>
        <div class="toast-progress" id="toastProgress"></div>
    </div>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <div class="sidebar-wrapper" id="sidebarWrapper">
            <%- include('../../partials/ram/sidebaar') %>
        </div>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <div class="mid-content">
                <!-- Page Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="mb-0">
                        <i class="fas fa-bell me-2" style="color: var(--primary);"></i>
                        Educator Notifications
                    </h4>
                    <div class="quick-actions">
                        <button class="btn-primary" onclick="openNewMessageModal()">
                            <i class="fas fa-plus"></i> Message to Superadmin
                        </button>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="stats-grid">
                    <div class="stat-card active" onclick="setFilter('all')">
                        <div class="stat-icon all">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="stat-info">
                            <small>Total Messages</small>
                            <h3 id="totalCount">0</h3>
                        </div>
                    </div>
                    <div class="stat-card" onclick="setFilter('unread')">
                        <div class="stat-icon unread">
                            <i class="fas fa-envelope-open"></i>
                        </div>
                        <div class="stat-info">
                            <small>Unread</small>
                            <h3 id="unreadCount">0</h3>
                        </div>
                    </div>
                    <div class="stat-card" onclick="setFilter('superadmin')">
                        <div class="stat-icon superadmin">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <div class="stat-info">
                            <small>From Superadmin</small>
                            <h3 id="superadminCount">0</h3>
                        </div>
                    </div>
                    <div class="stat-card" onclick="setFilter('sent')">
                        <div class="stat-icon sent">
                            <i class="fas fa-paper-plane"></i>
                        </div>
                        <div class="stat-info">
                            <small>Sent</small>
                            <h3 id="sentCount">0</h3>
                        </div>
                    </div>
                </div>

                <!-- Filters Bar -->
                <div class="filters-bar">
                    <div class="filter-group">
                        <button class="filter-btn active" onclick="setFilter('all')">All</button>
                        <button class="filter-btn" onclick="setFilter('unread')">Unread</button>
                        <button class="filter-btn" onclick="setFilter('superadmin')">From Superadmin</button>
                        <button class="filter-btn" onclick="setFilter('sent')">Sent</button>
                    </div>
                    
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="searchInput" placeholder="Search notifications..." onkeyup="handleSearch()">
                    </div>

                    <button class="btn-outline" onclick="markAllAsRead()">
                        <i class="fas fa-check-double"></i> Mark All Read
                    </button>
                </div>

                <!-- Notifications List -->
                <div class="notifications-container" id="notificationsList">
                    <div class="loading-spinner" id="loadingSpinner">
                        <i class="fas fa-spinner fa-spin"></i>
                        <p>Loading notifications...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Reply Modal -->
    <div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-reply me-2" style="color: var(--primary);"></i>
                        Reply to Superadmin
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="conversation-thread" id="conversationThread"></div>
                    <textarea id="replyMessage" placeholder="Type your reply here..." rows="4"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-outline" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="button" class="btn-primary" onclick="sendReply()">
                        <i class="fas fa-paper-plane me-1"></i> Send Reply
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- New Message Modal -->
    <div class="modal fade" id="newMessageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-plus-circle me-2" style="color: var(--primary);"></i>
                        New Message to Superadmin
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <textarea id="newMessage" placeholder="Type your message to superadmin..." rows="5"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-outline" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i> Cancel
                    </button>
                    <button type="button" class="btn-primary" onclick="sendNewMessage()">
                        <i class="fas fa-paper-plane me-1"></i> Send Message
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Global Variables
        let notifications = [];
        let currentFilter = 'all';
        let selectedId = null;
        let replyModal, newMessageModal;

        // ======================
        // INITIALIZATION
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Bootstrap modals
            replyModal = new bootstrap.Modal(document.getElementById('replyModal'));
            newMessageModal = new bootstrap.Modal(document.getElementById('newMessageModal'));
            
            // Load notifications
            fetchNotifications();
            
            // Auto refresh every 10 seconds
            setInterval(fetchNotifications, 10000);
            
            // Sidebar sync
            const sidebar = document.getElementById('mainSidebar');
            const sidebarWrapper = document.getElementById('sidebarWrapper');
            
            if (sidebar && sidebarWrapper) {
                if (sidebar.classList.contains('collapsed')) {
                    sidebarWrapper.classList.add('collapsed');
                }
                
                window.toggleCollapse = function() {
                    if (sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        sidebarWrapper.classList.remove('collapsed');
                    } else {
                        sidebar.classList.add('collapsed');
                        sidebarWrapper.classList.add('collapsed');
                    }
                };
                
                window.toggleMobileSidebar = function() {
                    if (sidebar.classList.contains('open')) {
                        sidebar.classList.remove('open');
                        sidebarWrapper.classList.remove('mobile-open');
                    } else {
                        sidebar.classList.add('open');
                        sidebarWrapper.classList.add('mobile-open');
                    }
                };
                
                window.closeMobileSidebar = function() {
                    sidebar.classList.remove('open');
                    sidebarWrapper.classList.remove('mobile-open');
                };
            }
        });

        // ======================
        // THEME FUNCTIONS
        // ======================
        function toggleTheme() {
            if (document.body.classList.contains('dark')) {
                document.body.classList.remove('dark');
                document.body.classList.add('light');
                localStorage.setItem('theme', 'light');
                showToast('Theme Updated', 'Light mode activated', 'info');
            } else {
                document.body.classList.remove('light');
                document.body.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                showToast('Theme Updated', 'Dark mode activated', 'info');
            }
        }

        function toggleBorder() {
            if (document.body.classList.contains('round-border')) {
                document.body.classList.remove('round-border');
                document.body.classList.add('no-radius');
                localStorage.setItem('border', 'no-radius');
                showToast('Border Style', 'Square corners activated', 'info');
            } else {
                document.body.classList.remove('no-radius');
                document.body.classList.add('round-border');
                localStorage.setItem('border', 'round-border');
                showToast('Border Style', 'Rounded corners activated', 'info');
            }
        }

        // ======================
        // TOAST FUNCTION
        // ======================
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toastNotification');
            const icon = document.getElementById('toastIcon');
            const toastTitle = document.getElementById('toastTitle');
            const toastMessage = document.getElementById('toastMessage');
            
            // Clear any existing timeout
            if (window.toastTimeout) {
                clearTimeout(window.toastTimeout);
            }
            
            // Set icon based on type
            icon.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : type === 'warning' ? 'exclamation-triangle' : 'info-circle'}"></i>`;
            
            // Set colors
            toast.className = 'toast-notification show ' + type;
            toastTitle.textContent = title;
            toastMessage.textContent = message;
            
            // Auto hide after 3 seconds
            window.toastTimeout = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // NOTIFICATION FUNCTIONS
        // ======================
        async function fetchNotifications() {
            try {
                const search = document.getElementById('searchInput').value;
                const res = await fetch(`/api/educator/notifications?filter=${currentFilter}&search=${search}`);
                const data = await res.json();
                
                if (data.success) {
                    notifications = data.notifications;
                    
                    // Update stats
                    document.getElementById('totalCount').innerText = data.stats.total || 0;
                    document.getElementById('unreadCount').innerText = data.stats.unread || 0;
                    document.getElementById('superadminCount').innerText = data.stats.superadmin || 0;
                    document.getElementById('sentCount').innerText = data.stats.sent || 0;
                    
                    renderList();
                }
            } catch (error) {
                console.error('Error fetching notifications:', error);
                showToast('Error', 'Failed to load notifications', 'error');
            }
        }

        function renderList() {
            const container = document.getElementById('notificationsList');
            const spinner = document.getElementById('loadingSpinner');
            
            if (!notifications.length) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-bell-slash"></i>
                        <h3>No notifications</h3>
                        <p>You don't have any notifications yet. New messages will appear here.</p>
                        <button class="btn-primary mt-3" onclick="openNewMessageModal()">
                            <i class="fas fa-plus"></i> Send First Message
                        </button>
                    </div>
                `;
                return;
            }

            let html = '';
            
            notifications.forEach(n => {
                if (n.type === 'sent') {
                    html += `
                        <div class="notification-item sent">
                            <div class="notification-avatar avatar sent">
                                <i class="fas fa-user"></i>
                            </div>
                            <div class="notification-content">
                                <div class="notification-header">
                                    <div class="sender-info">
                                        <span class="sender-name">You</span>
                                        <span class="role-badge sent">Sent</span>
                                    </div>
                                    <span class="time">${formatTime(n.createdAt)}</span>
                                </div>
                                <div class="message-text">${n.message}</div>
                                <div class="notification-actions">
                                    <button class="action-btn delete" onclick="deleteNotif('${n._id}')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                } else {
                    html += `
                        <div class="notification-item ${n.isRead ? '' : 'unread'}" onclick="openNotif('${n._id}')">
                            <div class="notification-avatar avatar superadmin">
                                ${n.senderName?.charAt(0) || 'S'}
                            </div>
                            <div class="notification-content">
                                <div class="notification-header">
                                    <div class="sender-info">
                                        <span class="sender-name">${n.senderName || 'Superadmin'}</span>
                                        <span class="role-badge superadmin">Superadmin</span>
                                    </div>
                                    <span class="time">${formatTime(n.createdAt)}</span>
                                </div>
                                <div class="message-text">${n.message}</div>
                                ${n.reply ? `
                                    <div class="reply-indicator">
                                        <i class="fas fa-reply"></i> 
                                        You replied: ${n.reply.message}
                                    </div>
                                ` : ''}
                                <div class="notification-meta">
                                    <span><i class="fas fa-phone-alt"></i> ${n.senderPhone || 'N/A'}</span>
                                </div>
                                <div class="notification-actions" onclick="event.stopPropagation()">
                                    <button class="action-btn reply" onclick="openReply('${n._id}')" ${n.reply ? 'disabled' : ''}>
                                        <i class="fas fa-reply"></i> ${n.reply ? 'Replied' : 'Reply'}
                                    </button>
                                    ${!n.isRead ? `
                                        <button class="action-btn mark-read" onclick="markRead('${n._id}')">
                                            <i class="fas fa-check"></i> Mark Read
                                        </button>
                                    ` : ''}
                                    <button class="action-btn delete" onclick="deleteNotif('${n._id}')">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                }
            });
            
            container.innerHTML = html;
            spinner.style.display = 'none';
        }

        function formatTime(timestamp) {
            const date = new Date(timestamp);
            const now = new Date();
            const diff = now - date;
            
            // Today
            if (diff < 24 * 60 * 60 * 1000) {
                return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            }
            // This week
            if (diff < 7 * 24 * 60 * 60 * 1000) {
                return date.toLocaleDateString([], { weekday: 'short' });
            }
            // Older
            return date.toLocaleDateString([], { month: 'short', day: 'numeric' });
        }

        // ======================
        // FILTER FUNCTIONS
        // ======================
        function setFilter(filter) {
            currentFilter = filter;
            
            // Update active state
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            
            // Update stat cards
            document.querySelectorAll('.stat-card').forEach((card, index) => {
                card.classList.remove('active');
            });
            
            // Find and activate corresponding stat card
            const statCards = document.querySelectorAll('.stat-card');
            if (filter === 'all') statCards[0].classList.add('active');
            else if (filter === 'unread') statCards[1].classList.add('active');
            else if (filter === 'superadmin') statCards[2].classList.add('active');
            else if (filter === 'sent') statCards[3].classList.add('active');
            
            fetchNotifications();
            showToast('Filter Applied', `Showing ${filter} notifications`, 'info');
        }

        function handleSearch() {
            clearTimeout(window.searchTimeout);
            window.searchTimeout = setTimeout(fetchNotifications, 500);
        }

        // ======================
        // MODAL FUNCTIONS
        // ======================
        function openNewMessageModal() {
            document.getElementById('newMessage').value = '';
            newMessageModal.show();
        }

        function openReply(id) {
            selectedId = id;
            const n = notifications.find(x => x._id === id);
            
            let threadHtml = `
                <div class="message-bubble incoming">
                    <div class="message-sender">${n.senderName} (Superadmin)</div>
                    <div>${n.message}</div>
                    <div class="message-time">${new Date(n.createdAt).toLocaleString()}</div>
                </div>
            `;
            
            if (n.reply) {
                threadHtml += `
                    <div class="message-bubble outgoing">
                        <div class="message-sender">You (Educator)</div>
                        <div>${n.reply.message}</div>
                        <div class="message-time">${new Date(n.reply.repliedAt).toLocaleString()}</div>
                    </div>
                `;
            }
            
            document.getElementById('conversationThread').innerHTML = threadHtml;
            document.getElementById('replyMessage').value = '';
            
            replyModal.show();
        }

        function openNotif(id) {
            const n = notifications.find(x => x._id === id);
            if (!n.isRead) markRead(id);
            openReply(id);
        }

        // ======================
        // API FUNCTIONS
        // ======================
        async function sendNewMessage() {
            const msg = document.getElementById('newMessage').value.trim();
            if (!msg) {
                showToast('Error', 'Please enter a message', 'error');
                return;
            }
            
            try {
                const res = await fetch('/api/educator/notifications/new', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg })
                });
                
                const data = await res.json();
                
                if (data.success) {
                    showToast('Success', 'Message sent successfully!', 'success');
                    newMessageModal.hide();
                    fetchNotifications();
                } else {
                    showToast('Error', data.error || 'Failed to send message', 'error');
                }
            } catch (error) {
                console.error('Error sending message:', error);
                showToast('Error', 'Failed to send message', 'error');
            }
        }

        async function sendReply() {
            const msg = document.getElementById('replyMessage').value.trim();
            if (!msg || !selectedId) {
                showToast('Error', 'Please enter a reply', 'error');
                return;
            }
            
            try {
                const res = await fetch('/api/educator/notifications/reply', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ notificationId: selectedId, message: msg })
                });
                
                const data = await res.json();
                
                if (data.success) {
                    showToast('Success', 'Reply sent successfully!', 'success');
                    replyModal.hide();
                    fetchNotifications();
                } else {
                    showToast('Error', data.error || 'Failed to send reply', 'error');
                }
            } catch (error) {
                console.error('Error sending reply:', error);
                showToast('Error', 'Failed to send reply', 'error');
            }
        }

        async function markRead(id) {
            try {
                await fetch(`/api/educator/notifications/${id}/read`, { method: 'PUT' });
                showToast('Success', 'Marked as read', 'success');
                fetchNotifications();
            } catch (error) {
                console.error('Error marking as read:', error);
                showToast('Error', 'Failed to mark as read', 'error');
            }
        }

        async function markAllAsRead() {
            if (!confirm('Mark all notifications as read?')) return;
            
            try {
                await fetch('/api/educator/notifications/read-all', { method: 'PUT' });
                showToast('Success', 'All notifications marked as read', 'success');
                fetchNotifications();
            } catch (error) {
                console.error('Error marking all as read:', error);
                showToast('Error', 'Failed to mark all as read', 'error');
            }
        }

        async function deleteNotif(id) {
            if (!confirm('Are you sure you want to delete this notification?')) return;
            
            try {
                await fetch(`/api/educator/notifications/${id}`, { method: 'DELETE' });
                notifications = notifications.filter(n => n._id !== id);
                renderList();
                showToast('Success', 'Notification deleted', 'success');
            } catch (error) {
                console.error('Error deleting notification:', error);
                showToast('Error', 'Failed to delete notification', 'error');
            }
        }

        // ======================
        // SIDEBAR FUNCTIONS
        // ======================
        window.toggleCollapse = function() {
            const sidebar = document.getElementById('sidebarWrapper');
            sidebar.classList.toggle('collapsed');
        };

        window.toggleMobileSidebar = function() {
            const sidebar = document.getElementById('sidebarWrapper');
            sidebar.classList.toggle('mobile-open');
        };

        window.closeMobileSidebar = function() {
            const sidebar = document.getElementById('sidebarWrapper');
            sidebar.classList.remove('mobile-open');
        };
    </script>
</body>
</html>