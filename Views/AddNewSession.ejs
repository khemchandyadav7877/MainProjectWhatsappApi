<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Session - SSPAR Cloud</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* ===== THEME VARIABLES ===== */
        :root {
            --primary: #f59e0b;
            --primary-dark: #d97706;
            --primary-light: #fbbf24;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            
            /* Light Mode */
            --bg-body: #f3f4f6;
            --bg-white: #ffffff;
            --bg-offwhite: #f8fafc;
            --bg-card: #ffffff;
            --text: #1f2937;
            --text-light: #4b5563;
            --text-muted: #6b7280;
            --dark: #111827;
            --border: #e5e7eb;
            --shadow: 0 2px 10px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.1);
            
            /* Layout */
            --header-height: 70px;
            --sidebar-width: 280px;
        }

        /* Dark Mode */
        body.dark {
            --bg-body: #111827;
            --bg-white: #1f2937;
            --bg-offwhite: #374151;
            --bg-card: #1f2937;
            --text: #f9fafb;
            --text-light: #e5e7eb;
            --text-muted: #9ca3af;
            --dark: #f9fafb;
            --border: #374151;
            --shadow: 0 2px 10px rgba(0,0,0,0.3);
            --shadow-lg: 0 10px 25px rgba(0,0,0,0.5);
        }

        /* RESET */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            overflow-x: hidden;
            background: var(--bg-body);
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            color: var(--text);
            transition: background-color 0.3s, color 0.3s;
        }

        /* ===== BORDER MODES ===== */
        body.round-border .header-wrapper,
        body.round-border .sidebar-wrapper,
        body.round-border .main-content-card,
        body.round-border .info-card,
        body.round-border .btn,
        body.round-border .form-control,
        body.round-border .preview-card,
        body.round-border .toast-notification {
            border-radius: 16px !important;
        }

        body.round-border .icon-circle {
            border-radius: 50% !important;
        }

        body.no-radius .header-wrapper,
        body.no-radius .sidebar-wrapper,
        body.no-radius .main-content-card,
        body.no-radius .info-card,
        body.no-radius .btn,
        body.no-radius .form-control,
        body.no-radius .preview-card,
        body.no-radius .toast-notification,
        body.no-radius .icon-circle {
            border-radius: 0 !important;
        }

        /* HEADER FIXED */
        .header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
            background: var(--bg-white);
            box-shadow: var(--shadow);
            border-bottom: 1px solid var(--border);
        }

        /* MAIN LAYOUT */
        .main-wrapper {
            margin-top: 70px;
            display: flex;
            width: 100%;
            min-height: calc(100vh - 70px);
        }

        /* SIDEBAR WRAPPER */
        .sidebar-wrapper {
            width: 280px;
            flex-shrink: 0;
            position: fixed;
            left: 0;
            top: 70px;
            bottom: 0;
            z-index: 1020;
            transition: width 0.3s ease;
            background: var(--bg-white);
            border-right: 1px solid var(--border);
        }

        .sidebar-wrapper.collapsed {
            width: 80px;
        }

        /* CONTENT WRAPPER */
        .content-wrapper {
            flex: 1;
            margin-left: 280px;
            padding: 25px;
            transition: margin-left 0.3s ease;
            background: var(--bg-body);
            min-height: calc(100vh - 70px);
        }

        .sidebar-wrapper.collapsed + .content-wrapper {
            margin-left: 80px;
        }

        /* PAGE HEADER */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .page-title {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .page-icon {
            width: 50px;
            height: 50px;
            background: var(--primary);
            color: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .page-title h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--dark);
            margin: 0;
        }

        .page-title p {
            color: var(--text-muted);
            margin: 5px 0 0;
            font-size: 14px;
        }

        /* MAIN CONTENT CARD */
        .main-content-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 30px;
            box-shadow: var(--shadow);
            max-width: 800px;
            margin: 0 auto;
        }

        /* FORM HEADER */
        .form-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .icon-circle {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            margin: 0 auto 15px;
            box-shadow: 0 10px 20px rgba(245, 158, 11, 0.3);
        }

        .form-header h3 {
            font-size: 24px;
            font-weight: 700;
            color: var(--dark);
            margin: 0 0 5px;
        }

        .form-header p {
            color: var(--text-muted);
            font-size: 14px;
            max-width: 400px;
            margin: 0 auto;
        }

        /* INFO CARD */
        .info-card {
            background: rgba(245, 158, 11, 0.1);
            border: 1px solid rgba(245, 158, 11, 0.3);
            border-radius: 12px;
            padding: 15px 20px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .info-card i {
            color: var(--primary);
            font-size: 20px;
        }

        .info-card p {
            color: var(--text);
            margin: 0;
            font-size: 14px;
        }

        .info-card strong {
            color: var(--primary);
        }

        /* FORM GROUP */
        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: var(--dark);
            margin-bottom: 8px;
            font-size: 14px;
        }

        .form-label i {
            color: var(--primary);
            margin-right: 8px;
        }

        .required-star {
            color: var(--danger);
            margin-left: 4px;
            font-size: 12px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary);
            font-size: 16px;
            z-index: 2;
        }

        .form-control {
            width: 100%;
            padding: 12px 15px 12px 45px;
            border: 2px solid var(--border);
            border-radius: 12px;
            background: var(--bg-white);
            color: var(--text);
            font-size: 15px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
        }

        .form-control::placeholder {
            color: var(--text-muted);
            opacity: 0.6;
        }

        /* VALIDATION ICON */
        .validation-icon {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 16px;
        }

        .validation-icon.valid {
            color: var(--success);
        }

        .validation-icon.invalid {
            color: var(--danger);
        }

        /* HINT TEXT */
        .hint-text {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-top: 6px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .hint-text i {
            color: var(--primary);
            font-size: 12px;
        }

        /* PREVIEW CARD */
        .preview-card {
            background: var(--bg-offwhite);
            border: 1px dashed var(--border);
            border-radius: 12px;
            padding: 20px;
            margin-top: 20px;
        }

        .preview-title {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .preview-title i {
            color: var(--primary);
        }

        .preview-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 15px;
        }

        .preview-session {
            background: var(--bg-card);
            padding: 10px 20px;
            border-radius: 30px;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .preview-session i {
            color: var(--primary);
        }

        .preview-session span {
            font-weight: 600;
            color: var(--dark);
        }

        .preview-badge {
            background: rgba(245, 158, 11, 0.1);
            color: var(--primary);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
        }

        /* BUTTONS */
        .button-group {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .btn {
            flex: 1;
            padding: 12px 20px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 15px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(245, 158, 11, 0.4);
        }

        .btn-secondary {
            background: transparent;
            color: var(--text);
            border: 2px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--bg-offwhite);
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .btn:active {
            transform: translateY(0);
        }

        /* MESSAGES */
        .message-container {
            margin-bottom: 25px;
        }

        .message {
            padding: 15px 20px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: slideDown 0.3s ease;
        }

        .message-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .message-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .message i {
            font-size: 18px;
        }

        .close-btn {
            background: none;
            border: none;
            color: currentColor;
            font-size: 18px;
            cursor: pointer;
            margin-left: auto;
            opacity: 0.7;
        }

        .close-btn:hover {
            opacity: 1;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* SESSION EXAMPLES */
        .examples {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 15px;
        }

        .example-tag {
            background: var(--bg-offwhite);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 5px 15px;
            font-size: 13px;
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.2s;
        }

        .example-tag:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        /* TOAST */
        #toast {
            position: fixed;
            top: 24px;
            right: 24px;
            width: 320px;
            padding: 14px 16px;
            border-radius: 12px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(-15px);
            transition: .3s ease;
            color: #fff;
            z-index: 9999;
        }

        #toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--info); }
        .toast-warning { background: var(--warning); color: #1f2937; }

        .toast-progress {
            height: 3px;
            border-radius: 4px;
            margin-top: 10px;
            background: rgba(255,255,255,.6);
            animation: toast-load 3s linear forwards;
        }

        @keyframes toast-load {
            from { width: 100%; }
            to { width: 0%; }
        }

        /* LOADING OVERLAY */
        .loading-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            z-index: 9999;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            color: white;
        }

        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 3px solid rgba(255,255,255,0.3);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 15px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .sidebar-wrapper {
                transform: translateX(-100%);
                width: 280px !important;
            }
            
            .sidebar-wrapper.mobile-open {
                transform: translateX(0);
            }
            
            .content-wrapper {
                margin-left: 0 !important;
                padding: 15px;
            }
            
            .main-content-card {
                padding: 20px;
            }
            
            .button-group {
                flex-direction: column;
            }
            
            .page-header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .preview-content {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>
    <!-- Theme Initialization Script -->
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            const savedBorder = localStorage.getItem('border') || 'round-border';
            document.body.classList.add(savedTheme);
            document.body.classList.add(savedBorder);
            console.log('🎨 Theme loaded:', savedTheme);
            console.log('📐 Border mode loaded:', savedBorder);
        })();
    </script>

    <!-- HEADER -->
    <div class="header-wrapper">
        <%- include('../partials/ram/header') %>
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">
        <!-- SIDEBAR -->
        <div class="sidebar-wrapper" id="sidebarWrapper">
            <%- include('../partials/ram/sidebaar') %>
        </div>

        <!-- CONTENT -->
        <div class="content-wrapper" id="contentWrapper">
            <!-- Toast Container -->
            <div id="toast"></div>

            <!-- Loading Overlay -->
            <div class="loading-overlay" id="loadingOverlay">
                <div class="loading-spinner"></div>
                <h5 id="loadingText">Processing...</h5>
                <p id="loadingSubtext">Please wait</p>
            </div>

            <!-- Page Header -->
            <div class="page-header">
                <div class="page-title">
                    <div class="page-icon">
                        <i class="fas fa-plus-circle"></i>
                    </div>
                    <div>
                        <h2>Add New Session</h2>
                        <p>Create a new academic session</p>
                    </div>
                </div>
            </div>

            <!-- Main Content Card -->
            <div class="main-content-card">
                <!-- Form Header -->
                <div class="form-header">
                    <div class="icon-circle">
                        <i class="fas fa-calendar-plus"></i>
                    </div>
                    <h3>Create New Session</h3>
                    <p>Add a new academic year session to the system</p>
                </div>

                <!-- Info Card -->
                <div class="info-card">
                    <i class="fas fa-info-circle"></i>
                    <p>Session format should be like <strong>2026-2027</strong> (4 digits - 4 digits)</p>
                </div>

                <!-- Messages -->
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="message-container">
                        <div class="message message-error">
                            <i class="fas fa-exclamation-circle"></i>
                            <span><%= error %></span>
                            <button class="close-btn" onclick="this.parentElement.remove()">&times;</button>
                        </div>
                    </div>
                <% } %>

                <% if (typeof message !== 'undefined' && message) { %>
                    <div class="message-container">
                        <div class="message message-success">
                            <i class="fas fa-check-circle"></i>
                            <span><%= message %></span>
                            <button class="close-btn" onclick="this.parentElement.remove()">&times;</button>
                        </div>
                    </div>
                <% } %>

                <!-- Form -->
                <form action="/addnewsessionyears" method="POST" id="sessionForm">
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-calendar-alt"></i>
                            Session Year
                            <span class="required-star">*</span>
                        </label>
                        <div class="input-wrapper">
                            <i class="fas fa-calendar input-icon"></i>
                            <input type="text" 
                                   id="session" 
                                   name="session" 
                                   class="form-control" 
                                   placeholder="e.g., 2026-2027" 
                                   value="<%= typeof sessionValue !== 'undefined' ? sessionValue : '' %>"
                                   required
                                   oninput="validateSession()"
                                   maxlength="9">
                            <div class="validation-icon" id="sessionValidation"></div>
                        </div>
                        <div class="hint-text">
                            <i class="fas fa-lightbulb"></i>
                            <span>Enter in format: YYYY-YYYY (e.g., 2026-2027)</span>
                        </div>
                    </div>

                    <!-- Quick Examples -->
                    <div class="form-group">
                        <label class="form-label">Quick Select</label>
                        <div class="examples">
                            <span class="example-tag" onclick="setSession('2024-2025')">2024-2025</span>
                            <span class="example-tag" onclick="setSession('2025-2026')">2025-2026</span>
                            <span class="example-tag" onclick="setSession('2026-2027')">2026-2027</span>
                            <span class="example-tag" onclick="setSession('2027-2028')">2027-2028</span>
                            <span class="example-tag" onclick="setSession('2028-2029')">2028-2029</span>
                            <span class="example-tag" onclick="setSession('2029-2030')">2029-2030</span>
                        </div>
                    </div>

                    <!-- Preview Card -->
                    <div class="preview-card" id="previewCard" style="display: none;">
                        <div class="preview-title">
                            <i class="fas fa-eye"></i>
                            Session Preview
                        </div>
                        <div class="preview-content">
                            <div class="preview-session">
                                <i class="fas fa-calendar-check"></i>
                                <span id="previewSession">2026-2027</span>
                            </div>
                            <span class="preview-badge">New Session</span>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="button-group">
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="fas fa-save"></i> Save Session
                        </button>
                        <a href="/addnewsessionyear" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ======================
        // SIDEBAR SYNC
        // ======================
        document.addEventListener('DOMContentLoaded', function() {
            const sidebar = document.getElementById('mainSidebar');
            const sidebarWrapper = document.getElementById('sidebarWrapper');
            
            if (sidebar && sidebarWrapper) {
                if (sidebar.classList.contains('collapsed')) {
                    sidebarWrapper.classList.add('collapsed');
                }
                
                window.toggleCollapse = function() {
                    if (sidebar.classList.contains('collapsed')) {
                        sidebar.classList.remove('collapsed');
                        sidebarWrapper.classList.remove('collapsed');
                    } else {
                        sidebar.classList.add('collapsed');
                        sidebarWrapper.classList.add('collapsed');
                    }
                };
                
                window.toggleMobileSidebar = function() {
                    if (sidebar.classList.contains('open')) {
                        sidebar.classList.remove('open');
                        sidebarWrapper.classList.remove('mobile-open');
                    } else {
                        sidebar.classList.add('open');
                        sidebarWrapper.classList.add('mobile-open');
                    }
                };
                
                window.closeMobileSidebar = function() {
                    sidebar.classList.remove('open');
                    sidebarWrapper.classList.remove('mobile-open');
                };
            }

            // Show welcome toast
            setTimeout(() => {
                showToast('Add New Session', 'Create a new academic session', 'info');
            }, 500);
        });

        // ======================
        // TOAST FUNCTION
        // ======================
        let toastTimer;
        function showToast(title, message, type = 'info') {
            const toast = document.getElementById('toast');
            
            clearTimeout(toastTimer);
            
            const icons = {
                'success': '✅',
                'error': '❌',
                'warning': '⚠️',
                'info': 'ℹ️'
            };
            
            const icon = icons[type] || 'ℹ️';
            
            toast.className = '';
            toast.innerHTML = `
                <div style="display: flex; gap: 12px; align-items: flex-start;">
                    <div style="width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,.25);">
                        ${icon}
                    </div>
                    <div style="flex: 1;">
                        <h4 style="margin: 0; font-size: 14px; font-weight: 600;">${title}</h4>
                        <p style="margin: 4px 0 0; font-size: 13px; opacity: .9;">${message}</p>
                    </div>
                </div>
                <div class="toast-progress"></div>
            `;
            
            toast.classList.add(`toast-${type}`, 'show');
            
            toastTimer = setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // ======================
        // LOADING OVERLAY
        // ======================
        const loadingOverlay = document.getElementById('loadingOverlay');
        const loadingText = document.getElementById('loadingText');
        const loadingSubtext = document.getElementById('loadingSubtext');

        function showLoading(text, subtext) {
            loadingText.textContent = text || 'Processing...';
            loadingSubtext.textContent = subtext || 'Please wait';
            loadingOverlay.style.display = 'flex';
        }

        function hideLoading() {
            loadingOverlay.style.display = 'none';
        }

        // ======================
        // SESSION VALIDATION
        // ======================
        const sessionInput = document.getElementById('session');
        const validationIcon = document.getElementById('sessionValidation');
        const previewCard = document.getElementById('previewCard');
        const previewSession = document.getElementById('previewSession');
        const submitBtn = document.getElementById('submitBtn');

        function validateSession() {
            let value = sessionInput.value.trim();
            
            // Auto-format: add hyphen after 4 digits
            if (value.length === 4 && !value.includes('-')) {
                value = value + '-';
                sessionInput.value = value;
            }
            
            // Remove any non-digit/hyphen characters
            value = value.replace(/[^\d-]/g, '');
            
            // Check format: XXXX-XXXX
            const regex = /^\d{4}-\d{4}$/;
            
            if (!value) {
                validationIcon.innerHTML = '';
                validationIcon.className = 'validation-icon';
                previewCard.style.display = 'none';
                return false;
            }
            
            if (regex.test(value)) {
                const [start, end] = value.split('-');
                
                // Validate years (end should be start + 1)
                if (parseInt(end) === parseInt(start) + 1) {
                    validationIcon.innerHTML = '<i class="fas fa-check-circle"></i>';
                    validationIcon.className = 'validation-icon valid';
                    
                    // Show preview
                    previewSession.textContent = value;
                    previewCard.style.display = 'block';
                    
                    return true;
                } else {
                    validationIcon.innerHTML = '<i class="fas fa-exclamation-circle"></i>';
                    validationIcon.className = 'validation-icon invalid';
                    validationIcon.title = 'End year must be start year + 1';
                    previewCard.style.display = 'none';
                    return false;
                }
            } else {
                if (value.length > 0) {
                    validationIcon.innerHTML = '<i class="fas fa-exclamation-circle"></i>';
                    validationIcon.className = 'validation-icon invalid';
                    validationIcon.title = 'Format: YYYY-YYYY';
                } else {
                    validationIcon.innerHTML = '';
                }
                previewCard.style.display = 'none';
                return false;
            }
        }

        // Set session from example tags
        function setSession(value) {
            sessionInput.value = value;
            validateSession();
            showToast('Quick Select', `Selected: ${value}`, 'info');
        }

        // Form submission
        document.getElementById('sessionForm').addEventListener('submit', function(e) {
            if (!validateSession()) {
                e.preventDefault();
                showToast('Validation Error', 'Please enter a valid session format (e.g., 2026-2027)', 'error');
                return;
            }
            
            showLoading('Creating Session', 'Please wait...');
        });

        // Auto-hide messages
        setTimeout(() => {
            document.querySelectorAll('.message-container').forEach(msg => {
                msg.style.opacity = '0';
                setTimeout(() => msg.remove(), 500);
            });
        }, 5000);

        // ======================
        // KEYBOARD SHORTCUTS
        // ======================
        document.addEventListener('keydown', function(e) {
            // Ctrl+Enter to submit
            if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
                e.preventDefault();
                if (validateSession()) {
                    document.getElementById('sessionForm').submit();
                }
            }
            
            // Escape to cancel
            if (e.key === 'Escape') {
                if (confirm('Cancel and go back?')) {
                    window.location.href = '/addnewsessionyear';
                }
            }
            
            // F1 for help
            if (e.key === 'F1') {
                e.preventDefault();
                showToast('Help', 'Format: YYYY-YYYY\nExample: 2026-2027', 'info');
            }
        });

        // ======================
        // AUTO-GENERATE NEXT SESSION
        // ======================
        function generateNextSession() {
            const currentYear = new Date().getFullYear();
            const nextYear = currentYear + 1;
            return `${currentYear}-${nextYear}`;
        }

        // If input is empty, suggest current session
        if (!sessionInput.value) {
            const suggested = generateNextSession();
            sessionInput.placeholder = `e.g., ${suggested}`;
        }
    </script>
</body>
</html>