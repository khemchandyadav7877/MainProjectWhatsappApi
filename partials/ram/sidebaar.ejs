<!-- views/partials/sidebar.ejs - USER CARD HIDE/UNHIDE ON CLICK - FIXED -->

<%
// Get user role color
const getRoleColor = (role) => {
    switch(role) {
        case 'SuperAdmin': return '#4f46e5';
        case 'Educator': return '#3b82f6';
        case 'Trainer': return '#10b981';
        case 'Student': return '#f59e0b';
        default: return '#6b7280';
    }
};

const user = locals.user || {};
const roleColor = getRoleColor(user.role);
%>

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
/* ===== SIDEBAR STYLES ===== */
:root {
    --sidebar-width: 280px;
    --sidebar-collapsed: 80px;
    --primary-color: <%= roleColor %>;
    --bg-primary: #ffffff;
    --bg-secondary: #f9fafb;
    --bg-hover: #f3f4f6;
    --text-primary: #111827;
    --text-secondary: #6b7280;
    --border-color: #e5e7eb;
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    --radius: 0.5rem;
}

.sidebar {
    width: var(--sidebar-width);
    height: 100vh;
    background: var(--bg-primary);
    border-right: 1px solid var(--border-color);
    position: fixed;
    left: 0;
    top: 0;
    display: flex;
    flex-direction: column;
    z-index: 1000;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--shadow-md);
}

.sidebar.collapsed {
    width: var(--sidebar-collapsed);
}

/* Header */
.sidebar-header {
    padding: 1.25rem 1rem;
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
}

.logo-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.logo-icon {
    font-size: 1.75rem;
    color: var(--primary-color);
}

.logo-text {
    display: flex;
    flex-direction: column;
}

.logo-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
}

.logo-subtitle {
    font-size: 0.675rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Collapse Button */
.collapse-btn {
    position: absolute;
    right: -12px;
    top: 80px;
    width: 24px;
    height: 24px;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 50%;
    color: var(--text-secondary);
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1001;
    transition: all 0.2s;
    box-shadow: var(--shadow-sm);
}

.collapse-btn:hover {
    background: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
}

/* Content */
.sidebar-content {
    flex: 1;
    padding: 1.25rem 1rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
}

/* Custom Scrollbar */
.sidebar-content::-webkit-scrollbar {
    width: 6px;
}

.sidebar-content::-webkit-scrollbar-track {
    background: transparent;
}

.sidebar-content::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 3px;
}

.sidebar-content::-webkit-scrollbar-thumb:hover {
    background: var(--text-secondary);
}

/* User Card - ENTIRE CARD WILL HIDE/SHOW */
.user-card {
    background: linear-gradient(135deg, <%= roleColor %>10, transparent);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 1rem;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
    cursor: pointer;
    position: relative;
}

.user-card:hover {
    background: linear-gradient(135deg, <%= roleColor %>15, transparent);
    border-color: <%= roleColor %>40;
}

.user-card.hidden {
    display: none;
}

/* Double arrow icon for hide/show */
.user-card-toggle {
    position: absolute;
    top: 5px;
    right: 5px;
    width: 24px;
    height: 24px;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 50%;
    color: var(--primary-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.2s;
    box-shadow: var(--shadow-sm);
}

.user-card:hover .user-card-toggle {
    opacity: 1;
}

.user-card-toggle i {
    transition: transform 0.3s;
}

.user-card-toggle.hidden i {
    transform: rotate(180deg);
}

/* When card is hidden, show a small bar to toggle back */
.user-card-minimized {
    display: none;
    background: linear-gradient(135deg, <%= roleColor %>10, transparent);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 0.5rem;
    margin-bottom: 1.5rem;
    cursor: pointer;
    text-align: center;
    color: var(--primary-color);
    font-size: 12px;
    font-weight: 500;
    transition: all 0.2s;
}

.user-card-minimized:hover {
    background: linear-gradient(135deg, <%= roleColor %>15, transparent);
    border-color: <%= roleColor %>40;
}

.user-card-minimized.show {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.user-card-minimized i {
    font-size: 14px;
}

.user-avatar-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
}

.avatar {
    position: relative;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--primary-color);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1.125rem;
    flex-shrink: 0;
}

.online-indicator {
    position: absolute;
    bottom: 2px;
    right: 2px;
    width: 10px;
    height: 10px;
    background: #10b981;
    border: 2px solid white;
    border-radius: 50%;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

.user-details {
    overflow: hidden;
}

.user-name {
    margin: 0 0 0.25rem 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.role-badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--primary-color);
    color: white;
    font-size: 0.675rem;
    font-weight: 600;
    border-radius: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.user-email {
    margin: 0.25rem 0 0 0;
    font-size: 0.675rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Stats */
.user-stats {
    display: flex;
    gap: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-color);
    margin-top: 0.25rem;
}

.stat-item {
    flex: 1;
    text-align: center;
}

.stat-value {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--primary-color);
}

.stat-label {
    display: block;
    font-size: 0.625rem;
    color: var(--text-secondary);
    text-transform: uppercase;
}

/* Navigation - THESE WILL ALWAYS BE VISIBLE */
.nav-sections {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-bottom: 1rem;
}

/* Section Title */
.section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.75rem;
    border-radius: 0.375rem;
    cursor: pointer;
    color: var(--text-secondary);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.2s;
}

.section-title:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
}

.section-title.open {
    color: var(--primary-color);
    background: <%= roleColor %>08;
}

.section-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.section-icon {
    font-size: 0.875rem;
    width: 20px;
    text-align: center;
}

.arrow-icon {
    font-size: 0.75rem;
    transition: transform 0.2s;
}

.arrow-icon.rotate {
    transform: rotate(180deg);
}

/* Section Links */
.section-links {
    padding: 0.25rem 0 0.25rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
}

/* Nav Link */
.nav-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    color: var(--text-secondary);
    font-size: 0.813rem;
    font-weight: 500;
    border-radius: 0.375rem;
    transition: all 0.2s;
    text-decoration: none;
    position: relative;
}

.nav-link:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
    transform: translateX(2px);
}

.nav-link.active {
    background: <%= roleColor %>10;
    color: var(--primary-color);
    font-weight: 600;
}

.nav-link.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 16px;
    background: var(--primary-color);
    border-radius: 0 2px 2px 0;
}

.link-icon {
    font-size: 0.875rem;
    width: 18px;
    text-align: center;
}

/* Feature Actions */
.feature-wrapper {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    position: relative;
}

.feature-actions {
    display: flex;
    gap: 0.125rem;
    opacity: 0;
    transition: opacity 0.2s;
}

.feature-wrapper:hover .feature-actions {
    opacity: 1;
}

.action-btns {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    border: 1px solid var(--border-color);
    background: white;
    color: var(--text-secondary);
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
}

.action-btns:hover {
    transform: scale(1.1);
}

.toggle-btn:hover {
    color: #10b981;
    border-color: #10b981;
}

.delete-btn:hover {
    color: #ef4444;
    border-color: #ef4444;
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 2rem 1rem;
    background: var(--bg-secondary);
    border-radius: var(--radius);
    border: 2px dashed var(--border-color);
    margin: 1rem 0;
}

.empty-icon {
    font-size: 2rem;
    color: var(--text-secondary);
    opacity: 0.5;
    margin-bottom: 0.5rem;
}

.empty-title {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
}

.empty-subtitle {
    color: var(--text-secondary);
    font-size: 0.75rem;
    opacity: 0.7;
}

/* Logout */
.logout-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    background: #fef2f2;
    border: 1px solid #fee2e2;
    border-radius: 0.375rem;
    color: #dc2626;
    font-size: 0.813rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
    margin-top: auto;
}

.logout-link:hover {
    background: #fee2e2;
    transform: translateY(-1px);
}

/* Collapsed State */
.sidebar.collapsed .logo-text,
.sidebar.collapsed .user-details,
.sidebar.collapsed .user-stats,
.sidebar.collapsed .user-card-toggle,
.sidebar.collapsed .user-card-minimized,
.sidebar.collapsed .section-title span:not(.section-icon),
.sidebar.collapsed .arrow-icon,
.sidebar.collapsed .section-links,
.sidebar.collapsed .nav-link span:not(.link-icon),
.sidebar.collapsed .logout-link span,
.sidebar.collapsed .feature-actions {
    display: none;
}

.sidebar.collapsed .section-title {
    padding: 0.625rem;
    justify-content: center;
}

.sidebar.collapsed .nav-link {
    padding: 0.625rem;
    justify-content: center;
}

.sidebar.collapsed .user-avatar-wrapper {
    justify-content: center;
}

/* Mobile */
.mobile-toggle {
    display: none;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 999;
    width: 40px;
    height: 40px;
    border-radius: 0.5rem;
    border: none;
    background: var(--primary-color);
    color: white;
    font-size: 1rem;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    align-items: center;
    justify-content: center;
}

.sidebar-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
    z-index: 998;
}

@media (max-width: 768px) {
    .mobile-toggle {
        display: flex;
    }
    
    .sidebar {
        transform: translateX(-100%);
        box-shadow: none;
    }
    
    .sidebar.open {
        transform: translateX(0);
        box-shadow: var(--shadow-md);
    }
    
    .sidebar-overlay.active {
        display: block;
    }
    
    .collapse-btn {
        display: none;
    }
}

/* Loading */
.loading-spinner {
    text-align: center;
    padding: 2rem;
}

.spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--border-color);
    border-top-color: var(--primary-color);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 0.5rem;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Toast Animations */
@keyframes slideIn {
    from { 
        transform: translateX(100%); 
        opacity: 0; 
    }
    to { 
        transform: translateX(0); 
        opacity: 1; 
    }
}

@keyframes slideOut {
    from { 
        transform: translateX(100%); 
        opacity: 1; 
    }
    to { 
        transform: translateX(0); 
        opacity: 0; 
    }
}

.toast-notification {
    position: fixed;
    top: 20px;
    right: 20px;
    background: #10b981;
    color: white;
    padding: 12px 20px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    z-index: 9999;
    animation: slideIn 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
}

.toast-error {
    background: #ef4444;
}
</style>

<!-- Mobile Toggle -->
<button class="mobile-toggle" onclick="toggleMobileSidebar()" style="background: <%= roleColor %>;">
    <i class="fas fa-bars" id="mobileIcon"></i>
</button>

<!-- Overlay -->
<div class="sidebar-overlay" onclick="closeMobileSidebar()"></div>

<!-- Main Sidebar -->
<div class="sidebar" id="mainSidebar">
    <!-- Header -->
    <div class="sidebar-header">
        <div class="logo-wrapper">
            <i class="fas fa-graduation-cap logo-icon"></i>
            <div class="logo-text">
                <span class="logo-title">WhatsApp API</span>
                <span class="logo-subtitle"><%= user.role || 'User' %> Panel</span>
            </div>
        </div>
    </div>

    <!-- Collapse Button -->
    <button class="collapse-btn" onclick="toggleCollapse()">
        <i class="fas fa-chevron-left" id="collapseIcon"></i>
    </button>

    <!-- Content -->
    <div class="sidebar-content">
        <!-- MINIMIZED USER CARD (shown when main card is hidden) -->
        <div class="user-card-minimized" id="userCardMinimized" onclick="toggleUserCard(event)">
            <i class="fas fa-user-circle"></i>
            <span>Show Profile</span>
            <i class="fas fa-chevron-down"></i>
        </div>
        
        <!-- MAIN USER CARD - Ye pura card hide/unhide hoga -->
        <div class="user-card" id="userCard" onclick="toggleUserCard(event)">
            <!-- Double arrow icon -->
            <div class="user-card-toggle" id="userCardToggle">
                <i class="fas fa-chevron-up"></i>
            </div>
            
            <div class="user-avatar-wrapper">
                <div class="avatar">
                    <%= (user.firstName || user.email || 'U').charAt(0).toUpperCase() %>
                    <span class="online-indicator"></span>
                </div>
                
                <div class="user-details">
                    <h4 class="user-name">
                        <%= user.firstName || '' %> <%= user.lastName || '' %>
                    </h4>
                    <span class="role-badge" style="background: <%= roleColor %>;">
                        <%= user.role || 'User' %>
                    </span>
                    <p class="user-email"><%= user.email || '' %></p>
                </div>
            </div>
            
            <!-- Stats - 12 FEATURES, 5 SECTIONS -->
            <div class="user-stats">
                <div class="stat-item">
                    <span class="stat-value" id="featuresCount">0</span>
                    <span class="stat-label">FEATURES</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value" id="sectionsCount">0</span>
                    <span class="stat-label">SECTIONS</span>
                </div>
            </div>
        </div>

        <!-- Navigation - YEH HAMESHA DIKHEGA, KABHI HIDE NAHI HOGA -->
        <div class="nav-sections" id="navContainer">
            <div id="featuresContainer"></div>
        </div>

        <!-- Logout -->
        <a href="/logout" class="logout-link">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </a>
    </div>
</div>

