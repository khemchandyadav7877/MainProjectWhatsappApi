// State
let features = [];
let openSections = {};
let isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
let userRole = '<%= user.role || "" %>';
let userCardVisible = true; // Initially visible

// ✅ Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    console.log('🚀 Sidebar initializing...');
    console.log('👤 User role:', userRole);
    
    // Load saved section states
    try {
        const saved = localStorage.getItem('sidebarOpenSections');
        if (saved) openSections = JSON.parse(saved);
    } catch(e) {
        console.error('Error parsing saved sections:', e);
        openSections = {};
    }
    
    // Load saved user card visibility
    try {
        const savedVisibility = localStorage.getItem('userCardVisible');
        if (savedVisibility !== null) {
            userCardVisible = savedVisibility === 'true';
            updateUserCardVisibility();
        }
    } catch(e) {}
    
    // Apply collapsed state
    if (isCollapsed) {
        document.getElementById('mainSidebar').classList.add('collapsed');
        document.getElementById('collapseIcon').className = 'fas fa-chevron-right';
    }
    
    // Load features
    loadSidebarFeatures();
    
    // Listen for updates from other tabs
    window.addEventListener('storage', function(e) {
        if (e.key === 'sidebarFeatures' || e.key === 'sidebar-update-time') {
            console.log('🔄 Update detected from another tab');
            loadSidebarFeatures(true);
        }
    });
});

// ✅ TOGGLE USER CARD VISIBILITY - FIXED: Added event.stopPropagation()
function toggleUserCard(event) {
    if (event) {
        event.stopPropagation();
    }
    userCardVisible = !userCardVisible;
    updateUserCardVisibility();
    
    // Save state
    try {
        localStorage.setItem('userCardVisible', userCardVisible);
        console.log('💾 Saved user card visibility:', userCardVisible);
    } catch(e) {}
}

// ✅ UPDATE USER CARD VISIBILITY UI
function updateUserCardVisibility() {
    const userCard = document.getElementById('userCard');
    const minimizedCard = document.getElementById('userCardMinimized');
    const toggleIcon = document.querySelector('.user-card-toggle i');
    
    if (!userCard || !minimizedCard) {
        console.error('❌ User card elements not found!');
        return;
    }
    
    if (userCardVisible) {
        userCard.classList.remove('hidden');
        minimizedCard.classList.remove('show');
        if (toggleIcon) {
            toggleIcon.className = 'fas fa-chevron-up';
        }
        console.log('👤 User card: VISIBLE');
    } else {
        userCard.classList.add('hidden');
        minimizedCard.classList.add('show');
        if (toggleIcon) {
            toggleIcon.className = 'fas fa-chevron-down';
        }
        console.log('👤 User card: HIDDEN');
    }
}

// ✅ LOAD FEATURES FROM LOCALSTORAGE
function loadSidebarFeatures(silent = false) {
    const container = document.getElementById('featuresContainer');
    
    if (!container) {
        console.error('❌ Features container not found!');
        return;
    }
    
    if (!silent) {
        container.innerHTML = `
            <div class="loading-spinner">
                <div class="spinner"></div>
                <p style="color: var(--text-secondary); font-size: 0.75rem;">Loading features...</p>
            </div>
        `;
    }
    
    try {
        const savedFeatures = localStorage.getItem('sidebarFeatures');
        
        if (!savedFeatures) {
            console.log('ℹ️ No features in localStorage');
            showEmptyState(container, 'No features available', 'Contact SuperAdmin for access');
            updateStats([]);
            return;
        }
        
        const allFeatures = JSON.parse(savedFeatures);
        console.log('✅ All features in storage:', allFeatures.length);
        
        let userFeatures = allFeatures.filter(f => {
            if (f.isActive === false) return false;
            return f.role === userRole;
        });
        
        console.log(`👤 ${userRole}: showing ${userFeatures.length} role-specific features`);
        
        if (userFeatures.length === 0) {
            showEmptyState(
                container, 
                `No features for ${userRole}`, 
                userRole === 'SuperAdmin' ? 'Add features from Admin panel' : 'Contact SuperAdmin for access',
                userRole === 'SuperAdmin' ? '/add-new-feature' : null
            );
            updateStats([]);
            return;
        }
        
        const featuresWithPaths = userFeatures.map(feature => {
            const cleanLabel = feature.label.replace(/^\d+\.\s*/, '');
            let path = feature.path || pathMappings[cleanLabel] || '#';
            
            return {
                ...feature,
                cleanLabel: cleanLabel,
                path: path
            };
        });
        
        features = featuresWithPaths;
        renderFeatures(features);
        updateStats(features);
        
    } catch (error) {
        console.error('❌ Error loading features:', error);
        showEmptyState(container, 'Failed to load features', error.message);
    }
}

// ✅ UPDATE STATS
function updateStats(featuresList) {
    const activeFeatures = featuresList.filter(f => f.isActive !== false);
    const sections = new Set(activeFeatures.map(f => f.section.replace('*** ', '')));
    
    const featuresCountEl = document.getElementById('featuresCount');
    const sectionsCountEl = document.getElementById('sectionsCount');
    
    if (featuresCountEl) featuresCountEl.textContent = activeFeatures.length;
    if (sectionsCountEl) sectionsCountEl.textContent = sections.size;
}

// ✅ RENDER FEATURES - FIXED: Proper section order
function renderFeatures(featuresList) {
    const container = document.getElementById('featuresContainer');
    
    if (!container) {
        console.error('❌ Features container not found!');
        return;
    }
    
    if (!featuresList || featuresList.length === 0) {
        showEmptyState(container, 'No features available', 'Contact SuperAdmin for access');
        return;
    }
    
    // Group features by section
    const grouped = {};
    featuresList.forEach(f => {
        const cleanSection = f.section.replace('*** ', '');
        if (!grouped[cleanSection]) grouped[cleanSection] = [];
        grouped[cleanSection].push(f);
    });
    
    // Define exact section order
    const sectionOrder = [
        'Dashboard',
        'Subscription Management',
        'Frontend Management',
        'CRM',
        'Notifications',
        'Chats',
        'Bulk Messaging',
        'RCS',
        'Campaign Management',
        'AI Chatbot',
        'Ads Management',
        'VOIP Service',
        'IVR Service',
        'Support Desk',
        'API',
        'Reports',
        'Settings',
        'Virtual Numbers',
        'Administration'
    ];
    
    // Sort sections according to defined order
    const sections = Object.keys(grouped).sort((a, b) => {
        const indexA = sectionOrder.indexOf(a);
        const indexB = sectionOrder.indexOf(b);
        
        // If both are in the order array, sort by index
        if (indexA !== -1 && indexB !== -1) {
            return indexA - indexB;
        }
        // If only one is in the array, prioritize the one in array
        if (indexA !== -1) return -1;
        if (indexB !== -1) return 1;
        // If neither is in array, sort alphabetically
        return a.localeCompare(b);
    });
    
    let html = '';
    const currentPath = window.location.pathname;
    
    sections.forEach(section => {
        const isOpen = openSections[section] ?? true;
        const sectionFeatures = grouped[section].sort((a, b) => 
            (a.order || 999) - (b.order || 999)
        );
        
        const sectionIcon = sectionIcons[section] || 'folder';
        
        html += `
            <div class="nav-section">
                <div class="section-title ${isOpen ? 'open' : ''}" 
                     onclick="toggleSection('${escapeString(section)}', event)">
                    <div class="section-left">
                        <span class="section-icon">
                            <i class="fas fa-${sectionIcon}"></i>
                        </span>
                        <span>${section}</span>
                    </div>
                    <i class="fas fa-chevron-down arrow-icon ${isOpen ? 'rotate' : ''}"></i>
                </div>
                
                ${isOpen ? `
                    <div class="section-links">
                        ${sectionFeatures.map(f => renderFeature(f, currentPath)).join('')}
                    </div>
                ` : ''}
            </div>
        `;
    });
    
    container.innerHTML = html;
}

// ✅ RENDER SINGLE FEATURE
function renderFeature(feature, currentPath) {
    const displayName = feature.cleanLabel || feature.label.replace(/^\d+\.\s*/, '');
    const isActive = currentPath === feature.path;
    const iconName = featureIcons[displayName] || 'circle';
    const hasPath = feature.path && feature.path !== '#';
    
    return `
        <div class="feature-wrapper">
            <a href="${hasPath ? feature.path : '#'}" 
               class="nav-link ${isActive ? 'active' : ''} ${!hasPath ? 'disabled' : ''}"
               ${!hasPath ? 'onclick="return false;" style="opacity:0.6; cursor:not-allowed;"' : ''}>
                <span class="link-icon">
                    <i class="fas fa-${iconName}"></i>
                </span>
                <span class="feature-name">${displayName}</span>
                ${!hasPath ? '<span class="warning-icon" title="No path configured">⚠️</span>' : ''}
            </a>
            
            ${userRole === 'SuperAdmin' && !isCollapsed ? `
                <div class="feature-actions">
                    <button onclick="toggleFeatureStatus('${feature.id}', ${feature.isActive}, event)" 
                            class="action-btns toggle-btn"
                            title="${feature.isActive ? 'Disable' : 'Enable'}">
                        <i class="fas fa-toggle-${feature.isActive ? 'on' : 'off'}"></i>
                    </button>
                    <button onclick="deleteFeature('${feature.id}', '${escapeString(displayName)}', event)" 
                            class="action-btns delete-btn"
                            title="Delete">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            ` : ''}
        </div>
    `;
}

// ✅ SHOW EMPTY STATE
function showEmptyState(container, title, message, addLink = null) {
    let html = `
        <div class="empty-state">
            <i class="fas fa-cubes empty-icon"></i>
            <p class="empty-title">${title}</p>
            <p class="empty-subtitle">${message}</p>
    `;
    
    if (addLink) {
        html += `<a href="${addLink}" class="add-feature-btn" style="display:inline-block; margin-top:1rem; padding:0.5rem 1rem; background:#4f46e5; color:white; text-decoration:none; border-radius:0.375rem;">+ Add Feature</a>`;
    }
    
    html += '</div>';
    container.innerHTML = html;
}

// ✅ TOGGLE SECTION - FIXED: Added event.stopPropagation()
function toggleSection(section, event) {
    if (event) {
        event.stopPropagation();
    }
    openSections[section] = !openSections[section];
    
    try {
        localStorage.setItem('sidebarOpenSections', JSON.stringify(openSections));
    } catch(e) {
        console.error('Error saving section state:', e);
    }
    
    renderFeatures(features);
}

// ✅ TOGGLE COLLAPSE
function toggleCollapse() {
    const sidebar = document.getElementById('mainSidebar');
    const icon = document.getElementById('collapseIcon');
    
    isCollapsed = !isCollapsed;
    
    try {
        localStorage.setItem('sidebarCollapsed', isCollapsed);
    } catch(e) {
        console.error('Error saving collapse state:', e);
    }
    
    if (isCollapsed) {
        sidebar.classList.add('collapsed');
        icon.className = 'fas fa-chevron-right';
    } else {
        sidebar.classList.remove('collapsed');
        icon.className = 'fas fa-chevron-left';
        renderFeatures(features);
    }
}

// ✅ TOGGLE MOBILE
function toggleMobileSidebar() {
    const sidebar = document.getElementById('mainSidebar');
    const icon = document.getElementById('mobileIcon');
    const overlay = document.querySelector('.sidebar-overlay');
    
    sidebar.classList.toggle('open');
    
    if (sidebar.classList.contains('open')) {
        icon.className = 'fas fa-times';
        overlay.classList.add('active');
    } else {
        icon.className = 'fas fa-bars';
        overlay.classList.remove('active');
    }
}

function closeMobileSidebar() {
    const sidebar = document.getElementById('mainSidebar');
    const icon = document.getElementById('mobileIcon');
    const overlay = document.querySelector('.sidebar-overlay');
    
    sidebar.classList.remove('open');
    icon.className = 'fas fa-bars';
    overlay.classList.remove('active');
}

// ✅ TOGGLE FEATURE STATUS - FIXED: Added event parameter
function toggleFeatureStatus(id, currentStatus, event) {
    if (event) {
        event.stopPropagation();
    }
    
    if (userRole !== 'SuperAdmin') {
        showToast('Permission denied', 'error');
        return;
    }
    
    try {
        const savedFeatures = localStorage.getItem('sidebarFeatures');
        if (!savedFeatures) {
            showToast('No features found', 'error');
            return;
        }
        
        let allFeatures = JSON.parse(savedFeatures);
        
        const featureIndex = allFeatures.findIndex(f => f.id == id);
        if (featureIndex === -1) {
            showToast('Feature not found', 'error');
            return;
        }
        
        allFeatures[featureIndex].isActive = !allFeatures[featureIndex].isActive;
        
        localStorage.setItem('sidebarFeatures', JSON.stringify(allFeatures));
        
        showToast(`Feature ${allFeatures[featureIndex].isActive ? 'enabled' : 'disabled'}`, 'success');
        
        localStorage.setItem('sidebar-update-time', Date.now().toString());
        
        loadSidebarFeatures();
        
    } catch (err) {
        console.error('Error:', err);
        showToast('Failed to update feature', 'error');
    }
}

// ✅ DELETE FEATURE - FIXED: Added event parameter
function deleteFeature(id, name, event) {
    if (event) {
        event.stopPropagation();
    }
    
    if (userRole !== 'SuperAdmin') {
        showToast('Permission denied', 'error');
        return;
    }
    
    if (!confirm(`Are you sure you want to delete "${name}"?`)) {
        return;
    }
    
    try {
        const savedFeatures = localStorage.getItem('sidebarFeatures');
        if (!savedFeatures) {
            showToast('No features found', 'error');
            return;
        }
        
        let allFeatures = JSON.parse(savedFeatures);
        
        allFeatures = allFeatures.filter(f => f.id != id);
        
        localStorage.setItem('sidebarFeatures', JSON.stringify(allFeatures));
        
        showToast('Feature deleted successfully', 'success');
        
        localStorage.setItem('sidebar-update-time', Date.now().toString());
        
        loadSidebarFeatures();
        
    } catch (err) {
        console.error('Error:', err);
        showToast('Failed to delete feature', 'error');
    }
}

// ✅ UTILITIES
function escapeString(str) {
    if (!str) return '';
    return str.replace(/'/g, "\\'").replace(/"/g, '&quot;');
}

function showToast(message, type = 'success') {
    document.querySelectorAll('.toast-notification').forEach(t => t.remove());
    
    const toast = document.createElement('div');
    toast.className = `toast-notification ${type === 'error' ? 'toast-error' : ''}`;
    
    const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    
    toast.innerHTML = `
        <i class="fas ${icon}"></i>
        <span>${message}</span>
    `;
    
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.style.animation = 'slideOut 0.3s ease';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

// ✅ Manual refresh function
window.refreshSidebar = function() {
    console.log('🔄 Manual sidebar refresh triggered');
    loadSidebarFeatures();
};

// ✅ Observe URL changes
let lastUrl = location.href;
new MutationObserver(() => {
    const url = location.href;
    if (url !== lastUrl) {
        lastUrl = url;
        console.log('📍 URL changed to:', url);
        renderFeatures(features);
    }
}).observe(document, {subtree: true, childList: true});

console.log('✅ Sidebar script loaded successfully - USER CARD HIDE/SHOW FIXED');
</script>