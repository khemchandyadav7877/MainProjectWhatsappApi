<!-- views/partials/second/left.ejs -->
<%
// Get user data from locals
const user = locals.user || { 
    firstName: 'John', 
    lastName: 'Doe', 
    email: 'admin@eduportal.com',
    role: 'SuperAdmin'
};

// Get user role color
const getRoleColor = (role) => {
    switch(role) {
        case 'SuperAdmin': return '#4f46e5';
        case 'Educator': return '#3b82f6';
        case 'Trainer': return '#10b981';
        case 'Student': return '#f59e0b';
        default: return '#6b7280';
    }
};

const roleColor = getRoleColor(user.role);
const userInitials = (user.firstName ? user.firstName.charAt(0).toUpperCase() : 'J') + 
                     (user.lastName ? user.lastName.charAt(0).toUpperCase() : 'D');
const userName = user.firstName + ' ' + user.lastName;
const userRole = user.role;
const userEmail = user.email;
%>

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
/* ===== SIDEBAR STYLES - PERFECT VERSION ===== */
:root {
    --sidebar-width: 280px;
    --header-height: 70px;
    --primary: <%= roleColor %>;
    --primary-dark: <%= roleColor %>;
    --success: #10b981;
    --danger: #ef4444;
}

/* Light mode variables */
:root, .light {
    --sidebar-bg: #ffffff;
    --bg-white: #ffffff;
    --bg-offwhite: #f9fafb;
    --border: #e5e7eb;
    --text: #4b5563;
    --text-light: #6b7280;
    --dark: #1f2937;
    --text-muted: #6b7280;
    --primary-pale: <%= roleColor %>10;
    --shadow: 0 1px 3px rgba(0,0,0,0.05);
    --shadow-lg: 0 10px 25px rgba(0,0,0,0.1);
}

/* Dark mode variables */
.dark {
    --sidebar-bg: #161B22;
    --bg-white: #1f2937;
    --bg-offwhite: #111827;
    --border: #374151;
    --text: #d1d5db;
    --text-light: #9ca3af;
    --dark: #f9fafb;
    --text-muted: #9ca3af;
    --primary-pale: <%= roleColor %>20;
    --shadow: 0 1px 3px rgba(0,0,0,0.3);
    --shadow-lg: 0 10px 25px rgba(0,0,0,0.5);
}

/* Sidebar Container */
.sidebar {
    width: var(--sidebar-width, 280px);
    background: var(--sidebar-bg);
    border-right: 1px solid var(--border);
    height: calc(100vh - var(--header-height, 70px));
    position: fixed;
    left: 0;
    top: var(--header-height, 70px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 999;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
}

.sidebar.closed {
    width: 0;
    min-width: 0;
    opacity: 0;
    transform: translateX(-100%);
}

/* Sidebar Header */
.sidebar-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    background: var(--sidebar-bg);
    flex-shrink: 0;
}

.logo-area {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.logo-icon {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, var(--primary-dark), var(--primary));
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
    flex-shrink: 0;
}

.logo-text {
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--dark);
    white-space: nowrap;
}

.logo-text span {
    color: var(--primary);
}

/* Sidebar Content */
.sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1rem;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
}

.sidebar-content::-webkit-scrollbar {
    width: 4px;
}

.sidebar-content::-webkit-scrollbar-track {
    background: transparent;
}

.sidebar-content::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 10px;
}

.sidebar-content::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
}

/* User Card */
.user-card {
    background: linear-gradient(135deg, var(--primary)10, transparent);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    position: relative;
    cursor: pointer;
    transition: all 0.3s;
}

.user-card:hover {
    border-color: var(--primary);
    background: linear-gradient(135deg, var(--primary)15, transparent);
}

.user-card.hidden {
    display: none;
}

.user-card-toggle {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--bg-white);
    border: 1px solid var(--border);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 2;
}

.user-card:hover .user-card-toggle {
    opacity: 1;
}

.user-avatar-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
}

.avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1.2rem;
    position: relative;
    flex-shrink: 0;
}

.online-indicator {
    position: absolute;
    bottom: 2px;
    right: 2px;
    width: 10px;
    height: 10px;
    background: var(--success);
    border: 2px solid white;
    border-radius: 50%;
    animation: pulse 2s infinite;
}

.dark .online-indicator {
    border-color: #1f2937;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

.user-details {
    overflow: hidden;
    flex: 1;
}

.user-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.role-badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    background: var(--primary);
    color: white;
    font-size: 0.65rem;
    font-weight: 600;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.user-email {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.user-stats {
    display: flex;
    gap: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
}

.stat-item {
    flex: 1;
    text-align: center;
}

.stat-value {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary);
    line-height: 1.2;
}

.stat-label {
    display: block;
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.3px;
}

/* Minimized User Card */
.user-card-minimized {
    display: none;
    background: linear-gradient(135deg, var(--primary)10, transparent);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    cursor: pointer;
    align-items: center;
    justify-content: space-between;
    transition: all 0.2s;
}

.user-card-minimized:hover {
    border-color: var(--primary);
}

.user-card-minimized.show {
    display: flex;
}

.minimized-left {
    display: flex;
    align-items: center;
    gap: 8px;
}

.minimized-left i {
    color: var(--primary);
    font-size: 1rem;
}

.minimized-left span {
    color: var(--text);
    font-size: 0.85rem;
    font-weight: 500;
}

.minimized-right {
    display: flex;
    align-items: center;
    gap: 8px;
}

.count-badge {
    background: var(--primary);
    color: white;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3px;
}

.minimized-right i {
    color: var(--text-muted);
    font-size: 0.75rem;
}

/* Navigation */
.nav-section {
    margin-bottom: 0.25rem;
}

.section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-light);
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.2s;
    margin-bottom: 0.25rem;
}

.section-title:hover {
    background: var(--bg-offwhite);
    color: var(--dark);
}

.section-title.open {
    color: var(--primary);
    background: var(--primary-pale);
}

.section-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.section-icon {
    width: 22px;
    text-align: center;
    font-size: 1rem;
}

.arrow-icon {
    font-size: 0.75rem;
    transition: transform 0.3s;
    color: var(--text-muted);
}

.arrow-icon.rotate {
    transform: rotate(180deg);
}

.section-links {
    padding-left: 2.2rem;
    margin-top: 0.15rem;
    margin-bottom: 0.25rem;
}

.feature-wrapper {
    margin-bottom: 0.15rem;
    width: 100%;
    position: relative;
    display: flex;
    align-items: center;
}

.nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    color: var(--text-light);
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
    width: 100%;
    cursor: pointer;
}

.nav-link:hover {
    background: var(--bg-offwhite);
    color: var(--dark);
    transform: translateX(3px);
}

.nav-link.active {
    background: var(--primary-pale);
    color: var(--primary);
    font-weight: 500;
}

.nav-link.active::before {
    content: '';
    position: absolute;
    left: -2px;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 18px;
    background: var(--primary);
    border-radius: 0 4px 4px 0;
}

.nav-link.disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.link-icon {
    width: 22px;
    text-align: center;
    font-size: 0.95rem;
    color: inherit;
}

.warning-icon {
    margin-left: 0.25rem;
    font-size: 0.7rem;
    color: #f59e0b;
}

/* Feature Actions for SuperAdmin */
.feature-actions {
    display: flex;
    gap: 0.125rem;
    opacity: 0;
    transition: opacity 0.2s;
    margin-left: 0.25rem;
}

.feature-wrapper:hover .feature-actions {
    opacity: 1;
}

.action-btns {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--bg-white);
    color: var(--text-muted);
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s;
}

.action-btns:hover {
    transform: scale(1.1);
}

.toggle-btn:hover {
    color: #10b981;
    border-color: #10b981;
}

.delete-btn:hover {
    color: #ef4444;
    border-color: #ef4444;
}

/* Logout Link */
.logout-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    margin-top: 1.5rem;
    border-radius: 8px;
    background: #fee2e2;
    border: 1px solid #fecaca;
    color: #dc2626;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s;
    cursor: pointer;
}

.dark .logout-link {
    background: rgba(220, 38, 38, 0.15);
    border-color: rgba(220, 38, 38, 0.3);
    color: #ef4444;
}

.logout-link:hover {
    background: #fecaca;
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(220, 38, 38, 0.15);
}

.dark .logout-link:hover {
    background: rgba(220, 38, 38, 0.25);
    color: #fca5a5;
}

.logout-link i {
    font-size: 1rem;
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 2rem 1rem;
    background: var(--bg-offwhite);
    border-radius: 12px;
    border: 2px dashed var(--border);
    margin: 1rem 0;
}

.empty-icon {
    font-size: 2rem;
    color: var(--text-muted);
    opacity: 0.5;
    margin-bottom: 0.5rem;
}

.empty-title {
    color: var(--text);
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
}

.empty-subtitle {
    color: var(--text-muted);
    font-size: 0.75rem;
    opacity: 0.7;
}

.add-feature-btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.5rem 1rem;
    background: var(--primary);
    color: white !important;
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.8rem;
    transition: all 0.2s;
}

.add-feature-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 6px rgba(79, 70, 229, 0.3);
}

/* Loading Spinner */
.loading-spinner {
    text-align: center;
    padding: 2rem;
}

.spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--border);
    border-top-color: var(--primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto 0.5rem;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Toast Notifications */
.toast-notification {
    position: fixed;
    top: 20px;
    right: 20px;
    background: #10b981;
    color: white;
    padding: 12px 20px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    z-index: 9999;
    animation: slideIn 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
}

.toast-error {
    background: #ef4444;
}

@keyframes slideIn {
    from { 
        transform: translateX(100%); 
        opacity: 0; 
    }
    to { 
        transform: translateX(0); 
        opacity: 1; 
    }
}

/* ===== BORDER MODE CLASSES - FIXED ===== */
/* Round Border Mode */
body.round-border .sidebar {
    border-radius: 20px 0 0 20px !important;
    overflow: hidden !important;
}

body.round-border .sidebar-header,
body.round-border .user-card,
body.round-border .user-card-minimized,
body.round-border .nav-link,
body.round-border .section-title,
body.round-border .logout-link,
body.round-border .action-btns,
body.round-border .add-feature-btn,
body.round-border .empty-state {
    border-radius: 12px !important;
}

body.round-border .avatar,
body.round-border .online-indicator {
    border-radius: 50% !important;
}

body.round-border .count-badge {
    border-radius: 20px !important;
}

body.round-border .loading-spinner .spinner {
    border-radius: 50% !important;
}

/* No Radius Mode */
body.no-radius .sidebar,
body.no-radius .sidebar-header,
body.no-radius .user-card,
body.no-radius .user-card-minimized,
body.no-radius .nav-link,
body.no-radius .section-title,
body.no-radius .logout-link,
body.no-radius .action-btns,
body.no-radius .add-feature-btn,
body.no-radius .empty-state,
body.no-radius .avatar,
body.no-radius .online-indicator,
body.no-radius .count-badge,
body.no-radius .loading-spinner .spinner {
    border-radius: 0 !important;
}

/* Sidebar Responsive */
@media (max-width: 768px) {
    .sidebar {
        transform: translateX(-100%);
        width: var(--sidebar-width, 280px) !important;
        opacity: 1;
        box-shadow: none;
    }
    
    .sidebar.open {
        transform: translateX(0);
        box-shadow: var(--shadow-lg);
    }

    body.round-border .sidebar {
        border-radius: 0 20px 20px 0 !important;
    }
}
</style>

<!-- Sidebar HTML -->
<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="logo-area">
            <div class="logo-icon">
                <i class="fab fa-whatsapp"></i>
            </div>
            <div class="logo-text">WaBlast<span>Pro</span></div>
        </div>
    </div>

    <div class="sidebar-content">
        <!-- Minimized User Card -->
        <div class="user-card-minimized" id="userCardMinimized" onclick="toggleUserCard(event)">
            <div class="minimized-left">
                <i class="fas fa-user-circle"></i>
                <span>Show Profile</span>
            </div>
            <div class="minimized-right">
                <span class="count-badge" id="minimizedStats">0F • 0S</span>
                <i class="fas fa-chevron-down"></i>
            </div>
        </div>
        
        <!-- Main User Card -->
        <div class="user-card" id="userCard" onclick="toggleUserCard(event)">
            <div class="user-card-toggle" id="userCardToggle">
                <i class="fas fa-chevron-up"></i>
            </div>
            
            <div class="user-avatar-wrapper">
                <div class="avatar">
                    <%= userInitials %>
                    <span class="online-indicator"></span>
                </div>
                
                <div class="user-details">
                    <h4 class="user-name"><%= userName %></h4>
                    <span class="role-badge"><%= userRole %></span>
                    <p class="user-email"><%= userEmail %></p>
                </div>
            </div>
            
            <div class="user-stats">
                <div class="stat-item">
                    <span class="stat-value" id="featuresCount">0</span>
                    <span class="stat-label">FEATURES</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value" id="sectionsCount">0</span>
                    <span class="stat-label">SECTIONS</span>
                </div>
            </div>
        </div>

        <!-- Navigation Container - Features will be loaded here -->
        <div class="nav-sections" id="navContainer">
            <div class="loading-spinner">
                <div class="spinner"></div>
                <p style="color: var(--text-muted);">Loading features...</p>
            </div>
        </div>

        <!-- Logout -->
        <a href="/logout" class="logout-link">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </a>
    </div>
</div>

<script>
// ============================================
