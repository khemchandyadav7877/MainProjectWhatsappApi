<!-- views/partials/second/header.ejs -->
<% 
// Get user data from locals
const user = locals.user || { 
    firstName: 'John', 
    lastName: 'Doe', 
    email: 'admin@eduportal.com',
    role: 'SuperAdmin'
};

// Get role color
const getRoleColor = (role) => {
    switch(role) {
        case 'SuperAdmin': return '#4f46e5';
        case 'Educator': return '#3b82f6';
        case 'Trainer': return '#10b981';
        case 'Student': return '#f59e0b';
        default: return '#6b7280';
    }
};

const roleColor = getRoleColor(user.role);
const userInitial = (user.firstName || user.email || 'U').charAt(0).toUpperCase();
const userAvatar = userInitial + (user.lastName ? user.lastName.charAt(0).toUpperCase() : '');
const userName = user.firstName + ' ' + user.lastName;
const userRole = user.role;

// Get active session from locals
const activeSession = locals.activeSession || { sessionna: '2026-2027' };
%>

<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
:root {
    --header-height: 70px;
    --primary: <%= roleColor %>;
    --primary-dark: <%= roleColor %>;
}

/* Light mode */
:root, .light {
    --header-bg: #ffffff;
    --bg-white: #ffffff;
    --border: #e5e7eb;
    --text: #4b5563;
    --dark: #1f2937;
    --text-muted: #6b7280;
    --dropdown-bg: #ffffff;
    --dropdown-hover: #f3f4f6;
    --shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
}

/* Dark mode */
.dark {
    --header-bg: #1f2937;
    --bg-white: #1f2937;
    --border: #374151;
    --text: #d1d5db;
    --dark: #f9fafb;
    --text-muted: #9ca3af;
    --dropdown-bg: #1f2937;
    --dropdown-hover: #374151;
    --shadow: 0 10px 25px -5px rgba(0,0,0,0.3);
}

.header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 70px;
    background: var(--header-bg);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 1000;
}

.header-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
}

.menu-toggle {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-white);
    color: var(--text);
    cursor: pointer;
}

.page-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--dark);
}

.header-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
}

/* ===== SESSION DROPDOWN ===== */
.session-dropdown {
    position: relative;
}

.session-btn {
    height: 42px;
    padding: 0 1.2rem;
    background: var(--bg-white);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--dark);
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
}

.session-btn i {
    color: var(--primary);
}

.session-menu {
    position: absolute;
    top: 100%;
    right: 0;
    width: 240px;
    margin-top: 0.5rem;
    background: var(--dropdown-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow);
    display: none;
    max-height: 350px;
    overflow-y: auto;
    z-index: 1001;
}

.session-menu.show {
    display: block;
}

.session-header {
    padding: 0.8rem 1rem;
    border-bottom: 1px solid var(--border);
    font-weight: 600;
    color: var(--dark);
    background: var(--dropdown-hover);
}

.session-list {
    max-height: 250px;
    overflow-y: auto;
}

.session-item {
    padding: 0.8rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    color: var(--text);
    font-size: 0.95rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
}

.session-item:last-child {
    border-bottom: none;
}

.session-item:hover {
    background: var(--dropdown-hover);
}

.session-item.active {
    color: var(--primary);
    font-weight: 500;
    background: var(--primary-pale);
}

.session-item.active i {
    color: var(--primary);
    opacity: 1;
}

.session-item i {
    font-size: 0.9rem;
    opacity: 0;
}

.session-item.active i {
    opacity: 1;
}

.session-footer {
    padding: 0.8rem 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 0.5rem;
}

.session-footer a {
    flex: 1;
    padding: 0.5rem;
    text-align: center;
    border-radius: 6px;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s;
}

.view-all-link {
    background: var(--dropdown-hover);
    color: var(--text);
    border: 1px solid var(--border);
}

.add-session-link {
    background: var(--primary);
    color: white !important;
}

.session-loading {
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
}

.session-loading i {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 0.5rem;
}

/* Header actions */
.header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.header-btn {
    width: 42px;
    height: 42px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-white);
    color: var(--text);
    cursor: pointer;
    position: relative;
}

.notification-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 18px;
    height: 18px;
    background: #ef4444;
    color: white;
    border-radius: 50%;
    font-size: 0.65rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--bg-white);
}

.dm-toggle {
    width: 42px;
    height: 42px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-white);
    color: var(--text);
    cursor: pointer;
}

.user-profile {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    background: var(--bg-white);
    border: 1px solid var(--border);
    cursor: pointer;
}

.profile-avatar {
    width: 42px;
    height: 42px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--primary-dark), var(--primary));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
}

.profile-info {
    line-height: 1.3;
}

.profile-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--dark);
}

.profile-role {
    font-size: 0.7rem;
    color: var(--text-muted);
}

/* Scrollbar */
.session-list::-webkit-scrollbar {
    width: 4px;
}

.session-list::-webkit-scrollbar-track {
    background: var(--border);
}

.session-list::-webkit-scrollbar-thumb {
    background: var(--primary);
    border-radius: 2px;
}

/* Responsive */
@media (max-width: 768px) {
    .header {
        padding: 0 1rem;
    }
    
    .profile-info {
        display: none;
    }
    
    .session-btn span {
        display: none;
    }
    
    .session-btn {
        padding: 0 0.8rem;
    }
}
</style>

<!-- Header HTML -->
<header class="header">
    <div class="header-left">
        <button class="menu-toggle" id="menuToggleBtn">
            <i class="fas fa-bars"></i>
        </button>
        <h1 class="page-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard' %></h1>
    </div>

    <div class="header-right">
        <!-- SESSION DROPDOWN - DYNAMIC -->
        <div class="session-dropdown" id="sessionDropdown">
            <button class="session-btn" id="sessionBtn">
                <i class="fas fa-calendar-alt"></i>
                <span id="activeSessionSpan"><%= activeSession.sessionna %></span>
                <i class="fas fa-chevron-down" style="font-size: 0.8rem;"></i>
            </button>
            
            <div class="session-menu" id="sessionMenu">
                <div class="session-header">
                    <i class="fas fa-calendar-check" style="margin-right: 8px;"></i> Academic Sessions
                </div>
                
                <div class="session-list" id="sessionList">
                    <div class="session-loading">
                        <i class="fas fa-spinner fa-pulse"></i>
                        <div>Loading sessions...</div>
                    </div>
                </div>
                
                
            </div>
        </div>

        <div class="header-actions">
            <button class="header-btn">
                <i class="fas fa-envelope"></i>
                <span class="notification-badge">3</span>
            </button>
            <button class="header-btn">
                <i class="fas fa-bell"></i>
                <span class="notification-badge">5</span>
            </button>
            <button class="dm-toggle" id="dmToggle">
                <i class="fas fa-moon" id="dmIcon"></i>
            </button>
        </div>

        <div class="user-profile">
            <div class="profile-avatar"><%= userAvatar %></div>
            <div class="profile-info">
                <div class="profile-name"><%= userName %></div>
                <div class="profile-role"><%= userRole %></div>
            </div>
            <i class="fas fa-chevron-down" style="font-size: 0.7rem; color: var(--text-muted);"></i>
        </div>
    </div>
</header>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ===== SESSION DROPDOWN =====
    const sessionBtn = document.getElementById('sessionBtn');
    const sessionMenu = document.getElementById('sessionMenu');
    const sessionList = document.getElementById('sessionList');
    const activeSessionSpan = document.getElementById('activeSessionSpan');
    
    // Toggle dropdown
    sessionBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        sessionMenu.classList.toggle('show');
        
        // Load sessions when dropdown opens
        if (sessionMenu.classList.contains('show')) {
            loadSessions();
        }
    });
    
    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
        if (!sessionBtn.contains(e.target) && !sessionMenu.contains(e.target)) {
            sessionMenu.classList.remove('show');
        }
    });
    
    // ===== LOAD SESSIONS FROM DATABASE =====
    async function loadSessions() {
        try {
            // Show loading
            sessionList.innerHTML = `
                <div class="session-loading">
                    <i class="fas fa-spinner fa-pulse"></i>
                    <div>Loading sessions...</div>
                </div>
            `;
            
            // Fetch sessions from server
            const response = await fetch('/api/sessions');
            const data = await response.json();
            
            if (data.success && data.sessions) {
                renderSessions(data.sessions, data.activeSession);
            } else {
                sessionList.innerHTML = `
                    <div class="session-loading">
                        <i class="fas fa-exclamation-circle" style="color: #ef4444;"></i>
                        <div>Failed to load sessions</div>
                    </div>
                `;
            }
        } catch (error) {
            console.error('Error:', error);
            sessionList.innerHTML = `
                <div class="session-loading">
                    <i class="fas fa-exclamation-circle" style="color: #ef4444;"></i>
                    <div>Error loading sessions</div>
                </div>
            `;
        }
    }
    
    // ===== RENDER SESSIONS =====
    function renderSessions(sessions, activeSess) {
        if (!sessions || sessions.length === 0) {
            sessionList.innerHTML = `
                <div class="session-loading">
                    <i class="fas fa-folder-open"></i>
                    <div>No sessions found</div>
                </div>
            `;
            return;
        }
        
        let html = '';
        sessions.forEach(session => {
            const isActive = activeSess && session._id === activeSess._id;
            const sessionName = session.sessionna || 'N/A';
            
            html += `
                <div class="session-item ${isActive ? 'active' : ''}" 
                     data-session-id="${session._id}" 
                     data-session-name="${sessionName}">
                    ${sessionName}
                    ${isActive ? '<i class="fas fa-check"></i>' : ''}
                </div>
            `;
        });
        
        sessionList.innerHTML = html;
        
        // Add click handlers
        document.querySelectorAll('.session-item').forEach(item => {
            item.addEventListener('click', async function() {
                const sessionId = this.dataset.sessionId;
                const sessionName = this.dataset.sessionName;
                
                // Update button text
                activeSessionSpan.textContent = sessionName;
                
                // Update active class in dropdown
                document.querySelectorAll('.session-item').forEach(i => {
                    i.classList.remove('active');
                    i.innerHTML = i.dataset.sessionName;
                });
                this.classList.add('active');
                this.innerHTML = `${sessionName} <i class="fas fa-check"></i>`;
                
                // Close dropdown
                sessionMenu.classList.remove('show');
                
                // Redirect to change session
                if (confirm(`Set ${sessionName} as active session?`)) {
                    window.location.href = `/activesession/${sessionId}`;
                }
            });
        });
    }
    
    // ===== DARK MODE =====
    const dmToggle = document.getElementById('dmToggle');
    const dmIcon = document.getElementById('dmIcon');
    
    // Check saved theme
    const savedTheme = localStorage.getItem('theme') || 'light';
    if (savedTheme === 'dark') {
        document.body.classList.add('dark');
        dmIcon.classList.replace('fa-moon', 'fa-sun');
    }
    
    dmToggle.addEventListener('click', () => {
        const isDark = document.body.classList.toggle('dark');
        
        if (isDark) {
            dmIcon.classList.replace('fa-moon', 'fa-sun');
            localStorage.setItem('theme', 'dark');
        } else {
            dmIcon.classList.replace('fa-sun', 'fa-moon');
            localStorage.setItem('theme', 'light');
        }
    });
    
    // ===== MENU TOGGLE =====
    document.getElementById('menuToggleBtn').addEventListener('click', function() {
        if (window.toggleSidebar) {
            window.toggleSidebar();
        }
    });
    
    // ===== USER PROFILE CLICK =====
    document.querySelector('.user-profile').addEventListener('click', function() {
        window.location.href = '/profile';
    });
});
</script>